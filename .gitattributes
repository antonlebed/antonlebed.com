# .ax IS the language. Map to Scheme for GitHub linguist recognition.
# Scheme is the closest match: s-expression-like, functional, parenthesized.
*.ax linguist-language=Scheme

# Generated build artifacts — not .ax source
worker.js linguist-generated
*.wasm linguist-generated
*.html linguist-generated
*.xml linguist-generated
*.json linguist-generated
*.jsonc linguist-generated
*.txt linguist-generated
*.jpg linguist-generated
*.png linguist-generated
