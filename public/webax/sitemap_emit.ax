/* sitemap_emit.ax -- [DEAD] SCAFFOLDING
   .ax IS the sitemap. True SSOT for sitemap.xml.
   Page-to-category mapping lives HERE, not in deploy.sh.
   Dies when .ax replaces all non-.ax build tooling. */

fn sm_url(path:str) =
  "  <url><loc>https://antonlebed.com" + path + "</loc><changefreq>weekly</changefreq></url>\n"

fn sm_tier_url(tier:str, page:str) =
  sm_url("/" + tier + "/" + page)

fn sm_basics() =
  sm_tier_url("basics", "numbers_clocks")
  + sm_tier_url("basics", "rings_channels")
