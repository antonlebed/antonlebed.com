fn emit_sitemap() =
  "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\n"
  + "<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">\n"
  + sm_url("/")
  + sm_url("/basics")
  + sm_url("/observe")
  + sm_url("/data")
  + sm_url("/teach")
  + sm_url("/deep")
  + sm_url("/living")
  + sm_basics()
  + sm_observe()
  + sm_data()
  + sm_teach()
  + sm_deep()
  + sm_living()
  + sm_url("/repl")
  + sm_url("/demos")
  + sm_tier_url("demos", "mesh")
  + sm_tier_url("demos", "crt_train")
  + sm_tier_url("demos", "arc")
