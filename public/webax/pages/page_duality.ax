  let sec = make_section("800px") in
  render_h2(sec, "The Bridge Self-Destructs");
  render_theorem(sec, "Bridge Theorem", "D builds the world and kills itself. D^3 = 0 mod D^3: the D-channel dies in K=3 steps. But gcd(D, K*E*b*L) = 1: D cannot kill ANY odd channel. Odd channels survive forever under D-multiplication. OMEGA = what remains when the bridge self-destructs. D is coprime to every other prime -- D-multiplication cycles odd channels indefinitely.");
