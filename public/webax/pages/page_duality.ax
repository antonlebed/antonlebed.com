  render_finding(g, "Chirality flip", "b inverts spinor sign", "Depth b=7 flips L <-> R handedness.", "S282");
  render_finding(g, "Exclusion", "D excluded from B/C Lie", "Odd exponents only. D enters D-series at rank K.", "S282");
