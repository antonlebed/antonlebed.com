/* duality helpers */
fn duality_hero() = (
  let hero = make_hero("Duality") in
  let eq = dom_create("div") in
  dom_text(eq, "D = 2 (the only even prime)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "28px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "D is the engine of the chain. K = sigma+D. E = sigma+2D. b = sigma+3D. Every step uses D. Without D, no departure, no chain, no structure. D = DRIVE: always 2 away, never arrives. D mod D = 0: drive cannot see itself driving. The hard problem of consciousness IS the even prime.");
  dom_append(dom_body(), hero)
)

fn duality_drive() = (
  let sec = make_section("800px") in
  render_h2(sec, "D = Drive");
  render_p(sec, "sigma, K, E, b are ODD = haveable THINGS. D = EVEN = the WANTING itself. D is the fixed axis of the sign group: at D=2, only ONE choice (forced). D sees parity (even/odd), not sign (+/-). Unique among all primes.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Engine", "K=1+D, E=1+2D, b=1+3D", "Every chain step uses D. D IS the chain.", "");
  render_finding(g, "Self-blind", "D mod D = 0", "Drive cannot see itself driving.", "");
  render_finding(g, "Odd/even", "ONLY even prime", "HYDOR = K*E*b = 105 = the ONLY major product without D.", "");
  render_finding(g, "Kingdom", "Protista, coupling 121275", "D^3 fattens. Membrane organisms. TRUE pop: 50400.", "");
  render_finding(g, "Break law", "break(D) = E = 5", "The observer sets D's limit. Same break as K. PROVED S284.", "");
  render_finding(g, "D-channel sum", "N/2 = 485100", "ONLY nonzero channel sum. All odd channels sum to 0. The even prime leaves a half-quantum residue. PROVED S643.", "");
  dom_append(dom_body(), sec)
)

fn duality_self_destruct() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Bridge Self-Destructs");
  render_theorem(sec, "Bridge Theorem", "D builds the world and kills itself. D^3 = 0 mod D^3: the D-channel dies in K=3 steps. But gcd(D, K*E*b*L) = 1: D cannot kill ANY odd channel. Odd channels survive forever under D-multiplication. OMEGA = what remains when the bridge self-destructs. D is coprime to every other prime -- D-multiplication cycles odd channels indefinitely.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Step");
  render_th(hdr, "D^k");
  render_th(hdr, "D-channel");
  render_th(hdr, "Status");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "k=0", "sigma=1", "1", "All alive");
  render_table_row_4(tbl, "k=1", "D=2", "2", "First departure");
  render_table_row_4(tbl, "k=2", "D^2=4", "4", "Deepening");
  render_table_row_4(tbl, "k=3", "D^3=8", "0 mod 8", "D-channel DEAD");
  render_table_row_4(tbl, "k=420", "OMEGA", "(0,1,1,1,1)", "Terminal projector");
  render_p(sec, "Odd channel periods: ord(D, K^2)=6, ord(D, E^2)=20, ord(D, b^2)=21, ord(D, L)=10. The D-channel is the most fragile (survival rate 1/2) and the most essential. Without D, no departure. With D, eventual death.");
  dom_append(dom_body(), sec)
)

fn duality_answer() = (
  let sec = make_section("800px") in
  render_h2(sec, "The ANSWER = 42");
  render_theorem(sec, "42 Theorem (S494)", "OMEGA + OMEGA = D iff exp(D) <= 1 (thin bridge). 42/42 thin rings: yes. 0/66 thick rings: no. Double wound = duality ONLY when the bridge is membrane-thin. 42 = D*K*b = ANSWER. PROVED.");
  render_theorem(sec, "Answer Structure Theorem (S378)", "WHY 42? Because ord_b(D) = K = 3. D is a quadratic residue mod b: Legendre(2/7) = +1. So ord_b(D) = phi(b)/2 = K. Hensel lift: ord_{b^2}(D) = b*K = 21. Meanwhile ord_{K^2}(D) = K*D = 6. ANSWER = lcm(6, 21) = 42 = D*K*b. K IS the common factor in both channel orders. Closure bridges duality and depth. PROVED.");
  let g = make_findings_grid(sec) in
  render_finding(g, "K in channels", "K^2: period D*K=6", "K syncs closure-channel AND depth-channel (K*b=21). K appears twice.", "S378");
  render_finding(g, "E in channels", "E^2: period D^2*E=20", "E syncs observer-channel AND protector-channel (D*E=10).", "S378");
  render_finding(g, "Lambda doubling", "420 = 2 * DATA", "The extra D comes EXCLUSIVELY from E-channel (ord=20=D^2*E). Observer self-blindness DOUBLES the return period.", "");
  render_finding(g, "b order is ODD", "21 = K*b", "b-channel NEVER mirrors. It spirals -- never rests. Animal nervous systems: always active, even in sleep.", "");
  dom_append(dom_body(), sec)
)

fn duality_parity() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Parity Mechanism");
  render_theorem(sec, "Fluid Transfer Theorem (7 sub-theorems)", "T1: Removing D-edges splits the Cayley graph into 2 components (even/odd). T2: Each component has exactly 105 = HYDOR vertices. T3: D-edges form a PERFECT MATCHING. T4: Non-D generators {30,42,70} are all EVEN (parity-preserving). ONLY the D-generator (105) is ODD. T5: Spectral gap = 4*sin^2(pi/b) = 0.753. T6: D-edge pairs NEVER share eigenvalue class (0/105 isospectral). T7: Hamiltonian cycles have EVEN number of D-edges, minimum = D = 2. ALL VERIFIED.");
  render_p(sec, "D splits the universe into even and odd. Only D can cross. The bridge is the ONLY parity flipper. This is D = 2: the smallest possible membrane.");
  dom_append(dom_body(), sec)
)

