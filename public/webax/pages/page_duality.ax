/* ================================================================
   INTERACTIVE: MIRROR EXPLORER
   Enter n → see n and N-n (mirror). CRT of both.
   Each channel pair sums to modulus. Duality = the pair.
   ================================================================ */

fn duality_mirror_compute() = (
  let n = parse_int_from("#mir-input") in
  let m = 970200 - n in
  let result = dom_query("#mir-result") in
  let nd = n % 8 in let nk = n % 9 in let ne = n % 25 in let nb = n % 49 in let nl = n % 11 in
  let md = m % 8 in let mk = m % 9 in let me_ch = m % 25 in let mb = m % 49 in let ml = m % 11 in
  /* Verify channel sums = modulus */
  let sd = nd + md in let sk = nk + mk in let se = ne + me_ch in let sb = nb + mb in let sl = nl + ml in
  /* Is n a unit? gcd(n, N) = 1 */
  let is_self_mirror = if n == m then "YES — fixed point of mirror!" else "no" in
  dom_inner(result, "<p style='color:#88ddaa;margin:4px 0'><b>n = " + "${n}" + "</b> | CRT = (" + "${nd}" + "," + "${nk}" + "," + "${ne}" + "," + "${nb}" + "," + "${nl}" + ")</p><p style='color:#ff8844;margin:4px 0'><b>mirror = " + "${m}" + "</b> | CRT = (" + "${md}" + "," + "${mk}" + "," + "${me_ch}" + "," + "${mb}" + "," + "${ml}" + ")</p><p style='color:#ffd700;margin:4px 0'>Channel sums: (" + "${sd}" + "," + "${sk}" + "," + "${se}" + "," + "${sb}" + "," + "${sl}" + ") = (D^3, K^2, E^2, b^2, L)</p><p style='color:#8888ff;margin:4px 0'>Self-mirror? " + is_self_mirror + " | n + mirror = " + "${n + m}" + " = 970200 = 0</p>")
)

fn duality_interactive() = (
  let sec = make_section("800px") in
  render_h2(sec, "Explore: The Mirror");
  render_p(sec, "Every element n has a twin: N-n. Their CRT residues sum to the channel modulus in each channel: (8,9,25,49,11). The mirror swaps without loss — addition is ALWAYS reversible. The mirror IS the additive inverse.");
  make_interactive_widget(sec, "Enter n to see its mirror:", "mir-input", "e.g. 137", "Mirror", "duality_mirror_compute", "mir-result");
  render_p(sec, "Try: 1 (sigma, mirror=970199), 485100 (N/2, self-mirror!), 606376 (OMEGA), 42 (ANSWER, mirror=970158).");
  dom_append(dom_body(), sec)
)

