)

fn duality_membrane() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Membrane Is the Gate");
  render_p(sec, "Life IS the membrane. Not body part counts, not complexity — the GATE function. Selective permeability. D=2 is a lipid BILAYER: two layers, the thinnest possible wall that separates inside from outside. Every living cell has it. Viruses without a membrane are not alive. The membrane IS the D-structure.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Na/K pump", "K=3 Na+ out, D=2 K+ in", "Ratio = K/D. Net charge = sigma. Total ions = E=5. Every animal cell.", "S498");
  render_finding(g, "Bilayer", "D=2 leaflets", "Lipid classes = K=3. ETC complexes = D^2=4 (+synthase = E=5).", "");
  render_finding(g, "Resting potential", "-70 mV = D*E*b", "Action potential +30 = D*K*E. Overshoot 100 = D^2*E^2. ALL axiom-smooth.", "");
  render_finding(g, "Nuclear pore", "D^3=8 fold symmetry", "D*K*E = 30 nucleoporin types. Spider legs at the gate.", "");
  render_finding(g, "Gate depth", "sigma -> D -> b -> D*E", "Prokaryote: 1 gate. Gram-neg: 2. Eukaryote: b=7. Plant: D*E=10.", "");
  render_finding(g, "13 vitamins", "D^2=4 fat + K^2=9 water", "Fat-soluble cross the D=2 bilayer directly. Water-soluble need transport.", "S530");
  render_p(sec, "The Na/K pump consumes 25% of ALL cellular ATP. A quarter of your energy maintains the D=2 gate. Medium IS signal: fish lateral line uses water (HYDOR = K*E*b = 105) as the bus. The ring IS the medium.");
  dom_append(dom_body(), sec)
)

