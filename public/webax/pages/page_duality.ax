  dom_head_meta("description", "D = 2 is the ONLY even prime. Engine of the chain. Self-destructs at step 3. The 42 Theorem. Parity mechanism. D-channel sum. Spinor zero. The bridge that burns behind you.");
  duality_hero();
  duality_drive();
  duality_interactive();
  duality_self_destruct();
  duality_answer();
  duality_membrane();
  duality_sex();
  duality_parity();
  duality_lie();
  duality_contrast()
)
