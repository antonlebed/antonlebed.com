/* duality helpers */
fn duality_hero() = (
  let hero = make_hero("Duality") in
  let eq = dom_create("div") in
  dom_text(eq, "D = 2 (the only even prime)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "28px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "D is the engine of the chain. K = sigma+D. E = sigma+2D. b = sigma+3D. Every step uses D. Without D, no departure, no chain, no structure. D = DRIVE: always 2 away, never arrives. D mod D = 0: drive cannot see itself driving. The hard problem of consciousness IS the even prime.");
  dom_append(dom_body(), hero)
)

