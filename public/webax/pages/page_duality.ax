/* ================================================================
   INTERACTIVE: MIRROR EXPLORER
   Enter n -> see n and N-n (mirror). CRT of both.
   Each channel pair sums to modulus. Duality = the pair.
   ================================================================ */

fn duality_mirror_compute() = (
  let n = parse_int_from("#mir-input") in
  let m = 12612600 - n in
  let result = dom_query("#mir-result") in
  let nd = n % 8 in let nk = n % 9 in let ne = n % 25 in let nb = n % 49 in let nl = n % 11 in let ng = n % 13 in
  let md = m % 8 in let mk = m % 9 in let me_ch = m % 25 in let mb = m % 49 in let ml = m % 11 in let mg = m % 13 in
  /* Verify channel sums = modulus */
  let sd = nd + md in let sk = nk + mk in let se = ne + me_ch in let sb = nb + mb in let sl = nl + ml in let sg_ch = ng + mg in
  /* Is n a unit? gcd(n, N) = 1 */
  let is_self_mirror = if n == m then "YES -- fixed point of mirror!" else "no" in
  dom_inner(result, "<p style='color:#88ddaa;margin:4px 0'><b>n = " + "${n}" + "</b> | CRT = (" + "${nd}" + "," + "${nk}" + "," + "${ne}" + "," + "${nb}" + "," + "${nl}" + "," + "${ng}" + ")</p><p style='color:#ff8844;margin:4px 0'><b>mirror = " + "${m}" + "</b> | CRT = (" + "${md}" + "," + "${mk}" + "," + "${me_ch}" + "," + "${mb}" + "," + "${ml}" + "," + "${mg}" + ")</p><p style='color:#ffd700;margin:4px 0'>Channel sums: (" + "${sd}" + "," + "${sk}" + "," + "${se}" + "," + "${sb}" + "," + "${sl}" + "," + "${sg_ch}" + ") = (D^3, K^2, E^2, b^2, L, GATE)</p><p style='color:#b0b0c0;margin:4px 0'>Self-mirror? " + is_self_mirror + " | n + mirror = " + "${n + m}" + " = 12612600 = 0</p>")
)

