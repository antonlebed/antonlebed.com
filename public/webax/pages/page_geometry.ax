  render_theorem(sec, "Linking Hierarchy (S500, PROVED)", "Linking numbers link(i,j) = N/(q_i*q_j) = product of all OTHER channel sizes. Small channels link most strongly: D^3--K^2 = 175175 (strongest). E^2--b^2 = 10296 (weakest). The linking hierarchy REVERSES channel size. This IS the coupling hierarchy in topological form.");
  let g = make_findings_grid(sec) in
