  let sec = make_section("800px") in
  render_h2(sec, "Numerology vs Axiom");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Feature");
  render_th(hdr, "Numerology");
  render_th(hdr, "Axiom");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "Foundation triangle", "Cherry-picked distances", "DK,DK,heartbeat isosceles forced by CRT arithmetic. DEEP: E,E,b. GATE transforms the triangle.");
  render_contrast_row(tbl, "Curvature duality", "Nice pattern", "D flat / L curved in Hamming, EXACTLY reversed in Cayley. PROVED S243+S352.");
  render_contrast_row(tbl, "Cayley diameter", "Close to DATA^2", "DEEP: DATA^2 + 1 (PRIME). GATE breaks primality via 3 resonances: GATE*D^2+sigma=SUM, b^2*GATE+sigma=D*L*29, D*43*GATE+sigma=K*373. Heegner 43 in the residue.");
  render_contrast_row(tbl, "42 = half-life", "Coincidence", "ln(2)/gap = 42.21. Kf(C_8) = W(C_b) = 42. Two independent proofs. Unique n.");
  render_contrast_row(tbl, "Cross product dims", "Same numbers", "{1,3,7} = Hurwitz 1898. The axiom chain IS the division algebra chain. K = 3 unique for orbits.");
  render_contrast_row(tbl, "Shell e_2 = 56", "Coincidence at E7", "D^3*b = dim(E7 fundamental). Shell polynomial E(x) = product(1 + (q_i-1)*x). Algebraically forced.");
  render_p(sec, "The ring's geometry is not imposed -- it precipitates from CRT. Three metrics, three curvatures, same ring. Every distance, every curvature, every shell count reduces to the six primes. The structure IS the proof.");
  dom_append(dom_body(), sec)
)

/* geometry widget: CRT distance from void */
fn geo_min(a, b) = if a < b then a else b

fn geo_lookup() = (
  let n = parse_int_from("#geo-input") in
  let result = dom_query("#geo-result") in
  if n < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter n >= 0.</p>")
  else (
    let r2 = n % 8 in
    let r3 = n % 9 in
    let r5 = n % 25 in
    let r7 = n % 49 in
    let r11 = n % 11 in
    let r13 = n % 13 in
    /* Hamming distance from void = count of nonzero channels */
    let h2 = if r2 > 0 then 1 else 0 in
    let h3 = if r3 > 0 then 1 else 0 in
    let h5 = if r5 > 0 then 1 else 0 in
    let h7 = if r7 > 0 then 1 else 0 in
    let h11 = if r11 > 0 then 1 else 0 in
    let h13 = if r13 > 0 then 1 else 0 in
    let hamming = h2 + h3 + h5 + h7 + h11 + h13 in
    /* CRT L1 distance from void = sum of min(r_i, q_i - r_i) */
    let d2 = geo_min(r2, 8 - r2) in
    let d3 = geo_min(r3, 9 - r3) in
    let d5 = geo_min(r5, 25 - r5) in
    let d7 = geo_min(r7, 49 - r7) in
    let d11 = geo_min(r11, 11 - r11) in
    let d13 = geo_min(r13, 13 - r13) in
    let l1 = d2 + d3 + d5 + d7 + d11 + d13 in
    /* Cayley distance from void = min(n, N-n) */
    let cayley = if n == 0 then 0 else if n < 6306300 then n else 12612600 - n in
    /* Shell = Hamming distance */
    let shell_name = if hamming == 0 then "VOID (maximum eigenvalue)"
      else if hamming == 1 then "Shell 1 (1 channel active)"
      else if hamming == 2 then "Shell 2"
      else if hamming == 3 then "Shell 3"
      else if hamming == 4 then "Shell 4"
      else if hamming == 5 then "Shell 5"
      else "Shell 6 (maximum distance)" in
    dom_inner(result,
      "<p style='color:#d8d8e0;margin:4px 0'>CRT(" + "${n}" + ") = (" + "${r2}" + ", " + "${r3}" + ", " + "${r5}" + ", " + "${r7}" + ", " + "${r11}" + ", " + "${r13}" + ")</p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>Per-channel wrapped: (" + "${d2}" + ", " + "${d3}" + ", " + "${d5}" + ", " + "${d7}" + ", " + "${d11}" + ", " + "${d13}" + ")</p>"
      + "<p style='color:#88aaff;margin:4px 0;font-size:18px'>Hamming = " + "${hamming}" + " &nbsp; L1 = " + "${l1}" + " &nbsp; Cayley = " + "${cayley}" + "</p>"
      + "<p style='color:#b0b0c0;margin:4px 0'>" + shell_name + "</p>")
  )
)

fn page_geometry() = (
  dom_head_meta("description", "CRT decomposition gives a 6D coordinate system on the torus T^6. Three metrics (Hamming, CRT L1, Cayley) see different structure. Foundation triangle: DK, DK, heartbeat isosceles. Curvature duality: D flat / L curved in Hamming, reversed in Cayley. Hamming degree 109 = OMEGA factor. Cayley diameter TRUE = 573301 = 29 x SUM x 373. Kirchhoff + heat half-life = 42.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Geometry\",\"description\":\"Ring geometry from CRT decomposition. T^6 torus keychain with linking numbers. Three metrics, three curvatures. Foundation triangle DK,DK,heartbeat isosceles. Hamming degree 109 = OMEGA factor. Cayley diameter TRUE = 573301. Heat half-life = 42.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/data/geometry\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"CRT distance\"},{\"@type\":\"DefinedTerm\",\"name\":\"Cayley graph\"},{\"@type\":\"DefinedTerm\",\"name\":\"torus topology\"}]}");
  geometry_hero();
  geometry_metrics();
  geometry_foundation();
  geometry_shells();
  geometry_curvature();
  geometry_cayley();
  geometry_answer();
  geometry_cross();
  geometry_collinear();
  geometry_torus();
  geometry_expansion();

  /* === INTERACTIVE: CRT DISTANCE EXPLORER === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Distance from Void");
  render_p(sec_i, "Enter n to see its CRT coordinates and distance from 0 in all three metrics. Hamming counts active channels, L1 sums wrapped per-channel distances, Cayley is clock distance.");
  make_interactive_widget(sec_i, "Enter n:", "geo-input", "e.g. 137", "Measure", "geo_lookup", "geo-result");
  render_p(sec_i, "Try: 1 (sigma, L1=6), 1576576 (OMEGA, L1=1), 12612599 (mirror), 13 (GATE).");
  dom_append(dom_body(), sec_i);

  geometry_contrast()
)
