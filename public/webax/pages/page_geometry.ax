  let g = make_findings_grid(sec) in
  render_finding(g, "GATE = 13", "Only 9/10 proper triangles", "The pair {sigma, D} stays collinear with GATE. D lies on the geodesic from sigma to GATE. The bridge IS on the road to the boundary.", "S779");
  render_finding(g, "Expansion", "girth = 4, degree = D^2*K = 12", "TRUE ring: triangle-free (all q_i >= 4). Degree 12 = heartbeat. Spectral gap from b^2 = 49 channel (slowest mixer).", "S245");
  dom_append(dom_body(), sec)
)

