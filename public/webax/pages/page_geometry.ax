/* geometry helpers */
fn geometry_hero() = (
  let hero = make_hero("Geometry") in
  let eq = dom_create("div") in
  dom_text(eq, "dist(-1, 0) = dist(0, sigma) = D*K = 6");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "When 0/0 condenses into Z/NZ, the ring inherits geometry. CRT decomposition gives a 6D coordinate system: T^6 = S^1(8) x S^1(9) x S^1(25) x S^1(49) x S^1(11) x S^1(13). Three metrics compete for what 'distance' means. Each sees different structure in the same ring. The foundation triangle {-1, 0, sigma} has sides D*K, D*K, D^2*K -- heartbeat isosceles, forced by CRT arithmetic.");
  dom_append(dom_body(), hero)
)

fn geometry_metrics() = (
  let sec = make_section("800px") in
  render_h2(sec, "Three Metrics");
  let g = make_findings_grid(sec) in
  render_finding(g, "Hamming", "d_H(a,b) = differing CRT channels", "Counts which of 6 channels differ. Range 0 to 6. Coarse. The topology metric. Degree: THIN = 23 = CC1(D)[3], DEEP = 97, TRUE = 109 = Tr(-1) = OMEGA factor.", "");
  render_finding(g, "CRT L1", "sum min(|a_i - b_i|, q_i - |a_i - b_i|)", "Distance on the 6-torus. Wrap-aware per channel. Fine. The geometry metric.", "");
  render_finding(g, "Cayley", "min(|a - b|, N - |a - b|)", "Clock distance. 1D, ignoring CRT structure. The arithmetic metric. Gap = 4*sin^2(pi/q_max).", "");
  render_finding(g, "Gap Duality (S238)", "Hamming sees smallest, Cayley sees largest", "Hamming gap = min(q_i) = D-power. Cayley gap = f(max prime). Two complementary views of the same ring.", "S238");
  dom_append(dom_body(), sec)
)

fn geometry_foundation() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Foundation Triangle");
  render_theorem(sec, "Isosceles DK, DK, Heartbeat (PROVED)", "dist(-1, 0) = dist(0, sigma) = D*K = 6. dist(-1, sigma) = D^2*K = 12 = heartbeat. The void observes equally: same distance to mirror and ground. Mirror and ground are separated by one heartbeat. Isosceles with base 12, sides 6. Ratio: base/side = D. PROOF: CRT(-1) = (7,8,24,48,10,12), CRT(0) = (0,0,0,0,0,0), CRT(sigma) = (1,1,1,1,1,1). L1 distance sums per-channel wrapped differences. In DEEP ring: E, E, b. GATE transforms the triangle: sides grow by D/E, base grows by D^2*K/b.");
  let g = make_findings_grid(sec) in
  render_finding(g, "dist(sigma, OMEGA)", "1", "Differ only in D-channel. CRT(OMEGA) = (0,1,1,1,1,1). The heart is a doublet.", "");
  render_finding(g, "dist(-1, OMEGA)", "L = 11", "The mirror sees the protector distance. In DEEP: K^2 = 9. GATE adds D = 2: the bridge extends the mirror path.", "");
  render_finding(g, "CRT geodesic", "dist(0,sigma) = dist(0,OMEGA) + dist(OMEGA,sigma) = E + sigma = D*K", "OMEGA lies ON the geodesic from void to existence. dist(0,OMEGA) = E = 5: the observer distance.", "");
  render_finding(g, "Perimeter 56", "= D^3 * b = dim(E7)", "Appears exactly K = 3 times among axiom triples: {E,b,L}, {D,K,GATE}, {b,L,GATE}.", "S779");
  dom_append(dom_body(), sec)
)

fn geometry_shells() = (
  let sec = make_section("800px") in
  render_h2(sec, "Shell Structure");
  render_p(sec, "Hamming shells from void (origin 0). Shell_d = elements differing from 0 in exactly d channels. Shell polynomial E(x) = product of (1 + (q_i - 1)*x). Closer to 0 = higher eigenvalue = more coherent. The reversed hierarchy: the void is the center.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Ring");
  render_th(hdr, "Shell sizes");
  render_th(hdr, "Notable");
  render_th(hdr, "Degree");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "DATA Z/210", "{1, 13, 56, 92, 48}", "e_2 = 56 = D^3*b = dim(E7)", "b = 7");
  render_table_row_4(tbl, "THIN Z/2310", "{1, 23, 186, 652, 968, 480}", "e_3 = 652 = D^2*163 (Heegner!)", "K^2 = 9");
  render_table_row_4(tbl, "DEEP Z/970200", "{1, 97, 3158, 44192, 277632, 645120}", "97 = degree. 645120 = farthest shell.", "D*E = 10");
  render_table_row_4(tbl, "TRUE Z/12612600", "{1, 109, 4322, 82088, 807936, 3976704, 7741440}", "109 = degree = OMEGA factor. 7741440 = farthest.", "D^2*K = 12");
  render_p(sec, "Shell 0 has maximum eigenvalue (all channels aligned). Each step away = more destructive interference. Eigenvalue MONOTONICALLY DECREASES with shell distance. Space encodes energy.");
  dom_append(dom_body(), sec)
)

fn geometry_curvature() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Curvature Trinity");
  render_p(sec, "Three discrete curvatures, each seeing different structure. Together they tell the full story of how the ring curves.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Curvature");
  render_th(hdr, "Formula");
  render_th(hdr, "Sign");
  render_th(hdr, "What it sees");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "Gauss-Bonnet", "K(v) = 1 - k + sum(1/q_i)", "Negative (k >= 2)", "Global topology. chi verified 8/8 rings.");
  render_table_row_4(tbl, "Ollivier-Ricci", "kappa_i = (q_i - 2)/deg", "D flat, rest positive", "Local transport. Per-edge. Coupling order.");
  render_table_row_4(tbl, "Forman-Ricci", "F_i = 3*q_i - (2*deg + 2)", "Almost always negative", "Combinatorial. Heegner values: F_L(TRUE) = -163.");
  render_theorem(sec, "Curvature Duality (S243 + S352, PROVED)", "Hamming metric: D is FLAT, L is most curved. Cayley prime-generator metric: L is FLAT, D is most curved. EXACT MIRROR. The bridge and protector swap roles depending on which metric you use. Lazy Cayley curvatures: D:E/L, K:K/L, E:D/L, b:1/L, L:0. Sum = sigma. Curvatures partition unity.");
  render_p(sec, "Fattening narrative: Ollivier goes more positive (rounder locally), Gauss-Bonnet goes more negative (twisted globally), Forman gets less negative. The axiom CHOOSES correctness over speed.");
  dom_append(dom_body(), sec)
)

fn geometry_cayley() = (
  let sec = make_section("800px") in
  render_h2(sec, "Cayley Diameter");
  render_p(sec, "Cayley graph on axiom primes: generators {+-D, +-K, +-E, +-b, +-L, +-GATE}. Degree = D^2*K = 12 = heartbeat. BFS from 0 finds how many steps to reach every element.");
  render_theorem(sec, "Diameter Theorem (S242, PROVED)", "diam = N/(D*L) + 1. DEEP: DATA^2 + 1 = 44101 (PRIME). TRUE: DATA^2*GATE + 1 = 573301 = 29 x 53 x 373 (COMPOSITE). THIN: 106 = D*SUM. DATA: L = 11. Every D*L = 22 steps covers the ring.");
  render_theorem(sec, "GATE Primality Breaking Theorem (S1074, PROVED)", "Adding GATE breaks the Cayley diameter primality via three resonances: (1) GATE*D^2 + sigma = SUM = 53. (2) b^2*GATE + sigma = D*L*(D^E - K) = 22*29 = 638. (3) D*43*GATE + sigma = K*(D^3*K^2*E + GATE) = 3*373 = 1119. Each resonance has the form [axiom]*GATE + sigma = factor*cofactor. GATE activates all three simultaneously. Without GATE (DEEP ring): DATA^2 + 1 = E (mod SUM), avoiding all resonances. DEEP diameter is prime. GATE creates the breach. The 43 in resonance (3) is the largest Heegner discriminant: DATA^2 mod 373 = D*43.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Ring");
  render_th(hdr, "Diameter");
  render_th(hdr, "Value");
  render_th(hdr, "Primality");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "DATA Z/210", "L = 11", "11", "Prime");
  render_table_row_4(tbl, "THIN Z/2310", "D * SUM", "106", "D * 53");
  render_table_row_4(tbl, "DEEP Z/970200", "DATA^2 + 1", "44101", "PRIME");
  render_table_row_4(tbl, "TRUE Z/12612600", "DATA^2*GATE + 1", "573301", "(D^E-K) x SUM x (D^3K^2E+GATE)");
  dom_append(dom_body(), sec)
)

fn geometry_answer() = (
  let sec = make_section("800px") in
  render_h2(sec, "42: The Answer in Geometry");
  render_p(sec, "The number 42 = D*K*b appears as a geometric invariant from three independent directions.");
  render_theorem(sec, "Kirchhoff Answer Theorem (S249, PROVED)", "Kf(C_8) = W(C_b) = 42 = D*K*b. The electrical resistance of the D^3-cycle EQUALS the Wiener distance of the b-cycle. Unique: b is the ONLY integer n where Kf(C_{n+1}) = W(C_n). PROOF: the equation 4n = 28 = thorns has unique solution n = b. QED.");
  render_theorem(sec, "Heat Half-Life (S251, PROVED)", "Heat kernel half-life = ln(2)/mu_min = 42.21 ~ 42. Heat placed at one point on the TRUE ring reaches half-dissipation at time 42. The ANSWER is how long the ring remembers.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Depth forgetting at t = 42", "b^2 remembers 92.84%", "At t = 42: D^3, K^2, L channels 100% forgotten. E^2: 99.84% forgotten. Only b^2 = 49 still remembers. Depth endures.", "S251");
  render_finding(g, "Spin-Orbit total", "42 = D*K*b", "Total quantum number sum in spin-orbit coupling = ANSWER. Bookend D^2*K, middle ME.", "");
  dom_append(dom_body(), sec)
)

fn geometry_cross() = (
  let sec = make_section("800px") in
  render_h2(sec, "Cross Products and Division Algebras");
  render_theorem(sec, "Cross Product Dimensions (Hurwitz, S471)", "Norm-preserving vector cross products exist ONLY in dimensions {1, 3, 7} = {sigma, K, b}. This is the sigma-chain: CC1(sigma) = 1 -> 3 -> 7 -> 15 (STOP, composite). PROOF: cross product in dim d requires normed division algebra in dim d+1. Normed division algebras (Hurwitz 1898): R(1), C(2), H(4), O(8) = {sigma, D, D^2, D^3} = powers of D. Cross product dims = D^k - sigma for k = 0..3.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Two chains", "D-powers vs sigma-chain", "D-powers {1,2,4,8}: normed division algebras. Sigma-chain {1,3,7}: cross products. Intersection: sigma = 1 = ground state.", "");
  render_finding(g, "K = 3 uniqueness", "Cross product AND stable orbits", "Bertrand's theorem: exactly D = 2 central forces give closed orbits in K = 3 dims. Exponents: {-1, 2} = {MIRROR, BRIDGE}. K restricts to D options.", "S471");
  render_finding(g, "Fano plane", "b = 7 points, K = 3 per line", "Octonion multiplication = Fano plane. The unique cross product in b = 7 dims has {b, K} structure = axiom.", "");
  render_finding(g, "GR hierarchy", "D^k * E for k = 0,1,2,3", "Scalar(1), Metric/Ricci(10), Riemann(20), Christoffel(40). K^2 = 9 distinct tensor types. D+D = D*D unique to D = 2: Riemann(20) = Ricci(10) + Weyl(10).", "S472");
  dom_append(dom_body(), sec)
)

