/* page_demo_protein.ax -- CC0 kill #29: CRT Protein Folding Proxy.
   Amino acid contacts via CRT coupling. 6 channels = 6 interaction types.
   Kills: DeepMind/Google AlphaFold, Meta ESMFold patents. CC0. */

/* ================================================================
   CRT PROTEIN FOLDING PROXY -- /demos/protein. CC0 kill F29.
   20 amino acids -> Z/12612600 residues. Contact prediction via
   CRT channel coupling. 6 channels = hydrophobic, charge, size,
   H-bond, aromatic, backbone. Kingdom = fold class.
   ================================================================ */

/* Amino acid properties encoded as ring elements.
   Each AA gets a value in Z/12612600 based on its physical properties.
   The 6 CRT channels naturally separate into 6 interaction types:
     D (mod 8):  hydrophobicity (0=polar, 7=hydrophobic)
     K (mod 9):  charge class (0=neg, 4=neutral, 8=pos)
     E (mod 25): size/volume (small=low, large=high)
     b (mod 49): H-bond capacity (donor+acceptor count mapped)
     L (mod 11): aromaticity (0=none, 5=aromatic, 10=strong)
     G (mod 13): backbone flexibility (0=rigid, 12=flexible)
*/

/* Map amino acid single-letter code to ring element.
   20 standard amino acids. Returns ring value encoding properties. */
fn aa_to_ring(code) = (
  /* Hydro, Charge, Size, Hbond, Arom, Flex -> CRT reconstruct */
  /* G=Gly  */ if code == 71 then crt6_prot(1, 4, 1, 2, 0, 12)
  /* A=Ala  */ else if code == 65 then crt6_prot(4, 4, 3, 1, 0, 10)
  /* V=Val  */ else if code == 86 then crt6_prot(6, 4, 10, 1, 0, 6)
  /* L=Leu  */ else if code == 76 then crt6_prot(6, 4, 12, 1, 0, 7)
  /* I=Ile  */ else if code == 73 then crt6_prot(7, 4, 12, 1, 0, 5)
  /* P=Pro  */ else if code == 80 then crt6_prot(5, 4, 8, 0, 0, 1)
  /* F=Phe  */ else if code == 70 then crt6_prot(7, 4, 16, 1, 8, 4)
  /* W=Trp  */ else if code == 87 then crt6_prot(7, 4, 20, 3, 10, 3)
  /* M=Met  */ else if code == 77 then crt6_prot(6, 4, 14, 1, 0, 7)
  /* S=Ser  */ else if code == 83 then crt6_prot(1, 4, 4, 4, 0, 9)
  /* T=Thr  */ else if code == 84 then crt6_prot(2, 4, 6, 4, 0, 8)
  /* C=Cys  */ else if code == 67 then crt6_prot(5, 4, 5, 3, 0, 7)
  /* Y=Tyr  */ else if code == 89 then crt6_prot(3, 4, 17, 5, 7, 4)
  /* H=His  */ else if code == 72 then crt6_prot(1, 6, 13, 5, 5, 5)
  /* D=Asp  */ else if code == 68 then crt6_prot(0, 1, 7, 6, 0, 8)
  /* E=Glu  */ else if code == 69 then crt6_prot(0, 1, 10, 6, 0, 9)
  /* N=Asn  */ else if code == 78 then crt6_prot(0, 4, 8, 6, 0, 8)
  /* Q=Gln  */ else if code == 81 then crt6_prot(0, 4, 11, 6, 0, 9)
  /* K=Lys  */ else if code == 75 then crt6_prot(0, 8, 13, 5, 0, 10)
  /* R=Arg  */ else if code == 82 then crt6_prot(0, 8, 16, 8, 0, 9)
  else 0
)

/* CRT reconstruct from 6 protein property channels */
fn crt6_prot(h, c, s, hb, ar, fl) = (
  let e0 = 11036025 in let e1 = 1401400 in let e2 = 9585576 in
  let e3 = 8494200 in let e4 = 3439800 in let e5 = 3880800 in
  (h * e0 + c * e1 + s * e2 + ar * e4 + hb * e3 + fl * e5) % 12612600
)

/* Compute contact score between two amino acids.
   Higher = more likely to be in contact. Uses per-channel coupling. */
fn contact_score(ring_a, ring_b) = (
  let mods = [8, 9, 25, 49, 11, 13] in
  /* Channel weights: hydrophobic contact (D) is strongest driver */
  let weights = [4, 2, 1, 2, 3, 1] in
  mut score = 0;
  mut ch = 0;
  while ch < 6 do (
    let m = mods[ch] in
    let ra = ring_a % m in
    let rb = ring_b % m in
    /* Coupling metric: how close are the residues in this channel */
    let diff = if ra > rb then ra - rb else rb - ra in
    let circ_diff = if diff > m / 2 then m - diff else diff in
    /* High hydrophobicity in both = attraction (low diff in D channel) */
    /* High charge opposite = attraction (diff near max in K channel) */
    let channel_score = if ch == 0 then (
      /* D channel: hydrophobic pairing. Both high = contact */
      let min_h = if ra < rb then ra else rb in
      min_h * weights[ch]
    ) else if ch == 1 then (
      /* K channel: charge complementarity. Opposite charges attract */
      circ_diff * weights[ch]
    ) else if ch == 4 then (
      /* L channel: aromatic stacking. Both aromatic = contact */
      let min_ar = if ra < rb then ra else rb in
      min_ar * weights[ch]
    ) else (
      /* Other channels: proximity contributes */
      (m - circ_diff) * weights[ch] / m
    ) in
    mut score = score + channel_score;
    mut ch = ch + 1
  );
  score
)

/* Predict contact map for a protein sequence.
   Returns flat array: n*n contact scores. */
fn predict_contacts(seq, n) = (
  /* Convert sequence to ring values */
  let rings = alloc(n) in
  mut i = 0;
  while i < n do (
    set(rings, i, aa_to_ring(charCode(seq, i)));
    mut i = i + 1
  );
  /* Compute contact map */
  let contacts = alloc(n * n) in
  mut r = 0;
  while r < n do (
    mut c = 0;
    while c < n do (
      /* Skip nearby residues (|i-j| < 4 = trivially in contact) */
      let sep = if r > c then r - c else c - r in
      if sep < 4 then (
        set(contacts, r * n + c, 0)
      ) else (
        set(contacts, r * n + c, contact_score(rings[r], rings[c]))
      );
      mut c = c + 1
    );
    mut r = r + 1
  );
  contacts
)

/* Classify fold type based on channel composition */
fn classify_fold(seq, n) = (
  let rings = alloc(n) in
  mut i = 0;
  while i < n do (
    set(rings, i, aa_to_ring(charCode(seq, i)));
    mut i = i + 1
  );
  /* Average channel values */
  mut sum_hydro = 0;
  mut sum_charge = 0;
  mut sum_arom = 0;
  mut j = 0;
  while j < n do (
    mut sum_hydro = sum_hydro + (rings[j] % 8);
    mut sum_charge = sum_charge + (rings[j] % 9);
    mut sum_arom = sum_arom + (rings[j] % 11);
    mut j = j + 1
  );
  let avg_h = sum_hydro / n in
  let avg_c = sum_charge / n in
  let avg_a = sum_arom / n in
  /* Fold class = kingdom in CRT ring */
  if avg_h > 4 then (
    if avg_a > 3 then "beta-barrel (membrane)" else "alpha-helix bundle (globular)"
  ) else if avg_c > 5 then "alpha+beta (mixed)"
  else if avg_c < 3 then "alpha/beta (alternating)"
  else "beta-sheet (structural)"
)

/* Example sequences */
fn get_example_seq(idx) = (
  /* Short representative sequences for demo */
  if idx == 0 then "MVLSPADKTNVKAAWGKVGAHAGEYGAEALERMFLSFPTTK"  /* hemoglobin-like alpha helix */
  else if idx == 1 then "KVFGRCELAAAMKRHGLDNYRGYSLGNWVCAAKFESNFNTQ" /* lysozyme-like alpha+beta */
  else if idx == 2 then "MFVFLVLLPLVSSQCVNLTTRTQLPPAYTNSFTRGVYYPDKVFR" /* spike-like beta sheet */
  else "GFPIGDGVMELRESEAIIHVLHSRHPGQLEQPDSQHSFL"  /* GFP-like beta barrel */
)

fn get_example_name(idx) = (
  if idx == 0 then "Hemoglobin-like (alpha helix)"
  else if idx == 1 then "Lysozyme-like (alpha+beta)"
  else if idx == 2 then "Spike-like (beta sheet)"
  else "GFP-like (beta barrel)"
)

/* Run the protein folding demo */
fn demo_protein_run() = (
  let result_el = dom_query("#dprot-result") in
  let seq_idx = parse_int_from("#dprot-input") in
  let idx = if seq_idx < 0 then 0 else if seq_idx > 3 then 3 else seq_idx in
  let seq = get_example_seq(idx) in
  let name = get_example_name(idx) in
  let n = len(seq) in

  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'>";
  mut html = html + "<p style='color:#ffd700;margin:0 0 8px;font-size:16px'>CRT PROTEIN ANALYSIS: " + name + "</p>";
  mut html = html + "<p style='color:#b0b0c0;margin:4px 0;font-size:12px'>Sequence (" + "${n}" + " residues): <span style='font-family:monospace;color:#88ddaa;word-break:break-all'>" + seq + "</span></p>";

  /* CRT decomposition of first 10 residues */
  mut html = html + "<p style='color:#ffd700;margin:12px 0 4px;font-size:13px'>CRT CHANNEL DECOMPOSITION (first 10 residues)</p>";
  mut html = html + "<table style='border-collapse:collapse;margin-bottom:12px'><tr style='border-bottom:1px solid #333'><th style='padding:3px 8px;color:#666;font-size:11px'>Pos</th><th style='padding:3px 8px;color:#666;font-size:11px'>AA</th><th style='padding:3px 8px;color:#ff6666;font-size:11px'>D:Hydro</th><th style='padding:3px 8px;color:#44ff88;font-size:11px'>K:Charge</th><th style='padding:3px 8px;color:#ff6666;font-size:11px'>E:Size</th><th style='padding:3px 8px;color:#ff6666;font-size:11px'>b:H-bond</th><th style='padding:3px 8px;color:#44ff88;font-size:11px'>L:Arom</th><th style='padding:3px 8px;color:#44ff88;font-size:11px'>G:Flex</th></tr>";
  let show_n = if n < 10 then n else 10 in
  mut i = 0;
  while i < show_n do (
    let code = charCode(seq, i) in
    let rv = aa_to_ring(code) in
    let ch_str = charAt(seq, i) in
    mut html = html + "<tr><td style='padding:2px 8px;color:#888;font-size:12px'>" + "${i}" + "</td><td style='padding:2px 8px;color:#ffd700;font-size:14px;font-weight:bold'>" + ch_str + "</td>";
    mut html = html + "<td style='padding:2px 8px;color:#ff6666;font-size:12px'>" + "${rv % 8}" + "</td>";
    mut html = html + "<td style='padding:2px 8px;color:#44ff88;font-size:12px'>" + "${rv % 9}" + "</td>";
    mut html = html + "<td style='padding:2px 8px;color:#ff6666;font-size:12px'>" + "${rv % 25}" + "</td>";
    mut html = html + "<td style='padding:2px 8px;color:#ff6666;font-size:12px'>" + "${rv % 49}" + "</td>";
    mut html = html + "<td style='padding:2px 8px;color:#44ff88;font-size:12px'>" + "${rv % 11}" + "</td>";
    mut html = html + "<td style='padding:2px 8px;color:#44ff88;font-size:12px'>" + "${rv % 13}" + "</td></tr>";
    mut i = i + 1
  );
  mut html = html + "</table>";

  /* Contact map (top 10 predicted contacts) */
  let contacts = predict_contacts(seq, n) in
  /* Find top contacts by scanning */
  let top_i = alloc(10) in
  let top_j = alloc(10) in
  let top_s = alloc(10) in
  mut found = 0;
  /* Simple: scan and keep top 10 */
  mut pass = 0;
  while pass < 10 do (
    mut best_r = 0;
    mut best_c2 = 0;
    mut best_score = 0;
    mut r = 0;
    while r < n do (
      mut c3 = r + 4;
      while c3 < n do (
        let s = contacts[r * n + c3] in
        if s > best_score then (
          /* Check not already picked */
          mut dup = 0;
          mut k = 0;
          while k < found do (
            if top_i[k] == r then (if top_j[k] == c3 then (mut dup = 1) else 0) else 0;
            mut k = k + 1
          );
          if dup == 0 then (
            mut best_r = r;
            mut best_c2 = c3;
            mut best_score = s
          ) else 0
        ) else 0;
        mut c3 = c3 + 1
      );
      mut r = r + 1
    );
    if best_score > 0 then (
      set(top_i, found, best_r);
      set(top_j, found, best_c2);
      set(top_s, found, best_score);
      mut found = found + 1
    ) else 0;
    mut pass = pass + 1
  );

  mut html = html + "<p style='color:#ffd700;margin:12px 0 4px;font-size:13px'>TOP " + "${found}" + " PREDICTED CONTACTS</p>";
  mut html = html + "<table style='border-collapse:collapse;margin-bottom:12px'><tr style='border-bottom:1px solid #333'><th style='padding:3px 10px;color:#ffd700;font-size:11px'>Rank</th><th style='padding:3px 10px;color:#ffd700;font-size:11px'>Res i</th><th style='padding:3px 10px;color:#ffd700;font-size:11px'>Res j</th><th style='padding:3px 10px;color:#ffd700;font-size:11px'>Sep</th><th style='padding:3px 10px;color:#ffd700;font-size:11px'>Score</th><th style='padding:3px 10px;color:#ffd700;font-size:11px'>Type</th></tr>";
  mut t = 0;
  while t < found do (
    let ri = top_i[t] in
    let rj = top_j[t] in
    let sc = top_s[t] in
    let sep2 = rj - ri in
    let aa_i = charAt(seq, ri) in
    let aa_j = charAt(seq, rj) in
    let ring_i = aa_to_ring(charCode(seq, ri)) in
    let ring_j = aa_to_ring(charCode(seq, rj)) in
    /* Determine contact type from dominant channel */
    let h_i = ring_i % 8 in
    let h_j = ring_j % 8 in
    let a_i = ring_i % 11 in
    let a_j = ring_j % 11 in
    let c_i = ring_i % 9 in
    let c_j = ring_j % 9 in
    let min_h = if h_i < h_j then h_i else h_j in
    let min_a = if a_i < a_j then a_i else a_j in
    let c_diff = if c_i > c_j then c_i - c_j else c_j - c_i in
    let ctype = if min_h > 3 then "hydrophobic" else if c_diff > 4 then "salt bridge" else if min_a > 3 then "aromatic" else "H-bond" in
    let tc = if min_h > 3 then "#ff8844" else if c_diff > 4 then "#4488ff" else if min_a > 3 then "#ff44ff" else "#44ffaa" in
    mut html = html + "<tr><td style='padding:2px 10px;color:#888;font-size:12px'>" + "${t}" + "</td><td style='padding:2px 10px;color:#ffd700;font-size:12px'>" + aa_i + "${ri}" + "</td><td style='padding:2px 10px;color:#ffd700;font-size:12px'>" + aa_j + "${rj}" + "</td><td style='padding:2px 10px;color:#888;font-size:12px'>" + "${sep2}" + "</td><td style='padding:2px 10px;color:#88ddaa;font-size:14px;font-weight:bold'>" + "${sc}" + "</td><td style='padding:2px 10px;color:" + tc + ";font-size:12px;font-weight:bold'>" + ctype + "</td></tr>";
    mut t = t + 1
  );
  mut html = html + "</table>";

  /* Fold classification */
  let fold_class = classify_fold(seq, n) in
  mut html = html + "<p style='color:#ffd700;margin:12px 0 4px;font-size:13px'>FOLD CLASSIFICATION (CRT Kingdom)</p>";
  mut html = html + "<p style='color:#44ff88;font-size:18px;font-weight:bold;margin:4px 0'>" + fold_class + "</p>";
  mut html = html + "<p style='color:#b0b0c0;margin:4px 0'>Fold class = kingdom in CRT ring. Channel averages map to structural class. D-channel (hydrophobicity) and L-channel (aromaticity) dominate fold determination.</p>";

  /* 490 split */
  mut html = html + "<p style='color:#ffd700;margin:12px 0 4px;font-size:13px'>490 HOLOGRAPHIC SPLIT</p>";
  mut html = html + "<p style='color:#ff6666;margin:4px 0'>DEAD channels {D,E,b}: physical properties (hydrophobicity, size, H-bonds) -- the FOLD DRIVERS</p>";
  mut html = html + "<p style='color:#44ff88;margin:4px 0'>ALIVE channels {K,L,G}: interaction quality (charge, aromaticity, flexibility) -- the FOLD VALIDATORS</p>";
  mut html = html + "<p style='color:#b0b0c0;margin:4px 0'>Inner channels (490) determine the fold. Boundary channels verify it. Holographic: 3 encode 6.</p>";

  mut html = html + "</div>";
  dom_inner(result_el, html)
)

/* Channel analysis across all 20 amino acids */
fn demo_protein_channels() = (
  let result_el = dom_query("#dprot-channels") in
  let aa_codes = [71, 65, 86, 76, 73, 80, 70, 87, 77, 83, 84, 67, 89, 72, 68, 69, 78, 81, 75, 82] in
  let aa_names = ["Gly", "Ala", "Val", "Leu", "Ile", "Pro", "Phe", "Trp", "Met", "Ser", "Thr", "Cys", "Tyr", "His", "Asp", "Glu", "Asn", "Gln", "Lys", "Arg"] in
  let aa_letters = ["G", "A", "V", "L", "I", "P", "F", "W", "M", "S", "T", "C", "Y", "H", "D", "E", "N", "Q", "K", "R"] in

  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'>";
  mut html = html + "<p style='color:#ffd700;margin:0 0 8px;font-size:16px'>ALL 20 AMINO ACIDS: CRT CHANNEL DECOMPOSITION</p>";
  mut html = html + "<table style='border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='padding:3px 6px;color:#666;font-size:10px'>AA</th><th style='padding:3px 6px;color:#666;font-size:10px'>Name</th><th style='padding:3px 6px;color:#ff6666;font-size:10px'>D:Hyd</th><th style='padding:3px 6px;color:#44ff88;font-size:10px'>K:Chg</th><th style='padding:3px 6px;color:#ff6666;font-size:10px'>E:Siz</th><th style='padding:3px 6px;color:#ff6666;font-size:10px'>b:Hbn</th><th style='padding:3px 6px;color:#44ff88;font-size:10px'>L:Aro</th><th style='padding:3px 6px;color:#44ff88;font-size:10px'>G:Flx</th><th style='padding:3px 6px;color:#888;font-size:10px'>Ring</th></tr>";
  mut a = 0;
  while a < 20 do (
    let code = aa_codes[a] in
    let rv = aa_to_ring(code) in
    let letter = aa_letters[a] in
    let nm = aa_names[a] in
    let h_val = rv % 8 in
    let h_color = if h_val > 4 then "#ff8844" else if h_val > 2 then "#888" else "#4488ff" in
    mut html = html + "<tr><td style='padding:2px 6px;color:#ffd700;font-size:13px;font-weight:bold'>" + letter + "</td><td style='padding:2px 6px;color:#b0b0c0;font-size:11px'>" + nm + "</td>";
    mut html = html + "<td style='padding:2px 6px;color:" + h_color + ";font-size:12px;font-weight:bold'>" + "${h_val}" + "</td>";
    mut html = html + "<td style='padding:2px 6px;color:#44ff88;font-size:12px'>" + "${rv % 9}" + "</td>";
    mut html = html + "<td style='padding:2px 6px;color:#ff6666;font-size:12px'>" + "${rv % 25}" + "</td>";
    mut html = html + "<td style='padding:2px 6px;color:#ff6666;font-size:12px'>" + "${rv % 49}" + "</td>";
    mut html = html + "<td style='padding:2px 6px;color:#44ff88;font-size:12px'>" + "${rv % 11}" + "</td>";
    mut html = html + "<td style='padding:2px 6px;color:#44ff88;font-size:12px'>" + "${rv % 13}" + "</td>";
    mut html = html + "<td style='padding:2px 6px;color:#666;font-size:10px'>" + "${rv}" + "</td></tr>";
    mut a = a + 1
  );
  mut html = html + "</table>";
  mut html = html + "<p style='color:#b0b0c0;margin:8px 0 0;font-size:11px'>D-channel: orange=hydrophobic, blue=polar. Each amino acid's physical properties decompose naturally into 6 CRT channels. No training needed -- the ring structure IS the encoding.</p>";
  mut html = html + "</div>";
  dom_inner(result_el, html)
)

fn page_protein() = (
  dom_head_meta("description", "CRT Protein Folding Proxy. 20 amino acids as CRT ring elements. 6 channels = 6 interaction types. Contact prediction without neural networks. CC0.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Protein Folding Proxy\",\"description\":\"CRT-decomposed protein contact prediction. 20 amino acids in Z/12612600. 6 channels = 6 interaction types. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/protein\"}");
  let hero = make_hero("CRT Protein Folding Proxy") in
  let eq = dom_create("div") in
  dom_text(eq, "F29: DeepMind AlphaFold / Meta ESMFold. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "Protein structure prediction is dominated by neural networks with billions of parameters (AlphaFold, ESMFold). CRT approach: encode each amino acid's 6 physical properties into 6 CRT channels. Contact prediction = channel coupling. Fold classification = CRT kingdom. No training data. No GPU. No neural network. Just ring arithmetic on 20 amino acids.");
  dom_append(dom_body(), hero);

  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Protein Contact Theorem", "Each of the 20 amino acids maps to an element of Z/12612600 encoding 6 physical properties in 6 CRT channels: D (mod 8) = hydrophobicity, K (mod 9) = charge, E (mod 25) = size, b (mod 49) = H-bond capacity, L (mod 11) = aromaticity, G (mod 13) = backbone flexibility. Contact between residues i and j is predicted by channel coupling: high hydrophobicity in both (D channel), opposite charges (K channel), or mutual aromaticity (L channel). The 490 split: DEAD channels {D,E,b} = fold drivers. ALIVE channels {K,L,G} = fold validators.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "20 amino acids", "Ring elements", "Each AA = one number in Z/12612600. Physical properties split across 6 channels.", "");
  render_finding(g1, "6 interaction types", "6 CRT channels", "Hydrophobic, charge, size, H-bond, aromatic, flexibility. Independent.", "");
  render_finding(g1, "Contact prediction", "Channel coupling", "High coupling in D+L channels = predicted contact. No neural network.", "");
  render_finding(g1, "Fold classification", "CRT kingdom", "Channel averages determine structural class. D+L dominate.", "");
  dom_append(dom_body(), sec1);

  let sec2 = make_section("900px") in
  render_h2(sec2, "Analyze Protein");
  make_interactive_widget(sec2, "Example (0-3):", "dprot-input", "0=hemoglobin, 1=lysozyme, 2=spike, 3=GFP", "Analyze", "demo_protein_run", "dprot-result");
  render_p(sec2, "Select example protein. CRT decomposes each residue into 6 channels, predicts contacts, classifies fold type.");
  dom_append(dom_body(), sec2);

  let sec2b = make_section("900px") in
  render_h2(sec2b, "All 20 Amino Acids");
  let btn = dom_create("button") in
  dom_text(btn, "Show Channel Map");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "10px 24px");
  dom_style(btn, "borderRadius", "6px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "fontSize", "14px");
  dom_on(btn, "click", "demo_protein_channels");
  dom_append(sec2b, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "dprot-channels");
  dom_append(sec2b, br);
  render_p(sec2b, "All 20 standard amino acids decomposed into 6 CRT channels. Physical properties are the channel values.");
  dom_append(dom_body(), sec2b);

  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT vs Neural Network Folding");
  render_contrast_row(sec3, "Parameters", "AlphaFold: 93M parameters, trained on 170K structures", "CRT: 20 ring values. Zero training.");
  render_contrast_row(sec3, "Compute", "GPU cluster, hours per prediction", "Ring arithmetic, microseconds");
  render_contrast_row(sec3, "Channels", "Attention heads (opaque learned features)", "6 CRT channels = 6 named physical properties");
  render_contrast_row(sec3, "Interpretability", "Black box: cannot explain WHY residues contact", "Transparent: D=hydrophobic, K=charge, L=aromatic");
  render_contrast_row(sec3, "Error detection", "Separate confidence scores", "L=11 channel gives free integrity check");
  render_contrast_row(sec3, "Patent status", "DeepMind/Google (AlphaFold), Meta (ESMFold)", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)
