fn constants_spectral_lie() = (
  let ssm = make_section("800px") in
  render_h2(ssm, "Spectral Mass Theorem");
  render_theorem(ssm, "Quark Spectrum (S352, PROVED)",
    "THIN eigenvalue range = 16.339. log2(m_t/m_u) = 16.287. Ratio = 1.003. If m_q ~ D^lambda(n_q), quarks span the FULL THIN spectrum. Base = D = bridge. Top = hub (n=0, lambda=K^2=9). Six quark generations = six spectral positions.");
  let qrt = make_table(ssm) in
  let qrh = dom_create("tr") in
  render_th(qrh, "Ratio");
  render_th(qrh, "Value");
  render_th(qrh, "Axiom");
  dom_append(qrt, qrh);
  render_table_row(qrt, "m_d/m_u", "~2", "D");
  render_table_row(qrt, "m_s/m_d", "~20", "D^2*E");
  render_table_row(qrt, "m_c/m_s", "~14", "D*b");
  render_table_row(qrt, "m_b/m_c", "~3.3", "D*E/K");
  render_table_row(qrt, "m_t/m_b", "~41", "KEY");
  render_p(ssm, "Each step = axiom expression. Charge determines path (up-type vs down-type). Generation determines depth. PREDICTION: m_u = m_t/D^16.339 = 2.08 MeV (PDG: 2.16, within 1-sigma). WHY THIN: range match 0.3%. TRUE 21% too wide. Quarks = primordial objects, living in the thinnest ring.");
  dom_append(dom_body(), ssm);
  let sla = make_section("800px") in
  render_h2(sla, "Lie Algebra Dimension Gates");
  render_theorem(sla, "13-Gate in Lie Theory (S278, PROVED)",
    "ALL four classical Lie series: first non-smooth dimension at 13. A (SU): n+2=13 at n=L=11. B (SO odd): 2n+1=13 at n=D*K=6. D (SO even): 2n-1=13 at n=b=7. The shadow stopper is universal across all of mathematics.");
  let lat = make_table(sla) in
  let lah = dom_create("tr") in
  render_th(lah, "Series");
  render_th(lah, "Break rank");
  render_th(lah, "Product");
  render_th(lah, "Identity");
  dom_append(lat, lah);
  render_table_row_4(lat, "A (SU)", "L = 11", "n!", "SU(12) last smooth");
  render_table_row_4(lat, "B (SO odd)", "D*K = 6", "(2n-1)!!", "SO(11) last smooth");
  render_table_row_4(lat, "D (SO even)", "b = 7", "(2n-3)!!*(n-1)", "SO(12) last smooth");
  render_table_row_4(lat, "D_5 = SO(10)", "E = 5", "prod(exp) = 420 = lambda", "GUT group SELECTED");
  render_p(sla, "LAMBDA UNIQUENESS THEOREM: D_5=SO(10) is the UNIQUE simple Lie algebra with exponent product = 420 = lambda(TRUE). The Carmichael function SELECTS the GUT group. D_5 exponents = {sigma,K,D^2,E,b}, product = D^2*K*E*b = 420, sum = 20 = degree(TRUE).");
  let lag = make_findings_grid(sla) in
