fn constants_quantum() = (
  let sqm = make_section("800px") in
  render_h2(sqm, "Quantum Mechanics");
  render_theorem(sqm, "Rydberg-Gate Theorem (S461, null-tested)", "R = GATE + K/E = 13.6 eV (420 ppm). Refined: GATE + K/E + 1/(E^2*b) = 13.60571 eV (2 ppm). Null model: only 2/343 expressions a+b/c match. The 13-gate IS hydrogen's ground state. GATE + Kolmogorov^(-1) = ionization energy.");
  let qg = make_findings_grid(sqm) in
  render_finding(qg, "g-factor gate (S462)", "denom 2l+1 = {sigma,K,E,b,K^2,L,13}", "Smooth for EXACTLY l=0..5 orbitals. l=6: denom=GATE. The chain IS the angular momentum spectrum.", "");
  render_finding(qg, "21-cm line", "K*b = 21 cm", "Hydrogen hyperfine = codon ring Z/21. Hydrogen speaks at the wavelength of the genetic code.", "");
  render_finding(qg, "Spin-statistics", "sigma/D = 1/2", "D-edge parity -> antisymmetry -> Pauli exclusion. Z/D IS the spin channel.", "");
  render_finding(qg, "Degeneracy", "D*n^2 states at shell n", "n=K: D*K^2=ME=18. n=D^2*K=12: D^3*K^2=288 = eigenvalue classes of THIN ring.", "");
  render_finding(qg, "m_p/m_e", "D^2*K^3*ESCAPE = 1836", "108 * 17. Null: 1/448 products match. UNIQUE. Refined: +E/(K*L) = 1836.152 (0.6 ppm).", "");
  dom_append(dom_body(), sqm)
)

