fn page_constants() = (
  dom_head_meta("description", "Physics precipitates from 0/0 = Z/12612600Z (TRUE). Kolmogorov = E/K = 5/3. Kleiber = K/D^2 = 3/4. alpha^-1 = ADDRESS + b/(D*G). Every constant is a rational function of 6 axiom primes. The Olga Equation: O = [(A +/- B)/C] * alpha^p. CODATA-verified with error bounds and p-values.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Physical Constants from Six Primes\",\"description\":\"Every physical constant is a rational function of D=2, K=3, E=5, b=7, L=11, GATE=13. Kolmogorov 5/3, Kleiber 3/4, fine structure constant, particle masses. CODATA-verified with error bounds.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\",\"url\":\"https://antonlebed.com\"},\"url\":\"https://antonlebed.com/data/constants\",\"isAccessibleForFree\":true,\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"Physical Constants\"},{\"@type\":\"DefinedTerm\",\"name\":\"Fine Structure Constant\"},{\"@type\":\"DefinedTerm\",\"name\":\"Number Theory\"}]}");
  constants_hero();
  constants_cosmic_pie();
  constants_fundamental();
  constants_particles();
  constants_hadrons();
  constants_mixing();
  constants_scaling_cosmo();
  constants_nuclear();
  constants_quantum();
  constants_exotic();
  constants_family();
  constants_spectral_lie();
  constants_solar_exotic();
  constants_null_persist();
  constants_orbits_math();
  constants_force_hierarchy();
  constants_em_gr();
  constants_bcs_deep();
  constants_predictions_contrast();
  /* === INTERACTIVE WIDGET === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Named Constants");
  render_p(sec_i, "Enter a number to see its axiom name (if any) and CRT decomposition in the TRUE FORM ring Z/12612600Z.");
  make_interactive_widget(sec_i, "Look up constant:", "con-input", "e.g. 42", "Look up", "con_lookup", "con-result");
  render_p(sec_i, "Try: 0 (void), 42 (ANSWER), 77 (b*L), 137 (ADDRESS), 420 (lambda), 1576576 (OMEGA), 606376 (DEEP OMEGA), 13 (GATE).");
  dom_append(dom_body(), sec_i)
)
