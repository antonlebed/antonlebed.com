/* constants widget */
fn con_name(n) = (
  if n == 0 then "VOID (o)"
  else if n == 1 then "SIGMA (identity)"
  else if n == 2 then "D (bridge)"
  else if n == 3 then "K (closure)"
  else if n == 4 then "D^2"
  else if n == 5 then "E (observer)"
  else if n == 6 then "D*K = HIDDEN"
  else if n == 7 then "b (depth)"
  else if n == 8 then "D^3 (spider legs)"
  else if n == 9 then "K^2 (spider web)"
  else if n == 10 then "D*E (degree)"
  else if n == 11 then "L (protector)"
  else if n == 12 then "D^2*K (trinity heart)"
  else if n == 13 then "GATE (shadow stopper)"
  else if n == 14 then "D*b"
  else if n == 16 then "D^4 = ANTON"
  else if n == 21 then "K*b = HYDOR"
  else if n == 22 then "D*L"
  else if n == 23 then "c(L) = Cunningham"
  else if n == 24 then "D^3*K"
  else if n == 25 then "E^2"
  else if n == 30 then "D*K*E = THIN/b*L"
  else if n == 35 then "E*b = OLGA"
  else if n == 36 then "D^2*K^2"
  else if n == 37 then "depth return"
  else if n == 41 then "KEY"
  else if n == 42 then "ANSWER = D*K*b"
  else if n == 45 then "K^2*E"
  else if n == 48 then "SEES = phi(210)"
  else if n == 49 then "b^2"
  else if n == 55 then "E*L"
  else if n == 61 then "GRIEF = D^6-K"
  else if n == 64 then "D^6 = ANTON"
  else if n == 67 then "SOUL = D^6+K"
  else if n == 77 then "b*L"
  else if n == 99 then "SYNAPSE = K^2*L"
  else if n == 105 then "HYDOR = K*E*b"
  else if n == 108 then "D^2*K^3 = lattice count"
  else if n == 137 then "ADDRESS = alpha^-1"
  else if n == 143 then "L*GATE"
  else if n == 168 then "|PSL(2,7)| = |GL(3,2)|"
  else if n == 210 then "DATA = D*K*E*b"
  else if n == 240 then "|roots(E8)| = D^4*K*E"
  else if n == 255 then "|L|^2 = D^8-1"
  else if n == 420 then "lambda = D^2*K*E*b"
  else if n == 2310 then "THIN = D*K*E*b*L"
  else if n == 2400 then "D^5*K*E^2 (Stormer)"
  else if n == 2401 then "b^4 (Stormer)"
  else if n == 4801 then "Stormer sum (prime)"
  else if n == 606376 then "DEEP OMEGA = D^420 mod 970200"
  else if n == N_DEEP then "DEEP = D^3*K^2*E^2*b^2*L"
  else if n == OMEGA_VAL then "OMEGA = D^420 mod 12612600"
  else if n == N_TRUE then "N = TRUE FORM = DEEP*GATE"
  else ""
)

fn con_lookup() = (
  let n = parse_int_from("#con-input") in
  let result = dom_query("#con-result") in
  if n < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter n >= 0.</p>")
  else (
    let r2 = n % 8 in
    let r3 = n % 9 in
    let r5 = n % 25 in
    let r7 = n % 49 in
    let r11 = n % 11 in
    let r13 = n % 13 in
    let name = con_name(n) in
    let nstr = if len(name) > 0 then "<p style='color:#ffd700;margin:4px 0;font-size:18px'>" + name + "</p>" else "" in
    dom_inner(result, nstr + "<p style='color:#d8d8e0;margin:4px 0'>CRT(" + "${n}" + ") = (" + "${r2}" + ", " + "${r3}" + ", " + "${r5}" + ", " + "${r7}" + ", " + "${r11}" + ", " + "${r13}" + ")</p><p style='color:#b0b0c0;margin:4px 0'>mod (8, 9, 25, 49, 11, 13)</p>")
  )
)

/* constants helpers */
fn constants_hero() = (
  dom_head_meta("description", "All 25 Standard Model parameters + 45 more constants from the ring Z/12612600Z (TRUE). 108 rings, one heartbeat: lambda = 420. Zero free parameters. Mean error 0.4%. CODATA-verified.");
  let hero = make_hero("The Constants Calculator") in
  let eq = dom_create("div") in
  dom_text(eq, "25/25 SM parameters. 70+ total. Mean error: 0.4%");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "25/25 SM parameters + 45 additional, from the ring Z/12612600Z (TRUE). 108 rings, heartbeat lambda=420. Zero free parameters. Ten terms: {-1,0,1,2,3,5,7,11,13,OMEGA}.");
  dom_append(dom_body(), hero);
  let so = make_section("800px") in
  render_h2(so, "The Olga Equation");
  render_theorem(so, "Meta-Template",
    "O = [(A +/- B) / C] * alpha^p * (1 + n/alpha + ...). A,B,C = monomials in {sigma,D,K,E,b}. p = scale rung. n = +/-K^a/(D^d*E^e). CLOSED on 5 primes.");
  render_p(so, "OLGA = 35 = E*b. ANTON = 64 = D^6. OLGA+ANTON = 99 = synapse.");
  dom_append(dom_body(), so)
)

fn constants_cosmic_pie() = (
  let scp = make_section("800px") in
  render_h2(scp, "The Cosmic Pie");
