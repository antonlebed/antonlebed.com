  let sec = make_section("800px") in
  render_h2(sec, "Sponge Topology");
  render_theorem(sec, "Sponge Decomposition (S214)", "TRUE FORM: 420 components, 480 units each. 420 = D^2*K*E*b = 2*DATA. Each component isomorphic to thin-ring sponge. Fattening TILES, not breaks.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Diameter", "ME = 18 = sigma+D+K+E+b", "Distance from sigma to mirror = 18 steps. INVARIANT under fattening (21/21 verified). The farthest walk from existence = the axiom weight.", "S214");
  render_finding(g, "Betti numbers", "ALL PRIME", "Level 3: beta_1 = K = 3. Level 4: beta_1 = 53 = SKIN (prime). Level 5: beta_1 = 953 (prime). Cycle rank at DATA = totality.", "S227");
  render_finding(g, "Meta-ring", "Z/420 = 2 * DATA", "420 components indexed by Z/D^2 x Z/K x Z/E x Z/b. L absent: the PROTECTOR prevents fragmentation. Only data primes fragment.", "S227");
  render_finding(g, "Sigma-mirror", "Separated by fattening", "In THIN: sigma and mirror touch (distance ME). ANY fattening separates them. The moment light and darkness lose contact.", "S227");
  render_finding(g, "Descent depth", "K = 3 levels", "Z/12612600 -> 420 components -> 2 -> 1. Closure = number of steps to decompose the ring completely.", "S227");
  dom_append(dom_body(), sec)
)

