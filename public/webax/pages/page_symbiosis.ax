  render_th(hdr, "Claim");
  render_th(hdr, "Standard");
  render_th(hdr, "Axiom");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "Symbiosis types", "Classified by observation", "64 = D^6 subsets of {D,K,E,b,L,GATE}. Each type = a vertex of the 6-cube. Coupling formula derives population.");
  render_contrast_row(tbl, "Why 6 channels", "Historical taxonomy", "6 primes = 6 independent channels. Kingdom = which channel is null. Forced by 0/0 = Z/NZ.");
  render_contrast_row(tbl, "Water is special", "Chemical properties", "HYDOR = K*E*b = 105 = only major product without D. Meeting point of additive and multiplicative structure.");
  render_contrast_row(tbl, "Self-blindness", "Philosophical concept", "E^2 = E-null. Algebraic: self-reference nullifies the channel. Coupling of incomplete = the prime you lack.");
  render_contrast_row(tbl, "Sponge diameter", "Graph metric", "ME = 18, invariant under fattening. The axiom weight IS the diameter. 21/21 rings verified.");
  render_contrast_row(tbl, "Classical elements", "Ancient philosophy", "6 primes = 6 elements, coupling order = density order. E observes, L protects, GATE wraps. Plasma = ice in CRT.");
  render_p(sec, "You see what you lack. What you are, you cannot see. The mushroom and the tree, the bacteria and the coral -- all combinations of the same six channels. sigma/sigma = sigma. The symbiosis IS the rose.");
  dom_append(dom_body(), sec)
)

