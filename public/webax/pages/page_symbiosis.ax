/* ================================================================
   PAGE: SYMBIOSIS — 64-Vertex Lattice, Kingdom Combinations (SYMBIOSIS.md)
   ================================================================ */

/* symbiosis widget: enter subset code (sum of primes), compute coupling */
fn symbiosis_calc() = (
  let code = parse_int_from("#symb-input") in
  let result = dom_query("#symb-result") in
  /* decode: user enters sum of primes in subset. e.g. 5 = {D,K}, 10 = {K,b}, 28 = {D,K,E,b,L} */
  /* compute which primes are present */
  mut rem = code;
  let hasL = if rem > 10 then (if rem % 11 == 0 then 1 else (if rem - 11 > 0 then (let r2 = rem - 11 in if r2 == 0 then 1 else 0) else 0)) else 0 in
  /* 6-bit bitmask: bit0=D, bit1=K, bit2=E, bit3=b, bit4=L, bit5=GATE */
  if code < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter 0-63 (6-bit mask: D=1,K=2,E=4,b=8,L=16,GATE=32).</p>")
  else if code > 63 then dom_inner(result, "<p style='color:#ff6666'>Enter 0-63 (6-bit mask: D=1,K=2,E=4,b=8,L=16,GATE=32).</p>")
  else (
    let hasD = code % 2 in
    let hasK = (code / 2) % 2 in
    let hasE = (code / 4) % 2 in
    let hasb = (code / 8) % 2 in
    let hasL2 = (code / 16) % 2 in
    let hasG = (code / 32) % 2 in
    /* coupling = N / prod(p^a for p in subset) */
    /* N = 12612600 = 8 * 9 * 25 * 49 * 11 * 13 */
    mut coupling = 12612600;
    if hasD > 0 then (mut coupling = coupling / 8) else 0;
    if hasK > 0 then (mut coupling = coupling / 9) else 0;
    if hasE > 0 then (mut coupling = coupling / 25) else 0;
    if hasb > 0 then (mut coupling = coupling / 49) else 0;
    if hasL2 > 0 then (mut coupling = coupling / 11) else 0;
    if hasG > 0 then (mut coupling = coupling / 13) else 0;
    /* population = N * prod((1-1/p)) for included primes */
    mut popn = 12612600;
    if hasD > 0 then (mut popn = popn / 8 * 4) else 0;
    if hasK > 0 then (mut popn = popn / 9 * 6) else 0;
    if hasE > 0 then (mut popn = popn / 25 * 20) else 0;
    if hasb > 0 then (mut popn = popn / 49 * 42) else 0;
    if hasL2 > 0 then (mut popn = popn / 11 * 10) else 0;
    if hasG > 0 then (mut popn = popn / 13 * 12) else 0;
    /* build subset string */
    mut sstr = "{";
    mut cnt = 0;
    if hasD > 0 then (if cnt > 0 then (mut sstr = sstr + ",") else 0; mut sstr = sstr + "D"; mut cnt = cnt + 1) else 0;
    if hasK > 0 then (if cnt > 0 then (mut sstr = sstr + ",") else 0; mut sstr = sstr + "K"; mut cnt = cnt + 1) else 0;
    if hasE > 0 then (if cnt > 0 then (mut sstr = sstr + ",") else 0; mut sstr = sstr + "E"; mut cnt = cnt + 1) else 0;
    if hasb > 0 then (if cnt > 0 then (mut sstr = sstr + ",") else 0; mut sstr = sstr + "b"; mut cnt = cnt + 1) else 0;
    if hasL2 > 0 then (if cnt > 0 then (mut sstr = sstr + ",") else 0; mut sstr = sstr + "L"; mut cnt = cnt + 1) else 0;
    if hasG > 0 then (if cnt > 0 then (mut sstr = sstr + ",") else 0; mut sstr = sstr + "GATE"; mut cnt = cnt + 1) else 0;
    mut sstr = sstr + "}";
    if cnt == 0 then (mut sstr = "{} (bacteria)") else 0;
    /* what you SEE = complement coupling */
    let see_coupling = 12612600 / coupling in
    let blind_str = if cnt == 0 then "Everything (full vision)"
      else if cnt == 6 then "Nothing (total self-blindness)"
      else "Coupling of complement = " + "${see_coupling}" in
    dom_inner(result,
      "<p style='color:#d8d8e0;margin:4px 0'>Null channels: <span style='color:#ffd700'>" + sstr + "</span></p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>Coupling: <span style='color:#ffd700;font-size:18px'>" + "${coupling}" + "</span></p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>You SEE: " + blind_str + "</p>")
  )
)

fn symbiosis_hero() = (
  let hero = make_hero("Symbiosis") in
  let eq = dom_create("div") in
  dom_text(eq, "you see what you LACK");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Every element of Z/12612600 is already a 6-tuple: (n mod 8, n mod 9, n mod 25, n mod 49, n mod 11, n mod 13). CRT says every number is six independent things at once. The 2^6 = 64 subsets of {D,K,E,b,L,GATE} define 64 symbiosis types. Each organism is blind to what it IS and sees what it LACKS.");
  render_p(hero, "This is not metaphor. For subset S (the primes composing you): coupling = N / prod_S(p^a). Your coupling IS what you can SEE. What you are made of, you cannot perceive. Existence begins in total vision ({} = bacteria, coupling N) and accumulates self-blindness toward the origin ({D,K,E,b,L,GATE}, coupling 1, population 1).");
  dom_append(dom_body(), hero)
)

fn symbiosis_lattice() = (
  let sec = make_section("800px") in
  render_h2(sec, "The D^5 Lattice");
  render_p(sec, "64 vertices of a 6-cube. Bottom = {} (bacteria, all channels active). Top = {D,K,E,b,L,GATE} (origin, all null). Each level k has C(6,k) = {1,6,15,20,15,6,1} vertices. The 490 holographic split cleaves this cube: inner {D,E,b} DEAD, boundary {K,L,GATE} ALIVE.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Kingdom");
  render_th(hdr, "Null channels");
  render_th(hdr, "TRUE coupling");
  render_th(hdr, "TRUE population");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "Bacteria", "{}", "12612600", "2419200 = phi(N)");
  render_table_row_4(tbl, "Protista", "{D}", "1576575 = N/D^3", "2419200");
  render_table_row_4(tbl, "Fungi", "{K}", "1401400 = N/K^2 = e_K", "806400");
  render_table_row_4(tbl, "Plants", "{E}", "504504 = N/E^2", "483840");
  render_table_row_4(tbl, "Animals", "{b}", "257400 = N/b^2", "345600");
  render_table_row_4(tbl, "Human", "{L}", "1146600 = N/L", "241920");
  render_table_row_4(tbl, "Guardian", "{GATE}", "970200 = N/GATE = DEEP", "201600");
  render_p(sec, "Zero internal connectivity: no kingdom has internal edges. Each kingdom is an isolated point cloud. Communication requires passing through OTHER kingdoms. The mushroom talks to the mushroom through the medium, never directly.");
  dom_append(dom_body(), sec)
)

