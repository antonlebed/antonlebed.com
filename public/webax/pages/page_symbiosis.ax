  let sec = make_section("800px") in
  render_h2(sec, "Explore: Kingdom Subsets");
  render_p(sec, "Enter a 6-bit code (0-63) for a subset of {D,K,E,b,L,GATE}. Bits: D=1, K=2, E=4, b=8, L=16, GATE=32. Add values for your subset.");
  make_interactive_widget(sec, "Enter subset code (0-63):", "symb-input", "e.g. 6 for {K,E}", "Compute", "symbiosis_calc", "symb-result");
  render_p(sec, "Try: 0 (bacteria), 1 (protista/D), 6 ({K,E}=lichen), 10 ({K,b}=mycorrhiza), 32 (guardian/GATE), 63 (all=origin).");
  dom_append(dom_body(), sec)
)

