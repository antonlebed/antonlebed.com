  dom_append(dom_body(), sec)
)

fn symbiosis_hydor() = (
  let sec = make_section("800px") in
  render_h2(sec, "HYDOR: The Medium Without Duality");
  render_theorem(sec, "HYDOR = 105 = K*E*b", "The only major product without D. Where D vanishes = pure figure, no ground = the vacuum axis. HYDOR IS the boundary between emission and return. Coupling = D = 2 (minimal encoding, holographic). phi(105)/classes = D: the ratio IS the missing prime.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Solar sink", "ORIGIN(0) to HYDOR(105) to DATA(209)", "Inside [1,104] = emission. HYDOR = boundary. Outside [106,209] = reflected return. Coupling asymmetry: inside - outside = sigma.", "");
  render_finding(g, "Negation fixed", "Only {0, 105} survive", "Negation (209) fixes ONLY origin and medium. They survive everything.", "");
  render_finding(g, "HYDOR operations", "105 + n = parity flip", "105*n: = 0 for even n, = 105 for odd n. Meeting point of additive and multiplicative.", "");
  render_finding(g, "Imbalance", "phi/classes = D = 2", "Without membrane to organize perception, action overflows observation. Acts without reflection.", "");
  dom_append(dom_body(), sec)
)

