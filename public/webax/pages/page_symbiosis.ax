  let sec = make_section("800px") in
  render_h2(sec, "Key Symbioses");
  let g = make_findings_grid(sec) in
  render_finding(g, "Lichen {K,E}", "coupling 56056 = D^3*b^2*L*GATE", "IS closure + observation. SEES duality + depth + transcendence. One of oldest life forms (~400 Myr). Fungi + algae: neither survives alone.", "");
  render_finding(g, "Mycorrhiza {K,b}", "coupling 28600 = D^3*E^2*L*GATE", "Fungi + depth: the underground network. The 'wood wide web.' Resource sharing through decomposition + depth. 90% of land plants.", "");
  render_finding(g, "HYDOR {K,E,b}", "coupling 1144 = D^3*L*GATE", "IS closure + observation + depth. SEES only D + L + GATE. N = HYDOR_coupling * HYDOR^2 = 1144 * 11025.", "");
  render_finding(g, "Coral {D,K,E}", "coupling 7007 = b^2*L*GATE", "Membrane + closure + observation. The reef as living boundary.", "");
  render_finding(g, "Gut microbiome {D,K}", "coupling 175175 = E^2*b^2*L*GATE", "Membrane + closure. Highest coupling multi-prime. Richest ground-state access outside bacteria.", "");
  render_finding(g, "Full set {all 6}", "coupling 1", "IS everything. SEES nothing. Total self-reference = total blindness. Population: ONE (n=0 only). Always.", "");
  dom_append(dom_body(), sec)
)

fn symbiosis_bridge() = (
  let sec = make_section("800px") in
  render_h2(sec, "D as Bridge: The Symbiosis Catalyst");
  render_theorem(sec, "D-Boost Theorem", "Adding D to any kingdom multiplies unit-neighbor density 3-5x. {K} -> {D,K}: 11.25% -> 41.0% (+3.6x). {E} -> {D,E}: 7.50% -> 32.3% (+4.3x). {b} -> {D,b}: 6.75% -> 30.0% (+4.4x). {L} -> {D,L}: 6.25% -> 28.3% (+4.5x). Boost INCREASES with distance from D. The further a kingdom from duality, the more it benefits from adding it.");
  render_p(sec, "Protista (D=2) = first eukaryotes WITH MEMBRANES. The self/other boundary (D=2) IS the mechanism of ground-state access. Without membrane: isolated. With membrane: connection multiplies.");
  dom_append(dom_body(), sec)
)

