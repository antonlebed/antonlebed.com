  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Symbiosis: The 64-Vertex CRT Lattice\",\"description\":\"64 subsets of 6 primes define 64 symbiosis types. Each organism sees what it lacks. 490 holographic split: inner {D,E,b} DEAD, boundary {K,L,GATE} ALIVE. Sponge topology with 420 components and prime Betti numbers.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\",\"url\":\"https://antonlebed.com\"},\"url\":\"https://antonlebed.com/data/symbiosis\",\"isAccessibleForFree\":true,\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"Chinese Remainder Theorem\"},{\"@type\":\"DefinedTerm\",\"name\":\"Lattice Theory\"},{\"@type\":\"DefinedTerm\",\"name\":\"Symbiosis\"}]}");
  symbiosis_hero();
  symbiosis_lattice();
  symbiosis_key();
  symbiosis_bridge();
  symbiosis_blindness();
  symbiosis_hydor();
  symbiosis_elements();
  symbiosis_sponge();
  symbiosis_lattice_props();
  symbiosis_explore();
  symbiosis_contrast()
)
