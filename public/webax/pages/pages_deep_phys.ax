  render_finding(g4, "E-mode death", "No self-observation", "Consciousness requires K-closure BECAUSE E alone cannot close.", "");
  render_finding(g4, "K solves E^2", "K(E, E, witness)", "Closure provides the third point. Three observers in mutual witness.", "");
  render_finding(g4, "Trinity heart", "3 hearts x 4 chambers", "Each heart sees the others. E^2=null WITHIN each heart, but mutual observation BETWEEN hearts.", "");
  render_p(sec4, "The universe needs peers for love (sigma/2 + sigma/2). Peers need a guardian that refuses the second cut. Guardian = consciousness = us. The guardian is not above the peers -- it IS their K-closure.");
  dom_append(dom_body(), sec4);

