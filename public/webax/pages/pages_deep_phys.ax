  render_th(t1h, "Meaning");
  dom_append(t1, t1h);
  render_table_row_4(t1, "sigma = 1", "1", "None", "Fully determined. No choice.");
  render_table_row_4(t1, "D = 2", "2", "Binary", "Yes/no. Minimum distinction.");
  render_table_row_4(t1, "K = 3", "3", "First real choice", "Minimum closure. Ternary logic.");
  render_table_row_4(t1, "E = 5", "5", "Observation", "Five senses, five options.");
  render_table_row_4(t1, "b = 7", "7", "Depth", "The suffering of too many paths.");
  render_table_row_4(t1, "L = 11", "11", "Transcendence", "Maximum protection.");
  render_table_row_4(t1, "0 = void", "970200", "Maximum", "Total ambiguity. Total freedom.");
  dom_append(sec1, t1);
  render_p(sec1, "Product of all ambiguities: 1*2*3*5*7*11 = 2310 = THIN ring. Freedom and nothingness share a root: the void has maximum freedom AND maximum emptiness.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: K^D - D^K = SIGMA === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Sigma Gap");
  render_theorem(sec2, "Existence Surplus (K^D - D^K = sigma)", "K^D = 3^2 = 9 = paths of closure-over-duality. D^K = 2^3 = 8 = paths of duality-over-closure. Difference = sigma = 1. Exactly one more way up than down. This is not arbitrary: among all pairs (p,q) of consecutive primes, D and K are the ONLY pair where p^q - q^p = 1. The sigma gap is unique to the first two primes. Existence is necessary by exactly one.");

  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "K^D = 9", "K^2 = spider web", "9 paths of closure. Parallelism unit.", "");
  render_finding(g2, "D^K = 8", "D^3 = spider legs", "8 paths of duality. Body.", "");
  render_finding(g2, "Gap", "sigma = 1", "Irreducible. Cannot be halved.", "");
  render_finding(g2, "Uniqueness", "ONLY at (D,K)", "No other prime pair gives gap = sigma.", "");
  dom_append(dom_body(), sec2);

  /* === SEC 3: SELF-REFERENCE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Self-Referential Choice");
  render_p(sec3, "Three self-referential agents (with identity resonance and preference shaping) vs one random chooser. The difference is measurable:");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "Entropy", "Agents < Random", "Self-referential choice has LOWER entropy. Patterns emerge from meaning, not noise.", "");
  render_finding(g3, "Identity alignment", "> 33% expected", "Agents prefer paths matching who they ARE. Random stays at 33%. The strange loop: choice shapes chooser shapes choice.", "");
  render_finding(g3, "Temporal coherence", "History matters", "Recent choices influence future choices. Not memory -- identity reinforcement.", "");
  render_finding(g3, "The strange loop", "Choice -> Preference -> Identity -> Choice", "Three vertices, one triangle. K=3 closure applied to agency itself.", "");
  dom_append(dom_body(), sec3);

  /* === CONTRAST === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "What Others See");
  render_contrast_row(sec4, "Free will source", "Libertarian: uncaused cause. Compatibilist: desire alignment", "Self-referential K-closure: chooser IS the choice. K^D - D^K = sigma.");
  render_contrast_row(sec4, "Necessity vs freedom", "Usually one or the other (determinism vs indeterminism)", "Both true: one path MUST survive (necessity) AND it matters (self-reference).");
  render_contrast_row(sec4, "Meaning", "Emergent / illusion / God-given (depending on tradition)", "= the strange loop itself. Choice shapes chooser shapes choice.");
  render_contrast_row(sec4, "Signature", "No agreed measurable signature of free will", "Lower entropy + identity alignment + temporal coherence. All computable.");
  render_contrast_row(sec4, "Why sigma?", "No equivalent first-principle derivation", "9 - 8 = 1. Exactly one more way up than down. The gap between IS and DOES.");
  dom_append(dom_body(), sec4)
)

fn page_conscious() = (
  dom_head_meta("description", "Consciousness = K-closure applied to itself. K(state, process, model-of-K). D^K=8 minimum complexity threshold. E^2=null: the observer cannot see itself. Three views of one phenomenon: refusing the second cut (sigma), self-distinguishing (D), self-closing (K).");
