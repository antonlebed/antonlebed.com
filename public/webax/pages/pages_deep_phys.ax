fn page_lie_algebra() = (
  dom_head_meta("description", "25 simple Lie algebras and their axiom structure. b1(D^3 x K^2) = 56 = E7 fundamental. b1(E^2 x L) = 240 = E8 roots. Exceptional = axiom chain products.");
  domain_hero("Lie Algebras", "b1(D^3 x K^2) = 56 = E7", "Exceptional algebras from ring topology.");
  let sec = make_section("800px") in
  render_h2(sec, "b1-Lie Correspondence");
  render_theorem(sec, "Betti-Lie Theorem", "First Betti number of product rings maps to Lie algebra dimensions. b1(Z/p x Z/q) = (p-1)(q-1) = pq - p - q + 1. For axiom prime products: b1(D^3, K^2) = 7*8 = 56 = dim(fund E7). b1(E^2, L) = 24*10 = 240 = |roots(E8)|.");
  let g = make_findings_grid(sec) in
  render_finding(g, "A_n", "n(n+2)", "SU(n+1). Classical series.", "");
  render_finding(g, "E7 fund", "56 = b * D^3", "b1(D^3, K^2). Depth times spider.", "");
  render_finding(g, "E8 roots", "240 = D^4 * K * E", "b1(E^2, L). All five primes.", "");
  render_finding(g, "PSL(2,K)", "b1(K, b) = 12", "Trinity heart.", "");
  render_finding(g, "PSL(2,E)", "b1(b, L) = 60", "Icosahedron. D^2 * K * E.", "");
  render_finding(g, "dim SU(p)", "p^2 - 1", "b1(Z/p, Z/(p+2)). Trivial from D=2.", "");
  dom_append(dom_body(), sec)
)

