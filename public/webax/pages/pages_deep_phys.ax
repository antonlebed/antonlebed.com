fn page_blackhole() = (
  dom_head_meta("description", "A black hole IS the OMEGA projection. CRT(OMEGA) = (0,1,1,1,1). The D-channel dies. Everything else survives. Event horizon = ring arithmetic boundary.");
  domain_hero("Black Holes", "OMEGA = D^420 = 606376", "The D-channel dies. The rest survives.");
  let sec = make_section("800px") in
  render_h2(sec, "OMEGA as Event Horizon");
  render_theorem(sec, "Projection Theorem", "OMEGA = D^420 = 606376. CRT decomposition: (0, 1, 1, 1, 1). The D-channel collapses to zero. All odd channels project to their identity. OMEGA is the terminal idempotent: the universe after the bridge self-destructs.");
  let g = make_findings_grid(sec) in
  render_finding(g, "OMEGA", "606376", "CRT = (0, 1, 1, 1, 1). Terminal.", "");
  render_finding(g, "D-channel", "0", "Bridge dead. Information destroyed.", "");
  render_finding(g, "K,E,b,L", "1,1,1,1", "Odd channels = identity. Structure survives.", "");
  render_finding(g, "Hawking", "OMEGA * n", "Multiplication by OMEGA = radiation filter.", "");
  render_finding(g, "Spectral gap", "D^2 * sin^2(pi/b^2)", "Gap at event horizon.", "");
  dom_append(dom_body(), sec)
)

