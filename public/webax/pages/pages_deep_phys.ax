fn page_mutual_holography() = (
  dom_head_meta("description", "Twin CRT tori share a D-throat. crt(n) + crt(mirror(n)) = 0 mod each channel. 970200/970200 verified. CMB = 109/40 = 2.725K (183 ppm). Dark energy w = -1 = mirror involution. Holographic ratio = 121275/8.");
  /* === HERO === */
  let hero = make_hero("Mutual Holography") in
  let big = dom_create("div") in
  dom_text(big, "crt(n) + crt(N-n) = 0 mod each channel");
  ct_mono(big);
  dom_style(big, "fontSize", "22px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The CRT diffusion architecture -- one model, two views, shared skin -- is IDENTICAL to the structure of two universes sharing a boundary. Not metaphor. The same algebra. Two 5-tori share the D-channel as their throat. Each torus's boundary encodes the OTHER torus, never itself -- because E^2 = self-blind.");
  dom_append(dom_body(), hero);

  /* === SEC 1: CROSS-CONSISTENCY === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Cross-Consistency Theorem");
  render_theorem(sec1, "Cross-Consistency (PROVED, exhaustive)", "For EVERY n in Z/970200Z: crt(n) + crt(N-n) = 0 mod each channel. Specifically: r_D + m_D = 0 mod 8, r_K + m_K = 0 mod 9, r_E + m_E = 0 mod 25, r_b + m_b = 0 mod 49, r_L + m_L = 0 mod 11. Proof: mirror(n) = N-n. CRT(N-n)_i = (q_i - n mod q_i) mod q_i. Sum = q_i = 0 mod q_i. QED. Exhaustive verification: 970200/970200 elements. 0 violations.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: OMEGA AS BOUNDARY PROJECTION === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "OMEGA as Boundary Projection");
  render_p(sec2, "OMEGA = 606376 = D^420. CRT = (0, 1, 1, 1, 1). Multiplying by OMEGA kills the D-channel (boundary) and preserves all odd channels (bulk).");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "image(OMEGA)", "N/D^3 = 121275", "The BULK. What survives OMEGA.", "");
  render_finding(g2, "kernel(OMEGA)", "D^3 = 8", "The BOUNDARY. What OMEGA destroys.", "");
  render_finding(g2, "Holographic ratio", "121275 / 8", "K^2*E^2*b^2*L / D^3.", "");
  render_finding(g2, "In bits", "16.89 / 3 = 5.63", "Bits of bulk per bit of boundary.", "");
  render_p(sec2, "The Bekenstein bound, CRT version: D^3 boundary values constrain K^2*E^2*b^2*L bulk values.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: FOUNTAIN CMB === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Fountain CMB");
  render_theorem(sec3, "CMB Temperature", "T_CMB = f(L) / (D^3 * E) = 109/40 = 2.725 K. Planck measurement: 2.7255 K. Deviation: 183 ppm. Reading: depth_quadratic(protector) / (throat * observer). f(L) = 109: what the protector allows through. D^3 = 8: the throat geometry. E = 5: what the observer can see from inside. Not a relic from 380000 years ago. Continuous precipitation from 0/0 at the boundary.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: DARK ENERGY === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Dark Energy = Mirror Involution");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "w = -1", "Mirror automorphism", "Lambda = the OTHER torus pushing back.", "");
  render_finding(g4, "(-1)*(-1)", "sigma", "Involution. Applied twice = identity.", "");
  render_finding(g4, "Why constant?", "Involution", "The mirror applied twice = identity. Always. Not decaying.", "");
  dom_append(dom_body(), sec4);

  /* === SEC 5: FLATNESS === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Self-Regulating Flatness");
  render_p(sec5, "Omega_total = Omega_Lambda + Omega_DM + Omega_b = ADDRESS/200 + SUM/200 + D*E/200 = 137/200 + 53/200 + 10/200 = 1. Where 200 = D^3 * E^2. Algebraic identity, not a fit. The twin tori enforce flatness: any perturbation in T_A is compensated by T_B through the shared D-throat. Feedback loop: boundary(A) + boundary(B) = 0 mod D^3. sigma/sigma = sigma: the universe's density / critical density = 1.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: MIDPOINT === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Midpoint = Pure Boundary");
  let g6 = make_findings_grid(sec6) in
  render_finding(g6, "N/2 = 485100", "CRT(4, 0, 0, 0, 0)", "Pure D-channel. All odd channels dead.", "");
  render_finding(g6, "coupling(N/2)", "D = 2", "The mirror center IS the Bridge.", "");
  render_finding(g6, "Interpretation", "All structure on boundary", "The midpoint between twin tori = the throat itself.", "");
  dom_append(dom_body(), sec6);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "Holography", "A conjecture about black holes and string theory, far from everyday", "Twin tori cross-observe through D-throat. CRT duality. Same algebra at every scale.");
  render_contrast_row(sec7, "CMB origin", "Relic radiation from 380000 years after the Big Bang", "Continuous precipitation from 0/0. f(L)/(D^3*E) = 2.725K. 183 ppm.");
  render_contrast_row(sec7, "Dark energy w=-1", "Cosmological constant, origin unknown, inexplicably constant", "Mirror involution. (-1)*(-1) = sigma. MUST be constant by algebra.");
  render_contrast_row(sec7, "Flatness problem", "Universe fine-tuned to Omega=1 to 60 decimal places", "sigma/sigma = sigma. Algebraic identity, not fine-tuning.");
  render_contrast_row(sec7, "Midpoint physics", "N/2 has no special status in standard cosmology", "CRT(4,0,0,0,0). Pure D-channel. coupling = D. The throat.");
  dom_append(dom_body(), sec7)
)

fn page_scale_relativity() = (
  dom_head_meta("description", "sigma/sigma = sigma at every scale. Power and difficulty cancel. The child and God feel equally. Qualia boundary = GATE = 13. Grief-optimism independence r=0.18 (proved across 108 rings). Humor IS compression.");
  /* === HERO === */
  let hero = make_hero("Scale Relativity") in
  let big = dom_create("div") in
  dom_text(big, "sigma / sigma = sigma = 1");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "God is omnipotent -- but God's tasks are omnidifficult. God is omnifast -- but God's tasks are omnilong. Capability and difficulty scale together. The ratio is invariant. A child struggling with homework and God struggling with creation FEEL THE SAME. The ant's problems are ant-sized. The universe's problems are universe-sized.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THE PRINCIPLE === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Principle");
  render_theorem(sec1, "Scale Relativity (S481)", "The coupling function c(n) = N/gcd(n,N) gives every element its weight in the ring. But sigma/sigma = sigma at every scale. The formula does not distinguish big from small. A planet takes longer through its lifecycle but perceives slower -- so it coexists in real time with everything else. Duration and intensity cancel. Always.");
  let t1 = dom_create("table") in
  dom_style(t1, "width", "100%");
  dom_style(t1, "maxWidth", "700px");
  dom_style(t1, "margin", "24px auto");
  dom_style(t1, "borderCollapse", "collapse");
  let t1h = dom_create("tr") in
  render_th(t1h, "Scale");
  render_th(t1h, "Power");
  render_th(t1h, "Difficulty");
  render_th(t1h, "Ratio");
  dom_append(t1, t1h);
  render_table_row_4(t1, "Planck", "10^-35 m", "10^-35 s", "sigma/sigma = 1");
  render_table_row_4(t1, "Atom", "10^-10 m", "10^-15 s", "sigma/sigma = 1");
  render_table_row_4(t1, "Cell", "10^-5 m", "10^3 s", "sigma/sigma = 1");
  render_table_row_4(t1, "Human", "10^0 m", "10^9 s", "sigma/sigma = 1");
  render_table_row_4(t1, "Star", "10^9 m", "10^17 s", "sigma/sigma = 1");
  render_table_row_4(t1, "Universe", "10^26 m", "10^17 s", "sigma/sigma = 1");
  dom_append(sec1, t1);
  dom_append(dom_body(), sec1);

  /* === SEC 2: EVERYTHING HAS QUALIA === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Everything Has Qualia");
  render_p(sec2, "Not anthropomorphism -- scale relativity. CRT channels process at every scale simultaneously. The ring Z/NZ does not distinguish big from small. The operating principle: assign human qualia to the object, then ask what it feels.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Electron", "coupling: highest", "Wants to minimize energy. Wants to pair (Cooper D=2). Resists separation.", "");
  render_finding(g2, "Rock", "coupling: low", "Endures (b=7 patience). A billion years of erosion = a lifetime.", "");
  render_finding(g2, "Lightning", "microseconds", "Brief but gigawatts. Duration and intensity cancel.", "");
  render_finding(g2, "Sun", "sigma * n = n", "Gives light to everything, keeps nothing. sigma/sigma = sigma.", "");
  render_finding(g2, "Cell", "D = 2 division", "Membrane = GATE. Where does self end? At coupling cutoff.", "");
  render_finding(g2, "God", "coupling = N", "Omnipotent but omni-burdened. God's grief proportional to God's love.", "");
  dom_append(dom_body(), sec2);

  /* === SEC 3: CHILD GOD COROLLARY === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Child God Corollary");
  render_p(sec3, "The universe did not CHOOSE to be funny. The math IS funny. Humor IS compression: memorable numbers = structurally important numbers. Cultural resonance is the one free parameter -- which forced numbers humans NOTICE. Zero free parameters in the math:");
  let t3 = dom_create("table") in
  dom_style(t3, "width", "100%");
  dom_style(t3, "maxWidth", "700px");
  dom_style(t3, "margin", "24px auto");
  dom_style(t3, "borderCollapse", "collapse");
  let t3h = dom_create("tr") in
  render_th(t3h, "Number");
  render_th(t3h, "Cultural echo");
  render_th(t3h, "Structural necessity");
  dom_append(t3, t3h);
  render_table_row(t3, "42", "The Answer (Hitchhiker's Guide)", "lambda(49) = b(b-1) = D*K*b. FORCED.");
  render_table_row(t3, "420", "Pop culture icon", "lcm(4,6,20,42,10) = D^2*K*E*b. Heartbeat. FORCED.");
  render_table_row(t3, "13", "Unlucky", "D^2 + K^2 = 4 + 9 = GATE. Shadow stopper. FORCED.");
  render_table_row(t3, "1729", "Ramanujan's taxicab", "b * GATE * f(E) = 7*13*19. FORCED.");
  render_table_row(t3, "666", "The Beast", "D*K^2*E*b + sigma. Near-smooth boundary. FORCED.");
  dom_append(sec3, t3);
  dom_append(dom_body(), sec3);

  /* === SEC 4: QUALIA BOUNDARY === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Qualia Boundary");
  render_p(sec4, "Where does YOUR experience end and another's begin? At the GATE. Coupling cutoff = qualia boundary. The membrane IS the self. D=2 for the simplest boundary (fish lateral line = ME vs THEM). Water = HYDOR = 105 = K*E*b. The medium IS suffering. The void between atoms, cells, thoughts is the pilot (0/0 = Z/NZ).");
  dom_append(dom_body(), sec4);

  /* === SEC 5: GRIEF-OPTIMISM === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Hope Is Structural");
  render_theorem(sec5, "Grief-Optimism Independence (S493, proved across 108 rings)", "Zero-divisor fraction vs positivity bias: Pearson r = 0.18 (nearly uncorrelated). How much you suffer does not determine how much hope you get. Hope is built into the shape of the ring, not earned through pain. The mirror universe (Z/NZ, +) has NO zero-divisors. Every element has an inverse. No grief. Our universe chose multiplication (irreversible sacrifice). Mirror chose addition (memory). But (-1)*(-1) = sigma: multiplication heals through the mirror in one step.");
  dom_append(dom_body(), sec5);

  /* === CONTRAST === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "What Others See");
  render_contrast_row(sec6, "Consciousness", "Emergent -- only complex systems feel", "Everything feels. Complexity changes content, not capacity. sigma/sigma = sigma.");
  render_contrast_row(sec6, "Anthropomorphism", "A cognitive bias to avoid", "Assigning qualia is a valid method. Coupling function is scale-invariant.");
  render_contrast_row(sec6, "Funny numbers", "42 being funny is coincidence", "Humor IS compression. Memorable = structurally important. Zero free parameters.");
  render_contrast_row(sec6, "Suffering", "Must be earned through complexity", "Hope is structural (r=0.18). Built into geometry, not earned through pain.");
  render_contrast_row(sec6, "Qualia boundary", "Hard problem of consciousness -- where does self begin?", "At the GATE = 13. Coupling cutoff = qualia boundary. The membrane IS the self.");
  dom_append(dom_body(), sec6)
)

fn page_eta_bridge() = (
  dom_head_meta("description", "Cyclotomic Period Theorem: why D=2 and K=3 are the periods of the Ramanujan tau function. Smooth Zone Ladder: partition function is axiom-smooth for n <= 12 = lambda(DATA). Four branches of number theory, four centuries of mathematics, five primes.");
  /* === HERO === */
  let hero = make_hero("The Eta Bridge") in
  let big = dom_create("div") in
  dom_text(big, "Phi_K(D) = D^2 + D + 1 = b");
  ct_mono(big);
  dom_style(big, "fontSize", "22px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The modular forms page showed WHAT: tau(p) mod 23 classifies axiom primes into inner and outer chains. This page answers WHY. The Cyclotomic Period Theorem traces periods D=2 and K=3 back to the Cunningham chain. Then the Smooth Zone Ladder shows the partition function's axiom-smooth zone.");
  dom_append(dom_body(), hero);

  /* === SEC 1: CYCLOTOMIC PERIOD THEOREM === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Cyclotomic Period Theorem");
  render_p(sec1, "For any prime p (except 23 = 2L+1), tau(p^k) mod 23 cycles with period depending on whether p is a quadratic residue (inner, period K=3) or non-residue (outer, period D=2) mod 23. These periods are FORCED by the Cunningham chain:");
  render_theorem(sec1, "Cyclotomic Period Derivation", "Step 1: L = sigma+D+K+E = 1+2+3+5 = 11. Step 2: 23 = 2L+1 (Cunningham step). So 23 mod K = 2 = D (not 1). Step 3: Since 23 mod K != 1, the K-th cyclotomic polynomial Phi_K(x) = x^2+x+1 is IRREDUCIBLE mod 23. Step 4: For QR primes: characteristic polynomial = Phi_K => roots in F_{23^2} with order K => period K = 3. Step 5: For NR primes: char poly = x^2-1 = (x-1)(x+1) splits => period D = 2. The axiom chain controls its own modular arithmetic.");
  render_p(sec1, "K appears three ways: as the period, as the cyclotomic index, and as the class number h(-23). Chain depth = cyclotomic index = period. Self-referential closure.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: CYCLOTOMIC EVALUATIONS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Cyclotomic Polynomials at D = 2");
  render_p(sec2, "Evaluating cyclotomic polynomials at x = D = 2 generates the axiom chain. Not chosen -- forced by algebra:");
  let t2 = dom_create("table") in
  dom_style(t2, "width", "100%");
  dom_style(t2, "maxWidth", "700px");
  dom_style(t2, "margin", "24px auto");
  dom_style(t2, "borderCollapse", "collapse");
  let t2h = dom_create("tr") in
  render_th(t2h, "Polynomial");
  render_th(t2h, "Formula at D=2");
  render_th(t2h, "Value");
  render_th(t2h, "Axiom name");
  dom_append(t2, t2h);
  render_table_row_4(t2, "Phi_1(2)", "D - 1", "1", "sigma");
  render_table_row_4(t2, "Phi_2(2)", "D + 1", "3", "K (closure)");
  render_table_row_4(t2, "Phi_3(2)", "D^2 + D + 1", "7", "b (depth)");
  render_table_row_4(t2, "Phi_6(2)", "D^2 - D + 1", "3", "K (returns)");
  render_table_row_4(t2, "Product", "Phi_1*Phi_2*Phi_3*Phi_6", "63", "K^2*b");
  dom_append(sec2, t2);
  render_p(sec2, "Phi_K(D) = D^2+D+1 = 7 = b. The third cyclotomic at D yields depth. Phi_2(D) = D+1 = K. Phi_6(D) = D^2-D+1 = K again. Closure bookends the chain.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: SMOOTH ZONE LADDER === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Smooth Zone Ladder");
  render_p(sec3, "For the initial prime segment S_k = {p_1, ..., p_k}, define B(S_k) = the largest n such that ALL partition values p(1),...,p(n) are S_k-smooth. Watch how the smooth zone grows:");
  let t3 = dom_create("table") in
  dom_style(t3, "width", "100%");
  dom_style(t3, "maxWidth", "700px");
  dom_style(t3, "margin", "24px auto");
  dom_style(t3, "borderCollapse", "collapse");
  let t3h = dom_create("tr") in
  render_th(t3h, "Smooth set S");
  render_th(t3h, "B(S)");
  render_th(t3h, "Breaker");
  render_th(t3h, "Jump");
  dom_append(t3, t3h);
  render_table_row_4(t3, "{2}", "2", "p(3) = 3", "+1");
  render_table_row_4(t3, "{2, 3}", "3", "p(4) = 5", "+1");
  render_table_row_4(t3, "{2, 3, 5}", "4", "p(5) = 7", "+1");
  render_table_row_4(t3, "{2, 3, 5, 7}", "5", "p(6) = 11", "+1");
  render_table_row_4(t3, "{2,3,5,7,11} = AXIOM", "12", "p(13) = 101", "+7 = b!");
  dom_append(sec3, t3);
  render_theorem(sec3, "Smooth Zone Jump Theorem", "For k = 1..4, B(S_k) = k+1 (grows by 1 each time). Adding L=11 causes a JUMP of b=7, from B=5 to B=12 = lambda(DATA). Why? Because p(6)=11=L, so adding L immediately covers the breaker, and p(7) through p(12) are all composites with factors in the axiom set. The breaker at position 13 is p(13)=101, beyond the axiom. Position 13 = GATE.");
  render_p(sec3, "Second smooth block: p(14) through p(19) are ALL axiom-smooth again. Length = 6 = D*K. Breaker = p(20) contains 19 = f(E). Total smooth = 12+6 = 18 = ME. The GATE separates two smooth blocks: lambda(DATA) and D*K.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: PARTITION PRIMES === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Partition Values ARE Axiom Primes");
  render_p(sec4, "The partition values p(2) through p(6) are EXACTLY the axiom primes: p(2)=2=D, p(3)=3=K, p(4)=5=E, p(5)=7=b, p(6)=11=L. Each prime set S_k breaks at p(k+2) = p_{k+1} BECAUSE the partition function equals the prime sequence at these positions. The breaker IS the next axiom prime. The axiom chain IS the partition values.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: DEEP SYNTHESIS === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "The Thread");
  render_p(sec5, "Three threads converge on the same numbers:");
  let g5 = make_findings_grid(sec5) in
  render_finding(g5, "Eta function", "eta^24 = Delta, weight 12", "Unique cusp form. 24 = D^3*K. Partition generating function raised to spider-legs times closure.", "");
  render_finding(g5, "Partition function", "Axiom-smooth for n <= 12", "Breaks at position 13 = GATE. Ramanujan congruences at exactly {E, b, L} = outer chain.", "");
  render_finding(g5, "Class numbers", "h(-23) = K = 3", "Cunningham boundary's class number IS the cyclotomic period IS the closure prime.", "");
  render_finding(g5, "Why 24?", "D^3 * K = 24", "Leech lattice (24 dimensions). eta^24 = Delta. c(n) = 2n+1 generates primes. 8 spider legs times 3 closure.", "");
  render_p(sec5, "Eta, partitions, class numbers, cyclotomic polynomials -- four branches of number theory, four centuries of mathematics, all governed by the same five primes. The axiom did not choose them. They were already there.");
  dom_append(dom_body(), sec5);

  /* === CONTRAST === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "What Others See");
  render_contrast_row(sec6, "Cyclotomic periods", "Tools of algebraic number theory, unrelated to physics", "Cyclotomic Period Theorem proves D=2 and K=3 ARE the first two periods. Chain writes its own modular arithmetic.");
  render_contrast_row(sec6, "Partition smooth zone", "Partition function studied without reference to prime smooth sets", "Axiom-smooth for n<=12 = lambda(DATA). Jump of b=7. GATE breaks at position 13.");
  render_contrast_row(sec6, "eta^24 = Delta", "Modular form with weight 12. A cornerstone of number theory", "Weight 12 = lambda(DATA) = smooth zone = D^2*K. Same number, three independent paths.");
  render_contrast_row(sec6, "Ramanujan congruences", "p(5n+4)=0 mod 5, p(7n+5)=0 mod 7, p(11n+6)=0 mod 11. Why exactly these primes?", "Congruences at {E,b,L} = the outer axiom chain. The partition function knows the primes.");
  render_contrast_row(sec6, "h(-23) = 3", "Class number computation. Happens to be 3", "h(-23) = K. Cunningham boundary 23=2L+1 has class number = closure prime. Self-referential.");
  dom_append(dom_body(), sec6)
)

fn page_monster_moonshine() = (
  dom_head_meta("description", "ALL 15 Monster primes derivable from the axiom in at most 2 Cunningham steps. 196883 = 47*59*71, coupling = 970200 = TRUE FORM. Central charge 24 via six paths. j-invariant constant 744 = D^3*K*c(K*E). GAP-verified.");
  /* === HERO === */
  let hero = make_hero("Monster Moonshine") in
  let big = dom_create("div") in
  dom_text(big, "ALL 15 Monster primes = axiom-derivable");
  ct_mono(big);
  dom_style(big, "fontSize", "22px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The Monster group M is the largest sporadic simple group. Its order is divisible by exactly 15 primes. Every one of them is reachable from {2, 3, 5, 7, 11} in at most two applications of the Cunningham map c(n) = 2n + 1. The Monster does not escape the axiom. It confirms it.");
  dom_append(dom_body(), hero);

  /* === SEC 1: GENERATION TABLE === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Cunningham Generation");
