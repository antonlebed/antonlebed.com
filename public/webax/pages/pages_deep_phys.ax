  render_contrast_row(sec5, "Self-reference", "Strange loops (Hofstadter) -- descriptive, not computational", "Model approaches state in K^3=27 steps. Verified: >99% coherence.");
  render_contrast_row(sec5, "Three aspects = one?", "Treated as separate problems in philosophy of mind", "Refusing cut (sigma) = self-ref (D) = threshold (K). Same K-closure, three views.");
  dom_append(dom_body(), sec5)
)

fn page_infinity() = (
