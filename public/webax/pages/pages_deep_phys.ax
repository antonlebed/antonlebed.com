  render_table_row_4(t1, "0", "2, 3, 5, 7, 11", "axiom", "D, K, E, b, L");
  render_table_row_4(t1, "1", "13", "c(D*K) = c(6)", "GATE");
  render_table_row_4(t1, "1", "17", "c(D^3) = c(8)", "ESCAPE");
  render_table_row_4(t1, "1", "19", "c(K^2) = c(9)", "f(E)");
  render_table_row_4(t1, "1", "29", "c(D*b) = c(14)", "c(D*b)");
  render_table_row_4(t1, "1", "31", "c(K*E) = c(15)", "c(K*E)");
  render_table_row_4(t1, "1", "41", "c(D^2*E) = c(20)", "KEY");
  render_table_row_4(t1, "1", "71", "c(E*b) = c(35)", "c(E*b)");
  render_table_row_4(t1, "2", "47", "c(c(L)) = c(23)", "c(c(L))");
  render_table_row_4(t1, "2", "59", "c(c(D*b)) = c(29)", "c(c(D*b))");
  dom_append(sec1, t1);
  render_theorem(sec1, "Monster-Axiom Completeness (S341, GAP-verified)", "K*E = 15 primes total = the Fibonacci chain termination level. The Monster uses EXACTLY as many primes as the axiom's Cunningham chain allows.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: THE 196883 TRINITY === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The 196883 Trinity");
  render_p(sec2, "The Monster's smallest faithful representation has dimension 196883. This number factors into exactly three primes -- the three OUTERMOST Monster primes:");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "196883", "47 * 59 * 71", "Three outermost Monster primes.", "");
  render_finding(g2, "coupling", "970200 = TRUE FORM", "Full coupling to the axiom ring.", "");
  render_finding(g2, "CRT", "(K, D^3, D^3, sigma, E)", "(3, 8, 8, 1, 5).", "");
  render_finding(g2, "47", "c(c(L))", "Protector's grandchild. Primitive root mod 59 AND 71.", "");
  render_finding(g2, "59", "c(c(D*b))", "Bridge-Depth grandchild.", "");
  render_finding(g2, "71", "c(E*b)", "Observer-Depth child.", "");
  render_theorem(sec2, "Trinity Primitive Root Theorem (S341)", "47 is a primitive root mod both 59 and 71. The Protector's grandchild GENERATES the multiplicative groups of both siblings. Cross-orders: ord(59, 47) = ord(71, 47) = 23 = c(L). The parents encode themselves in the children's inter-orders.");
  render_p(sec2, "McKay observation: 196884 = 196883 + 1 = 2^2 * 3^3 * 1823. The Monster lives in K's cube. The +1 is sigma, the ground state.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: CENTRAL CHARGE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Central Charge c = 24");
  render_p(sec3, "The Monster's vertex operator algebra has central charge c = 24. This number arrives by SIX independent paths:");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "HYDOR - K^4", "105 - 81 = 24", "Vacuum minus pure closure.", "");
  render_finding(g3, "trace(Sigma/6Z)", "sum = 24", "Gravitational sector trace.", "");
  render_finding(g3, "(D^2)!", "4! = 24", "Spacetime factorial.", "");
  render_finding(g3, "D^K * K", "8 * 3 = 24", "Spider legs times closure.", "");
  render_finding(g3, "26 - D", "26 - 2 = 24", "Bosonic string dims minus bridge.", "");
  render_finding(g3, "2 * weight", "2 * 12 = 24", "Twice the modular form weight.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: EXPONENT ALGEBRA === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Exponent Algebra");
  render_p(sec4, "The axiom-prime exponents in |Monster| are themselves axiom-structured:");
