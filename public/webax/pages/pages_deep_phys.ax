fn page_freewill() = (
  dom_head_meta("description", "K^D - D^K = sigma. 9 paths up minus 8 paths down = 1 survivor. Self-referential choice vs random: lower entropy, identity alignment, temporal coherence. Free will is the irreducible sigma between what a system IS and what it DOES.");
  /* === HERO === */
  let hero = make_hero("Free Will") in
  let big = dom_create("div") in
  dom_text(big, "K^D - D^K = 9 - 8 = sigma");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Free will is not about WHICH path survives. It is about WHETHER the path MATTERS. K^D = 9 paths up. D^K = 8 paths down. The difference is exactly sigma = 1. Existence wins by one. Self-reference creates meaning: choice affects chooser, chooser affects choice.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THE AMBIGUITY LADDER === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Ambiguity Ladder");
  render_p(sec1, "In Z/NZ, n/n has exactly p solutions when p^k divides N. The number of solutions IS the degree of freedom:");
