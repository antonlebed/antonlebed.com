  render_finding(g2, "D^1 -> D^420", "420 steps up", "Lambda = the universal pulse. Powers of D.", "");
  render_finding(g2, "D^420 = OMEGA", "606376", "Terminal projector. CRT = (0,1,1,1,1). Death that preserves.", "");
