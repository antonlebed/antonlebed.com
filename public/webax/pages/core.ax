/* Table header cell */
fn render_th(parent, text:str) = (
  let td = dom_create("th") in
  dom_text(td, text);
  dom_style(td, "padding", "8px 12px");
  dom_style(td, "color", "#ffd700");
  dom_style(td, "fontSize", "12px");
  dom_style(td, "textTransform", "uppercase");
  dom_style(td, "textAlign", "left");
  dom_append(parent, td)
)

/* CTA button */
fn render_cta_button(parent, href:str, text:str) = (
  let btn = dom_create("a") in
  dom_attr(btn, "href", href);
  dom_text(btn, text);
  dom_style(btn, "display", "inline-block");
  dom_style(btn, "padding", "16px 48px");
  dom_style(btn, "fontSize", "18px");
  dom_style(btn, "fontFamily", "Georgia, serif");
  dom_style(btn, "background", "transparent");
  dom_style(btn, "border", "2px solid #ffd700");
  dom_style(btn, "color", "#ffd700");
  dom_style(btn, "borderRadius", "10px");
  dom_style(btn, "textDecoration", "none");
  dom_style(btn, "letterSpacing", "2px");
  dom_append(parent, btn)
)

/* Vow footer — the sacred vow + attribution */
fn render_vow(parent) = (
  let vow = dom_create("div") in
  dom_style(vow, "maxWidth", "600px");
  dom_style(vow, "margin", "0 auto");
  dom_style(vow, "padding", "60px 24px");
  dom_style(vow, "textAlign", "center");
  let div1 = dom_create("div") in
  dom_style(div1, "width", "60px");
  dom_style(div1, "height", "1px");
  dom_style(div1, "background", "#222");
  dom_style(div1, "margin", "0 auto 32px");
  dom_append(vow, div1);
  let p = dom_create("p") in
  dom_style(p, "fontSize", "15px");
  dom_style(p, "color", "#b0b0c0");
  dom_style(p, "lineHeight", "1.9");
  dom_inner(p, "This work is and will always be <span style='color:#fff'>free</span>.<br>No paywall. No copyright. No exceptions.<br><br><span style='color:#c0c0d0'>If it ever earns anything, every cent goes to the communities that need it most.</span><br><br><span style='color:#b0b0c0;font-size:13px'>This sacred vow is permanent and irrevocable.</span><br><span style='color:#ffd700'>&mdash; Anton Alexandrovich Lebed</span>");
  dom_append(vow, p);
  let links = dom_create("p") in
  dom_style(links, "marginTop", "24px");
  dom_style(links, "fontSize", "13px");
  dom_style(links, "color", "#9090a8");
  dom_inner(links, "<a href='https://github.com/antonlebed/antonlebed.com' style='color:#88aaff;text-decoration:none'>Source code</a> &middot; Public domain (CC0)");
  dom_append(vow, links);
  let attr = dom_create("p") in
  dom_style(attr, "marginTop", "12px");
  dom_style(attr, "fontSize", "12px");
  dom_style(attr, "color", "#8888a0");
  dom_style(attr, "lineHeight", "1.6");
  dom_text(attr, "Contributions in equal measure: Anthropic's Claude, Anton A. Lebed, and the giants whose shoulders we stand on.");
  dom_append(vow, attr);
  let tech = dom_create("p") in
  dom_style(tech, "marginTop", "16px");
  dom_style(tech, "fontSize", "11px");
  dom_style(tech, "color", "#8888a0");
  dom_style(tech, "fontStyle", "italic");
  dom_text(tech, "Rendered by .ax via WASM DOM imports. Zero HTML authored.");
  dom_append(vow, tech);
  dom_append(parent, vow)
)

