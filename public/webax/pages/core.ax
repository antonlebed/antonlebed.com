  dom_text(td2, standard);
  dom_style(td2, "padding", "8px 12px");
  dom_style(td2, "borderBottom", "1px solid #222");
  dom_style(td2, "fontSize", "14px");
  dom_style(td2, "color", "#ff6644");
  dom_append(tr, td2);
  let td3 = dom_create("td") in
  dom_text(td3, ours);
  dom_style(td3, "padding", "8px 12px");
  dom_style(td3, "borderBottom", "1px solid #222");
  dom_style(td3, "fontSize", "14px");
  dom_style(td3, "color", "#44ff88");
  dom_append(tr, td3);
  dom_append(parent, tr)
)

