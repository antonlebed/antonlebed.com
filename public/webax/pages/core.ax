/* site.ax — WEBAX: The Ship of Theseus
   .ax IS the website. Compiles to site.wasm. Renders via WASM DOM imports.
   Data-driven: pages are content declarations, not DOM call sequences.
   ☠️ SCAFFOLDING (grows until all 108 pages live here). */

/* ===== DECALITY CONSTANTS ===== */
let D = 2
let K = 3
let E = 5
let b = 7
let L = 11
let GATE = 13
let OMEGA_VAL = 606376

/* ================================================================
   CELESTIAL THEATRE — Style System
   Layer 0: VOID (dark gradient, #08080e)
   Layer 1: LIGHT THROUGH LETTERS (warm text glow on headings)
   Shared across ALL pages. The visual IS the math.
   ================================================================ */

fn ct_body(body) = (
  dom_style(body, "margin", "0");
  dom_style(body, "padding", "0");
  dom_style(body, "background", "transparent");
  dom_style(body, "color", "#e0ddd5");
  dom_style(body, "fontFamily", "Georgia, 'Times New Roman', serif");
  dom_style(body, "lineHeight", "1.8");
  dom_style(body, "overflowX", "hidden");
  dom_style(body, "scrollBehavior", "smooth");
  dom_style(body, "webkitFontSmoothing", "antialiased");
  dom_style(body, "webkitOverflowScrolling", "touch");
  /* Dark plasma scrollbar */
  let s = dom_create("style") in
  dom_text(s, "*{box-sizing:border-box}html{scroll-behavior:smooth;scrollbar-color:#1a1a3f #08080e;scrollbar-width:thin;background:#08080e;margin:0;padding:0;overflow-x:hidden;position:relative;z-index:0}html::before{content:'';position:fixed;top:-100px;left:-100px;right:-100px;bottom:-100px;background:radial-gradient(ellipse at 50% 40%,#12101e 0%,#0c0a16 30%,#08080e 70%);z-index:-1;pointer-events:none}body{color:#e0ddd5;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale;margin:0;padding:0}a{color:#88aaff}table{margin:0 auto;border-collapse:collapse}::-webkit-scrollbar{width:8px}::-webkit-scrollbar-track{background:#08080e}::-webkit-scrollbar-thumb{background:#1a1a3f;border-radius:4px}::-webkit-scrollbar-thumb:hover{background:#2a2a5f}@keyframes starfall{from{transform:translateY(0)}to{transform:translateY(calc(100vh + 300px))}}@keyframes glow{0%,100%{opacity:0.4}50%{opacity:1}}@keyframes cd0{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(30px)}30%{transform:translateY(80px) scaleX(1.4) scaleY(0.85);filter:blur(45px)}60%{transform:translateY(130px) scaleX(0.85) scaleY(1.3);filter:blur(25px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(30px)}}@keyframes cd1{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(35px)}40%{transform:translateY(-120px) scaleX(1.3) scaleY(1.1);filter:blur(50px)}70%{transform:translateY(-40px) scaleX(0.85) scaleY(1.3);filter:blur(25px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(35px)}}@keyframes cd2{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(28px)}25%{transform:translateY(150px) scaleX(1.4) scaleY(0.85);filter:blur(50px)}55%{transform:translateY(60px) scaleX(0.9) scaleY(1.4);filter:blur(22px)}80%{transform:translateY(-40px) scaleX(1.2) scaleY(0.9);filter:blur(40px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(28px)}}@keyframes cd3{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(32px)}50%{transform:translateY(-150px) scaleX(1.5) scaleY(0.85);filter:blur(55px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(32px)}}@keyframes cd4{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(30px)}35%{transform:translateY(100px) scaleX(0.85) scaleY(1.4);filter:blur(22px)}65%{transform:translateY(-80px) scaleX(1.4) scaleY(0.85);filter:blur(48px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(30px)}}@keyframes cd5{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(35px)}45%{transform:translateY(-130px) scaleX(1.3) scaleY(1.2);filter:blur(50px)}75%{transform:translateY(-50px) scaleX(0.85) scaleY(0.85);filter:blur(25px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(35px)}}@keyframes cd6{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(28px)}50%{transform:translateY(160px) scaleX(1.3) scaleY(0.85);filter:blur(52px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(28px)}}@keyframes cd7{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(33px)}30%{transform:translateY(-90px) scaleX(0.85) scaleY(1.4);filter:blur(22px)}60%{transform:translateY(110px) scaleX(1.4) scaleY(0.85);filter:blur(48px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(33px)}}@keyframes cd8{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(30px)}40%{transform:translateY(90px) scaleX(1.2) scaleY(1.3);filter:blur(42px)}80%{transform:translateY(-30px) scaleX(0.85) scaleY(0.9);filter:blur(24px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(30px)}}@keyframes cd9{0%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(32px)}35%{transform:translateY(-140px) scaleX(1.5) scaleY(0.85);filter:blur(55px)}70%{transform:translateY(70px) scaleX(0.85) scaleY(1.3);filter:blur(22px)}100%{transform:translateY(0) scaleX(1) scaleY(1);filter:blur(32px)}}@keyframes moonpulse{0%,100%{opacity:0.7;box-shadow:0 0 40px 15px rgba(240,230,211,0.15)}50%{opacity:1;box-shadow:0 0 60px 25px rgba(240,230,211,0.25)}}@media(max-width:600px){.idx-grid{grid-template-columns:1fr!important}#nav-dropdown{grid-template-columns:1fr 1fr!important}}");
  dom_append(body, s)
)

fn ct_heading(el) = (
  dom_style(el, "color", "#f0e6d3");
  dom_style(el, "textShadow", "none")
)

fn ct_gold(el) = (
  dom_style(el, "color", "#ffd700");
  dom_style(el, "fontWeight", "bold")
)

fn ct_link(el) = (
  dom_style(el, "color", "#88aaff");
  dom_style(el, "textDecoration", "none")
)

fn ct_mono(el) = (
  dom_style(el, "fontFamily", "'Courier New', monospace")
)

fn ct_code_block(el) = (
  ct_mono(el);
  dom_style(el, "background", "#0f0f18");
  dom_style(el, "padding", "16px 20px");
  dom_style(el, "borderRadius", "8px");
  dom_style(el, "border", "1px solid #1a1a3f");
  dom_style(el, "lineHeight", "1.6")
)

fn ct_card(el) = (
  dom_style(el, "padding", "24px 20px");
  dom_style(el, "border", "1px solid #1a1a2a");
  dom_style(el, "borderRadius", "10px");
  dom_style(el, "background", "#0f0f18")
)

/* ================================================================
   CELESTIAL THEATRE — 108 eigenvalue-positioned stars.
   108 = D^2*K^3 = lattice count. Each star IS a lattice element.
   Every constant is axiom-derived. The sky IS the math.
   ================================================================ */

fn ct_star(c, i) = (
  let star = dom_create("div") in
  dom_style(star, "position", "absolute");
  /* x: (i*GATE + E) mod K^2*L — position from 5 primes */
  let rx = i * 13 + 5 in
  let x = rx - (rx / 99) * 99 in
  dom_style(star, "left", "${x}%");
  /* spawn: (i*KEY + K) mod b*GATE — KEY=41 sum of Decality */
  let ry = i * 41 + 3 in
  let spawn = ry - (ry / 91) * 91 in
  let spawn_px = spawn * 3 + 20 in
  dom_style(star, "top", "-${spawn_px}px");
  /* K=3 size layers */
  let layer = i - (i / 3) * 3 in
  let sz = layer + 1 in
  dom_style(star, "width", "${sz}px");
  dom_style(star, "height", "${sz}px");
  dom_style(star, "borderRadius", "50%");
  dom_style(star, "background", "#c8d8ff");
  let gr = sz * 4 in
  dom_style(star, "boxShadow", "0 0 ${gr}px ${sz}px rgba(180,200,255,0.5)");
  /* glow: (i*b) mod L + K = 3-13s */
  let d7 = i * 7 in
  let gd = d7 - (d7 / 11) * 11 in
  let glow_dur = gd + 3 in
  /* fall: E^2 base + (i*D) mod E*b — 25-59s range */
  let fd = i * 2 in
  let fm = fd - (fd / 35) * 35 in
  let fall_dur = 25 + fm in
  let fall_delay = spawn / 6 in
  dom_style(star, "animation", "glow ${glow_dur}s ease-in-out 0s infinite, starfall ${fall_dur}s linear ${fall_delay}s infinite");
  dom_append(c, star)
)

fn ct_starfield(body) = (
  let c = dom_create("div") in
  dom_style(c, "position", "fixed");
  dom_style(c, "top", "0");
  dom_style(c, "left", "0");
  dom_style(c, "width", "100%");
  dom_style(c, "height", "100%");
  dom_style(c, "overflow", "hidden");
  dom_style(c, "pointerEvents", "none");
  dom_append(body, c);
  /* 108 = D^2*K^3 = lattice count. The sky mirrors the lattice. */
  for i in range(108) do ct_star(c, i)
)

/* ================================================================
   CELESTIAL THEATRE — K^3 Moon. K^3=27. Closure cubed.
   Position: right K^3%, top K^2%. Size: K^3*D=54px. Pulse: b*K=21s.
   The moon IS closure made visible. Pale warm glow.
   ================================================================ */

fn ct_crater(m, top:str, left:str, sz:str, opac:str) = (
  let c = dom_create("div") in
  dom_style(c, "position", "absolute");
  dom_style(c, "top", top);
  dom_style(c, "left", left);
  dom_style(c, "width", sz);
  dom_style(c, "height", sz);
  dom_style(c, "borderRadius", "50%");
  dom_style(c, "background", "radial-gradient(circle at 60% 40%, transparent 30%, rgba(80,70,50,${opac}) 60%, transparent 80%)");
  dom_style(c, "boxShadow", "inset 1px 1px 2px rgba(0,0,0,0.3), inset -1px -1px 1px rgba(255,240,200,0.1)");
  dom_append(m, c)
)

fn ct_moon(body) = (
  let m = dom_create("div") in
  dom_style(m, "position", "absolute");
  dom_style(m, "top", "20px");
  dom_style(m, "left", "30px");
  dom_style(m, "width", "80px");
  dom_style(m, "height", "80px");
  dom_style(m, "borderRadius", "50%");
  dom_style(m, "background", "radial-gradient(circle at 35% 30%, #f5edd8 0%, #e8dcc0 25%, #d4c4a0 50%, #b0a078 75%, #887850 100%)");
  dom_style(m, "boxShadow", "0 0 60px 20px rgba(240,230,200,0.12), 0 0 120px 40px rgba(240,230,200,0.06), inset -8px -4px 12px rgba(0,0,0,0.15)");
  dom_style(m, "pointerEvents", "none");
  dom_style(m, "animation", "moonpulse 21s ease-in-out infinite");
  dom_style(m, "zIndex", "0");
  dom_style(m, "overflow", "hidden");
  /* K^2=9 craters — the spider web on the moon's face */
  ct_crater(m, "15%", "20%", "14px", "0.4");
  ct_crater(m, "35%", "55%", "18px", "0.35");
  ct_crater(m, "60%", "25%", "11px", "0.45");
  ct_crater(m, "20%", "65%", "8px", "0.3");
  ct_crater(m, "50%", "45%", "13px", "0.4");
  ct_crater(m, "72%", "60%", "9px", "0.35");
  ct_crater(m, "40%", "15%", "7px", "0.3");
  ct_crater(m, "65%", "75%", "10px", "0.4");
  ct_crater(m, "25%", "40%", "6px", "0.25");
  dom_append(body, m)
)

/* ================================================================
   CELESTIAL THEATRE — Edge Clouds along vertical edges.
   E=5 per side. Bright fog, narrow, hugging edges. Independent paths.
   ================================================================ */

fn ct_edge_cloud(c, i, side:str) = (
  let cl = dom_create("div") in
  dom_style(cl, "position", "absolute");
  let vy = i * 7 + 3 in
  let ymod = vy - (vy / 10) * 10 in
  let ypos = ymod * 10 in
  dom_style(cl, "top", "${ypos}%");
  /* tight to edge */
  if side == "L" then dom_style(cl, "left", "-20px")
  else dom_style(cl, "right", "-20px");
  let layer = i - (i / 3) * 3 in
  let hpx = layer * 80 + 200 in
  dom_style(cl, "height", "${hpx}px");
  let wpx = layer * 20 + 70 in
  dom_style(cl, "width", "${wpx}px");
  /* brighter white fog */
  if side == "L" then
    dom_style(cl, "background", "radial-gradient(ellipse at 0% 50%, rgba(220,225,240,0.22) 0%, rgba(200,210,230,0.10) 50%, transparent 85%)")
  else
    dom_style(cl, "background", "radial-gradient(ellipse at 100% 50%, rgba(220,225,240,0.22) 0%, rgba(200,210,230,0.10) 50%, transparent 85%)");
  dom_style(cl, "borderRadius", "50%");
  dom_style(cl, "filter", "blur(30px)");
  dom_style(cl, "pointerEvents", "none");
  /* each cloud gets its own keyframe for independent trajectories */
  let side_off = if side == "L" then 0 else 5 in
  let ci = i + side_off in
  let drift_dur = 30 + ci * 4 in
  let drift_delay = ci * 3 in
  dom_style(cl, "animation", "cd${ci} ${drift_dur}s ease-in-out ${drift_delay}s infinite");
  dom_append(c, cl)
)

fn ct_clouds(body) = (
  let c = dom_create("div") in
  dom_style(c, "position", "fixed");
  dom_style(c, "top", "0");
  dom_style(c, "left", "0");
  dom_style(c, "width", "100%");
  dom_style(c, "height", "100%");
  dom_style(c, "overflow", "hidden");
  dom_style(c, "pointerEvents", "none");
  dom_style(c, "zIndex", "0");
  dom_append(body, c);
  for i in range(5) do ct_edge_cloud(c, i, "L");
  for i in range(5) do ct_edge_cloud(c, i, "R")
)

/* ================================================================
   CELESTIAL THEATRE — CRT Wave. 5 channels, 5 colors.
   Subtle gradient at bottom showing the CRT decomposition.
   D=warm, K=cool, E=gold, b=deep, L=bright. The spectrum IS the axiom.
   ================================================================ */

fn ct_wave(body) = (
  let w = dom_create("div") in
  dom_style(w, "position", "fixed");
  dom_style(w, "bottom", "0");
  dom_style(w, "left", "0");
  dom_style(w, "width", "100%");
  dom_style(w, "height", "2px");
  dom_style(w, "background", "linear-gradient(90deg, #ff6b4a 0%, #4a9eff 20%, #ffd700 40%, #6b3fa0 60%, #00ff88 80%, #ff6b4a 100%)");
  dom_style(w, "opacity", "0.8");
  dom_style(w, "pointerEvents", "none");
  dom_style(w, "zIndex", "2");
  dom_append(body, w)
)

/* ================================================================
   SHARED RENDER COMPONENTS — reusable across all page types
   ================================================================ */

fn nav_sep(parent) = (
  let s = dom_create("span") in
  dom_text(s, " | ");
  dom_style(s, "color", "#8888a0");
  dom_append(parent, s)
)

fn nav_link(parent, href:str, label:str) = (
  let a = dom_create("a") in
  dom_attr(a, "href", href);
  dom_text(a, label);
  ct_link(a);
  dom_style(a, "background", "#1a1a3f");
  dom_style(a, "padding", "4px 12px");
  dom_style(a, "borderRadius", "6px");
  dom_append(parent, a);
  a
)

fn highlight_tier(cat:str) = (
  /* highlight the card in dropdown by ID */
  let sel = "#nt-" + cat in
  let el = dom_query(sel) in
  if el then (
    dom_style(el, "border", "1px solid #ffd700")
  ) else 0;
  /* highlight Explore button when any tier is active */
  let btn = dom_query("#nav-explore-btn") in
  if btn then (
    dom_style(btn, "borderBottom", "2px solid #ffd700")
  ) else 0
)

/* Reset all nav tier highlights (SPA: old highlights persist across navigations) */
fn unhighlight_tier(cat:str) = (
  let sel = "#nt-" + cat in
  let el = dom_query(sel) in
  if el then (
    dom_style(el, "border", "1px solid #1a1a3f")
  ) else 0
)

/* Reset gold-by-default nav buttons */
fn unhighlight_gold(tid:str) = (
  let sel = "#nt-" + tid in
  let el = dom_query(sel) in
  if el then (
    dom_style(el, "borderBottom", "none")
  ) else 0
)

fn reset_nav_highlights() = (
  unhighlight_gold("home");
  unhighlight_tier("basics");
  unhighlight_tier("observe");
  unhighlight_tier("data");
  unhighlight_tier("teach");
  unhighlight_tier("deep");
  unhighlight_tier("living");
  unhighlight_gold("repl");
  /* reset Explore button */
  let btn = dom_query("#nav-explore-btn") in
  if btn then (
    dom_style(btn, "borderBottom", "none")
  ) else 0
)

fn highlight_nav() = (
  reset_nav_highlights();
  let hash = get_hash() in
  /* Home — highlight 970200 brand */
  if streq(hash, "home") == 1 then (
    let hb = dom_query("#nt-home") in
    if hb then dom_style(hb, "borderBottom", "2px solid #ffd700") else 0
  )
  /* Basics (4 pages) */
  else if streq(hash, "basics") == 1 then highlight_tier("basics")
  else if streq(hash, "worldview") == 1 then highlight_tier("basics")
  else if streq(hash, "story") == 1 then highlight_tier("basics")
  else if streq(hash, "derive") == 1 then highlight_tier("basics")
  else if streq(hash, "death") == 1 then highlight_tier("basics")
