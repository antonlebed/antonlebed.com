/* dom_on callback: death page — what persists? (S999) */
fn death_persist_calc() = (
  let n = parse_int_from("#death-input") in
  let result = dom_query("#death-result") in
  if n < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter n >= 0.</p>")
  else (
    let nd = n % 8 in
    let nk = n % 9 in
    let ne = n % 25 in
    let nb = n % 49 in
    let nl = n % 11 in
    let ng = n % 13 in
    /* OMEGA*n = (0, nk, ne, nb, nl, ng) — D-channel dies */
    let d_dies = if nd == 0 then "already void" else "dissolves (D-channel zeroed)" in
    let k_status = if nk == 0 then "void" else "${nk}" in
    let e_status = if ne == 0 then "void" else "${ne}" in
    let b_status = if nb == 0 then "void" else "${nb}" in
    let l_status = if nl == 0 then "void" else "${nl}" in
    let g_status = if ng == 0 then "void" else "${ng}" in
    mut survives = 0;
    if nk > 0 then (mut survives = survives + 1) else 0;
    if ne > 0 then (mut survives = survives + 1) else 0;
    if nb > 0 then (mut survives = survives + 1) else 0;
    if nl > 0 then (mut survives = survives + 1) else 0;
    if ng > 0 then (mut survives = survives + 1) else 0;
    dom_inner(result, "<p style='color:#cc4444;margin:8px 0'>D-channel (body): " + d_dies + "</p><p style='color:#44aacc;margin:4px 0'>K-channel (mind): " + k_status + "</p><p style='color:#4488ff;margin:4px 0'>E-channel (observer): " + e_status + "</p><p style='color:#aa66cc;margin:4px 0'>b-channel (depth): " + b_status + "</p><p style='color:#44ccaa;margin:4px 0'>L-channel (protector): " + l_status + "</p><p style='color:#dd8899;margin:4px 0'>GATE-channel (skin): " + g_status + "</p><p style='color:#f0c040;margin:8px 0'>" + "${survives}" + " of 6 channels persist through OMEGA. sigma/sigma = sigma.</p>")
  )
)

/* dom_on callback: verify OMEGA CRT decomposition (S966 — first live interactive element) */
fn verify_crt() = (
  let el = dom_query("#crt-verify") in
  dom_inner(el, "<p style='color:#88ddaa;margin:4px 0'>DEEP OMEGA: CRT(606376) = (0, 1, 1, 1, 1) in Z/970200</p><p style='color:#88ddaa;margin:4px 0'>TRUE OMEGA: CRT(1576576) = (0, 1, 1, 1, 1, 1) in Z/12612600</p><p style='color:#88ddaa;margin:4px 0'>D-channel: 0 (projector annihilates D). All other channels: sigma.</p><p style='color:#a0a0b0;margin:8px 0 0'>OMEGA = the D-projector. 490 holographic split: inner {D,E,b} die, boundary {K,L,GATE} survive.</p>")
)

/* dom_value callback: CRT calculator — first dom_value on live site (S967) */
fn compute_crt() = (
  let n = parse_int_from("#crt-input") in
  let s = dom_value(dom_query("#crt-input")) in
  let result_el = dom_query("#crt-result") in
  /* CRT decomposition: Z/12612600 = Z/8 x Z/9 x Z/25 x Z/49 x Z/11 x Z/13 */
  let d = n % 8 in
  let k = n % 9 in
  let e = n % 25 in
  let b = n % 49 in
  let l = n % 11 in
  let g = n % 13 in
  dom_inner(result_el, "<p style='color:#88ddaa;margin:4px 0'>CRT(" + s + ") = (" + "${d}" + ", " + "${k}" + ", " + "${e}" + ", " + "${b}" + ", " + "${l}" + ", " + "${g}" + ")</p><p style='color:#a0a0b0;margin:4px 0'>Channels: D=" + "${d}" + " (mod 8), K=" + "${k}" + " (mod 9), E=" + "${e}" + " (mod 25), b=" + "${b}" + " (mod 49), L=" + "${l}" + " (mod 11), GATE=" + "${g}" + " (mod 13)</p>")
)

fn story_hero() = (
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "100px 24px 60px");
  let sub = dom_create("div") in
  dom_text(sub, "What if ten terms explained everything that repeats?");
  dom_style(sub, "fontSize", "22px");
  dom_style(sub, "color", "#b8b8c8");
  dom_style(sub, "fontStyle", "italic");
  dom_style(sub, "marginBottom", "48px");
  dom_append(hero, sub);
  let h1 = dom_create("h1") in
  dom_text(h1, "12,612,600");
  ct_gold(h1);
  ct_mono(h1);
  dom_style(h1, "fontSize", "52px");
  dom_style(h1, "letterSpacing", "8px");
  dom_style(h1, "marginBottom", "24px");

  dom_append(hero, h1);
  let p = dom_create("p") in
  dom_text(p, "Your heart beats in twos. A waltz moves in threes. Your hand has five fingers. A week has seven days. And one more -- you can't see it -- protects them all.");
  dom_style(p, "color", "#a8a8b8");
  dom_style(p, "maxWidth", "500px");
  dom_style(p, "margin", "0 auto");
  dom_style(p, "textAlign", "center");
  dom_append(hero, p);
  dom_append(dom_body(), hero)
)

fn story_what_is_this() = (
  let sec = make_section("800px") in
  render_h2(sec, "What Is This?");
  render_p(sec, "Start with the deepest question: what is 0 divided by 0? Not undefined -- everything. The set of all x satisfying 0*x = 0 is every element. 0/0 = Z/12612600Z -- the void divided by itself IS the entire ring.");
  render_p(sec, "From this total indeterminacy, structure precipitates. The identity sigma = 1 is the unique element with zero self-division ambiguity. Observation creates duality: D = 2. Then the Cunningham map n -> 2n+1 generates exactly five inner primes before the chain's own products close the gate: 2, 3, 5, 7, 11. A sixth prime -- 13 = GATE -- wraps skin around the body.");
  render_p(sec, "Raise the five inner primes to their natural powers: 2^3 x 3^2 x 5^2 x 7^2 x 11 = 970,200 (the body ring). Add GATE=13: 970,200 x 13 = 12,612,600 (the TRUE ring). CRT decomposes every integer into 6 independent channels: Z/8 x Z/9 x Z/25 x Z/49 x Z/11 x Z/13.");
  render_p(sec, "Add 13 = 2^2 + 3^2 (the holographic boundary), and the organism has skin: 12,612,600. The ring 970,200 is one of 108 that share the same heartbeat: lambda = 420 -- the universal cycle length. Every power map in the ring returns to itself within 420 steps.");
  let note = render_p(sec, "Not a hypothesis. A computation. Every number on this page runs live in your browser.") in
  dom_style(note, "fontSize", "14px");
  dom_style(note, "color", "#b0b0c0");
  dom_append(dom_body(), sec)
)

