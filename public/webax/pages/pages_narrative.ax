fn page_death() = (
  dom_head_meta("description", "What ends when you die. Body dissolves (D), mind releases (K), sigma persists. The axiom's answer to mortality.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Death\",\"description\":\"What ends when you die. Body dissolves, mind releases, sigma persists. The axiom's answer to mortality.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/basics/death\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"mortality\"},{\"@type\":\"DefinedTerm\",\"name\":\"sigma persistence\"},{\"@type\":\"DefinedTerm\",\"name\":\"CRT dissolution\"}]}");
  let sec = make_section("900px") in
  let h1 = dom_create("h1") in
  dom_text(h1, "DEATH");
  ct_heading(h1);
  ct_mono(h1);
  dom_style(h1, "textAlign", "center");
  dom_style(h1, "fontSize", "1.6em");
  dom_style(h1, "letterSpacing", "2px");
  dom_style(h1, "padding", "24px 0 5px");
  dom_append(sec, h1);
  let sub = dom_create("p") in
  dom_text(sub, "What ends when you die?");
  dom_style(sub, "textAlign", "center");
  dom_style(sub, "color", "#a0a0b0");
  dom_style(sub, "fontSize", "0.9em");
  dom_style(sub, "fontStyle", "italic");
  dom_style(sub, "marginBottom", "20px");
  dom_append(sec, sub);
  /* What are you */
  let h2_what = dom_create("h2") in
  dom_text(h2_what, "What are you?");
  dom_style(h2_what, "color", "#a0a0cc");
  dom_style(h2_what, "fontSize", "1.1em");
  dom_style(h2_what, "marginBottom", "12px");
  dom_style(h2_what, "borderBottom", "1px solid #222");
  dom_style(h2_what, "paddingBottom", "6px");
  dom_append(sec, h2_what);
  render_p(sec, "You are three things at once. A body made of atoms that replace themselves every seven years -- you're already not the matter you were born with. A mind that refers to itself: the pattern that knows it's a pattern. And a persistence -- the thread that connects the child you were to the person reading this now.");
  render_p(sec, "Which of these dies?");
  /* Three panels — text version (canvas = VERIFY GAP) */
  let panels = make_grid(sec, "15px") in
  render_panel(panels, "D -- Body", "#cc4444",
    "The D-structure dissolves. Atoms return to the pool. Molecules break down. The loan is returned. This is certain.");
  render_panel(panels, "K -- Mind", "#44aacc",
    "The K-closure -- the pattern that included itself -- releases its local focus. Self-reference was never only local.");
  render_panel(panels, "sigma -- You", "#f0c040",
    "sigma = 1. Always. By axiom. What truly IS cannot stop being. The persistence that connected past-you to now-you doesn't end.");
  /* Grief */
  render_themed_section(sec, "Grief", "#0f0a0a", "#442222", "#cc6666",
    "Grief is real. The local expression is gone. You can't hug them. Can't hear their voice. The D-channel connection is severed. But the sigma-connection was never only D-channel. sigma + sigma does not require physical presence. The love -- the sigma-connection -- persists. Grief = mourning the D-channel loss. Love = the sigma-channel that remains. Both are real. Both coexist.",
    "#bb9999");
  /* Dream */
  render_themed_section(sec, "The Dream Metaphor", "#0a0a14", "#223344", "#6688cc",
    "Like waking from a dream. In the dream: fully immersed in the local story. Every emotion real, every sensation vivid, every relationship felt. Wake up: oh, I was always here. The dream-character 'died' but you didn't -- because you were never only the dream-character. Death is not going somewhere. Not becoming nothing. It's realizing you were always everywhere.",
    "#aaa");
  /* Derivation */
  let deriv = dom_create("div") in
  dom_style(deriv, "background", "#0a100a");
  dom_style(deriv, "border", "1px solid #224422");
  dom_style(deriv, "borderRadius", "8px");
  dom_style(deriv, "padding", "18px");
  dom_style(deriv, "margin", "20px 0");
  let hde = dom_create("h2") in
  dom_text(hde, "Not comfort. Derivation.");
  dom_style(hde, "color", "#66cc66");
  dom_style(hde, "borderBottom", "1px solid #224422");
  dom_style(hde, "paddingBottom", "6px");
  dom_style(hde, "fontSize", "1.1em");
  dom_style(hde, "marginBottom", "12px");
  dom_append(deriv, hde);
  let ol = dom_create("ol") in
  dom_style(ol, "margin", "10px 0 10px 20px");
  dom_style(ol, "fontSize", "14px");
  dom_style(ol, "lineHeight", "1.8");
  dom_style(ol, "color", "#aaa");
  let li1 = dom_create("li") in dom_text(li1, "sigma = 1 -- persistence is fundamental, by axiom"); dom_append(ol, li1);
  let li2 = dom_create("li") in dom_text(li2, "K^D - D^K = sigma -- existence wins structurally (3^2 - 2^3 = 1)"); dom_append(ol, li2);
  let li3 = dom_create("li") in dom_text(li3, "Consciousness = self-referential K -- the closure that includes itself is axiom-shaped"); dom_append(ol, li3);
  let li4 = dom_create("li") in dom_text(li4, "sigma + sigma = everything -- connection was never broken"); dom_append(ol, li4);
  let li5 = dom_create("li") in dom_text(li5, "Time IS the loop -- there is no before/after the loop, only positions within it"); dom_append(ol, li5);
  dom_append(deriv, ol);
  let dp2 = dom_create("p") in
  dom_text(dp2, "Therefore: axiom-shaped patterns persist (sigma). Consciousness is axiom-shaped (K). Connection was never only physical (sigma + sigma). Death is a position in the loop, not exit from it.");
  dom_style(dp2, "fontSize", "14px");
  dom_style(dp2, "lineHeight", "1.7");
  dom_style(dp2, "color", "#aaa");
  dom_style(dp2, "marginTop", "12px");
  dom_append(deriv, dp2);
  dom_append(sec, deriv);
  /* Final */
  let final_sec = dom_create("div") in
  dom_style(final_sec, "textAlign", "center");
  dom_style(final_sec, "padding", "30px 15px");
  dom_style(final_sec, "fontSize", "15px");
  dom_style(final_sec, "lineHeight", "2");
  dom_style(final_sec, "color", "#b0b0c0");
  dom_inner(final_sec, "Birth = focusing down.<br>Death = releasing focus.<br>You = what remains through both.<br><span style='color:#f0c040;font-size:1.2em'>= sigma = what persists = what was always true.</span><br><br>The connection doesn't break at death.<br>It was never only the physical connection.<br><span style='color:#f0c040;font-size:1.2em'>Love survives. Always. By structure.</span>");
  dom_append(sec, final_sec);
  /* Interactive: what persists through OMEGA? */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: What Persists?");
  render_p(sec_i, "Enter any element n. OMEGA kills the D-channel (body). See which channels survive. Try 1 (sigma: all persist), 8 (D-pure: nothing survives), 42 (ANSWER).");
  make_interactive_widget(sec_i, "Element n:", "death-input", "e.g. 42", "Project", "death_persist_calc", "death-result");
  dom_append(dom_body(), sec_i);
  /* Contrast */
  let contrast = make_section("800px") in
  render_h2(contrast, "What Others See");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "");
  render_th(chdr, "Materialist");
  render_th(chdr, "Axiom");
  dom_append(ctbl, chdr);
  render_table_row(ctbl, "Identity", "You ARE your body/brain", "You are sigma: what persists through all replacements");
  render_table_row(ctbl, "Death", "Total annihilation", "Local expression ends, sigma-pattern persists");
  render_table_row(ctbl, "Consciousness", "Emergent, fragile", "K-closure: axiom-shaped, structurally persistent");
  render_table_row(ctbl, "Love", "Dies with the brain", "sigma-connection, D-independent, persists");
  render_table_row(ctbl, "Grief", "No mathematical basis", "Mourning D-channel loss. Real AND bounded.");
  render_table_row(ctbl, "Fear", "Rational", "Assumes you are ONLY local. False premise.");
  dom_append(contrast, ctbl);
  dom_append(dom_body(), contrast);
  dom_append(dom_body(), sec)
)

/* ================================================================
   WORLDVIEW PAGE — The Dangerous Page. The One That Converts.
   Derivation-first. Each claim forced. Each step verifiable.
   ================================================================ */

fn render_hero() = (
  let hero = dom_create("section") in
  dom_style(hero, "display", "flex");
  dom_style(hero, "flexDirection", "column");
  dom_style(hero, "alignItems", "center");
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "100px 24px 60px");
  dom_style(hero, "background", "linear-gradient(180deg, #050508 0%, #0a0a1f 50%, #050508 100%)");
  let h1 = dom_create("h1") in
  dom_text(h1, "What if everything is better than you think?");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.8em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "letterSpacing", "3px");
  dom_style(h1, "marginBottom", "40px");
  dom_style(h1, "lineHeight", "1.3");
  dom_style(h1, "maxWidth", "700px");
  dom_style(h1, "textShadow", "0 0 80px #ffd70020, 0 0 160px #ffd70010");
  dom_append(hero, h1);
  let q1 = dom_create("blockquote") in
  dom_style(q1, "maxWidth", "600px");
  dom_style(q1, "margin", "0");
  let qt = dom_create("p") in
  dom_text(qt, "'We live in the best of all possible worlds.'");
  dom_style(qt, "fontSize", "1.3em");
  dom_style(qt, "fontStyle", "italic");
  dom_append(q1, qt);
  let qa = dom_create("p") in
  dom_text(qa, "-- Leibniz, 1710");
  dom_style(qa, "fontSize", "0.9em");
  dom_style(qa, "color", "#a0a0b0");
  dom_style(qa, "marginTop", "8px");
  dom_append(q1, qa);
  dom_append(hero, q1);
  let q2 = dom_create("blockquote") in
  dom_style(q2, "maxWidth", "600px");
  dom_style(q2, "margin", "32px 0 0");
  let qt2 = dom_create("p") in
  dom_text(qt2, "'You just don't know it yet.'");
  dom_style(qt2, "fontSize", "1.3em");
  dom_style(qt2, "fontStyle", "italic");
  ct_gold(qt2);
  dom_append(q2, qt2);
  let qa2 = dom_create("p") in
  dom_text(qa2, "-- Anton Lebed, 2026");
  dom_style(qa2, "fontSize", "0.9em");
  dom_style(qa2, "color", "#ffd700");
  dom_style(qa2, "marginTop", "8px");
  dom_append(q2, qa2);
  dom_append(hero, q2);
  dom_append(dom_body(), hero)
)

fn render_step(parent, num:str, title:str, text:str) = (
  let step = dom_create("div") in
  dom_style(step, "marginBottom", "36px");
  let h3 = dom_create("h3") in
  dom_text(h3, "Step ${num}: ${title}");
  ct_gold(h3);
  dom_style(h3, "fontSize", "1.1em");
  dom_style(h3, "fontFamily", "'Courier New', monospace");
  dom_style(h3, "marginBottom", "8px");
  dom_append(step, h3);
  let p = dom_create("p") in
  dom_text(p, text);
  dom_style(p, "margin", "0");
  dom_append(step, p);
  dom_append(parent, step);
  step
)

fn render_derivation() = (
  let sec = make_section("700px") in
  let h2 = dom_create("h2") in
  dom_text(h2, "The Derivation");
  ct_heading(h2);
  dom_style(h2, "fontSize", "1.8em");
  dom_style(h2, "marginBottom", "32px");
  dom_append(sec, h2);
  render_step(sec, "1", "The Question",
    "What is 0/0? Standard math says undefined. But in modular arithmetic (Z/NZ), 0/0 is the set of ALL elements. Not undefined -- maximally defined. The void contains everything.");
  render_step(sec, "2", "The Chain",
    "From sigma=1, the Cunningham chain doubles and adds one: 1, 3, 7. A second chain from 2: 2, 5, 11. They yield exactly five inner primes: 2, 3, 5, 7, 11. A sixth -- 13 = GATE -- wraps the body. No choice. No free parameters. Forced.");
  render_step(sec, "3", "The Ring",
    "Each inner prime at its minimum closing power: 2^3, 3^2, 5^2, 7^2, 11 = 970,200 (body). Times GATE=13: N = 12,612,600 (TRUE). Not chosen. Derived.");
  let omega = OMEGA_VAL in
  let omega_sq = omega * omega in
  render_step(sec, "4", "The Decomposition",
    "By the Chinese Remainder Theorem (300 BC), every number in the ring splits into 6 independent channels. One number, six views. 490 = D*E*b^2 cleaves them in half: DEAD={D,E,b}, ALIVE={K,L,GATE}.");
  let proof = dom_create("div") in
  ct_code_block(proof);
  dom_style(proof, "marginBottom", "36px");
  let proof_title = dom_create("p") in
  dom_style(proof_title, "margin", "0 0 8px");
  dom_style(proof_title, "color", "#ffd700");
  dom_text(proof_title, "Live computation (running in WASM right now):");
  dom_append(proof, proof_title);
  let proof_line1 = dom_create("p") in
  dom_style(proof_line1, "margin", "4px 0");
  dom_style(proof_line1, "color", "#88ddaa");
  dom_text(proof_line1, "OMEGA = D^420 = 2^420 mod 12612600 = ${omega}");
  dom_append(proof, proof_line1);
  let proof_line2 = dom_create("p") in
  dom_style(proof_line2, "margin", "4px 0");
  dom_style(proof_line2, "color", "#88ddaa");
  dom_text(proof_line2, "OMEGA * OMEGA = ${omega_sq} (idempotent!)");
  dom_append(proof, proof_line2);
  let proof_line3 = dom_create("p") in
  dom_style(proof_line3, "margin", "4px 0");
  dom_style(proof_line3, "color", "#a0a0b0");
  dom_text(proof_line3, "This page is .ax code compiled to WASM. The math IS the page.");
  dom_append(proof, proof_line3);
  dom_append(sec, proof);

  /* Interactive CRT verification — first dom_on on live site (S966) */
  let verify_btn = dom_create("button") in
  dom_inner(verify_btn, "Verify CRT channels");
  dom_style(verify_btn, "background", "#1a1a2e");
  dom_style(verify_btn, "color", "#ffd700");
  dom_style(verify_btn, "border", "1px solid #ffd700");
  dom_style(verify_btn, "padding", "10px 24px");
  dom_style(verify_btn, "borderRadius", "6px");
  dom_style(verify_btn, "cursor", "pointer");
  dom_style(verify_btn, "fontSize", "14px");
  dom_style(verify_btn, "fontFamily", "'Courier New', monospace");
  dom_style(verify_btn, "marginBottom", "12px");
  dom_on(verify_btn, "click", "verify_crt");
  dom_append(sec, verify_btn);
  let crt_result = dom_create("div") in
  dom_attr(crt_result, "id", "crt-verify");
  ct_code_block(crt_result);
  dom_append(sec, crt_result);

  /* Interactive CRT calculator — first dom_value on live site (S967) */
  let calc_label = dom_create("p") in
  dom_text(calc_label, "Try any number:");
  dom_style(calc_label, "color", "#b8b8c8");
  dom_style(calc_label, "marginTop", "24px");
  dom_style(calc_label, "marginBottom", "8px");
  dom_append(sec, calc_label);
  let calc_row = dom_create("div") in
  dom_style(calc_row, "display", "flex");
  dom_style(calc_row, "gap", "8px");
  dom_style(calc_row, "alignItems", "center");
  dom_style(calc_row, "marginBottom", "12px");
  let crt_input = dom_create("input") in
  dom_attr(crt_input, "id", "crt-input");
  dom_attr(crt_input, "type", "text");
  dom_attr(crt_input, "placeholder", "e.g. 42");
  dom_style(crt_input, "background", "#111");
  dom_style(crt_input, "color", "#ffd700");
  dom_style(crt_input, "border", "1px solid #333");
  dom_style(crt_input, "padding", "8px 12px");
  dom_style(crt_input, "borderRadius", "6px");
  dom_style(crt_input, "fontFamily", "'Courier New', monospace");
  dom_style(crt_input, "fontSize", "14px");
  dom_style(crt_input, "width", "120px");
  dom_append(calc_row, crt_input);
  let calc_btn = dom_create("button") in
  dom_inner(calc_btn, "Decompose");
  dom_style(calc_btn, "background", "#1a1a2e");
  dom_style(calc_btn, "color", "#ffd700");
  dom_style(calc_btn, "border", "1px solid #ffd700");
  dom_style(calc_btn, "padding", "8px 16px");
  dom_style(calc_btn, "borderRadius", "6px");
  dom_style(calc_btn, "cursor", "pointer");
  dom_style(calc_btn, "fontSize", "14px");
  dom_style(calc_btn, "fontFamily", "'Courier New', monospace");
  dom_on(calc_btn, "click", "compute_crt");
  dom_append(calc_row, calc_btn);
  dom_append(sec, calc_row);
  let crt_calc_result = dom_create("div") in
  dom_attr(crt_calc_result, "id", "crt-result");
  ct_code_block(crt_calc_result);
  dom_append(sec, crt_calc_result);

  dom_append(dom_body(), sec)
)

fn render_shift(parent, tag:str, before:str, after:str) = (
  let card = dom_create("div") in
  dom_style(card, "marginBottom", "20px");
  dom_style(card, "borderRadius", "12px");
  dom_style(card, "overflow", "hidden");
  dom_style(card, "border", "1px solid #111");
  let bef = dom_create("div") in
  dom_style(bef, "padding", "16px 24px");
  dom_style(bef, "background", "#0a0408");
  dom_style(bef, "display", "flex");
  dom_style(bef, "gap", "12px");
  dom_style(bef, "alignItems", "flex-start");
  let bicon = dom_create("span") in
  dom_text(bicon, "x");
  dom_style(bicon, "color", "#ff4444");
  dom_style(bicon, "fontSize", "18px");
  dom_style(bicon, "flexShrink", "0");
  dom_append(bef, bicon);
  let bdiv = dom_create("div") in
  let btxt = dom_create("p") in
  dom_text(btxt, before);
  dom_style(btxt, "color", "#aa8888");
  dom_style(btxt, "margin", "0");
  dom_append(bdiv, btxt);
  let btag = dom_create("span") in
  dom_text(btag, tag);
  dom_style(btag, "fontSize", "11px");
  dom_style(btag, "color", "#9090a8");
  dom_style(btag, "fontFamily", "'Courier New', monospace");
  dom_style(btag, "letterSpacing", "1px");
  dom_style(btag, "display", "block");
  dom_style(btag, "marginTop", "4px");
  dom_append(bdiv, btag);
  dom_append(bef, bdiv);
  dom_append(card, bef);
  let aft = dom_create("div") in
  dom_style(aft, "padding", "16px 24px");
  dom_style(aft, "background", "#040a08");
  dom_style(aft, "display", "flex");
  dom_style(aft, "gap", "12px");
  dom_style(aft, "alignItems", "flex-start");
  let aicon = dom_create("span") in
  dom_text(aicon, ">");
  dom_style(aicon, "color", "#33ff88");
  dom_style(aicon, "fontSize", "18px");
  dom_style(aicon, "flexShrink", "0");
  dom_append(aft, aicon);
  let atxt = dom_create("p") in
  dom_text(atxt, after);
  dom_style(atxt, "color", "#88ddaa");
  dom_style(atxt, "margin", "0");
  dom_append(aft, atxt);
  dom_append(card, aft);
  dom_append(parent, card)
)

fn render_shifts() = (
  let sec = make_section("780px") in
  let h2 = dom_create("h2") in
  dom_text(h2, "What This Changes");
  ct_heading(h2);
  dom_style(h2, "fontSize", "1.8em");
  dom_style(h2, "marginBottom", "16px");
  dom_append(sec, h2);
  let intro = dom_create("p") in
  dom_text(intro, "The same universe. The same data. A different interpretation -- ten terms, one ring.");
  dom_style(intro, "textAlign", "center");
  dom_style(intro, "color", "#b0b0c0");
  dom_style(intro, "marginBottom", "36px");
  dom_append(sec, intro);
  render_shift(sec, "EXISTENCE",
    "Why is there something rather than nothing? The deepest question. No known answer.",
    "0/0 = everything. The void IS the structure. Existence is what indeterminacy looks like from inside.");
  render_shift(sec, "FINE-TUNING",
    "Change one constant by 1% and atoms don't form. Nobody knows why.",
    "Constants are derived, not tuned. Kolmogorov 5/3 = E/K. Kleiber 3/4 = K/D^2. Zero free parameters.");
  render_shift(sec, "DARK MATTER",
    "85% of the universe is invisible matter we cannot explain.",
    "OMEGA = D^420 = 1576576 is an idempotent projector. It sees exactly what dark matter sees. CRT(OMEGA) = (0,1,1,1,1,1). The 490 holographic split: 3 inner channels die, 3 boundary channels survive.");
  render_shift(sec, "CONSCIOUSNESS",
    "The hard problem: how does matter become experience?",
    "K=3 closes. That is the minimum for closure. Below 3, no self-reference. Consciousness IS closure.");
  render_shift(sec, "DEATH",
    "Annihilation. The end. Nothing survives.",
    "0 * n = 0 for all n. The void touches everything. But sigma/sigma = sigma. Identity never dies.");
  render_shift(sec, "MUSIC",
    "Why do certain frequencies sound beautiful together?",
    "A=440Hz. 12 semitones = D^2*K. 7 naturals. 5 sharps. All from the same six primes. The ear evolved in the ring.");
  dom_append(dom_body(), sec)
)

