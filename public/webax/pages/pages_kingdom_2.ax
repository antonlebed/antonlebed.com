fn omega_funnel() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Funnel");
  render_p(sec, "Birth = wide mouth: all N = 12612600 elements. OMEGA = narrow drain: 1576575 survive. Funnel factor = D^3 = 8 = number of spider legs. The axiom's own geometry determines the constriction.");
