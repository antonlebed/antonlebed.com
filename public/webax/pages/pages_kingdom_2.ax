  dom_head_meta("description", "Every alphabet decomposes into axiom primes. Georgian=K*L=33. Hebrew=D*L=22. Sacred boundary: 70.3% smooth, 13 dominates. Voynich: MI=1.635 near E/K (1.9%), mean WL near log2(E^2) (0.08%). Greenberg 45=K^2*E universals. Dante: 9+7+9=E^2. Culture: 88.4% smooth (9.1x). Paleolithic: 35,000-year invariance.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Language and Alphabets\",\"description\":\"Every alphabet decomposes into axiom primes. Georgian=33, Hebrew=22. Sacred boundary 70.3% smooth. Greenberg universals. Dante: 9+7+9=25.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/deep/language\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"alphabet decomposition\"},{\"@type\":\"DefinedTerm\",\"name\":\"linguistic universals\"},{\"@type\":\"DefinedTerm\",\"name\":\"axiom primes\"}]}");
