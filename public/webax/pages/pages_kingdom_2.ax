/* Alphabet size factorizer */
fn language_factor_calc() = (
  let n = parse_int_from("#lang-input") in
  let result = dom_query("#lang-result") in
  if n < 2 then dom_inner(result, "<p style='color:#ff6666'>Enter alphabet size >= 2.</p>")
  else (
    /* trial divide by axiom primes */
    mut rem = n;
    mut v2 = 0;
    while rem % 2 == 0 do (mut rem = rem / 2; mut v2 = v2 + 1);
    mut v3 = 0;
    while rem % 3 == 0 do (mut rem = rem / 3; mut v3 = v3 + 1);
    mut v5 = 0;
    while rem % 5 == 0 do (mut rem = rem / 5; mut v5 = v5 + 1);
    mut v7 = 0;
    while rem % 7 == 0 do (mut rem = rem / 7; mut v7 = v7 + 1);
    mut v11 = 0;
    while rem % 11 == 0 do (mut rem = rem / 11; mut v11 = v11 + 1);
    let smooth = if rem == 1 then 1 else 0 in
    let tag = if smooth > 0 then "<b style='color:#88ddaa'>AXIOM-SMOOTH</b>" else "<b style='color:#ffd700'>Contains intruder ${rem}</b>" in
    let d_null = if v2 > 0 then "D-null (writing IS duality)" else "D-coprime (rare: breaks the writing = duality rule)" in
    let known = if n == 26 then " = Latin (D * 13 = GATE)" else if n == 33 then " = Georgian/Cyrillic (K * L)" else if n == 22 then " = Hebrew (D * L)" else if n == 24 then " = Greek (D^3 * K)" else if n == 28 then " = Arabic (D^2 * b)" else if n == 46 then " = Devanagari (D * 23)" else "" in
    let factors = "${v2}*D ${v3}*K ${v5}*E ${v7}*b ${v11}*L" in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>Alphabet size = ${n}${known}</p><p style='margin:4px 0'>${tag}</p><p style='margin:4px 0;color:#b8b8c8'>Exponents: D^${v2} * K^${v3} * E^${v5} * b^${v7} * L^${v11}${if smooth > 0 then "" else " * ${rem}"}</p><p style='margin:4px 0;color:#b0b0c0'>${d_null}</p>")
  )
)

