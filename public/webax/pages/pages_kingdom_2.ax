/* E^2 self-blindness: enter n, compute n mod 25 */
fn observer_e2_calc() = (
  let n = parse_int_from("#obs-input") in
  let result = dom_query("#obs-result") in
  if n < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter n >= 0.</p>")
  else (
    let r25 = n % 25 in
    let blind = if r25 == 0 then "<b style='color:#ffd700'>E-NULL</b>: invisible to the observer. Self-blind zone."
      else "<span style='color:#88ddaa'>E-visible</span>: observer sees position ${r25} in Z/25." in
    let r5 = n % 5 in
    let ediv = if r5 == 0 then "E-divisible (frozen in E-channel)." else "E-coprime (spinning in E-channel)." in
    let name = if n == 0 then " = VOID" else if n == 1 then " = sigma" else if n == 25 then " = E^2" else if n == 42 then " = ANSWER" else if n == 125 then " = E^3 (Higgs)" else if n == 1576576 then " = OMEGA" else "" in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>n = ${n}${name}</p><p style='margin:4px 0'>n mod E^2 = n mod 25 = <b>${r25}</b></p><p style='margin:4px 0'>${blind}</p><p style='margin:4px 0;color:#b8b8c8'>${ediv}</p><p style='margin:4px 0;color:#a0a0b0'>E^2 = 25 = number of SM particles = observer squared. The count IS the self-blindness.</p>")
  )
)

