  render_finding(g, "PROJECT", "~849000 elements", "D-channel stripped, odd channels preserved. Not dead but CHANGED. Like scattered -- still operating, no distinction.", "S478");
  render_finding(g, "Conservation", "|ker| * |image| = N", "D^3 * N/D^3 = 12612600. Nothing lost, just sorted.", "");
  render_finding(g, "Fattening", "constricts the funnel", "THIN funnel: D^1 = 2x narrowing. TRUE funnel: D^3 = 8x. Richer rings have tighter funnels.", "");
  render_p(sec, "HIGH COUPLING = SURVIVES DEATH. Electrons orbit forever (units, phi(N)=2419200). Nuclei plug (fixed points). Only D^3 = 8 things truly die. The funnel IS natural selection: coupling is fitness.");
  dom_append(dom_body(), sec)
)

fn omega_contrast() = (
  let sec = make_section("800px") in
  render_h2(sec, "Paradigm Contrast");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Claim");
  render_th(hdr, "Standard");
  render_th(hdr, "Axiom");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "Death", "Cessation, entropy", "Selective projection. D dies. Depth survives. OMEGA^2=OMEGA.");
  render_contrast_row(tbl, "Life cycle", "Emergent, each unique", "Universal: 0->sigma->OMEGA->0. Growth=420 steps, collapse=1, rebirth=free.");
  render_contrast_row(tbl, "Natural selection", "Fitness landscape", "Coupling IS fitness. High coupling survives OMEGA. |ker|=D^3=8.");
  render_contrast_row(tbl, "Self-sacrifice", "Altruism paradox", "L*OMEGA = (0,2,11,11,0,11). GATE*OMEGA = (0,4,13,13,2,0). Both protective primes lose their own channel. Forced algebraically.");
  render_contrast_row(tbl, "Observer role", "Passive measurement", "E needs 2 passes. Period doubles. Observer CREATES the timescale.");
  render_contrast_row(tbl, "Identity in death", "Lost", "OMEGA + e_D = sigma. Existence = terminal + dual. Orthogonal. Neither lost.");
  render_p(sec, "sigma/sigma = sigma. What survives OMEGA is what was never dependent on duality.");
  dom_append(dom_body(), sec)
)

