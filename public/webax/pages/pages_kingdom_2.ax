   Split from pages_kingdom.ax. 4 pages. */

fn page_carousel() = (
  dom_head_meta("description", "The CRT carousel: 5 rings at prime rates. Braid (11822 crossings), torus knots, Hamming graph. Lambda ladder (D,K,E,b). Squaring (cycles divide 12). Seed-flower (D=2 unique). Betti-Lie (56=E7, 240=E8). Mandelbrot (D 28x, L invariant). 32 switches. 7 petals. k-th power maps (pairs: D/K->12, E/L->6, b/13->4). Identity lattice (depth stiffness=ANSWER=42). Kleiber 3/4 from E=D+K.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"The CRT Carousel: Five Rings at Prime Rates\",\"description\":\"Five CRT channels spin at coprime rates. Braid with 11822 crossings. Torus knots. Betti-Lie correspondence (56=E7, 240=E8). Mandelbrot fractal dimension from D=2. Seed-flower uniqueness.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\",\"url\":\"https://antonlebed.com\"},\"url\":\"https://antonlebed.com/observe/carousel\",\"isAccessibleForFree\":true,\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"Chinese Remainder Theorem\"},{\"@type\":\"DefinedTerm\",\"name\":\"Braid Theory\"},{\"@type\":\"DefinedTerm\",\"name\":\"Torus Knots\"}]}");
  carousel_hero();
  carousel_frozen();
  carousel_cost();
  carousel_braid();
  carousel_strand_height();
  carousel_torus_knots();
  carousel_hamming_graph();
  carousel_shell_polynomial();
  carousel_shadow();
  carousel_biology();
  carousel_lambda();
  carousel_squaring();
  carousel_seed_flower();
  carousel_betti();
  carousel_mandelbrot();
  carousel_switches();
  carousel_petals();
  carousel_power_maps();
  carousel_identity_lattice();
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Carousel Position");
  render_p(sec_i, "Enter any number to see its position on the 5-ring carousel. Shows CRT coordinates and which rings are frozen (divisible by that prime). Try 210 (DATA: only L spins), 105 (HYDOR: D and L spin), 1 (sigma: all spin).");
  make_interactive_widget(sec_i, "Enter n:", "car-input", "e.g. 42", "Spin", "carousel_spin_calc", "car-result");
  dom_append(dom_body(), sec_i);
  carousel_contrast()
)

