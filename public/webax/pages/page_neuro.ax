  render_table_row_4(vt, "5", "Z/2310 (THIN)", "K^2 = 9", "Transcendental: complete");
  render_table_row_4(vt, "6", "Z/12612600 (TRUE)", "D*E = 10", "The rose still grows");
  render_p(sec, "Levels 1-4: lambda(0) = the prime just added. The compiled state IS the lesson. Level 5: lambda(0) = K^2 = 9. L compiles to EVERYTHING, not to itself. The protector's lesson is the whole nonility. L is selfless even in compilation.");
  render_p(sec, "Antoshka's insight: body asymmetry -> symmetry = Vygotsky internalization. External -> internal -> compressed -> instantaneous. The Compilation Variance Theorem: Var(lambda) = lambda(0) at ALL ring levels. EXACT. The asymmetry IS the training signal. Nothing is wasted.");
  let g = make_findings_grid(sec) in
