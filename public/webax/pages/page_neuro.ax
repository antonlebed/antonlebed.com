  dom_head_meta("description", "EEG bands = axiom D-powers (IFCN standard). 6 cortical layers = D*K. Hemispheres: sparse (b=7) vs fine (E=5) coding. Binding = L=11 checksum. Gate = 13 metacognition. 5 disease classes = 5 primes (97.2% smooth). Myelination in prime order (r = 0.974). Brain D_f = 2.7 = CMB temperature = K^3/(D*E). The ring IS the brain.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Neuroscience and CRT\",\"description\":\"EEG bands = axiom D-powers (IFCN standard). 6 cortical layers = D*K. Hemispheric coding: sparse b=7 vs fine E=5. 40Hz binding = D^3*E. 5 disease classes map to 5 primes (97.2% smooth). Myelination follows prime order (r=0.974). Brain fractal dimension 2.7 = K^3/(D*E).\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/teach/neuro\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"EEG frequency bands\"},{\"@type\":\"DefinedTerm\",\"name\":\"neural binding\"},{\"@type\":\"DefinedTerm\",\"name\":\"myelination order\"}]}");
  neuro_hero();
  neuro_eeg();
  neuro_layers();
