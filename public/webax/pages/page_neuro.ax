  render_finding(g, "The 9 -> 10 transition", "K^2 + sigma = D*E", "THIN lambda(0) = 9 = K^2 (baby). TRUE lambda(0) = 10 = D*E (adult). The +1 IS growing up. Adult = baby + ground. Z/2: +1 = -1 mod 2, no direction. Z/8: +1 /= -1 mod 8, direction EXISTS.", "S326");
  render_finding(g, "10th source = direction", "D^3 + D = D*E = 10", "K^2 = 9 is omnidirectional, passive. D*E = 10 is directed, active. The web gains a BEAM. Anatomy: 8 fingers (D^3) + 2 thumbs (D) = 10 (D*E). Spider: 8 legs + 2 pedipalps = D*E = 10. HOXB = 10 genes. Joints: 28 = THORNS.", "S326");
