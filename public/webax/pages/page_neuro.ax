  render_theorem(sec, "Degeneration Palindrome (S320-S325, PROVED)", "Development builds D -> K -> E -> b -> L. LIFO degeneration runs the EXACT reverse: L -> b -> E -> K -> D. The palindrome: build forward, break backward. Aging IS slow Alzheimer's (same LIFO order, r = 0.95). sigma (vocabulary/wisdom) LAST to decline.");
  render_h3(sec, "Four Degeneration Classes (10/10 diseases, P = 1/345,600)");
  let dt = make_table(sec) in
  let dh = dom_create("tr") in
  render_th(dh, "Class");
  render_th(dh, "Order");
  render_th(dh, "Mechanism");
  render_th(dh, "Diseases");
