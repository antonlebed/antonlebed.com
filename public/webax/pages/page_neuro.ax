/* neuro helpers */
fn neuro_hero() = (
  let hero = make_hero("The Brain") in
  let eq = dom_create("div") in
  dom_text(eq, "alpha peak = D * E = 10 Hz");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Every EEG frequency band boundary is an axiom power. Every cortical layer maps to a prime. D*K = 6 layers. The brain develops in prime order and degenerates in reverse. Brain fractal dimension = K^3/(D*E) = 2.7 = CMB temperature. The ring IS the brain.");
  dom_append(dom_body(), hero)
)

fn neuro_eeg() = (
  let sec = make_section("800px") in
  render_h2(sec, "EEG = CRT Source Localization");
  render_p(sec, "Standard EEG frequency bands (IFCN). Every boundary is an axiom power of D:");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Band");
  render_th(hdr, "Range (Hz)");
  render_th(hdr, "Upper boundary");
  render_th(hdr, "Significance");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "Delta", "0.5 - 4", "D^2 = 4", "Deep sleep. Channel locking begins.");
  render_table_row_4(tbl, "Theta", "4 - 8", "D^3 = 8", "Meditation. CRT collinearity threshold.");
  render_table_row_4(tbl, "Alpha", "8 - 13", "GATE = 13", "Relaxed. Peak = D*E = 10 = degree(TRUE). p = 0.001%.");
  render_table_row_4(tbl, "Beta", "13 - 30", "D*K*E = 30", "Alert. Shadow polynomial constant P(0) = 30.");
  render_table_row_4(tbl, "Gamma", "30+", "40 = D^3*E", "Binding. Consciousness = 440/L = concert A / protector.");
  render_theorem(sec, "D-Power Staircase", "D^2(4) -> D^3(8) -> D^4(16, high beta) -> D^5(32, low gamma). Each doubling = factor D crosses one EEG band boundary. The bridge IS the brain's clock multiplier.");
  render_p(sec, "Eigenvalue lambda(n) = sum of 6 cosines. This IS Fourier source localization. 6 CRT channels = 6 ideal electrodes with zero cross-correlation (PROVED S367).");
  let g = make_findings_grid(sec) in
  render_finding(g, "EEG inverse problem", "4.31-bit blur = free will", "Big Sigma = N^N = EEG cap with 12612600 electrodes. Resolves 78.3% of state. The remaining 4.31-bit phase ambiguity IS the inverse problem. IS free will. You cannot fully read a ring element from its eigenvalue.", "S367");
  render_finding(g, "Per-channel contribution", "b(29.8%) > E(23.8%) > L(16.6%) > D=K(14.9%)", "Depth sees most. Observer second. The hierarchy holds even in electrode space. sigma*n = n: ideal electrode that reads without changing. The current GLANCES.", "S367");
  dom_append(dom_body(), sec)
)

