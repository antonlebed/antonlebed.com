fn page_worldview() = (
  dom_head_meta("description", "Everything you were taught about the universe is more beautiful than you thought. 0/0 = Z/NZ. Five primes. All of physics. Verifiable.");
  render_hero();
  render_derivation();
  render_shifts();
  render_cta()
)

/* ================================================================
   DERIVE PAGE — Step-by-step derivation of 0/0 → 970200
   ================================================================ */

fn render_derive_step(parent, num:str, title:str, text:str, result:str) = (
  let step = dom_create("div") in
  dom_style(step, "marginBottom", "48px");
  dom_style(step, "padding", "24px");
  dom_style(step, "background", "#080810");
  dom_style(step, "borderRadius", "12px");
  dom_style(step, "borderLeft", "3px solid #ffd700");
  let h3 = dom_create("h3") in
  dom_text(h3, "Step ${num}: ${title}");
  ct_gold(h3);
  dom_style(h3, "fontSize", "1.2em");
  dom_style(h3, "fontFamily", "'Courier New', monospace");
  dom_style(h3, "marginBottom", "12px");
  dom_append(step, h3);
  let p = dom_create("p") in
  dom_text(p, text);
  dom_style(p, "margin", "0 0 12px");
  dom_append(step, p);
  let res = dom_create("div") in
  ct_code_block(res);
  dom_style(res, "color", "#88ddaa");
  dom_text(res, result);
  dom_append(step, res);
  dom_append(parent, step)
)

fn page_derive() = (
  dom_head_meta("description", "Step-by-step derivation: 0/0 to Z/970200Z. Each step forced. Zero free parameters. Verify in REPL.");
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "The Derivation");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.5em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let sub = dom_create("p") in
  dom_text(sub, "From nothing to everything in 6 steps. Each step forced. No choices.");
  dom_style(sub, "color", "#888");
  dom_style(sub, "fontSize", "1.1em");
  dom_append(hero, sub);
  dom_append(dom_body(), hero);
  let sec = make_section("700px") in
  render_derive_step(sec, "1", "The Indeterminacy",
    "What is 0/0? In standard math: undefined. In modular arithmetic (Z/NZ): the set of ALL elements. Every n satisfies 0*n = 0. The void doesn't destroy structure -- it reveals it.",
    "0/0 in Z/NZ = {0, 1, 2, ..., N-1} = the entire ring");
  render_derive_step(sec, "2", "The First Chain",
    "Start from sigma = 1 (the identity). Apply the Cunningham map c(p) = 2p+1. This generates: 1, 3, 7, 15=3*5 (stops). Three primes: 2, 3, 7.",
    "c(1)=3 [prime], c(3)=7 [prime], c(7)=15=3*5 [composite: STOP]");
  render_derive_step(sec, "3", "The Second Chain",
    "A second Cunningham chain starts from 2: 2, 5, 11, 23, 47... Cross with the first chain. The intersection is exactly {2, 3, 5, 7, 11}. Five primes. Forced.",
    "Chain 1: {1,3,7} -> primes {2,3,7}. Chain 2: {2,5,11,...}. Cross: {2,3,5,7,11}");
  let d3 = D * D * D in
  let k2 = K * K in
  let e2 = E * E in
  let b2 = b * b in
  render_derive_step(sec, "4", "The Ring",
    "Each prime needs its minimum closing power. D=2 needs D^3=8 (2^2=4 doesn't close). K=3 needs K^2=9. E=5 needs E^2=25. b=7 needs b^2=49. L=11 needs just L. Multiply: N = 8*9*25*49*11.",
    "D^3=${d3}, K^2=${k2}, E^2=${e2}, b^2=${b2}, L=${L} -> N = 970200");
  let omega = OMEGA_VAL in
  render_derive_step(sec, "5", "The Projector",
    "lambda = lcm(D^3,K^2,E^2,b^2,L) = 420. Raise D to the 420th power: OMEGA = D^420. This is an idempotent: OMEGA*OMEGA = OMEGA. It projects the ring into its shadow.",
    "OMEGA = 2^420 mod 970200 = ${omega}. OMEGA^2 = ${omega * omega}. Idempotent!");
  render_derive_step(sec, "6", "The Decomposition",
    "By the Chinese Remainder Theorem, every element decomposes into 5 independent channels. The ring Z/970200Z is isomorphic to Z/8 x Z/9 x Z/25 x Z/49 x Z/11. One number, five views.",
    "CRT(OMEGA) = (0, 1, 1, 1, 1). Zero in the D-channel, identity everywhere else.");
  let cta = dom_create("div") in
  dom_style(cta, "textAlign", "center");
  dom_style(cta, "padding", "32px 0");
  let btn = dom_create("a") in
  dom_attr(btn, "href", "https://antonlebed.com/repl.html");
  dom_text(btn, "Verify every step in the REPL");
  dom_style(btn, "display", "inline-block");
  dom_style(btn, "padding", "12px 36px");
  dom_style(btn, "border", "2px solid #ffd700");
  dom_style(btn, "color", "#ffd700");
  dom_style(btn, "borderRadius", "8px");
  dom_style(btn, "textDecoration", "none");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_append(cta, btn);
  dom_append(sec, cta);
  dom_append(dom_body(), sec)
)

/* ================================================================
   SHARED: Theorem card + table row
