/* Cosmic Pie fraction: enter a ratio numerator/200, identify component */
fn cosmo_pie_calc() = (
  let pct = parse_int_from("#cosmo-input") in
  let result = dom_query("#cosmo-result") in
  if pct < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter percentage (1-100).</p>")
  else (
    let close_de = if pct > 66 then (if pct < 71 then 1 else 0) else 0 in
    let close_dm = if pct > 24 then (if pct < 29 then 1 else 0) else 0 in
    let close_bar = if pct > 3 then (if pct < 7 then 1 else 0) else 0 in
    let match = if close_de > 0 then "Dark Energy: ADDRESS/200 = 137/200 = <b style='color:#ffd700'>68.5%</b>. ADDRESS = 137 = 11th prime."
      else if close_dm > 0 then "Dark Matter: SUM/200 = 53/200 = <b style='color:#ffd700'>26.5%</b>. SUM = sum of Decality = 53."
      else if close_bar > 0 then "Baryonic: D*E/200 = 10/200 = <b style='color:#ffd700'>5.0%</b>. D*E = degree of TRUE FORM."
      else "No cosmic component at this percentage." in
    let axiom_200 = pct * 2 in
    let smooth = 1 in
    let rem = axiom_200 in
    let r2 = if rem % 2 == 0 then 1 else 0 in
    let r3 = if rem % 3 == 0 then 1 else 0 in
    let r5 = if rem % 5 == 0 then 1 else 0 in
    let r7 = if rem % 7 == 0 then 1 else 0 in
    let r11 = if rem % 11 == 0 then 1 else 0 in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>${pct}% of the universe</p><p style='margin:4px 0'>${match}</p><p style='margin:4px 0;color:#b8b8c8'>As fraction of 200: ${axiom_200}/200. Divides by: ${if r2 > 0 then "D " else ""}${if r3 > 0 then "K " else ""}${if r5 > 0 then "E " else ""}${if r7 > 0 then "b " else ""}${if r11 > 0 then "L " else ""}</p><p style='margin:4px 0;color:#a0a0b0'>Total = ADDRESS(137) + SUM(53) + D*E(10) = 200 = D^3 * E^2.</p>")
  )
)

