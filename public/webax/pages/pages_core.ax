  dom_head_meta("description", "Cosmology from ten terms. 16 quantities from six primes. Cosmic Pie: 137+53+10=200. CMB = 2.725 K. Lambda = 3e-122. Hubble tension resolved. Zero free parameters.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Cosmology from Ten Terms\",\"description\":\"16 cosmological quantities from six primes. CMB, Hubble constant, dark energy fraction. Zero free parameters.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/data/cosmo\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"cosmic microwave background\"},{\"@type\":\"DefinedTerm\",\"name\":\"Hubble constant\"},{\"@type\":\"DefinedTerm\",\"name\":\"dark energy\"}]}");
