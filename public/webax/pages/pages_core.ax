  render_h2(sec_i, "Explore: Build alpha^(-1)");
  render_p(sec_i, "Enter number of terms (1-7). Watch the inverse fine structure constant converge. Each term uses only six primes + G=97.");
  make_interactive_widget(sec_i, "Number of terms (1-7):", "alpha-input", "e.g. 4", "Compute", "alpha_sum_calc", "alpha-result");
  render_p(sec_i, "Term 1: ADDRESS=137. Term 2: +b/(D*G). Terms 3-7: progressively smaller corrections.");
  dom_append(dom_body(), sec_i)
)

