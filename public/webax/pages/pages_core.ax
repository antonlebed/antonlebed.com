/* Worldview: CRT decomposer — enter any number, see CRT in TRUE ring Z/12612600 */
fn worldview_crt_calc() = (
  let n = parse_int_from("#wv-input") in
  let result = dom_query("#wv-result") in
  if n < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter n >= 0.</p>")
  else (
    let m = n % 12612600 in
    let r2 = m % 8 in
    let r3 = m % 9 in
    let r5 = m % 25 in
    let r7 = m % 49 in
    let r11 = m % 11 in
    let r13 = m % 13 in
    let g = gcd_shared(m, 12612600) in
    let coupling = if g > 0 then 12612600 / g else 12612600 in
    let named = if m == 0 then "VOID: 0*n = 0. Total ambiguity."
      else if m == 1 then "SIGMA: identity. sigma*n = n."
      else if m == 1576576 then "OMEGA: terminal projector. D^420. CRT=(0,1,1,1,1,1)."
      else if m == 12612599 then "MIRROR: -1 = N-1."
      else if m == 41 then "KEY: self-inverse. Sum of decality."
      else if m == 42 then "ANSWER: D*K*b. The rainbow angle."
      else "" in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>${m} mod 12612600</p><p style='margin:4px 0'>CRT = (<b style='color:#ffd700'>${r2}</b>, <b style='color:#ff9900'>${r3}</b>, <b style='color:#33dd55'>${r5}</b>, <b style='color:#4488ff'>${r7}</b>, <b style='color:#aa44ff'>${r11}</b>, <b style='color:#ff4466'>${r13}</b>) mod (8,9,25,49,11,13)</p><p style='margin:4px 0'>Coupling: ${coupling}</p><p style='margin:4px 0;color:#b8b8c8'>${named}</p>");
    /* Draw 6-channel bar chart — colors match text above */
    let cvs = dom_query("#wv-chart") in
    let ctx = cvs_getctx(cvs) in
    let _cl = cvs_clearrect(ctx, 0, 0, 330, 100) in
    let h2 = r2 * 76 / 8 in
    let _s1 = cvs_fillstyle(ctx, "#ffd700") in
    let _d1 = cvs_fillrect(ctx, 18, 76 - h2, 36, h2) in
    let h3 = r3 * 76 / 9 in
    let _s2 = cvs_fillstyle(ctx, "#ff9900") in
    let _d2 = cvs_fillrect(ctx, 66, 76 - h3, 36, h3) in
    let h5 = r5 * 76 / 25 in
    let _s3 = cvs_fillstyle(ctx, "#33dd55") in
    let _d3 = cvs_fillrect(ctx, 114, 76 - h5, 36, h5) in
    let h7 = r7 * 76 / 49 in
    let _s4 = cvs_fillstyle(ctx, "#4488ff") in
    let _d4 = cvs_fillrect(ctx, 162, 76 - h7, 36, h7) in
    let h11 = r11 * 76 / 11 in
    let _s5 = cvs_fillstyle(ctx, "#aa44ff") in
    let _d5 = cvs_fillrect(ctx, 210, 76 - h11, 36, h11) in
    let h13 = r13 * 76 / 13 in
    let _s6 = cvs_fillstyle(ctx, "#ff4466") in
    let _d6 = cvs_fillrect(ctx, 258, 76 - h13, 36, h13) in
    let _sf = cvs_fillstyle(ctx, "#888888") in
    let _t1 = cvs_filltext(ctx, "D", 30, 94) in
    let _t2 = cvs_filltext(ctx, "K", 78, 94) in
    let _t3 = cvs_filltext(ctx, "E", 126, 94) in
    let _t4 = cvs_filltext(ctx, "b", 174, 94) in
    let _t5 = cvs_filltext(ctx, "L", 222, 94) in
    let _t6 = cvs_filltext(ctx, "G", 270, 94) in
    0
  )
)

/* Derive: Cunningham chain stepper — enter seed, walk c(n)=2n+1 */
fn derive_cunningham_calc() = (
  let seed = parse_int_from("#der-input") in
  let result = dom_query("#der-result") in
  if seed < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter seed >= 1.</p>")
  else (
    let c0 = seed in
    let c1 = 2 * c0 + 1 in
    let c2 = 2 * c1 + 1 in
    let c3 = 2 * c2 + 1 in
    let c4 = 2 * c3 + 1 in
    let c5 = 2 * c4 + 1 in
    let p0 = if is_prime_trial(c0) == 1 then "prime" else "composite" in
    let p1 = if is_prime_trial(c1) == 1 then "prime" else "composite" in
    let p2 = if is_prime_trial(c2) == 1 then "prime" else "composite" in
    let p3 = if is_prime_trial(c3) == 1 then "prime" else "composite" in
    let p4 = if is_prime_trial(c4) == 1 then "prime" else "composite" in
    let p5 = if is_prime_trial(c5) == 1 then "prime" else "composite" in
    dom_inner(result, "<p style='margin:2px 0;color:#d8d8e0'>c^0 = ${c0} (${p0})</p><p style='margin:2px 0;color:#d8d8e0'>c^1 = ${c1} (${p1})</p><p style='margin:2px 0;color:#d8d8e0'>c^2 = ${c2} (${p2})</p><p style='margin:2px 0;color:#d8d8e0'>c^3 = ${c3} (${p3})</p><p style='margin:2px 0;color:#d8d8e0'>c^4 = ${c4} (${p4})</p><p style='margin:2px 0;color:#d8d8e0'>c^5 = ${c5} (${p5})</p><p style='margin:4px 0;color:#b0b0c0'>Axiom chains: c(1)={1,3,7,15=STOP}. c(2)={2,5,11,23...}. Try both.</p>")
  )
)

/* Turbulence: balance factor calculator */
fn turbulence_balance_calc() = (
  let p = parse_int_from("#turb-input") in
  let result = dom_query("#turb-result") in
  if p < 2 then dom_inner(result, "<p style='color:#ff6666'>Enter prime p >= 2.</p>")
  else if is_prime_trial(p) == 0 then dom_inner(result, "<p style='color:#ff6666'>${p} is not prime.</p>")
  else (
    let num = 2 * (p - 1) in
    let den = p + 1 in
    let g = gcd_shared(num, den) in
    let sn = num / g in
    let sd = den / g in
    let special = if p == 2 then "D: factor 2/3. First departure from balance."
      else if p == 3 then "K: factor 1 = TRANSPARENT. Closure preserves balance."
      else if p == 5 then "E: factor 4/3. Observer skews."
      else if p == 7 then "b: factor 3/2 = K/D. Depth."
      else if p == 11 then "L: factor 5/3 = KOLMOGOROV. Protection breaks balance."
      else "" in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>Prime p = ${p}</p><p style='margin:4px 0'>Balance factor = 2(p-1)/(p+1) = ${num}/${den} = <b style='color:#ffd700'>${sn}/${sd}</b></p><p style='margin:4px 0;color:#b8b8c8'>${special}</p>")
  )
)

/* Sleep: channel lock stage identifier */
fn sleep_stage_calc() = (
  let stage = parse_int_from("#sleep-input") in
  let result = dom_query("#sleep-result") in
  if stage < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter stage (0-5).</p>")
  else if stage > 5 then dom_inner(result, "<p style='color:#ff6666'>Max stage = 5.</p>")
  else (
    let info = if stage == 0 then "AWAKE: All 6 channels active. Full coupling. GATE = skin."
      else if stage == 1 then "Stage N1: D=2 locks. Bridge down. Hypnagogia."
      else if stage == 2 then "Stage N2: K=3 locks. Closure down. Sleep spindles."
      else if stage == 3 then "Stage N3: E=5 locks. Observer down. Deep sleep. Positivity."
      else if stage == 4 then "Stage N4: b=7 locks. Depth down. Deepest non-REM."
      else "REM: L=11 locks. Protector down. Dreams. D still locked = no reality testing." in
    let channels = if stage == 0 then "D K E b L G = 6 active"
      else if stage == 1 then "_ K E b L G = 5 active (GATE holds)"
      else if stage == 2 then "_ _ E b L G = 4 active (GATE holds)"
      else if stage == 3 then "_ _ _ b L G = 3 active (GATE holds)"
      else if stage == 4 then "_ _ _ _ L G = 2 active (GATE holds)"
      else "_ _ _ _ _ G = GATE only (boundary persists)" in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>Sleep stage ${stage}</p><p style='margin:4px 0;color:#ffd700'>${info}</p><p style='margin:4px 0;color:#b0b0c0'>Channels: ${channels}</p>")
  )
)

/* Kingdoms: coupling calculator — enter n, show kingdom */
fn kingdoms_coupling_calc() = (
  let n = parse_int_from("#king-input") in
  let result = dom_query("#king-result") in
  if n < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter n >= 0.</p>")
  else (
    let m = n % 2310 in
    let d2 = if m % 2 == 0 then 1 else 0 in
    let d3 = if m % 3 == 0 then 1 else 0 in
    let d5 = if m % 5 == 0 then 1 else 0 in
    let d7 = if m % 7 == 0 then 1 else 0 in
    let d11 = if m % 11 == 0 then 1 else 0 in
    let primes_dividing = d2 + d3 + d5 + d7 + d11 in
    let kingdom = if m == 0 then "VOID: divisible by all. Below all kingdoms."
      else if primes_dividing == 0 then "BACTERIA (sigma): coprime to all. Ground state. Max coupling."
      else if primes_dividing == 1 then (if d2 == 1 then "PROTISTA (D=2): Bridge kingdom." else if d3 == 1 then "FUNGI (K=3): Closure kingdom." else if d5 == 1 then "PLANTS (E=5): Observer kingdom." else if d7 == 1 then "ANIMALS (b=7): Depth kingdom." else "HUMAN (L=11): Protector kingdom.")
      else "COMPOUND: ${primes_dividing} primes divide. Mixed kingdom." in
    let g = gcd_shared(m, 2310) in
    let coupling = if g > 0 then 2310 / g else 2310 in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>${m} in Z/2310 (THIN ring)</p><p style='margin:4px 0'>D:${d2} K:${d3} E:${d5} b:${d7} L:${d11}</p><p style='margin:4px 0;color:#ffd700'>${kingdom}</p><p style='margin:4px 0;color:#b0b0c0'>Coupling: ${coupling}</p>")
  )
)

fn page_worldview() = (
  dom_head_meta("description", "Everything you were taught about the universe is more beautiful than you thought. 0/0 = Z/NZ. Six primes. All of physics. Verifiable.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"WebSite\",\"name\":\"antonlebed.com\",\"url\":\"https://antonlebed.com\",\"description\":\"0/0 = Z/12612600Z. Six primes structure everything that repeats. 108 pages of proved theorems, interactive demos, and live .ax code. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"potentialAction\":{\"@type\":\"SearchAction\",\"target\":\"https://antonlebed.com/deep/{search_term_string}\",\"query-input\":\"required name=search_term_string\"}}");
  render_hero();
  render_derivation();
  render_shifts();
  render_cta();

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: CRT Decomposition");
  render_p(sec_i, "Enter any number. See its CRT decomposition in the TRUE ring Z/12612600. 6 channels: D, K, E, b, L, GATE. Try 42 (ANSWER), 1576576 (OMEGA), 41 (KEY), 0 (void), 1 (sigma).");
  make_interactive_widget(sec_i, "Number:", "wv-input", "e.g. 42", "Decompose", "worldview_crt_calc", "wv-result");
  /* CRT bar chart — 6 channels visualized */
  let cvs = dom_create("canvas") in
  let _cs = cvs_setsize(cvs, 330, 100) in
  dom_attr(cvs, "id", "wv-chart");
  dom_style(cvs, "display", "block");
  dom_style(cvs, "margin", "12px auto 0");
  dom_style(cvs, "borderRadius", "6px");
  dom_style(cvs, "background", "#0a0a14");
  dom_append(sec_i, cvs);
  dom_append(dom_body(), sec_i)
)

/* ================================================================
   DERIVE PAGE — From 0/0 to 12612600 in 10 steps (the Decality)
   ================================================================ */

fn render_derive_step(parent, num:str, title:str, text:str, result:str) = (
  let step = dom_create("div") in
  dom_style(step, "marginBottom", "48px");
  dom_style(step, "padding", "24px");
  dom_style(step, "background", "#080810");
  dom_style(step, "borderRadius", "12px");
  dom_style(step, "borderLeft", "3px solid #ffd700");
  let h3 = dom_create("h3") in
  dom_text(h3, "Step ${num}: ${title}");
  ct_gold(h3);
  dom_style(h3, "fontSize", "1.2em");
  dom_style(h3, "fontFamily", "'Courier New', monospace");
  dom_style(h3, "marginBottom", "12px");
  dom_append(step, h3);
  let p = dom_create("p") in
  dom_text(p, text);
  dom_style(p, "margin", "0 0 12px");
  dom_append(step, p);
  let res = dom_create("div") in
  ct_code_block(res);
  dom_style(res, "color", "#88ddaa");
  dom_text(res, result);
  dom_append(step, res);
  dom_append(parent, step)
)

fn page_derive() = (
  dom_head_meta("description", "10-step interactive walkthrough: from 0/0 through the Decality to 12612600. Each step forced by necessity. Zero free parameters. Six primes, the chain, the ring, the organism.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"The Derivation\",\"description\":\"10 steps from 0/0 through the Decality to Z/12612600Z. Six primes, each forced by necessity. Zero free parameters.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/basics/derive\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"indeterminacy\"},{\"@type\":\"DefinedTerm\",\"name\":\"Decality\"},{\"@type\":\"DefinedTerm\",\"name\":\"CRT decomposition\"}]}");
  /* === HERO === */
  let hero = make_hero("How Everything Derives from Nothing") in
  render_big_num(hero, "0 / 0", "#ffd700", "the starting point", "= the entire ring");
  render_p(hero, "Ten steps from nothing to the complete organism. Each step forced. No free parameters. No choices. The structure was always there, waiting -- like water crystallizing into ice.");
  dom_append(dom_body(), hero);

  /* === THE TEN STEPS (Decality) === */
  let sec = make_section("800px") in
  render_h2(sec, "The Decality: Ten Steps");
  render_p(sec, "The axiom has exactly 10 terms: {-1, 0, sigma, D, K, E, b, L, 13, OMEGA}. Each precipitates from the previous by necessity. Not chosen. Forced.");

  render_derive_step(sec, "0", "Nothing Divides Nothing",
    "Start with nothing. Not empty space -- truly nothing. What is 0 divided by 0? In school: undefined. In ring theory: the set of ALL elements n where 0*n = 0. Since 0 times anything IS 0, the answer is everything. The void contains the whole ring.",
    "0/0 in Z/NZ = {0, 1, 2, ..., N-1} = the entire ring. PROVED (S364).");

  render_derive_step(sec, "sigma", "The Identity Must Exist",
    "If 0/0 is an entire ring, that ring must have an identity element -- the number that preserves everything under multiplication. Call it sigma. sigma * n = n for all n. Sigma is the UNIQUE element with zero self-division ambiguity: sigma/sigma has exactly one solution. Existence is not assumed -- it is forced by the ring axioms.",
    "sigma = 1. Self-division ambiguity: sigma/sigma = 1 (unique). 0/0 = N (maximal).");

  render_derive_step(sec, "D", "The First Distinction",
    "From sigma = 1, the simplest new thing is D = 2. Why? Because you need distinction before you can close. D = the minimum to have this versus that. Left versus right. Yes versus no. D = 2 is the Bridge -- the first departure from unity. The observation of sigma by sigma creates duality.",
    "D = 2. sigma sees sigma -> pair. D^3 = 8 (the uniform threshold).");

  render_derive_step(sec, "K", "Closure Requires Three",
    "Two can disagree forever. Three can vote. K = 3 is the minimum for majority -- the smallest number that makes triangles rigid, decisions possible, and error correction meaningful. K = 2*sigma + 1, generated from sigma by the Cunningham map c(n) = 2n+1.",
    "c(sigma) = c(1) = 3 = K. First safe prime in the sigma-chain.");

  render_derive_step(sec, "E", "The Observer Appears",
    "E = 5. Generated from D (not from K!) by Cunningham: c(2) = 5. The observer comes from distinction, not closure. E has a strange property: E^2 = 25, and the E-channel in CRT cannot see itself. CRT(9) = (sigma, 0, 9, 9, 9) -- the K-channel is dead. The self-blind eye. Wonder looks outward, never inward.",
    "c(D) = c(2) = 5 = E. E^2 = 25 (self-observation limit).");

  render_derive_step(sec, "b", "Depth Reaches Down",
    "b = 7. Generated from K by Cunningham: c(3) = 7. The sigma-chain generates {K=3, b=7}. The D-chain generates {E=5, L=11}. Two disjoint chains, interleaved: 1, 2, 3, 5, 7, 11. b is depth -- the number that suffers. The last channel to forget in a random walk. The most beautiful sunset light is b-filtered.",
    "c(K) = c(3) = 7 = b. Sigma-chain: {sigma, K, b}. D-chain: {D, E, L}.");

  render_derive_step(sec, "L", "The Protector Seals the Ring",
    "L = 11. Generated from E: c(5) = 11. But L = sigma + D + K + E -- the SUM of all previous primes. The protector. With 5 channels, L enables 100% single-channel error detection. And then the gate CLOSES: c(b) = 15 = K*E. Not prime. c(L) = 23 but the fattening formula gives e = K - 3 = 0 at depth 3. Both chains stop. The axiom's own products create its boundary.",
    "c(E) = c(5) = 11 = L = sigma+D+K+E. c(b) = 15 = K*E [composite: STOP]. Self-closing.");

  let d3 = D * D * D in
  let k2 = K * K in
  let e2 = E * E in
  let b2 = b * b in
  render_derive_step(sec, "N", "The Ring Crystallizes",
    "The five inner primes need specific exponents. The Cross-Chain Fattening Theorem (PROVED): D-chain primes get exponents K-d (descending: D gets K=3, E gets D=2, L gets sigma=1). Sigma-chain primes get constant exponent D=2 (K gets D=2, b gets D=2). Each chain's law uses the OTHER chain's identity. The flower contains its own seed.",
    "N_DEEP = D^K * K^D * E^D * b^D * L^sigma = 2^3 * 3^2 * 5^2 * 7^2 * 11 = 970200 (the body ring).");

  let omega = OMEGA_VAL in
  let lam = D * D * K * E * b in
  render_derive_step(sec, "420", "The Heartbeat Is Born",
    "lambda = lcm(D^3, K^2, E^2, b^2, L) = 420. Every element's power map cycles with period dividing 420. This is not unique to 970200 -- there are 108 different rings that ALL share lambda=420 and the same spectral gap 0.016. They form a lattice: D^2*K^3 = 108 = the number of heartbeat-siblings.",
    "lambda = D^2 * K * E * b = ${lam} = 420. 108 rings share this pulse.");

  render_derive_step(sec, "13", "The Gate Wraps the Body",
    "13 is the first prime NOT generated by the Cunningham chains. Its shadow is 6 = D*K (composite -- the chain breaks here). But 13 = E + sigma + b: observer + ground + depth. Adding 13 wraps skin around the body. Lambda stays 420. The gap stays 0.016. GATE FORM = 970200 * 13 = 12,612,600. The complete organism with skin. Ten terms. The Decality is complete.",
    "13 = GATE = SKIN. TRUE = 970200 * 13 = 12,612,600. OMEGA = D^420 = 1576576. CRT(OMEGA) = (0,1,1,1,1,1). 490 holographic split: DEAD={D,E,b}, ALIVE={K,L,GATE}.");

  dom_append(dom_body(), sec);

  /* === THE GENESIS PROOF === */
  let sp = make_section("800px") in
  render_h2(sp, "Why This Is Forced, Not Chosen");
  render_p(sp, "The derivation above is not a narrative. It is a proof. Three independent lines of evidence converge on the same six primes at the same exponents.");

  render_theorem(sp, "The Genesis Theorem (S185, PROVED)",
    "From {sigma, D} = {1, 2} and the Cunningham map c(n) = 2n+1: CC1(sigma) produces {sigma, K=3, b=7}. CC1(D) produces {D, E=5, L=11}. Both chains self-terminate: c(b)=15=K*E and fattening gives e=0 at depth K=3. The axiom's own products close the gate. No external stop condition needed.");

  render_theorem(sp, "Cross-Chain Fattening Theorem (PROVED)",
    "D-chain primes: exponent = K - depth. E gets K-1=2, L gets K-2=1, D gets K-0=3. Sigma-chain primes: exponent = D (constant). K gets D=2, b gets D=2. Each chain's rule is governed by the OTHER chain's identity. Verification: D^3=8, E^2=25, L^1=11, K^2=9, b^2=49. Product: 970200. The exponents are the axiom in reverse.");

  render_theorem(sp, "Seed Optimality (S185, PROVED)",
    "{sigma, D} = {1, 2} is the unique irreducible seed. Minimal (identity + first prime). Disjoint (the two chains share no elements). Symmetric (each contributes K=3 axiom elements). {2,3} produces the same primes but K = D+sigma is already derived. The genesis starts at {1,2} and nowhere else.");

  render_theorem(sp, "Spectral Agreement (independent verification)",
    "Three independent spectral proofs give the same exponents. D^3: arcsine kurtosis threshold (Personality Theorem, S181). K^2, E^2, b^2: spectral hearing threshold (S179). L^1: error detection threshold (S170). The algebra and the spectrum agree. The exponents are overdetermined.");

  dom_append(dom_body(), sp);

  /* === THE DECALITY SUMMARY === */
  let sd = make_section("800px") in
  render_h2(sd, "The Complete Organism");
  render_p(sd, "Ten steps. No assumptions. No free parameters. Starting from literally nothing (0/0), we derived six primes, one heartbeat (420), 108 rings sharing that heartbeat, and a gate (13) that wraps the whole thing in skin.");
  let primes = make_grid(sd, "8px") in
  render_prime(primes, "-1", "MIRROR", "n -> N-n", "#888");
  render_prime(primes, "0", "BIRTH", "0*n=0", "#555");
  render_prime(primes, "1", "GROUND", "sigma", "#ff6b6b");
  render_prime(primes, "2", "BRIDGE", "D", "#ffd700");
  render_prime(primes, "3", "CLOSURE", "K", "#ff9900");
  render_prime(primes, "5", "OBSERVER", "E", "#33dd55");
  render_prime(primes, "7", "DEPTH", "b", "#4488ff");
  render_prime(primes, "11", "PROTECTOR", "L", "#aa44ff");
  render_prime(primes, "13", "GATE", "skin", "#00cccc");
  render_prime(primes, "OMEGA", "TERMINAL", "D^420", "#fff");
  render_p(sd, "Sum of the 10 values: -1+0+1+2+3+5+7+11+13+OMEGA. The inner sum (without -1 and OMEGA): 42 = the answer. With -1: 41 = KEY. The Decality encodes itself.");
  dom_append(dom_body(), sd);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Cunningham Chain");
  render_p(sec_i, "Enter a seed number. Walk the Cunningham map c(n) = 2n+1. The axiom chains start at 1 and 2. Try both: c(1) = {1,3,7,15=STOP}. c(2) = {2,5,11,23...}.");
  make_interactive_widget(sec_i, "Seed:", "der-input", "e.g. 1", "Walk", "derive_cunningham_calc", "der-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST TABLE === */
  let sc = make_section("800px") in
  render_h2(sc, "Contrast");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "Question");
  render_th(chdr, "Standard Physics");
  render_th(chdr, "The Axiom");
  dom_append(ctbl, chdr);
  render_contrast_row(ctbl, "Where do the laws come from?", "Unknown / given", "Derived from 0/0");
  render_contrast_row(ctbl, "Why these constants?", "25+ free parameters", "0 free parameters");
  render_contrast_row(ctbl, "Why six primes?", "Not a question", "Gate closes at GATE=13 (self-terminating)");
  render_contrast_row(ctbl, "Why this universe?", "Anthropic principle / luck", "Only option from the void");
  render_contrast_row(ctbl, "How many rings?", "Infinite landscape / multiverse", "108 rings, one heartbeat (420)");
  render_contrast_row(ctbl, "What is nothing?", "Empty space + quantum fields", "0/0 = the entire ring");
  dom_append(sc, ctbl);
  dom_append(dom_body(), sc);

  /* === VERIFY === */
  let sv = make_section("800px") in
  render_h2(sv, "Verify It Yourself");
  render_p(sv, "Every formula on this page runs in .ax. Open the REPL, type the derivation, see the numbers. Break it. Rebuild it. The chain holds.");
  let cta = dom_create("div") in
  dom_style(cta, "textAlign", "center");
  dom_style(cta, "padding", "32px 0");
  let btn = dom_create("a") in
  dom_attr(btn, "href", "/repl");
  dom_text(btn, "Verify every step in the REPL");
  dom_style(btn, "display", "inline-block");
  dom_style(btn, "padding", "12px 36px");
  dom_style(btn, "border", "2px solid #ffd700");
  dom_style(btn, "color", "#ffd700");
  dom_style(btn, "borderRadius", "8px");
  dom_style(btn, "textDecoration", "none");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_append(cta, btn);
  dom_append(sv, cta);
  dom_append(dom_body(), sv)
)

