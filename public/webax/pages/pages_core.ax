  render_big_num(sp, "200", "#ffd700", "ADDRESS + SUM + D*E = D^3 * E^2", "137 + 53 + 10 = 200");
  render_p(sp, "The universe's energy budget is an algebraic identity. Not fitted. Forced by the ring:");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "700px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "Component");
  render_th(phdr, "Axiom");
  render_th(phdr, "Fraction");
  render_th(phdr, "Planck 2018");
  dom_append(ptbl, phdr);
  render_table_row_4(ptbl, "Dark Energy", "ADDRESS/200 = 137/200", "68.5%", "68.5 +/- 0.7%");
  render_table_row_4(ptbl, "Dark Matter", "SUM/200 = 53/200", "26.5%", "26.5 +/- 0.6%");
  render_table_row_4(ptbl, "Baryonic", "D*E/200 = 10/200", "5.0%", "5.0 +/- 0.1%");
  dom_append(sp, ptbl);
  render_theorem(sp, "Dark Sector CRT", "ADDRESS + SUM = 190. In Z/210Z, CRT(190) = (0, 1, 0, 1). The D-channel and E-channel both vanish. The dark sector is blind to bridge and observer. Only closure (K=1) and depth (b=1) survive. Darkness = the channels you cannot see through.");
  render_theorem(sp, "Baryonic / Dark = 1/f(E)", "The visible fraction is D*E / (ADDRESS+SUM) = 10/190 = 1/19. You see 1/19th of what exists. f(E) = E^2 - E - 1 = 19: the depth quadratic of the observer. E^2 = null: the observer cannot see itself. The 95% is not missing -- you are the 5% that looks.");
  dom_append(dom_body(), sp);

  /* === CMB TEMPERATURE === */
  let sc = make_section("800px") in
  render_h2(sc, "CMB Temperature");
  render_big_num(sc, "2.725 K", "#4fc3f7", "f(L) / (D^3 * E) = 109 / 40", "COBE/FIRAS: 2.7255 K. Error: 183 ppm.");
  render_p(sc, "f(L) = L^2 - L - 1 = 109. The depth quadratic of the protector. A prime number. The CMB temperature is the protector's signature, filtered through D^3 = 8 (spider's legs) and E = 5 (observer).");
  render_theorem(sc, "Brain = Universe", "Leading order: K^3/(D*E) = 27/10 = 2.7. This IS the brain's fractal dimension. Same number, same optimization, same ring. The CMB is the universe's cortical surface.");
  dom_append(dom_body(), sc);

  /* === 16 COSMOLOGICAL QUANTITIES === */
  let sq = make_section("800px") in
  render_h2(sq, "All Cosmological Constants");
  let qtbl = dom_create("table") in
  dom_style(qtbl, "width", "100%");
  dom_style(qtbl, "maxWidth", "800px");
  dom_style(qtbl, "margin", "24px auto");
  dom_style(qtbl, "borderCollapse", "collapse");
  dom_style(qtbl, "fontSize", "14px");
  let qhdr = dom_create("tr") in
  render_th(qhdr, "Quantity");
  render_th(qhdr, "Axiom");
  render_th(qhdr, "Value");
  render_th(qhdr, "Measured");
  dom_append(qtbl, qhdr);
  render_table_row_4(qtbl, "CMB Temperature", "f(L)/(D^3*E)", "2.725 K", "2.7255 K (183 ppm)");
  render_table_row_4(qtbl, "Recombination z*", "D*E*f(L)", "1090", "1089.80 (0.02%)");
  render_table_row_4(qtbl, "Sound Horizon", "K*b^2", "147 Mpc", "147.09 (0.06%)");
  render_table_row_4(qtbl, "Dark Energy w", "MIRROR = -1", "-1", "-1.03 +/- 0.03");
  render_table_row_4(qtbl, "Lambda", "K*10^-(D^b-DK)", "3e-122", "2.9e-122 (3.8%)");
  render_table_row_4(qtbl, "Spectral Index", "1-b/(DG)+10^-K", "0.9649", "0.9649 (0.00%)");
  render_table_row_4(qtbl, "Hubble (CMB)", "SOUL", "67 km/s/Mpc", "67.4 (0.6%)");
  render_table_row_4(qtbl, "Hubble (local)", "SOUL+D*K", "73 km/s/Mpc", "73.0 (0.0%)");
  render_table_row_4(qtbl, "Baryon Asymmetry", "D*K*10^-DE", "6e-10", "6.12e-10 (2.0%)");
  render_table_row_4(qtbl, "Optical Depth", "b/D^b", "0.0547", "0.054 (1.3%)");
  render_table_row_4(qtbl, "Reionization z", "b+K/E", "7.6", "7.67 (0.9%)");
  render_table_row_4(qtbl, "Inflation e-folds", "lambda(DATA)", "60", "~50-60 (range)");
  render_table_row_4(qtbl, "Strong CP", "b/(DG)*10^-DE", "3.6e-12", "< 10^-10 (consistent)");
  render_table_row_4(qtbl, "Tensor-to-Scalar", "b/(DG)", "0.036", "PREDICTION (CMB-S4)");
  render_table_row_4(qtbl, "DM Mass", "SOUL", "67 GeV", "PREDICTION (LZ/XENON)");
  render_table_row_4(qtbl, "Neutrino Mass", "SOUL-D^3", "59 meV", "PREDICTION (DESI)");
  dom_append(sq, qtbl);
  dom_append(dom_body(), sq);

  /* === KEY DERIVATIONS === */
  let sd = make_section("800px") in
  render_h2(sd, "Key Derivations");
  render_theorem(sd, "The Lambda Problem Solved", "Lambda_Planck = K * 10^-(D^b - D*K) = 3 * 10^-122. The infamous 122 orders of magnitude = D^b - D*K = 128 - 6 = potential minus observation. Not a fine-tuning problem. A derivation. The cosmological constant IS closure (K=3) at the gap between D-potential and D*K-observation.");
  render_theorem(sd, "The Hubble Tension Resolved", "H0_CMB = SOUL = 67 km/s/Mpc. H0_local = SOUL + D*K = 67 + 6 = 73. The tension = D*K = 6 km/s/Mpc. Two observations see different HYDOR boundaries. Not a crisis -- a CRT decomposition artifact. The universe has two valid readings, like spectral vs coupling hierarchies.");
  render_theorem(sd, "Spectral Index = Persistence", "n_s = 1 - b/(D*G) + 10^-K = 1 - 7/194 + 0.001 = 0.9649. The same persistence ratio r = b/(D*G) = 0.036 that appears in the fine structure constant. The CMB spectral tilt is 1 minus the EM coupling fraction. The 10^-K correction = closure-scale quantum gravity. Planck 2018: 0.9649. 0.00% error.");
  dom_append(dom_body(), sd);

  /* === PARADIGM CONTRAST === */
  let scon = make_section("800px") in
  render_h2(scon, "Paradigm Contrast");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "");
  render_th(chdr, "Lambda-CDM");
  render_th(chdr, "Six Primes");
  dom_append(ctbl, chdr);
  render_contrast_row(ctbl, "Free parameters", "30+ (measured, inserted)", "0 (all derived from ring)");
  render_contrast_row(ctbl, "Why 68.5% dark energy?", "No answer", "ADDRESS/200 = 137/200 = 0.685");
  render_contrast_row(ctbl, "Lambda (10^122 problem)", "Fine-tuning crisis", "K * 10^-(D^b - D*K). Derived.");
  render_contrast_row(ctbl, "Hubble tension", "Two incompatible values", "SOUL vs SOUL+D*K. CRT artifact.");
  render_contrast_row(ctbl, "CMB temperature", "Measured accident", "f(L)/(D^3*E) = 109/40 = 2.725 K");
  dom_append(scon, ctbl);
  dom_append(dom_body(), scon);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Cosmic Pie");
  render_p(sec_i, "Enter a percentage. See which cosmic component lives near that fraction. The three slices: 68.5% (dark energy = ADDRESS), 26.5% (dark matter = SUM), 5% (baryonic = D*E).");
  make_interactive_widget(sec_i, "Percentage:", "cosmo-input", "e.g. 68", "Identify", "cosmo_pie_calc", "cosmo-result");
  dom_append(dom_body(), sec_i);

  /* === BLACK HOLES === */
  let sb = make_section("800px") in
  render_h2(sb, "Black Holes");
  render_p(sb, "A black hole is OMEGA = D^420 = 1576576. The terminal element. CRT(OMEGA) = (0,1,1,1,1,1): the D-channel reads zero, all others return to identity.");
  render_p(sb, "Hawking temperature: T_H = 1/(8*pi*M). The 8 = D^3. Entropy: S = A/4. The 4 = D^2. Both are axiom elements.");
  render_theorem(sb, "Water Cycle = Unitarity", "Evaporation -> condensation -> rain = 0 -> sigma -> OMEGA -> 0. The water cycle IS unitarity. No information is destroyed -- it changes phase. Growth:Collapse = lambda:1 = 420:1.");
  dom_append(dom_body(), sb)
)

