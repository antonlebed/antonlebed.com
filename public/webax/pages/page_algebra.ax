  render_table_row_4(tbl, "E^2 = 25", "24", "D^3*K = Leech lattice dim", "Leech");
  render_table_row_4(tbl, "b^2 = 49", "48 = SEES", "phi(DATA) = sees itself", "--");
  render_table_row_4(tbl, "L = 11", "D*E = 10 = degree", "Degree of TRUE FORM", "--");
  render_p(sec, "Crossed ranks: p^e - 1 always gives an axiom quantity. Fattening creates exceptional Lie algebras: b = rank(E7), D^3 = rank(E8), 24 = Leech lattice dimension. Total roots: D*E*L*29 = 3190. Spectral variance: D*K*f(E) = 114. Pell(K) gives (G=97, 56): Lie rank sum and dim(E7 fundamental). G = pi(E^2) = the 25th prime.");
  dom_append(dom_body(), sec)
)

