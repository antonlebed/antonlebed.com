  dom_append(tbl, hdr);
  render_table_row(tbl, "D=2", "sigma = 1", "");
  render_table_row(tbl, "K=3", "D = 2", "");
  render_table_row(tbl, "E=5", "K = 3", "");
  render_table_row(tbl, "b=7", "D^2 = 4", "");
