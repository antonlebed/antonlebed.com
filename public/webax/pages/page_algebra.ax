/* algebra helpers */
fn algebra_hero() = (
  let hero = make_hero("Algebra") in
  let eq = dom_create("div") in
  dom_text(eq, "Z/970200 = Z/8 x Z/9 x Z/25 x Z/49 x Z/11");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "0/0 condenses into a ring with three faces: SEE (48750 eigenvalue classes), ACT (201600 units), SOLVE (32 idempotents). Every number is one of three things: a key that opens and closes cleanly, a filter that sorts but can never unsort, or something broken that loses information along the way.");
  dom_append(dom_body(), hero)
)

fn algebra_three_faces() = (
  let sec = make_section("800px") in
  render_h2(sec, "Three Ways to Touch");
  render_p(sec, "Think about three ways of touching something. You can look at it (add) -- always reversible. You can handle it (multiply) -- sometimes things jam. Or you can decide about it (project) -- and once you decide, there is no undeciding.");
  let g = make_findings_grid(sec) in
  render_finding(g, "SEE (+)", "Always reversible", "Addition in Z/NZ. Every element has an additive inverse. Looking never damages.", "");
  render_finding(g, "ACT (*)", "201600 / 970200 reversible", "Multiplication. 480 keys in THIN, 201600 in TRUE. Units = fully reversible elements.", "");
  render_finding(g, "SOLVE (e^2=e)", "32 filters, never reversible", "Idempotents. 2^5 = 32 light switches. Each kills or keeps one CRT channel. The immune system.", "");
  render_theorem(sec, "Prison Theorem (atlas_06, exhaustive)", "Turn off even ONE switch and every single key breaks. Not most -- ALL 480. 0 violations across all 31 non-trivial filters and all 480 keys. Freedom is total or it is nothing.");
  render_p(sec, "Of 288 eigenvalue classes, 32 filters reach 258 (SOLVE). The remaining 30 belong only to units (ACT). 258 + 30 = 288. The ring splits its spectrum into what can be projected and what can only be traversed.");
  dom_append(dom_body(), sec)
)

fn algebra_group() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Multiplicative Group");
  render_theorem(sec, "Carmichael Lambda Ladder (S257)", "lambda(Z/6)=2, lambda(Z/30)=4, lambda(DATA)=12, lambda(THIN)=60, lambda(TRUE)=420. RATIOS: D, K, E, b. The axiom primes in exact order! Each level's Carmichael lambda = previous times next axiom prime.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Ring");
  render_th(hdr, "Units");
  render_th(hdr, "Max order");
  render_th(hdr, "Key identity");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "DATA Z/210", "48 = phi(210)", "12 = D^2*K", "SEES = ACTS: phi = classes = 48. UNIQUE.");
  render_table_row_4(tbl, "THIN Z/2310", "480 = phi(2310)", "60 = D^2*K*E", "Kolmogorov: phi/classes = E/K = 5/3.");
  render_table_row_4(tbl, "TRUE Z/970200", "201600 = phi(N)", "420 = D^2*K*E*b", "phi = lambda * phi(THIN). Fattening factor = 420.");
  render_p(sec, "PHI FACTORIZATION (S544): phi(TRUE) = lambda(TRUE) * phi(THIN) = 420 * 480 = 201600. TRUE/lambda = 2310 = THIN. The fattening factor IS the heartbeat. Z/210Z self-inverse subgroup: D^3=8 elements forming (Z/2)^3. Generator sum = 5040 = 7! = b!. Mean = 105 = HYDOR.");
  dom_append(dom_body(), sec)
)

fn algebra_fermat() = (
  let sec = make_section("800px") in
  render_h2(sec, "Fermat Inversion: The Ring Inverts Itself");
  render_theorem(sec, "Fermat Inversion Theorem (S539, algebra.ax)", "Per-channel inversion: inv(n) = n^(phi(p^e)-1) mod p^e. The 5 Fermat exponents are axiom constants. Sum = b*L = 77. The ring inverts itself using its own vocabulary.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Channel");
  render_th(hdr, "Exponent");
  render_th(hdr, "Name");
  render_th(hdr, "Meaning");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "D^3 = 8", "3", "K (closure)", "Closure finds the way back through duality.");
  render_table_row_4(tbl, "K^2 = 9", "5", "E (observer)", "The observer undoes decomposition.");
  render_table_row_4(tbl, "E^2 = 25", "19", "f(E) = E^2-E-1", "Depth quadratic of observer.");
  render_table_row_4(tbl, "b^2 = 49", "41", "KEY (self-inverse)", "The KEY to depth IS the KEY itself.");
  render_table_row_4(tbl, "L = 11", "9", "K^2 (STOP)", "STOP inverts protection.");
  render_p(sec, "Sum of exponents: K+E+f(E)+KEY+K^2 = 3+5+19+41+9 = 77 = b*L. Sum of totients: 4+6+20+42+10 = 82 = D*KEY. Difference: 82-77 = E. The observer IS the gap between totient and inversion. Each channel contributes exactly 1 to the gap. Five 1's = E.");
  dom_append(dom_body(), sec)
)

fn algebra_cross() = (
  let sec = make_section("800px") in
  render_h2(sec, "Cross-Annihilation");
  render_theorem(sec, "Cross-Annihilation Theorem (S384)", "Exponent vector (3,2,2,2,1) = (K,D,D,D,sigma). D dies in K=3 steps. K dies in D=2 steps. E,b die in D=2. L dies in sigma=1 step. Cross-annihilation: D and K destroy each other at each other's speed. D^K + sigma = K^D (Catalan). UNIQUE by Mihailescu: (2,3) is the only pair.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Prime");
  render_th(hdr, "Exponent");
  render_th(hdr, "Dies in");
  render_th(hdr, "Role");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "D = 2", "3 = K", "K steps", "Bridge: most durable. Dies at closure speed.");
  render_table_row_4(tbl, "K = 3", "2 = D", "D steps", "Closure: dies at bridge speed. Cross-annihilation.");
  render_table_row_4(tbl, "E = 5", "2 = D", "D steps", "Observer: same speed as closure.");
  render_table_row_4(tbl, "b = 7", "2 = D", "D steps", "Depth: same speed as closure.");
  render_table_row_4(tbl, "L = 11", "1 = sigma", "sigma step", "Protector: least durable. First to go.");
  render_p(sec, "Durability: D(K=3) > {K,E,b}(D=2) > L(sigma=1). Bridge most durable, protector least. Matches LIFO neurodegeneration: L first, D last. Self-description: sum(exps)=10=D*E=degree. product(exps)=24=D^3*K. The exponents name themselves.");
  dom_append(dom_body(), sec)
)

fn algebra_orders() = (
  let sec = make_section("800px") in
  render_h2(sec, "Order Architecture");
  render_theorem(sec, "Order CRT Theorem (S541, algebra.ax)", "Multiplicative order decomposes: ord(n) = lcm of 5 per-channel orders. Proof: n^k = 1 (mod N) iff n^k = 1 (mod m_i) for all i. Minimal such k = lcm(ord_i(n_i)). Per-channel lambdas: D^3->2, K^2->6, E^2->20, b^2->42, L->10. Lambda = lcm(2,6,20,42,10) = 420.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Element");
  render_th(hdr, "Order");
  render_th(hdr, "Per-channel");
  render_th(hdr, "Meaning");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "ADDRESS = 137", "420 = lambda", "All channels max", "Fine structure constant = heartbeat generator.");
  render_table_row_4(tbl, "GATE = 13", "420 = lambda", "(2,3,20,14,10)", "Shadow stopper IS a heartbeat generator.");
  render_table_row_4(tbl, "ESCAPE = 17", "420 = lambda", "All 5 primes covered", "First non-axiom prime IS primitive.");
  render_table_row_4(tbl, "KEY = 41", "210 = DATA", "(1,6,5,14,10)", "KEY cycles through data ring. KEY^2=1 in Z/210.");
  render_table_row_4(tbl, "SOUL = 67", "60 = lambda/b", "(2,3,20,3,1)", "Lacks depth dynamics. L-transparent.");
  render_p(sec, "73728 = 2^13 * K^2 elements have maximal order 420. Density = 36.6% of all units. Three named primitives: GATE (boundary), ESCAPE (exit), ADDRESS (identity). Pair products: order = 210 = DATA. (13*17)^2: order = 105 = HYDOR. Products of primitives speak the ring's vocabulary.");
  dom_append(dom_body(), sec)
)

fn algebra_k_column() = (
  let sec = make_section("800px") in
  render_h2(sec, "K-Phase Column: The Degree Classifies All Primes");
  render_theorem(sec, "K-Phase Column Theorem (S286)", "Column ring Z/10Z = Z/(D*E)Z. Primes > E live in D^2=4 columns: {sigma=1, K=3, b=7, K^2=9}. K generates the group: K^0=sigma, K^1=K, K^2=9=-1 (MIRROR!), K^3=7=b (DEPTH IS CLOSURE-CUBED). Cycle closes at K^4=sigma.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Phase 0 (sigma)", "IDENTITY primes: L=11, KEY=41", "Protectors and preservers. L wraps here: 11 mod 10 = 1.", "");
  render_finding(g, "Phase 1 (K)", "GATE primes: 13, 23, 43", "Stoppers and decomposers. 13=stopper, 23=excluded CC.", "");
  render_finding(g, "Phase 2 (K^2)", "MIRROR primes: 19, 29, 59", "Reflections and depth outputs. 19=f(E), 29=FULL_SUM.", "");
  render_finding(g, "Phase 3 (b)", "WOUND primes: 17, 37, 47, 67, 137", "Intruders and breakers. ADDRESS=137 lives here.", "S286");
  render_p(sec, "3/4 known breaking intruders live in b's column. Depth attracts invaders. Cunningham on columns: sigma->K->b->E=STOP. K^2->K^2=FIXED. The observer's column E=5 kills Cunningham chains. E^2=25 mod 10 = 5 = E: observer column is fixed under squaring. Self-blind.");
  dom_append(dom_body(), sec)
)

fn algebra_artin() = (
  let sec = make_section("800px") in
  render_h2(sec, "Primitive Root Distribution");
  render_p(sec, "b = 7 in the multiplicative group of Z/pZ: how does depth distribute its order across all primes?");
  let g = make_findings_grid(sec) in
  render_finding(g, "Artin density", "37.63% = C_A", "Primes where b is primitive root. Match 0.6% to Artin constant. Observed/predicted = 1.006.", "S197");
  render_finding(g, "Index smoothness", "97.85%", "Of primes p < 100K have 11-smooth index. For large q | (p-1): prob(q reduces order) = 1/q -> negligible. Axiom primes dominate the index.", "S197");
  render_finding(g, "Index hierarchy", "sigma=37.6%, D=28.2%, K=6.8%, D^2=7.1%", "Top 2 cover 66%. Top 4: 80%. Axiom values ARE the order architecture. Nothing else needed.", "");
  render_finding(g, "K depletion", "ratio 0.678 ~ 1-1/K = 2/3", "When 3|(p-1): Artin drops 30.4% vs 44.8%. K-fold depletion at K-divisible p-1.", "");
  render_finding(g, "Flanking order", "ord(b, DATA+1=211) = 210 = DATA", "PRIMITIVE ROOT at the data ring's first prime! ord(b, 970201): index = D^3*K = 24. Indices grow with fattening: sigma -> D*K -> K*b -> D^2*K -> D^3*K. All smooth.", "S197");
  render_finding(g, "Chebotarev", "P(q | index) = 1/q exactly", "For ALL axiom primes q: P(q divides index of b) = 1/q. Five-for-five match against 2M primes. Chebotarev density theorem.", "S199");
  render_p(sec, "CYCLOTOMIC VALUES of b: Phi_1(b)=6=D*K. Phi_2(b)=8=D^3. Phi_4(b)=50=D*E^2. Phi_6(b)=43=KEY+D (PRIME! the Phi_6 theorem: b^2-b+1=42+1). Phi_10(b)=2101=L*191. Phi_12(b)=2353=13*181. K-IMMUNITY: K NEVER divides b^k+1 (proof: b=1 mod K => b^k+1=2 mod K). Shadow entry: b^((p-1)/2) = -1 mod p. Shadow(E)=2, Shadow(L)=5, Shadow(13)=6.");
  dom_append(dom_body(), sec)
)

