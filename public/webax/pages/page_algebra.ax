  dom_head_meta("description", "Z/970200 = Z/8 x Z/9 x Z/25 x Z/49 x Z/11. Three faces: SEE/ACT/SOLVE. Fermat exponents = axiom constants. Cross-annihilation Catalan-forced. Artin density 37.63%. D^3 subgroup trapping: v_2>=3 kills g=2, g=13 index=1. Axiom-open primes 1.54%, Stephens degree 32. CRT trace: E-multiplication, L-swap, L^2 triangle. Lie rank tower sum=G=97. 350+ tests.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Ring Algebra of Z/970200Z\",\"description\":\"The multiplicative group of Z/970200Z through three faces: SEE (eigenvalues), ACT (multiplication), SOLVE (idempotents). Fermat exponents, Artin density, D^3 subgroup trapping, CRT trace, Lie rank tower.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\",\"url\":\"https://antonlebed.com\"},\"url\":\"https://antonlebed.com/data/algebra\",\"isAccessibleForFree\":true,\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"Ring Theory\"},{\"@type\":\"DefinedTerm\",\"name\":\"Primitive Roots\"},{\"@type\":\"DefinedTerm\",\"name\":\"Lie Algebras\"}]}");
  algebra_hero();
