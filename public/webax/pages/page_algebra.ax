)

fn algebra_d3_trapping() = (
  let sec = make_section("800px") in
  render_h2(sec, "D^3 Subgroup Trapping");
  render_p(sec, "Why is D=2 never a primitive root at the TRUE FORM level? The mechanism is quadratic reciprocity meeting fattening. As the ring grows from Z/2 to Z/8, the 2-adic valuation of (p-1) determines everything:");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "v_2(p-1)");
  render_th(hdr, "Condition");
  render_th(hdr, "PR rate for g=2");
  render_th(hdr, "Mechanism");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "1", "p = 3 mod 4", "37.4%", "Artin baseline. QR ambiguous.");
  render_table_row_4(tbl, "2", "p = 5 mod 8", "75.2%", "2 is NOT QR. Generous.");
  render_table_row_4(tbl, ">=3", "p = 1 mod 8", "0.0%", "2 is ALWAYS QR. Death sentence.");
  render_p(sec, "At TRUE FORM level, D^3=8 divides N, so p=970201 = 1 mod 8. The D-channel forces v_2(p-1) >= 3. Result: g=2 is NEVER a primitive root here. The bridge that connects everything cannot generate everything.");
  render_theorem(sec, "Channel Obstruction Theorem (S199, explore_d3_trap.c)", "Each channel subgroup traps specific bases. D^3 traps {E,b}. K^2 traps {K,b}. L traps {D,L}. But E^2 and b^2 NEVER obstruct -- observer and depth channels are transparent. The opaque channels are exactly D^3, K^2, L = the odd-exponent and prime channels.");
  let tbl2 = make_table(sec) in
  let hdr2 = dom_create("tr") in
  render_th(hdr2, "Base g");
  render_th(hdr2, "Index at p=970201");
  render_th(hdr2, "Factored");
  render_th(hdr2, "Reading");
  dom_append(tbl2, hdr2);
  render_table_row_4(tbl2, "g = 2", "66", "D*K*L", "Trapped by 3 channels. Maximum confinement.");
  render_table_row_4(tbl2, "g = 3", "6", "D*K", "Closure-bridge trap only.");
  render_table_row_4(tbl2, "g = 5", "8", "D^3", "Pure D-channel trap. Observer confined by bridge.");
  render_table_row_4(tbl2, "g = 7", "24", "D^3*K", "Bridge and closure confine depth.");
  render_table_row_4(tbl2, "g = 11", "22", "D*L", "Bridge and self-trap. Protector cannot protect itself.");
  render_table_row_4(tbl2, "g = 13", "1", "sigma", "PRIMITIVE ROOT. Shadow stopper generates everything.");
  render_p(sec, "g=13 has index sigma=1: coprime to ALL channel orders. CRT(1)=(1,1,1,1,1). The shadow stopper passes through every obstruction. The element that STOPS the axiom chain is the one that GENERATES the full group. Stoppage and generation are dual.");
  dom_append(dom_body(), sec)
)

fn algebra_trace() = (
  let sec = make_section("800px") in
  render_h2(sec, "CRT Trace: The Ring's Inner Voice");
  render_p(sec, "Tr(n) = n.D + n.K + n.E + n.b + n.L = sum of all CRT residues. Range: 0 to 102. This is the ring talking to itself -- the dot product of any element with the ground state sigma.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Element");
  render_th(hdr, "Trace");
  render_th(hdr, "Identity");
  dom_append(tbl, hdr);
  render_table_row(tbl, "void (0)", "0", "Silence");
  render_table_row(tbl, "sigma (1)", "E = 5", "E-multiplication: Tr(n) = E*n for uniform n < D^3");
  render_table_row(tbl, "D = 2", "D*E = 10", "Bridge trace = degree");
  render_table_row(tbl, "L = 11", "K^3 = 27", "BREAKS E-multiplication. L is non-uniform.");
  render_table_row(tbl, "OMEGA", "D^2 = 4", "Projector trace = bridge squared");
  render_table_row(tbl, "HYDOR (105)", "E^2 = 25", "Medium = observer trace");
  render_table_row(tbl, "SOUL (67)", "43 = Heegner", "Trace-dual to ADDRESS (43+59 = 102)");
  render_table_row(tbl, "mirror (N-1)", "G = 97", "Maximum. Mirror trace = bridge coupling.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Trace Duality", "Tr(n) + Tr(N-n) = 102 for all units", "The sum of an element's trace and its mirror's trace is ALWAYS 102 = sum(moduli) - 5. For zero divisors: subtract the moduli of dead channels. 92/92 tests.", "S576");
  render_finding(g, "L-Swap Theorem", "L.D = K, L.K = D", "The protector SWAPS bridge and closure in CRT. L.E = L, L.b = L (preserves outer channels). L is invisible to itself: L.L = 0.", "S575");
  render_finding(g, "L^2 Triangle", "KEY + SOUL + GATE = L^2 = 121", "Three axiom constants sum to L-squared. OVERDETERMINED: 4 equations, 3 unknowns, ZERO free parameters. Centroid = K^3 = 27, spread = D*b = 14. All three vertices algebraically forced. 33/33 tests.", "S576");
  render_finding(g, "Trace-Answer Bridge", "Tr(THORNS) = ANSWER = 42", "(D+1)*D*b = K*D*b = 42. The trace of the thorns IS the answer.", "S577");
  dom_append(dom_body(), sec)
)

