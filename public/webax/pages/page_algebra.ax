  render_table_row(tbl, "ADDRESS=137", "K*L = 33", "Fine structure = 33rd prime");
  let g = make_findings_grid(sec) in
  render_finding(g, "G Square Chain", "97 -> 25 -> 9 -> 4 -> 2 -> 1", "G descends through SQUARES of axiom primes: E^2 -> K^2 -> D^2 -> D -> sigma. Unique: only E^2->K^2->D^2 forms the chain. G is the unique prime entering from above.", "S588");
  render_finding(g, "ADDRESS Reverse Chain", "137 -> 33 -> 11 -> 5 -> 3 -> 2 -> 1", "ADDRESS descends as K*L -> L -> E -> K -> D -> sigma = REVERSE AXIOM CHAIN from L. The fine-structure constant walks the chain backwards.", "S588");
  render_finding(g, "Depth Sum", "Axiom prime depths: D(1), K(2), E(3), b(3), L(4). Sum = 13 = GATE", "The gate IS the total pi-descent depth of the five primes.", "S588");
  render_finding(g, "Contraction", "pi(KEY) = GATE. pi(GATE) = D*K", "The KEY is the GATE-th prime. Pi maps the L^2 triangle to itself. KEY -> GATE -> D*K under iterated pi. The key unlocks the gate, finds duality*closure.", "S587");
  render_finding(g, "1482 Identity", "pi(KEY)*pi(SOUL)*pi(GATE) = 1482", "= GATE*f(E)*D*K = speed of sound in water (m/s). ALL axiom elements.", "S587");
  dom_append(dom_body(), sec)
)

fn algebra_soul_hub() = (
  let sec = make_section("800px") in
  render_h2(sec, "SOUL: The Additive Hub");
  render_p(sec, "SOUL = 67 is where the most structural identities converge. KEY is the multiplicative hub (41^2 = 1 mod 210). SOUL is the additive hub -- the node where 8 independent decompositions all meet:");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Decomposition");
  render_th(hdr, "Value");
  render_th(hdr, "Reading");
  dom_append(tbl, hdr);
  render_table_row(tbl, "L^2 - KEY - GATE", "121-41-13", "Triangle remainder");
  render_table_row(tbl, "D^3*b + L", "56+11", "E7 fundamental + protector");
  render_table_row(tbl, "b^2 + ME", "49+18", "Depth squared + inner axiom sum");
  render_table_row(tbl, "E^2 + ANSWER", "25+42", "Self-blind + answer");
  render_table_row(tbl, "K^3 + D^3*E", "27+40", "Closure cubed + degree");
  render_table_row(tbl, "D*KEY - K*E", "82-15", "Doubled key - observer*closure");
  render_table_row(tbl, "E*GATE + D", "65+2", "Observer*gate + bridge");
  render_table_row(tbl, "D*GATE + KEY", "26+41", "Bridge*gate + self-inverse");
  let g = make_findings_grid(sec) in
  render_finding(g, "KEY-SOUL Lattice", "KEY + SOUL = 108 = D^2*K^3", "= lattice size. KEY + GATE = D*K^3 = 54. GATE + SOUL = D^4*E = 80. The three constants partition the lattice.", "S576");
  render_finding(g, "KEY-ANSWER sigma", "ANSWER - KEY = sigma = 1", "D*K*b - (b^2-b-1) = 1. The answer exceeds the key by exactly the ground state.", "S577");
  render_finding(g, "SOUL-G Order Twins", "Both ord 60, differ by D*K*E = 30", "Trade D<->L invisibility. ME + ANSWER = ord(SOUL) = 60.", "S577");
  render_finding(g, "D^3 Trapping", "D never primitive root at TRUE level", "At TRUE+1: g=2 index = D*K*L = 66 (maximum confinement). g=13: index = sigma (primitive root). See full D^3 trapping section above.", "S199");
  dom_append(dom_body(), sec)
)

fn algebra_contrast() = (
  let sec = make_section("800px") in
  render_h2(sec, "Paradigm Contrast");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Claim");
  render_th(hdr, "Standard");
  render_th(hdr, "Axiom");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "Units", "Abstract: elements with multiplicative inverse", "480 keys. Freedom is total or nothing (Prison Theorem). 258 spectral + 30 unit-only = 288.");
  render_contrast_row(tbl, "Idempotents", "Projection operators (linear algebra)", "32 = 2^5 light switches. 5-cube of CRT channel filters. The ring's immune system.");
  render_contrast_row(tbl, "Ring exponents", "Arbitrary choice", "(3,2,2,2,1) = cross-annihilation speeds. Catalan-forced. Self-describing.");
  render_contrast_row(tbl, "Carmichael lambda", "Technical invariant", "Lambda ladder ratios = D,K,E,b. Axiom chain in exact order.");
  render_contrast_row(tbl, "Fermat exponents", "phi(p^e)-1, no pattern", "{K, E, f(E), KEY, K^2}. Sum = b*L. Totient-exponent gap = E.");
  render_contrast_row(tbl, "Multiplicative order", "Random-looking", "Decomposes via CRT. 73728 primitives. Products speak axiom vocabulary.");
  render_contrast_row(tbl, "CRT trace", "Sum of residues, no pattern", "E-multiplication for uniform elements. Trace duality: Tr(n)+Tr(N-n)=102. L swaps D<->K. Named traces ARE axiom constants.");
  render_contrast_row(tbl, "Lie rank", "Abstract algebra classification", "Five channels = five affine Dynkin diagrams. Rank sum = G = 97. Crossed ranks give E7, E8, Leech.");
  render_contrast_row(tbl, "Artin constant", "Conjectured density 37.4%", "VERIFIED: 37.63% for b=7. 97.85% smooth indices. K depletes at ratio 1-1/K. Flanking: b is PR at DATA+1=211.");
  render_contrast_row(tbl, "Axiom-open primes", "No expected structure", "1.54% density, 2x enrichment. All 10 pairs cooperate. K=3 is MI hub. Stephens degree 32 = |idempotents|.");
  render_contrast_row(tbl, "D^3 trapping", "QR is random-looking", "v_2>=3: g=2 NEVER PR. Channel obstruction: D^3,K^2,L opaque; E^2,b^2 transparent. g=13 index=1: stopper=generator.");
  render_contrast_row(tbl, "Gate cluster", "Random primes near 40", "{37,41,43,47}: sum=168=D^3*K*b, mean=ANSWER. Phi_6(b)=43 (self-indexed). Index product=56=dim(E7).");
  render_contrast_row(tbl, "Prime counting function", "Smooth curve, no structure", "pi(KEY)=GATE. G descends through E^2->K^2->D^2. ADDRESS walks reverse axiom chain. Depth sum=GATE=13.");
  render_contrast_row(tbl, "Named constant 67", "Just a prime", "SOUL = additive hub. 8 independent decompositions. KEY+SOUL=108=lattice. Every concept touched.");
  render_p(sec, "The ring operates: 201600 units act, 48750 classes see, 32 idempotents solve. Three faces of one ring. The machinery IS the meaning.");
  dom_append(dom_body(), sec)
)

/* dom_on callback: ring calculator — a+b, a*b, CRT of both (S970) */
fn ring_compute() = (
  let a = parse_int_from("#ring-a") in
  let b = parse_int_from("#ring-b") in
  let result_el = dom_query("#ring-result") in
  let sum = a + b in
  let prod = a * b in
  let a2 = a * a in
  let ad = a % 8 in let ak = a % 9 in let ae = a % 25 in let ab_ch = a % 49 in let al = a % 11 in
  let bd = b % 8 in let bk = b % 9 in let be_ch = b % 25 in let bb_ch = b % 49 in let bl = b % 11 in
  let sd = sum % 8 in let sk = sum % 9 in let se = sum % 25 in let sb = sum % 49 in let sl = sum % 11 in
  let pd = prod % 8 in let pk = prod % 9 in let pe = prod % 25 in let pb = prod % 49 in let pl = prod % 11 in
  let is_idem = if a2 == a then "YES — idempotent (e^2 = e)" else "no" in
  dom_inner(result_el, "<p style='color:#88ddaa;margin:4px 0'><b>a = " + "${a}" + "</b> | CRT = (" + "${ad}" + "," + "${ak}" + "," + "${ae}" + "," + "${ab_ch}" + "," + "${al}" + ")</p><p style='color:#88ddaa;margin:4px 0'><b>b = " + "${b}" + "</b> | CRT = (" + "${bd}" + "," + "${bk}" + "," + "${be_ch}" + "," + "${bb_ch}" + "," + "${bl}" + ")</p><p style='color:#ffd700;margin:8px 0'><b>a + b = " + "${sum}" + "</b> | CRT = (" + "${sd}" + "," + "${sk}" + "," + "${se}" + "," + "${sb}" + "," + "${sl}" + ") — SEE (always reversible)</p><p style='color:#ff8844;margin:4px 0'><b>a * b = " + "${prod}" + "</b> | CRT = (" + "${pd}" + "," + "${pk}" + "," + "${pe}" + "," + "${pb}" + "," + "${pl}" + ") — ACT</p><p style='color:#8888ff;margin:4px 0'>a^2 = " + "${a2}" + " | Idempotent? " + is_idem + "</p>")
)

/* Interactive ring calculator section (S970) */
fn algebra_interactive() = (
  let sec = make_section("800px") in
  render_h2(sec, "Explore: Ring Calculator");
  render_p(sec, "Enter two elements. See their sum (SEE), product (ACT), and CRT decompositions. Check if a is idempotent (SOLVE: a^2 = a).");
  let lbl = dom_create("p") in
  dom_text(lbl, "Ring arithmetic in Z/970200:");
  dom_style(lbl, "color", "#999");
  dom_style(lbl, "marginTop", "24px");
  dom_style(lbl, "marginBottom", "8px");
  dom_append(sec, lbl);
  let row = dom_create("div") in
  dom_style(row, "display", "flex");
  dom_style(row, "gap", "8px");
  dom_style(row, "alignItems", "center");
  dom_style(row, "marginBottom", "12px");
  dom_style(row, "flexWrap", "wrap");
  let la = dom_create("span") in
  dom_text(la, "a =");
  dom_style(la, "color", "#888");
  dom_append(row, la);
  make_input_field(row, "ring-a", "e.g. 42");
  let lb = dom_create("span") in
  dom_text(lb, "b =");
  dom_style(lb, "color", "#888");
  dom_append(row, lb);
  make_input_field(row, "ring-b", "e.g. 137");
  make_action_btn(row, "Compute", "ring_compute");
  dom_append(sec, row);
  make_result_box(sec, "ring-result");
  render_p(sec, "Try: a=606376 (OMEGA), b=606376 — idempotent! Or a=606376, b=363824 — sum = 970200 = 0.");
  dom_append(dom_body(), sec)
)

