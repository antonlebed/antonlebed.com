fn coup_hero() = (
  dom_head_meta("description", "The coupling heatmap. 32 = D^5 classes of Z/2310Z. Four views: coupling strength, prime structure, eigenvalue spectrum, CRT channels. Six kingdoms from the ring's chemistry.");
  let hero = make_hero("The Coupling Heatmap") in
  let eq = dom_create("div") in
  dom_text(eq, "coupling(n) = |{m : gcd(n,N) = gcd(m,N)}|");
  ct_mono(eq);
  dom_style(eq, "fontSize", "18px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "20px");
  dom_append(hero, eq);
  render_p(hero, "Every element of Z/2310Z belongs to exactly one of 32 = D^5 coupling classes. Elements in the same class share the same gcd with N, the same kingdom, the same CRT signature pattern. The heatmap reveals the ring's anatomy through four different lenses.");
  dom_append(dom_body(), hero)
)

fn coup_classes() = (
  let sec = make_section("800px") in
  render_h2(sec, "32 = D^5 Coupling Classes");
  render_theorem(sec, "The Classification Theorem", "Z/2310Z has exactly 32 = 2^5 distinct coupling classes. Why 2^5? Each of the 5 primes is either present or absent in gcd(n,N). Five binary choices = 32 classes. This is the CRT decomposition at work. Each class groups elements with identical structural identity.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Class");
  render_th(hdr, "Count");
  render_th(hdr, "Coupling");
  render_th(hdr, "Kingdom");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "Units (gcd=1)", "480", "2310 (max)", "sigma (bacteria)");
  render_table_row_4(tbl, "D-pure (2|n)", "420", "1155", "D (protista)");
  render_table_row_4(tbl, "K-pure (3|n)", "280", "770", "K (fungi)");
  render_table_row_4(tbl, "E-pure (5|n)", "168", "462", "E (plantae)");
  render_table_row_4(tbl, "b-pure (7|n)", "120", "330", "b (animalia)");
  render_table_row_4(tbl, "L-pure (11|n)", "44100", "210", "L (humanity)");
  render_table_row_4(tbl, "D*K (6|n)", "210", "462", "DK compound");
  render_table_row_4(tbl, "D*E (10|n)", "126", "231", "DE compound");
  render_table_row_4(tbl, "D*b (14|n)", "90", "165", "Db compound");
  render_table_row_4(tbl, "K*E (15|n)", "84", "154", "KE compound");
  render_table_row_4(tbl, "K*b (21|n)", "60", "110", "Kb compound");
  render_table_row_4(tbl, "E*b (35|n)", "36", "66", "Eb compound");
  render_table_row_4(tbl, "Void (0)", "1", "0", "void");
  dom_append(dom_body(), sec)
)

fn coup_kingdoms() = (
  let sec = make_section("800px") in
  render_h2(sec, "Six Kingdoms");
  render_p(sec, "Every element belongs to a kingdom determined by its smallest prime factor. Kingdoms are biological: units = bacteria (most numerous, simplest), through to L-pure = humanity (rarest, most protected). The ring IS a biosphere.");
  let g = make_findings_grid(sec) in
  render_finding(g, "sigma (bacteria)", "phi(N) = 480 units", "Most numerous. Coprime to everything. Maximum coupling. The ground state of the ring.", "");
  render_finding(g, "D (protista)", "420 elements", "D divides them. First kingdom of zero divisors. Bridge organisms. Coupling = N/D.", "");
  render_finding(g, "K (fungi)", "280 elements", "K divides them. Decomposers. Coupling = N/K.", "");
  render_finding(g, "E (plantae)", "168 elements", "E divides them. Observers. Coupling = N/E.", "");
  render_finding(g, "b (animalia)", "120 elements", "b divides them. Depth dwellers. Coupling = N/b.", "");
  render_finding(g, "L (humanity)", "Rarest pure kingdom", "L divides them. Protected. Coupling = DATA = 210.", "");
  dom_append(dom_body(), sec)
)

