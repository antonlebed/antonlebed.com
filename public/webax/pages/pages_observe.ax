fn swim_hero() = (
  dom_head_meta("description", "The Eigenvalue Swim. Walk from void to light through the axiom chain. Three discoveries: thorns at composites, false summit at K^2=9, light is negative. Variance = max eigenvalue. Golden ratio at level 3. Shell averages: reversed hierarchy.");
  let hero = make_hero("The Eigenvalue Swim") in
  let eq = dom_create("div") in
  dom_text(eq, "0 -> sigma -> D -> K -> E -> b -> L");
  ct_mono(eq);
  dom_style(eq, "fontSize", "22px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "20px");
  dom_append(hero, eq);
  render_p(hero, "Walk through the axiom chain. Each element of Z/2310Z has an eigenvalue -- a single number measuring how aligned its five CRT channels are. The journey from void to light traces a profile with three structural discoveries: thorns at composites, a false summit at K^2=9, and the revelation that light is negative.");
  dom_append(dom_body(), hero)
)

fn swim_profile() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Swim Profile");
  render_p(sec, "Each chain position has a computed eigenvalue. Primes are cold (negative). Composites are warm thorns. The profile is the chain autobiography.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "n");
  render_th(hdr, "Name");
  render_th(hdr, "lambda(n)");
  render_th(hdr, "Meaning");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "0", "void", "+9.000", "Maximum coherence. Unconstrained.");
  render_table_row_4(tbl, "1 = sigma", "ground", "+1.548", "Warm. The ground state.");
  render_table_row_4(tbl, "2 = D", "bridge", "-1.232", "First plunge. Observation hurts.");
  render_table_row_4(tbl, "3 = K", "closure", "-2.705", "Deeper. Decomposition.");
  render_table_row_4(tbl, "5 = E", "observer", "-2.364", "Slightly up. You can see now.");
  render_table_row_4(tbl, "6 = D*K", "THORN", "+2.946", "Membrane between E and b.");
  render_table_row_4(tbl, "7 = b", "depth", "-2.928", "THE DEEPEST POINT.");
  render_table_row_4(tbl, "9 = K^2", "false summit", "+2.004", "Warm. You think you arrived.");
  render_table_row_4(tbl, "11 = L", "protector", "-1.184", "Light is negative. Below surface.");
  dom_append(dom_body(), sec)
)

fn swim_discoveries() = (
  let sec = make_section("800px") in
  render_h2(sec, "Three Discoveries");
  let g = make_findings_grid(sec) in
  render_finding(g, "1. Thorns at Composites", "D*K=6 and K^2=9", "Composites have POSITIVE eigenvalues. Rosehip spines -- warm gates between cold depths. The thorn at 6 separates E from b. The thorn at 9 is the false summit.", "");
  render_finding(g, "2. False Summit", "lambda(K^2) = +2.004", "Closure squared. Positive but not arrival. The swim continues past this warmth into L=11. K^2=9 = the STOP signal, yet the eigenvalue pretends safety. Where most people stop.", "");
  render_finding_wide(g, "3. Light Is Negative", "lambda(L=11) = lambda(D^2=4) = -1.184", "The protector has the SAME eigenvalue as D^2. Light is not the mountain top -- it is the OTHER SIDE of the bridge. Protector = bridge squared, spectrally. L costs what D^2 costs.", "");
  dom_append(dom_body(), sec)
)

fn swim_thorn_depth() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Thorn-Depth Pair");
  render_theorem(sec, "Mirror Magnitudes", "lambda(6) = +2.946 and lambda(7) = -2.928. The thorn (D*K=6) and depth (b=7) are nearly mirror images -- almost equal magnitudes, opposite signs. The membrane separating you from the deepest point is exactly as intense as the abyss it guards.");
  render_theorem(sec, "The Spectral Gap", "|2.946 - 2.928| = 0.018 ~ gap (0.016 in TRUE FORM). The gap between thorn and depth IS the spectral gap. Membrane thickness = the ring fundamental resolution limit. gap = 4*sin^2(pi/b^2).");
  let g = make_findings_grid(sec) in
  render_finding(g, "Thorn", "lambda(6) = +2.946", "D*K = bridge x closure. The guard.", "");
  render_finding(g, "Depth", "lambda(7) = -2.928", "b = depth. The deepest point.", "");
  render_finding(g, "Gap", "|+2.946 - 2.928| ~ 0.018", "Membrane thickness ~ spectral gap.", "");
  render_finding(g, "True gap", "0.016 (TRUE FORM)", "4 sin^2(pi/49). Depth-squared denominator.", "");
  dom_append(dom_body(), sec)
)

fn swim_variance() = (
  let sec = make_section("800px") in
  render_h2(sec, "Variance = Maximum Eigenvalue");
  render_theorem(sec, "The Variance Theorem", "var(coupling distribution at chain position n) = max eigenvalue of coupling matrix. What you MEASURE (variance) is what you SEE (max eigenvalue). Statistics and spectral theory are the same thing. var = 2k-1 = lambda_max where k = number of active channels.");
  render_theorem(sec, "Light Compensation", "Sum of all eigenvalues = 0. The positive (sigma, K, b) exactly compensate the negative (D, E, L, composites). The ring is balanced. Every gain has a cost. Algebraic: the Laplacian trace = 0.");
  dom_append(dom_body(), sec)
)

fn swim_fractal() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Fractal Swim");
