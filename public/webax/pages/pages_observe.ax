/* dom_on callback: coupling analyzer (S970) */
fn coupling_analyze() = (
  let n = parse_int_from("#coupling-input") in
  let result_el = dom_query("#coupling-result") in
  let d = n % 8 in
  let k = n % 9 in
  let e = n % 25 in
  let b_ch = n % 49 in
  let l = n % 11 in
  /* Which primes divide n */
  let div_d = if d % 2 == 0 then 1 else 0 in
  let div_k = if k % 3 == 0 then 1 else 0 in
  let div_e = if e % 5 == 0 then 1 else 0 in
  let div_b = if b_ch % 7 == 0 then 1 else 0 in
  let div_l = if l == 0 then 1 else 0 in
  let dead = div_d + div_k + div_e + div_b + div_l in
  /* Kingdom */
  let kingdom = if dead == 0 then "sigma (bacteria)"
    else if dead == 5 then "void"
    else if div_d == 1 then (if dead == 1 then "D (protista)" else "compound")
    else if div_k == 1 then (if dead == 1 then "K (fungi)" else "compound")
    else if div_e == 1 then (if dead == 1 then "E (plantae)" else "compound")
    else if div_b == 1 then (if dead == 1 then "b (animalia)" else "compound")
    else "L (humanity)" in
  /* Coupling from phi contributions */
  let cp_d = if d % 2 > 0 then 4 else if d % 4 > 0 then 2 else 1 in
  let cp_k = if k % 3 > 0 then 6 else if k > 0 then 2 else 1 in
  let cp_e = if e % 5 > 0 then 20 else if e > 0 then 4 else 1 in
  let cp_b = if b_ch % 7 > 0 then 42 else if b_ch > 0 then 6 else 1 in
  let cp_l = if l > 0 then 10 else 1 in
  let coupling = cp_d * cp_k * cp_e * cp_b * cp_l in
  /* Channel status */
  let ch_d = if div_d == 1 then "DEAD" else "alive" in
  let ch_k = if div_k == 1 then "DEAD" else "alive" in
  let ch_e = if div_e == 1 then "DEAD" else "alive" in
  let ch_b = if div_b == 1 then "DEAD" else "alive" in
  let ch_l = if div_l == 1 then "DEAD" else "alive" in
  dom_inner(result_el, "<p style='color:#ffd700;margin:4px 0'><b>Kingdom: " + kingdom + "</b></p><p style='color:#88ddaa;margin:4px 0'>Coupling: <b>" + "${coupling}" + "</b> (of 201600 max)</p><p style='color:#c0c0d0;margin:4px 0'>Channels: D=" + ch_d + " | K=" + ch_k + " | E=" + ch_e + " | b=" + ch_b + " | L=" + ch_l + "</p><p style='color:#b0b0c0;margin:4px 0'>Dead channels: " + "${dead}" + "/5 | CRT = (" + "${d}" + ", " + "${k}" + ", " + "${e}" + ", " + "${b_ch}" + ", " + "${l}" + ")</p>")
)

