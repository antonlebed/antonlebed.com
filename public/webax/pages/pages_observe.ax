/* pages_observe.ax — OBSERVE: explorer + interactive pages.
   Z/30Z. You can SEE the structure. 9 pages + ecc_live.
   eigenvalue_swim split to page_swim.ax (S989). */
/* ================================================================
   EXPLORER / INTERACTIVE PAGES — 10 pages (108/108)
   dom_on + dom_value LIVE (S966-S970). Interactive widgets on:
   crt_anatomy, coupling, ecc_live, eigenvalue_swim. Shared helpers in core.ax.
   S999: +emergence MAJ vote, +omega_emergence kingdom, +omega_watercycle D^k.
   ================================================================ */

/* dom_on callback: K=3 majority vote (emergence page, S999) */
fn emergence_maj_calc() = (
  let a = parse_int_from("#emrg-input-a") in
  let result = dom_query("#emrg-result") in
  let b = parse_int_from("#emrg-input-b") in
  let c = parse_int_from("#emrg-input-c") in
  /* AND = sigma, XOR = D, MAJ = K */
  let v_and = a * b * c in
  let v_xor = ((a + b + c) - 2 * (a * b) - 2 * (a * c) - 2 * (b * c) + 4 * (a * b * c)) in
  /* MAJ(a,b,c) = ab + ac + bc - 2abc for bits */
  let ab = a * b in
  let ac = a * c in
  let bc = b * c in
  let v_maj = ab + ac + bc - 2 * (a * b * c) in
  /* For bits: clamp to 0/1 */
  let ca = if a > 0 then 1 else 0 in
  let cb = if b > 0 then 1 else 0 in
  let cc = if c > 0 then 1 else 0 in
  let s = ca + cb + cc in
  let maj = if s >= 2 then 1 else 0 in
  let band = if ca == 1 then (if cb == 1 then (if cc == 1 then 1 else 0) else 0) else 0 in
  let bxor = (ca + cb + cc) % 2 in
  dom_inner(result, "<p style='color:#f0c040;margin:8px 0'>Inputs: " + "${ca}" + ", " + "${cb}" + ", " + "${cc}" + "</p><p style='color:#88ddaa;margin:4px 0'>AND (sigma): " + "${band}" + " — persistence. What survives AND survives.</p><p style='color:#88ddaa;margin:4px 0'>XOR (D): " + "${bxor}" + " — distinction. Parity. Bridge.</p><p style='color:#88ddaa;margin:4px 0'>MAJ (K): " + "${maj}" + " — closure. " + (if s == 3 then "Unanimous." else if s == 2 then "2-vs-1: majority decides." else if s == 1 then "1-vs-2: minority overruled." else "All zero. Void.") + "</p><p style='color:#a0a0b0;margin:4px 0'>LIFE = 7 = all three on (AND=1, XOR=1, MAJ=1). Try 1,1,1.</p>")
)

/* dom_on callback: omega_emergence kingdom classifier (S999) */
fn omega_em_kingdom_calc() = (
  let n = parse_int_from("#omem-input") in
  let result = dom_query("#omem-result") in
  let big_n = 970200 in
  let n2 = n % big_n in
  let nd = n2 % 8 in
  let nk = n2 % 9 in
  let ne = n2 % 25 in
  let nb = n2 % 49 in
  let nl = n2 % 11 in
  let kingdom = if nd == 0 then (if nk == 0 then (if ne == 0 then (if nb == 0 then (if nl == 0 then "void (0)" else "L-only") else "multi-zero") else "multi-zero") else "multi-zero") else (if nk == 0 then "K-dead (green)" else if ne == 0 then "E-dead (blue)" else if nb == 0 then "b-dead (purple)" else if nl == 0 then "L-dead (cyan)" else "sigma (gold — UNIT)") in
  let kingdom2 = if nd == 0 then "D-dead (red)" else kingdom in
  let is_unit = if nd > 0 then (if nk > 0 then (if ne > 0 then (if nb > 0 then (if nl > 0 then 1 else 0) else 0) else 0) else 0) else 0 in
  dom_inner(result, "<p style='color:#88ddaa;margin:8px 0'>n = " + "${n2}" + " mod 970200</p><p style='color:#88ddaa;margin:4px 0'>CRT = (" + "${nd}" + ", " + "${nk}" + ", " + "${ne}" + ", " + "${nb}" + ", " + "${nl}" + ")</p><p style='color:" + (if is_unit == 1 then "#ffd700" else "#ff6666") + ";margin:4px 0'>Kingdom: " + kingdom2 + "</p><p style='color:#a0a0b0;margin:4px 0'>" + (if is_unit == 1 then "Unit: all channels alive. Thrives." else "Zero divisor: at least one dead channel. Drains.") + "</p>")
)

/* dom_on callback: omega_watercycle D^k step (S999) */
fn watercycle_dk_calc() = (
  let k = parse_int_from("#owc-input") in
  let result = dom_query("#owc-result") in
  if k < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter k >= 0.</p>")
  else (
    /* compute D^k mod each channel */
    mut pd = 1;
    mut pk = 1;
    mut pe = 1;
    mut pb = 1;
    mut pl = 1;
    mut i = 0;
    while i < k do (
      mut pd = (pd * 2) % 8;
      mut pk = (pk * 2) % 9;
      mut pe = (pe * 2) % 25;
      mut pb = (pb * 2) % 49;
      mut pl = (pl * 2) % 11;
      mut i = i + 1
    );
    let note = if k == 0 then "D^0 = sigma. Starting point."
      else if k == 3 then "D^3 = 8. D-channel DIES (8 mod 8 = 0). First sub-return."
      else if k == 6 then "D^6 = 64. K returns home (64 mod 9 = 1)."
      else if k == 10 then "D^10. L returns home (1024 mod 11 = 1)."
      else if k == 20 then "D^20. E returns home (mod 25 = 1)."
      else if k == 21 then "D^21. b returns home (mod 49 = 1)."
      else if k == 42 then "D^42 = THE ANSWER. All channels visited. Half-cycle."
      else if k == 210 then "D^210 = DATA. Half of lambda."
      else if k == 420 then "D^420 = OMEGA. Terminal. CRT = (0,1,1,1,1)."
      else "" in
    dom_inner(result, "<p style='color:#88ddaa;margin:8px 0'>D^" + "${k}" + " mod channels:</p><p style='color:#88ddaa;margin:4px 0'>CRT = (" + "${pd}" + ", " + "${pk}" + ", " + "${pe}" + ", " + "${pb}" + ", " + "${pl}" + ")</p><p style='color:" + (if pd == 0 then "#ff6666" else "#88ddaa") + ";margin:4px 0'>D-channel (mod 8): " + "${pd}" + (if pd == 0 then " — DEAD" else "") + "</p><p style='color:" + (if pk == 1 then "#ffd700" else "#aaa") + ";margin:4px 0'>K-channel (mod 9): " + "${pk}" + (if pk == 1 then " — HOME" else "") + "</p><p style='color:" + (if pe == 1 then "#ffd700" else "#aaa") + ";margin:4px 0'>E-channel (mod 25): " + "${pe}" + (if pe == 1 then " — HOME" else "") + "</p><p style='color:" + (if pb == 1 then "#ffd700" else "#aaa") + ";margin:4px 0'>b-channel (mod 49): " + "${pb}" + (if pb == 1 then " — HOME" else "") + "</p><p style='color:" + (if pl == 1 then "#ffd700" else "#aaa") + ";margin:4px 0'>L-channel (mod 11): " + "${pl}" + (if pl == 1 then " — HOME" else "") + "</p>" + (if len(note) > 0 then "<p style='color:#f0c040;margin:8px 0'>" + note + "</p>" else ""))
  )
)

fn coup_hero() = (
  dom_head_meta("description", "The coupling heatmap. 32 = D^5 classes of Z/2310Z. Four views: coupling strength, prime structure, eigenvalue spectrum, CRT channels. Six kingdoms from the ring's chemistry.");
  let hero = make_hero("The Coupling Heatmap") in
  let eq = dom_create("div") in
  dom_text(eq, "coupling(n) = |{m : gcd(n,N) = gcd(m,N)}|");
  ct_mono(eq);
  dom_style(eq, "fontSize", "18px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "20px");
  dom_append(hero, eq);
  render_p(hero, "Every element of Z/2310Z belongs to exactly one of 32 = D^5 coupling classes. Elements in the same class share the same gcd with N, the same kingdom, the same CRT signature pattern. The heatmap reveals the ring's anatomy through four different lenses.");
  dom_append(dom_body(), hero)
)

