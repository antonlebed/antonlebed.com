fn omega_em_hero() = (
  dom_head_meta("description", "OMEGA Emergence. Full Decality cellular automaton in Z/970200Z. CRT 5-tuple cells evolving by per-channel median consensus. Six kingdoms, OMEGA projector every 420 generations, L=11 error correction. The axiom running at scale.");
  let hero = make_hero("OMEGA Emergence") in
  let eq = dom_create("div") in
  dom_text(eq, "CRT cells in Z/12612600Z -- 10 terms, 6 channels, 420 heartbeat");
  ct_mono(eq);
  dom_style(eq, "fontSize", "18px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "20px");
  dom_append(hero, eq);
  render_p(hero, "The full Decality cellular automaton. Each cell is an element of Z/970200Z, decomposed into 5 independent CRT channels. Evolution: per-channel median of neighbors. OMEGA projects every 420 generations. Units thrive. Zero divisors drain. Natural selection from pure algebra.");
  dom_append(dom_body(), hero)
)

fn omega_em_anatomy() = (
  let sec = make_section("800px") in
  render_h2(sec, "CRT Cell Anatomy");
  render_theorem(sec, "Five Independent Channels", "Each cell is a 5-tuple: (mod 8, mod 9, mod 25, mod 49, mod 11). Evolution rule: per-channel median of K=3 neighbors (self + 2 orthogonal). Each channel evolves INDEPENDENTLY -- the CRT separation IS the parallel substrate. No interaction between channels except through the organism they compose.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Channel");
  render_th(hdr, "Space");
  render_th(hdr, "Median rule");
  render_th(hdr, "What it does");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "D-channel", "Z/8", "median of 3 values mod 8", "Bridge dynamics. Dies at OMEGA.");
  render_table_row_4(tbl, "K-channel", "Z/9", "median of 3 values mod 9", "Closure dynamics. K^2=9 parallelism.");
  render_table_row_4(tbl, "E-channel", "Z/25", "median of 3 values mod 25", "Observer dynamics. Self-blind.");
  render_table_row_4(tbl, "b-channel", "Z/49", "median of 3 values mod 49", "Depth dynamics. Deepest cycles.");
  render_table_row_4(tbl, "L-channel", "Z/11", "median of 3 values mod 11", "Protector dynamics. ECC parity.");
  dom_append(dom_body(), sec)
)

fn omega_em_kingdoms() = (
  let sec = make_section("800px") in
  render_h2(sec, "Six Kingdoms");
