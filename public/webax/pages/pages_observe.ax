  render_h2(sec, "Try It: Live ECC");
  render_p(sec, "Type any number. Decompose it into 5 CRT channels. Then corrupt the E channel and watch L=11 detect the error and CRT reconstruct the original.");
  /* Input row */
  let row = dom_create("div") in
  dom_style(row, "display", "flex");
  dom_style(row, "gap", "12px");
  dom_style(row, "alignItems", "center");
