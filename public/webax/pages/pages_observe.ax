/* dom_on callback: CRT explorer — full decomposition + kingdom + mirror (S970) */
fn crt_explore() = (
  let n = parse_int_from("#crt-explore-input") in
  let result_el = dom_query("#crt-explore-result") in
  let d = n % 8 in
  let k = n % 9 in
  let e = n % 25 in
  let b_ch = n % 49 in
  let l = n % 11 in
  let g_ch = n % 13 in
  /* Determine which primes divide n from CRT channels */
  let div_d = if d % 2 == 0 then 1 else 0 in
  let div_k = if k % 3 == 0 then 1 else 0 in
  let div_e = if e % 5 == 0 then 1 else 0 in
  let div_b = if b_ch % 7 == 0 then 1 else 0 in
  let div_l = if l == 0 then 1 else 0 in
  let div_g = if g_ch == 0 then 1 else 0 in
  /* Kingdom from smallest dividing prime */
  let kingdom = if div_d + div_k + div_e + div_b + div_l + div_g == 0 then "sigma (unit)"
    else if d == 0 then if k == 0 then if e == 0 then if b_ch == 0 then if l == 0 then if g_ch == 0 then "void" else "DKEbL" else "DKEb" else "DKE" else "DK+E" else "DK"
    else if div_d == 1 then "D (bridge)"
    else if div_k == 1 then "K (closure)"
    else if div_e == 1 then "E (observer)"
    else if div_b == 1 then "b (depth)"
    else if div_l == 1 then "L (protector)"
    else "GATE (skin)" in
  /* Mirror: 0-n in ring = N-n */
  let mirror = 0 - n in
  let md = mirror % 8 in
  let mk = mirror % 9 in
  let me_ch = mirror % 25 in
  let mb = mirror % 49 in
  let ml = mirror % 11 in
  let mg = mirror % 13 in
  /* Trace = sum of CRT residues */
  let trace = d + k + e + b_ch + l + g_ch in
  let mtrace = md + mk + me_ch + mb + ml + mg in
  /* Coupling: compute phi contribution from each channel */
  let cp_d = if d % 2 > 0 then 4 else if d % 4 > 0 then 2 else 1 in
  let cp_k = if k % 3 > 0 then 6 else if k > 0 then 2 else 1 in
  let cp_e = if e % 5 > 0 then 20 else if e > 0 then 4 else 1 in
  let cp_b = if b_ch % 7 > 0 then 42 else if b_ch > 0 then 6 else 1 in
  let cp_l = if l > 0 then 10 else 1 in
  let cp_g = if g_ch > 0 then 12 else 1 in
  let coupling = cp_d * cp_k * cp_e * cp_b * cp_l * cp_g in
  dom_inner(result_el, "<p style='color:#88ddaa;margin:4px 0'><b>CRT(" + "${n}" + ") = (" + "${d}" + ", " + "${k}" + ", " + "${e}" + ", " + "${b_ch}" + ", " + "${l}" + ", " + "${g_ch}" + ")</b></p><p style='color:#c0c0d0;margin:4px 0'>D=" + "${d}" + " (mod 8) | K=" + "${k}" + " (mod 9) | E=" + "${e}" + " (mod 25) | b=" + "${b_ch}" + " (mod 49) | L=" + "${l}" + " (mod 11) | GATE=" + "${g_ch}" + " (mod 13)</p><p style='color:#ffd700;margin:8px 0'>Kingdom: <b>" + kingdom + "</b> | Coupling: <b>" + "${coupling}" + "</b> | Trace: <b>" + "${trace}" + "</b></p><p style='color:#b0b0c0;margin:4px 0'>Mirror(" + "${n}" + ") = " + "${mirror}" + " | CRT = (" + "${md}" + ", " + "${mk}" + ", " + "${me_ch}" + ", " + "${mb}" + ", " + "${ml}" + ", " + "${mg}" + ") | Trace: " + "${mtrace}" + "</p><p style='color:#a0a0b0;margin:4px 0'>Trace + Mirror trace = " + "${trace + mtrace}" + " (should = 115 for units)</p>")
)

