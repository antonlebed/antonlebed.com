fn crt_mirror() = (
  let sec = make_section("800px") in
  render_h2(sec, "Mirror Duality");
  render_theorem(sec, "Trace Sum Formula", "For any element n: Tr(n) + Tr(N-n) = 102. Trace = sum of CRT residues. sigma has trace 5 (1+1+1+1+1). Mirror (-1) has trace 97 (7+8+24+48+10). Sum = 102 = (D^3-1)+(K^2-1)+(E^2-1)+(b^2-1)+(L-1). The mirror always completes what the element lacks.");
  let g = make_findings_grid(sec) in
  render_finding(g, "sigma = 1", "Tr = 5", "All channels at minimum nonzero.", "");
  render_finding(g, "-1 = 970199", "Tr = 97", "All channels at maximum.", "");
  render_finding(g, "OMEGA = 606376", "Tr = 3", "D dead (0), rest alive (1+1+1+1).", "");
  render_finding(g, "mirror(OMEGA)", "Tr = 99", "D alive (7), rest at max-1.", "");
  render_theorem(sec, "Spectral Mirror Theorem", "lambda(n) = lambda(N-n). Exhaustive: 485101 pairs, every one matches. The mirror is spectrally invisible -- you cannot distinguish an element from its mirror by eigenvalue alone. The ring has two sides, same music.");
  dom_append(dom_body(), sec)
)

