  dom_head_meta("description", "CRT anatomy. Every number in Z/970200Z has a unique 5-channel decomposition. Coupling, kingdom, trace, mirror duality, constant staircase, and axiom sentence. 2300 years old, still the deepest lens.");
  let hero = make_hero("CRT Anatomy") in
  let eq = dom_create("div") in
  dom_text(eq, "n = (n mod 8, n mod 9, n mod 25, n mod 49, n mod 11)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "18px");
