  dom_append(dom_body(), sec)
)

/* ================================================================
   CRT RECONSTRUCTION — absorbed from crt_index_demo.html (S1021)
   Reverse direction: 6 channel values → unique integer. TRUE ring.
   ================================================================ */

fn crt_recon_run() = (
  let vd = parse_int_from("#recon-d") in
  let vk = parse_int_from("#recon-k") in
  let ve = parse_int_from("#recon-e") in
  let vb = parse_int_from("#recon-b") in
  let vl = parse_int_from("#recon-l") in
  let vg = parse_int_from("#recon-g") in
  let result_el = dom_query("#recon-result") in
  if vd > 7 then dom_inner(result_el, "<p style='color:#ff6666'>D-channel: 0-7</p>")
  else if vk > 8 then dom_inner(result_el, "<p style='color:#ff6666'>K-channel: 0-8</p>")
  else if ve > 24 then dom_inner(result_el, "<p style='color:#ff6666'>E-channel: 0-24</p>")
  else if vb > 48 then dom_inner(result_el, "<p style='color:#ff6666'>b-channel: 0-48</p>")
  else if vl > 10 then dom_inner(result_el, "<p style='color:#ff6666'>L-channel: 0-10</p>")
  else if vg > 12 then dom_inner(result_el, "<p style='color:#ff6666'>GATE-channel: 0-12</p>")
  else (
    /* CRT reconstruction via TRUE ring idempotents */
    let n = vd * 11036025 + vk * 1401400 + ve * 9585576 + vb * 8494200 + vl * 3439800 + vg * 3880800 in
    /* Verify round-trip */
    let rd = n % 8 in let rk = n % 9 in let re = n % 25 in let rb = n % 49 in let rl = n % 11 in let rg = n % 13 in
    let ok = if rd == vd then if rk == vk then if re == ve then if rb == vb then if rl == vl then if rg == vg then 1 else 0 else 0 else 0 else 0 else 0 else 0 in
    /* Coupling */
    let g = gcd_shared(n, 12612600) in
    let coup = 12612600 / g in
    dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT RECONSTRUCTION</p><p style='color:#88ddaa;margin:4px 0;font-size:18px'><b>(" + "${vd}" + ", " + "${vk}" + ", " + "${ve}" + ", " + "${vb}" + ", " + "${vl}" + ", " + "${vg}" + ") = " + "${n}" + "</b></p><p style='color:#b0b0c0;margin:4px 0'>Coupling: <b>" + "${coup}" + "</b> | gcd(n,N) = " + "${g}" + "</p><p style='color:" + (if ok == 1 then "#44ff88" else "#ff4444") + ";margin:4px 0'>Round-trip: " + (if ok == 1 then "VERIFIED — bijection confirmed" else "MISMATCH") + "</p><p style='color:#a0a0b0;margin:8px 0 0;font-size:12px'>n = sum(ch_i * e_i) mod 12612600. Idempotents: {11036025, 1401400, 9585576, 8494200, 3439800, 3880800}. Every 6-tuple maps to exactly ONE integer. This IS a perfect hash — zero collisions by CRT.</p></div>")
  )
)

fn make_ch_field(parent, label:str, id:str, default_val:str) = (
  let wrap = dom_create("div") in
  dom_style(wrap, "textAlign", "center");
  let lbl = dom_create("div") in
  dom_text(lbl, label);
  dom_style(lbl, "color", "#888");
  dom_style(lbl, "fontSize", "11px");
  dom_style(lbl, "marginBottom", "2px");
  dom_append(wrap, lbl);
  let inp = dom_create("input") in
  dom_attr(inp, "type", "text");
  dom_attr(inp, "id", id);
  dom_attr(inp, "value", default_val);
  dom_style(inp, "background", "#111");
  dom_style(inp, "color", "#ffd700");
  dom_style(inp, "border", "1px solid #333");
  dom_style(inp, "padding", "6px");
  dom_style(inp, "fontFamily", "'Courier New', monospace");
  dom_style(inp, "width", "48px");
  dom_style(inp, "textAlign", "center");
  dom_style(inp, "borderRadius", "4px");
  dom_append(wrap, inp);
  dom_append(parent, wrap)
)

fn crt_index() = (
  let sec = make_section("800px") in
  render_h2(sec, "CRT Reconstruction: Perfect Hash");
  render_p(sec, "The decomposer above splits a number into 6 channels. This reverses it: enter channel values, get the unique integer. CRT guarantees ZERO collisions — this is a perfect hash function by theorem. No hash table resizing. No collision chains. No load factor. The ring structure IS the index.");
  render_theorem(sec, "CRT Bijection", "The map n -> (n mod 8, n mod 9, n mod 25, n mod 49, n mod 11, n mod 13) is a bijection on Z/12612600. Every valid 6-tuple reconstructs a unique integer: n = sum(ch_i * e_i) mod N, where e_i are CRT idempotents. Insert O(1). Lookup O(1). Range query per channel O(bucket_size). No rebalancing. 6 independent index dimensions for free.");
  let lbl = dom_create("p") in
  dom_text(lbl, "Enter CRT channel values:");
  dom_style(lbl, "color", "#b8b8c8");
  dom_style(lbl, "marginTop", "16px");
  dom_style(lbl, "marginBottom", "8px");
  dom_append(sec, lbl);
  let row = dom_create("div") in
  dom_style(row, "display", "flex");
  dom_style(row, "gap", "8px");
  dom_style(row, "alignItems", "flex-end");
  dom_style(row, "flexWrap", "wrap");
  dom_style(row, "marginBottom", "12px");
  make_ch_field(row, "D (0-7)", "recon-d", "1");
  make_ch_field(row, "K (0-8)", "recon-k", "2");
  make_ch_field(row, "E (0-24)", "recon-e", "12");
  make_ch_field(row, "b (0-48)", "recon-b", "39");
  make_ch_field(row, "L (0-10)", "recon-l", "5");
  make_ch_field(row, "GATE (0-12)", "recon-g", "7");
  make_action_btn(row, "Reconstruct", "crt_recon_run");
  dom_append(sec, row);
  make_result_box(sec, "recon-result");
  render_p(sec, "Try: (1,1,1,1,1,1) = sigma, (0,0,0,0,0,0) = void, (0,1,1,1,1,1) = OMEGA = 1576576, (1,2,12,39,5,7) = 137 = ADDRESS.");
  let g = make_findings_grid(sec) in
  render_finding(g, "6-dim address", "CRT = perfect hash", "12612600 = 8*9*25*49*11*13. Every integer has a unique address in this 6-dimensional space. No collisions possible.", "");
  render_finding(g, "Per-channel query", "Independent index", "Each channel IS a dimension. Query 'mod 49 = 7' returns exactly 1/49 of all elements. 6 B-trees for free.", "");
  render_finding(g, "CC0", "No patents", "CRT indexing is public domain. The ring gives you the perfect hash. No secret needed.", "");
  dom_append(dom_body(), sec)
)

