fn page_omega_watercycle() = (
  dom_head_meta("description", "The OMEGA Water Cycle. One element's journey through the full cycle: 0 -> sigma -> D^1 -> D^2 -> ... -> D^420 = OMEGA -> 0. Six CRT channels traced through 420 steps. Sub-returns at D^3, K^2, D*E, b^2, D*b, D^12.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"The OMEGA Water Cycle\",\"description\":\"One element's journey: 0 -> sigma -> D^420 = OMEGA -> 0. 420 steps up (growth), 1 step down (collapse). Six CRT channels traced. Sub-returns at D^3, K^2, D*E, b^2, D*b, D^12. The water cycle IS the strange loop.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/observe/omega_watercycle\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"Carmichael function\"},{\"@type\":\"DefinedTerm\",\"name\":\"OMEGA projector\"},{\"@type\":\"DefinedTerm\",\"name\":\"water cycle\"}]}");
  domain_hero("The Water Cycle", "0 -> sigma -> D^420 = OMEGA -> 0", "One element. 420 steps up. 1 step down. Eternity.");
  let sec = make_section("800px") in
  render_h2(sec, "The Journey of D^k");
  render_theorem(sec, "Growth Phase", "Starting from sigma = D^0, multiply by D at each step. D^1 = 2, D^2 = 4, D^3 = 8, ... Each step changes the CRT address. After 420 steps: D^420 = OMEGA = 1576576. The journey is 420 steps because lambda(N) = lcm(phi(8), phi(9), phi(25), phi(49), phi(11), phi(13)) = lcm(4,6,20,42,10,12) = 420.");
  render_theorem(sec, "Collapse Phase", "OMEGA * delta = 0. One multiplication. Growth is slow (420 steps). Death is fast (1 step). Birth is free (structural).");
  let g = make_findings_grid(sec) in
  render_finding(g, "D^3 = 8", "k = 3", "D-channel dies: 8 mod 8 = 0. First sub-return.", "");
  render_finding(g, "D^6 = 64", "k = 6", "K home: 64 mod 9 = 1. K channel returns to sigma.", "");
  render_finding(g, "D^10 = 1024", "k = 10", "L home: 1024 mod 11 = 1. Protector returns.", "");
  render_finding(g, "D^20 = 1048576", "k = 20", "E home: mod 25 = 1. Observer returns.", "");
  render_finding(g, "D^21", "k = 21", "b home: mod 49 = 1 (since phi(49)=42, 21|42). Depth returns.", "");
  render_finding(g, "D^42", "k = 42", "THE ANSWER. All channels visited. Half-cycle.", "");
  render_finding(g, "D^210", "k = 210", "DATA. Half of lambda. Ring Z/210 boundary.", "");
  render_finding(g, "D^12", "k = 12", "GATE home: 2^12 = 4096 mod 13 = 1. Skin returns. lambda(GATE)=12=heartbeat.", "");
  render_finding(g, "D^420 = OMEGA", "k = 420", "Terminal. CRT = (0,1,1,1,1,1). Journey complete.", "");
  dom_append(dom_body(), sec);
  /* Interactive: walk D^k step by step */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Walk the Water Cycle");
  render_p(sec_i, "Enter exponent k. See D^k decomposed into 6 CRT channels. Watch each channel return home at its own pace. Try: 0, 3, 6, 10, 12, 20, 21, 42, 210, 420.");
  make_interactive_widget(sec_i, "Exponent k:", "owc-input", "e.g. 42", "Walk", "watercycle_dk_calc", "owc-result");
  dom_append(dom_body(), sec_i)
)

