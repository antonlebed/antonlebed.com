  let sec = make_section("800px") in
  render_h2(sec, "Six Channels");
  render_theorem(sec, "The Chinese Remainder Theorem", "Z/12612600Z = Z/8 x Z/9 x Z/25 x Z/49 x Z/11 x Z/13. Forced by prime power factorization. Each channel is independent: knowing n mod 8 tells you NOTHING about n mod 9. Six orthogonal views of one number. Reconstruction is unique and total.");
