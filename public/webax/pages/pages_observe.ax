  render_table_row_4(tbl, "D", "Red", "D-channel = 0", "Drain. Bridge dead.");
  render_table_row_4(tbl, "K", "Green", "K-channel = 0", "Drain. Closure dead.");
  render_table_row_4(tbl, "E", "Blue", "E-channel = 0", "Drain. Observer dead.");
  render_table_row_4(tbl, "b", "Purple", "b-channel = 0", "Drain. Depth dead.");
  render_table_row_4(tbl, "L", "Cyan", "L-channel = 0", "Drain. Protector dead.");
  render_theorem(sec, "Natural Selection", "Units (gold) gain energy because all 6 channels are active -- they can participate in all ring operations. Zero divisors drain because a dead channel means broken arithmetic. Not coded. Falls out of CRT structure. phi(N)/N = 192/1001 ~ 19.18% of elements are units. The selection pressure = the septum.");
  dom_append(dom_body(), sec)
)

fn omega_em_heartbeat() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Lambda Heartbeat");
  let g = make_findings_grid(sec) in
  render_finding(g, "lambda = 420", "Full heartbeat", "lcm(4,6,20,42,10) = 420. Every 420 generations: all channels complete one full cycle. D^420 = OMEGA.", "");
  render_finding(g, "OMEGA projector", "Every 420 gens", "D-channel death wave. CRT(OMEGA) = (0,1,1,1,1). Bridge dies, everything else survives. One-third of cells hit.", "");
  render_finding(g, "Sub-pulses", "42, 210", "ANSWER=42 generations: half-cycle. DATA=210: half of lambda. Structural sub-rhythms.", "");
  render_finding(g, "L=11 ECC", "Error correction", "L-channel detects corruption in other channels. 4 remaining channels + L parity = 100% single-channel recovery.", "");
  render_theorem(sec, "OMEGA = Death + Memory", "OMEGA kills the D-channel (bridge dies) but preserves K, E, b, L. Not destruction -- selective pruning. OMEGA remembers everything except how it got there. The terminal projector: end of growth, beginning of return.");
  dom_append(dom_body(), sec)
)

