  make_interactive_widget(sec, "Analyze any element:", "coupling-input", "e.g. 42", "Analyze", "coupling_analyze", "coupling-result");
  render_p(sec, "Try: 1 (unit), 2 (D-pure), 6 (DK compound), 11 (L-pure), 0 (void), 30 (DKE compound).");
  dom_append(dom_body(), sec)
)

