  render_table_row_4(tbl, "Recurrence", "every config returns", "water cycle", "0 -> sigma -> OMEGA -> 0");
  dom_append(dom_body(), sec)
)

fn sand_why() = (
  let sec = make_section("800px") in
  render_h2(sec, "Why 4 = K + sigma");
  render_theorem(sec, "Closure + Identity", "The threshold is not arbitrary. In a 2D lattice each cell has 4 neighbors. But deeper: 4 = K + sigma = 3 + 1. Toppling occurs when closure is reached and identity propagates. K=3 is the minimum for a decisive majority. sigma=1 is the identity that carries the grain. Together: the minimum structure that can cascade.");
  render_theorem(sec, "Structural Necessity", "A sandpile with threshold T on a grid with D_grid dimensions requires T = 2*D_grid neighbors. For D_grid=2: T=4. The 2D sandpile is the SIMPLEST nontrivial case. D=2 is the simplest prime, and K+sigma=4 is the simplest closure threshold.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Threshold 3", "1D line", "Trivial. Cascades go left/right only.", "");
  render_finding(g, "Threshold 4", "2D grid", "CRITICAL. Power laws. SOC.", "");
  render_finding(g, "Threshold 6", "Triangular lattice", "Also critical but more neighbors.", "");
  render_finding(g, "Threshold 8", "3D cubic", "Higher dimensional SOC.", "");
  dom_append(dom_body(), sec)
)

