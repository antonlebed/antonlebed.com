  ct_gold(eq);
  dom_style(eq, "marginBottom", "20px");
  dom_append(hero, eq);
  render_p(hero, "Thousands of cells. Three operations. Zero intelligence coded. Each cell is a 3-bit pattern (0-7). Every generation: neighbors vote via MAJ (K=3 majority), cells metabolize, and the dying are saved by sacrifice. LIFE = pattern 7 = b (depth) emerges from random noise and sweeps the field.");
