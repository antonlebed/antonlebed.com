  render_finding(g, "All zero", "Void", "Only n=0. Zero coupling. The origin.", "");
  render_finding_wide(g, "L-channel = 0", "L-divisible", "Kingdom L. L=11 itself lives here (CRT L-channel = 0). The protector's OWN channel is dead -- selfless norm.", "");
