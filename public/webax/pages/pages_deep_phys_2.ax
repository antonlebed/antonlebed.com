  render_theorem(sec1, "Sigma Uniqueness Theorem", "sigma is the ONLY element n in Z/NZ such that n/n has exactly one solution. For every prime factor p^k of N: p/p has p solutions. D/D has 2, K/K has 3, E/E has 5, b/b has 7, L/L has 11, GATE/GATE has 13. And 0/0 has N = 12612600 solutions. sigma = 1 solution = zero ambiguity. Zero ambiguity = infinite persistence. sigma^k = sigma for ALL k. The identity cannot divide itself into anything other than itself.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: THE SIGMA SURPLUS === */
