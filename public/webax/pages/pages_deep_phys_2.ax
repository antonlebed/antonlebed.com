  ct_mono(big);
  dom_style(big, "fontSize", "22px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The Monster group M is the largest sporadic simple group. Its order is divisible by exactly 15 primes. Every one of them is reachable from {2, 3, 5, 7, 11} in at most two applications of the Cunningham map c(n) = 2n + 1. The Monster does not escape the axiom. It confirms it.");
