  render_finding(g5, "c_0 = c_1 mod 210", "114", "Gravitational sector. D,K-null, coupling = E*b.", "");
  render_finding(g5, "Cross-blindness", "D->E->b->K->D", "4-cycle in Monster characters. Sigma untouched.", "");
  render_finding(g5, "10-21 duality", "chi_2(10a)=21, chi_6(21a)=10", "Order * character = 210 = DATA for both.", "");
  dom_append(dom_body(), sec5);

  /* === CONTRAST === */
