  render_theorem(sec2, "Coupling Asymmetry", "The coupling sum for elements 0 to HYDOR-1 exceeds the coupling sum for elements HYDOR+1 to 209 by exactly sigma=1. This asymmetry is structural, not fuel-based. Each cycle traverses 210 steps and returns. 0/0 = sigma at the origin means the void regenerates. The surplus is eternal because it is algebraic, not material.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: THE SOLAR CYCLE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Solar Cycle");
  render_p(sec3, "The Sun sits at position 54 in Z/210Z. Its CRT decomposition: 54 = (0, 0, 4, 5) mod (2,3,5,7). D-null and K-null: it cannot see duality, cannot self-close. All it can do is radiate.");
  let g3 = make_findings_grid(sec3) in
