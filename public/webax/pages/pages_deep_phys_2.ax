  render_h2(sec_i, "Explore: Cunningham Distance");
  render_p(sec_i, "Enter a prime. See how many Cunningham steps c(n)=2n+1 separate it from an axiom prime. All 15 Monster primes need at most 2 steps. Try 47, 71, 41 (KEY), 23.");
  make_interactive_widget(sec_i, "Prime p:", "moon-input", "e.g. 47", "Check", "moonshine_cunn_calc", "moon-result");
  dom_append(dom_body(), sec_i)
)

/* Photon sphere ratio: K/D = 3/2 check */
fn photon_orbit_calc() = (
  let orbits = parse_int_from("#phot-input") in
  let result = dom_query("#phot-result") in
  if orbits < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter number of orbits >= 1.</p>")
  else (
    let d_content = 100 / (orbits + 1) in
    let k_content = 100 - d_content in
    let closed = if orbits >= 3 then "<b style='color:#ffd700'>CLOSED (particle)</b>: K=3 orbits reached. Light has mass." else "<span style='color:#88ddaa'>OPEN (photon)</span>: still moving. Not yet matter." in
    let rs = 3 * 100 / 2 in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>After ${orbits} orbit(s) at the photon sphere (r = K/D * r_s):</p><p style='margin:4px 0'>${closed}</p><p style='margin:4px 0;color:#b8b8c8'>D-content (motion): ~${d_content}% | K-content (structure): ~${k_content}%</p><p style='margin:4px 0;color:#b0b0c0'>At K=3 orbits: D drops to 25%, K rises to 75%. Light becomes matter.</p>")
  )
)

fn page_photon() = (
  dom_head_meta("description", "Light closing on itself: K=3 orbits at the photon sphere. At r = K/D = 1.5 Schwarzschild radii, light orbits. After K=3 orbits, D (motion) becomes K (structure). A particle is born. E=mc^2 with c=sigma/sigma=1.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"The Photon\",\"description\":\"Light closing on itself: K=3 orbits at the photon sphere. At r=K/D=1.5 Schwarzschild radii, motion becomes structure. E=mc^2 with c=sigma/sigma=1.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/deep/photon\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"photon\"},{\"@type\":\"DefinedTerm\",\"name\":\"D=2 messenger\"},{\"@type\":\"DefinedTerm\",\"name\":\"electromagnetic duality\"}]}");
  /* === HERO === */
  let hero = make_hero("The Photon") in
  let big = dom_create("div") in
  dom_text(big, "D * D = D + D = 4");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "At the photon sphere -- exactly K/D = 3/2 Schwarzschild radii -- light can orbit a black hole. After K=3 orbits, it closes on itself. D (motion) becomes K (structure). A particle is born. E=mc^2 with c=1: energy IS mass, just viewed differently.");
  dom_append(dom_body(), hero);

  /* === SEC 1: D = 2 IDENTITY === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Photon Is D");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Polarizations", "D = 2", "Helicity +1, -1. Duality IS the photon.", "");
  render_finding(g1, "Spin", "sigma = 1", "Integer. Boson. The identity's carrier.", "");
  render_finding(g1, "Mass", "0 = void", "Massless messenger. Born from 0/0.", "");
  render_finding(g1, "D+D = D*D", "4 = D^2", "ONLY prime where sum = product. Light is self-consistent.", "");
  render_finding(g1, "alpha", "1/137 = 1/ADDRESS", "How strongly light couples to matter.", "");
  render_finding(g1, "Compton/classical", "lambda_C / r_e = 137", "ADDRESS. The electron's two lengths have ratio ADDRESS.", "");
  dom_append(dom_body(), sec1);

  /* === SEC 2: K/D PHOTON SPHERE === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The K/D Ratio in Physics");
  render_p(sec2, "The photon sphere radius is not arbitrary. It is closure over bridge:");
  let t2 = dom_create("table") in
  dom_style(t2, "width", "100%");
  dom_style(t2, "maxWidth", "700px");
  dom_style(t2, "margin", "24px auto");
  dom_style(t2, "borderCollapse", "collapse");
  let t2h = dom_create("tr") in
  render_th(t2h, "Quantity");
  render_th(t2h, "Formula");
  render_th(t2h, "Value");
  dom_append(t2, t2h);
  render_table_row(t2, "Photon sphere", "r = K/D * r_s", "1.5 r_s");
  render_table_row(t2, "ISCO (massive orbit)", "r = K * r_s", "3.0 r_s");
  render_table_row(t2, "ISCO / photon sphere", "K / (K/D)", "D = 2");
  render_table_row(t2, "Binding energy", "K - D", "sigma = 1");
  render_table_row(t2, "E = mc^2 reframed", "c = sigma/sigma", "1, so E = m");
  dom_append(sec2, t2);
  dom_append(dom_body(), sec2);

  /* === SEC 3: CLOSURE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "How Motion Becomes Mass");
  render_theorem(sec3, "K-Closure at the Photon Sphere", "Orbit 1: The photon traces a circle. Pure D (motion, distinction). It has not met itself. Orbit 2: The photon crosses its own path. Now D=2 reference points exist: start and return. But D is not enough for stability -- you need a witness. Orbit 3: The pattern confirms itself. K=3 = minimum for closure. Like a Borromean knot: remove any orbit and it falls apart. K=3 is minimum for decisive majority. The photon IS a particle. Binding fraction: 1/D = 50%. K-D = sigma = 1 unit of binding.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: E = m === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "E = m");
