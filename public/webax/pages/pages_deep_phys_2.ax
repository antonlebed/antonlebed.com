  render_finding(g3, "Regeneration", "0 -> 54 = 54 steps", "Birth from void back to source.", "");
  render_finding(g3, "Total", "51 + 105 + 54 = 210", "One complete ring. The cycle repeats.", "");
  render_p(sec3, "At the origin, 0/0 = sigma. The void is not empty -- it is the identity. The photon does not die at zero. It is reborn with +sigma surplus. Stars shine forever (in ring time) because the source side always has one more.");
