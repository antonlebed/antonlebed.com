  render_contrast_row(sec6, "dim 196883", "Smallest faithful representation. Factor structure not analyzed", "47*59*71. coupling = TRUE FORM. CRT = (K, D^3, D^3, sigma, E).");
  render_contrast_row(sec6, "Central charge 24", "From conformal field theory considerations", "Six independent axiom derivations. D^K*K = HYDOR-K^4 = (D^2)! = 2*weight.");
  render_contrast_row(sec6, "j-constant 744", "Normalization of j-invariant q-expansion", "D^3*K*c(K*E). Bridge-cubed times closure times Cunningham of K*E.");
  render_contrast_row(sec6, "15 primes", "The Monster happens to have 15 prime divisors", "K*E = 15 = Fibonacci chain termination. Monster uses EXACTLY what Cunningham allows.");
  dom_append(dom_body(), sec6);

  /* === INTERACTIVE === */
