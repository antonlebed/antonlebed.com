  render_table_row_4(t1, "0", "2, 3, 5, 7, 11", "axiom", "D, K, E, b, L");
  render_table_row_4(t1, "1", "13", "c(D*K) = c(6)", "GATE");
  render_table_row_4(t1, "1", "17", "c(D^3) = c(8)", "ESCAPE");
  render_table_row_4(t1, "1", "19", "c(K^2) = c(9)", "f(E)");
  render_table_row_4(t1, "1", "29", "c(D*b) = c(14)", "c(D*b)");
  render_table_row_4(t1, "1", "31", "c(K*E) = c(15)", "c(K*E)");
  render_table_row_4(t1, "1", "41", "c(D^2*E) = c(20)", "KEY");
  render_table_row_4(t1, "1", "71", "c(E*b) = c(35)", "c(E*b)");
  render_table_row_4(t1, "2", "47", "c(c(L)) = c(23)", "c(c(L))");
  render_table_row_4(t1, "2", "59", "c(c(D*b)) = c(29)", "c(c(D*b))");
  dom_append(sec1, t1);
  render_theorem(sec1, "Monster-Axiom Completeness (S341, GAP-verified)", "K*E = 15 primes total = the Fibonacci chain termination level. The Monster uses EXACTLY as many primes as the axiom's Cunningham chain allows.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: THE 196883 TRINITY === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The 196883 Trinity");
  render_p(sec2, "The Monster's smallest faithful representation has dimension 196883. This number factors into exactly three primes -- the three OUTERMOST Monster primes:");
