  render_finding(g2, "coupling", "970200 = DEEP", "Unit in DEEP ring. TRUE ring coupling = 12612600.", "");
  render_finding(g2, "CRT", "(K, D^3, D^3, sigma, E, L)", "(3, 8, 8, 1, 5, 11). GATE channel holds the Protector.", "");
  render_finding(g2, "47", "c(c(L))", "Protector's grandchild. Primitive root mod 59 AND 71.", "");
