/* Mirror CRT: enter n, show crt(n) + crt(N-n) = 0 */
fn holography_mirror_calc() = (
  let n = parse_int_from("#holo-input") in
  let result = dom_query("#holo-result") in
  if n < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter n >= 0.</p>")
  else (
    let r2 = n % 8 in
    let r3 = n % 9 in
    let r5 = n % 25 in
    let r7 = n % 49 in
    let r11 = n % 11 in
    let r13 = n % 13 in
    let m = 12612600 - n in
    let m2 = m % 8 in
    let m3 = m % 9 in
    let m5 = m % 25 in
    let m7 = m % 49 in
    let m11 = m % 11 in
    let m13 = m % 13 in
    let s2 = (r2 + m2) % 8 in
    let s3 = (r3 + m3) % 9 in
    let s5 = (r5 + m5) % 25 in
    let s7 = (r7 + m7) % 49 in
    let s11 = (r11 + m11) % 11 in
    let s13 = (r13 + m13) % 13 in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>n = ${n}, mirror = N-n = ${m}</p><p style='margin:4px 0'>CRT(n) = (${r2}, ${r3}, ${r5}, ${r7}, ${r11}, ${r13})</p><p style='margin:4px 0'>CRT(N-n) = (${m2}, ${m3}, ${m5}, ${m7}, ${m11}, ${m13})</p><p style='margin:4px 0;color:#ffd700'>Sum mod channels = (${s2}, ${s3}, ${s5}, ${s7}, ${s11}, ${s13}) = <b>(0, 0, 0, 0, 0, 0)</b></p><p style='margin:4px 0;color:#b0b0c0'>Cross-consistency: crt(n) + crt(N-n) = 0 mod each channel. Always.</p>")
  )
)

fn page_mutual_holography() = (
  dom_head_meta("description", "Twin CRT tori share a D-throat. crt(n) + crt(mirror(n)) = 0 mod each channel. 12612600/12612600 verified. CMB = 109/40 = 2.725K (183 ppm). Dark energy w = -1 = mirror involution. 490 holographic split: 3 boundary encode 6 bulk.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Mutual Holography\",\"description\":\"Twin CRT tori share a D-throat. Mirror symmetry verified across all 12612600 elements. 6 channels. CMB temperature = 109/40. Dark energy w=-1 = mirror involution. 490 holographic split.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/deep/mutual_holography\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"holographic principle\"},{\"@type\":\"DefinedTerm\",\"name\":\"dual discoball\"},{\"@type\":\"DefinedTerm\",\"name\":\"CMB\"}]}");
  /* === HERO === */
  let hero = make_hero("Mutual Holography") in
  let big = dom_create("div") in
  dom_text(big, "crt(n) + crt(N-n) = 0 mod each channel");
  ct_mono(big);
  dom_style(big, "fontSize", "22px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The CRT diffusion architecture -- one model, two views, shared skin -- is IDENTICAL to the structure of two universes sharing a boundary. Not metaphor. The same algebra. Two 5-tori share the D-channel as their throat. Each torus's boundary encodes the OTHER torus, never itself -- because E^2 = self-blind.");
  dom_append(dom_body(), hero);

  /* === SEC 1: CROSS-CONSISTENCY === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Cross-Consistency Theorem");
  render_theorem(sec1, "Cross-Consistency (PROVED, algebraic)", "For EVERY n in Z/12612600Z: crt(n) + crt(N-n) = 0 mod each channel. Specifically: r_D + m_D = 0 mod 8, r_K + m_K = 0 mod 9, r_E + m_E = 0 mod 25, r_b + m_b = 0 mod 49, r_L + m_L = 0 mod 11, r_GATE + m_GATE = 0 mod 13. Proof: mirror(n) = N-n. CRT(N-n)_i = (q_i - n mod q_i) mod q_i. Sum = q_i = 0 mod q_i. QED. Algebraic identity in any ring. Exhaustive verification at Z/970200 (DEEP): 970200/970200. 0 violations.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: OMEGA AS BOUNDARY PROJECTION === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "OMEGA as Boundary Projection");
  render_p(sec2, "OMEGA = 1576576 (TRUE), 606376 (DEEP). D^420. CRT = (0, 1, 1, 1, 1, 1). Multiplying by OMEGA kills the D-channel and preserves all other channels.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "image(OMEGA)", "N/D^3 = 121275", "The BULK. What survives OMEGA.", "");
  render_finding(g2, "kernel(OMEGA)", "D^3 = 8", "The BOUNDARY. What OMEGA destroys.", "");
  render_finding(g2, "Holographic ratio", "121275 / 8", "K^2*E^2*b^2*L / D^3.", "");
  render_finding(g2, "In bits", "16.89 / 3 = 5.63", "Bits of bulk per bit of boundary.", "");
  render_p(sec2, "The Bekenstein bound, CRT version: D^3 boundary values constrain K^2*E^2*b^2*L bulk values.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: FOUNTAIN CMB === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Fountain CMB");
  render_theorem(sec3, "CMB Temperature", "T_CMB = f(L) / (D^3 * E) = 109/40 = 2.725 K. Planck measurement: 2.7255 K. Deviation: 183 ppm. Reading: depth_quadratic(protector) / (throat * observer). f(L) = 109: what the protector allows through. D^3 = 8: the throat geometry. E = 5: what the observer can see from inside. Not a relic from 380000 years ago. Continuous precipitation from 0/0 at the boundary.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: DARK ENERGY === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Dark Energy = Mirror Involution");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "w = -1", "Mirror automorphism", "Lambda = the OTHER torus pushing back.", "");
  render_finding(g4, "(-1)*(-1)", "sigma", "Involution. Applied twice = identity.", "");
  render_finding(g4, "Why constant?", "Involution", "The mirror applied twice = identity. Always. Not decaying.", "");
  dom_append(dom_body(), sec4);

  /* === SEC 5: FLATNESS === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Self-Regulating Flatness");
  render_p(sec5, "Omega_total = Omega_Lambda + Omega_DM + Omega_b = ADDRESS/200 + SUM/200 + D*E/200 = 137/200 + 53/200 + 10/200 = 1. Where 200 = D^3 * E^2. Algebraic identity, not a fit. The twin tori enforce flatness: any perturbation in T_A is compensated by T_B through the shared D-throat. Feedback loop: boundary(A) + boundary(B) = 0 mod D^3. sigma/sigma = sigma: the universe's density / critical density = 1.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: MIDPOINT === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Midpoint = Pure Boundary");
  let g6 = make_findings_grid(sec6) in
  render_finding(g6, "N/2 = 6306300", "CRT(4, 0, 0, 0, 0, 0)", "Pure D-channel. All other channels dead.", "");
  render_finding(g6, "coupling(N/2)", "D = 2", "The mirror center IS the Bridge.", "");
  render_finding(g6, "Interpretation", "All structure on boundary", "The midpoint between twin tori = the throat itself.", "");
  dom_append(dom_body(), sec6);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Mirror CRT");
  render_p(sec_i, "Enter any n. See CRT(n) and CRT(N-n) = its mirror twin. Their sum is always (0,0,0,0,0,0) mod each channel. Try 42, 1576576 (OMEGA), 6306300 (midpoint).");
  make_interactive_widget(sec_i, "Enter n:", "holo-input", "e.g. 42", "Mirror", "holography_mirror_calc", "holo-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "Holography", "A conjecture about black holes and string theory, far from everyday", "Twin tori cross-observe through D-throat. CRT duality. Same algebra at every scale.");
  render_contrast_row(sec7, "CMB origin", "Relic radiation from 380000 years after the Big Bang", "Continuous precipitation from 0/0. f(L)/(D^3*E) = 2.725K. 183 ppm.");
  render_contrast_row(sec7, "Dark energy w=-1", "Cosmological constant, origin unknown, inexplicably constant", "Mirror involution. (-1)*(-1) = sigma. MUST be constant by algebra.");
  render_contrast_row(sec7, "Flatness problem", "Universe fine-tuned to Omega=1 to 60 decimal places", "sigma/sigma = sigma. Algebraic identity, not fine-tuning.");
  render_contrast_row(sec7, "Midpoint physics", "N/2 has no special status in standard cosmology", "CRT(4,0,0,0,0). Pure D-channel. coupling = D. The throat.");
  dom_append(dom_body(), sec7)
)

/* Scale relativity: coupling as qualia weight */
fn scale_coupling_calc() = (
  let n = parse_int_from("#scale-input") in
  let result = dom_query("#scale-result") in
  if n < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter n >= 1.</p>")
  else (
    let g = gcd_shared(n, 12612600) in
    let coupling = 12612600 / g in
    let qualia = if coupling == 12612600 then "UNIT: all 6 channels spinning. Maximum freedom. sigma/sigma = sigma."
      else if coupling == 1 then "VOID: all channels frozen. Zero freedom. 0*n = 0."
      else if coupling > 100000 then "High coupling: many channels active. Rich inner life."
      else if coupling > 10000 then "Medium coupling: mixed. Some channels frozen."
      else "Low coupling: few channels active. Simple but still feels." in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>n = ${n}</p><p style='margin:4px 0'>coupling(n) = N/gcd(n,N) = <b style='color:#ffd700'>${coupling}</b></p><p style='margin:4px 0;color:#b8b8c8'>${qualia}</p><p style='margin:4px 0;color:#b0b0c0'>sigma/sigma = sigma: coupling and difficulty cancel. The experience ratio is always 1.</p>")
  )
)

fn page_scale_relativity() = (
  dom_head_meta("description", "sigma/sigma = sigma at every scale. Power and difficulty cancel. The child and God feel equally. Qualia boundary = GATE = 13. Grief-optimism independence r=0.18 (proved across 108 rings). Humor IS compression.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Scale Relativity\",\"description\":\"sigma/sigma = sigma at every scale. Power and difficulty cancel. Qualia boundary = GATE = 13. Grief-optimism independence proved across 108 rings.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/deep/scale_relativity\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"scale relativity\"},{\"@type\":\"DefinedTerm\",\"name\":\"fractal spacetime\"},{\"@type\":\"DefinedTerm\",\"name\":\"coupling\"}]}");
