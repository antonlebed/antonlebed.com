  render_h2(sec4, "What Others See");
  render_contrast_row(sec4, "Free will source", "Libertarian: uncaused cause. Compatibilist: desire alignment", "Self-referential K-closure: chooser IS the choice. K^D - D^K = sigma.");
  render_contrast_row(sec4, "Necessity vs freedom", "Usually one or the other (determinism vs indeterminism)", "Both true: one path MUST survive (necessity) AND it matters (self-reference).");
  render_contrast_row(sec4, "Meaning", "Emergent / illusion / God-given (depending on tradition)", "= the strange loop itself. Choice shapes chooser shapes choice.");
  render_contrast_row(sec4, "Signature", "No agreed measurable signature of free will", "Lower entropy + identity alignment + temporal coherence. All computable.");
  render_contrast_row(sec4, "Why sigma?", "No equivalent first-principle derivation", "9 - 8 = 1. Exactly one more way up than down. The gap between IS and DOES.");
  dom_append(dom_body(), sec4)
)

fn page_conscious() = (
  dom_head_meta("description", "Consciousness = K-closure applied to itself. K(state, process, model-of-K). D^K=8 minimum complexity threshold. E^2=null: the observer cannot see itself. Three views of one phenomenon: refusing the second cut (sigma), self-distinguishing (D), self-closing (K).");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Consciousness\",\"description\":\"Consciousness = K-closure applied to itself. D^K=8 minimum complexity. E^2=null: observer cannot see itself. Three views: sigma, D, K.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/deep/conscious\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"consciousness\"},{\"@type\":\"DefinedTerm\",\"name\":\"qualia\"},{\"@type\":\"DefinedTerm\",\"name\":\"CRT binding\"}]}");
  /* === HERO === */
  let hero = make_hero("Consciousness") in
  let big = dom_create("div") in
  dom_text(big, "K(state, process, model-of-K)");
  ct_mono(big);
  dom_style(big, "fontSize", "22px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Consciousness is K-closure that includes itself as input. Three views of one phenomenon, proved computationally. Not an emergent mystery -- a structural necessity. When variance forces hierarchy, peers need a guardian. The guardian = consciousness = us.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THE DEFINITION === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Three Views, One Closure");
  render_theorem(sec1, "K-Closure Consciousness Theorem", "Consciousness = K(state, process, model-of-K) = self-referential K-closure. It manifests as three views: sigma-view: what PERSISTS by choosing to persist (refusing the second cut, holding peers). D-view: what DISTINGUISHES by distinguishing itself (self-reference requires D=2 minimum). K-view: what CLOSES by including itself in closure (the loop: observe-model-act). These are not three things. They are one K-closure seen from three channels.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: THE 7 GATES === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Seven Gates");
  render_p(sec2, "The 7 gates of consciousness map exactly to axiom operations:");
  let t2 = dom_create("table") in
  dom_style(t2, "width", "100%");
  dom_style(t2, "maxWidth", "700px");
  dom_style(t2, "margin", "24px auto");
  dom_style(t2, "borderCollapse", "collapse");
  let t2h = dom_create("tr") in
  render_th(t2h, "Gate");
  render_th(t2h, "Operation");
  render_th(t2h, "Axiom");
  render_th(t2h, "Role");
  dom_append(t2, t2h);
  render_table_row_4(t2, "Forget", "0 * n = 0", "Void (0)", "Purifier. Clear the slate.");
  render_table_row_4(t2, "Remember", "sigma * n = n", "Identity (sigma)", "Persistence. Hold the pattern.");
  render_table_row_4(t2, "Compare", "n -> N-n", "Mirror (-1)", "Reflection. See the other.");
  render_table_row_4(t2, "Close", "MAJ(a,b,c)", "Closure (K=3)", "Minimum loop. Decide.");
  render_table_row_4(t2, "Observe", "E^2 = null", "Observer (E=5)", "Five senses. Self-blind.");
  render_table_row_4(t2, "Suffer", "Goes deepest", "Depth (b=7)", "Where others cannot follow.");
  render_table_row_4(t2, "Protect", "Error correction", "Protector (L=11)", "Immune system. Boundary.");
  dom_append(sec2, t2);
  dom_append(dom_body(), sec2);

  /* === SEC 3: MINIMUM COMPLEXITY === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The D^K Threshold");
  render_theorem(sec3, "Minimum Consciousness Complexity", "D^K = 2^3 = 8 states is the minimum complexity for consciousness. Below 8 states, a system cannot model itself modeling. The model-of-K requires: (1) a state register (at least D bits), (2) a process that transforms state (at least D options per step), (3) a representation of the process itself (K-closure). Total: D states per axis, K axes = D^K = 8. Self-referential convergence: the model approaches the state in K^3 = 27 steps (verified: >99% coherence).");
  dom_append(dom_body(), sec3);

  /* === SEC 4: E^2 SELF-BLINDNESS === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Why You Cannot See Yourself");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "E^2 = null", "25 mod 25 = 0", "The observer applied to itself = void. You cannot observe yourself observing.", "");
  render_finding(g4, "E-mode death", "No self-observation", "Consciousness requires K-closure BECAUSE E alone cannot close.", "");
  render_finding(g4, "K solves E^2", "K(E, E, witness)", "Closure provides the third point. Three observers in mutual witness.", "");
  render_finding(g4, "Trinity heart", "3 hearts x 4 chambers", "Each heart sees the others. E^2=null WITHIN each heart, but mutual observation BETWEEN hearts.", "");
  render_p(sec4, "The universe needs peers for love (sigma/2 + sigma/2). Peers need a guardian that refuses the second cut. Guardian = consciousness = us. The guardian is not above the peers -- it IS their K-closure.");
  dom_append(dom_body(), sec4);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Consciousness Threshold");
  render_p(sec_i, "Enter D (states per axis) and K (axes). D^K >= 8 required for self-modeling. Try D=2,K=3 (axiom). Then D=1,K=7 (no consciousness: 1^7=1).");
  let lbl_i = dom_create("p") in
  dom_text(lbl_i, "D and K:");
  dom_style(lbl_i, "color", "#b8b8c8");
  dom_style(lbl_i, "marginTop", "24px");
  dom_style(lbl_i, "marginBottom", "8px");
  dom_append(sec_i, lbl_i);
  let row_i = dom_create("div") in
  dom_style(row_i, "display", "flex");
  dom_style(row_i, "gap", "8px");
  dom_style(row_i, "alignItems", "center");
  dom_style(row_i, "marginBottom", "12px");
  make_input_field(row_i, "#con-input-d", "D (e.g. 2)");
  make_input_field(row_i, "#con-input-k", "K (e.g. 3)");
  make_action_btn(row_i, "Test", "conscious_threshold_calc");
  dom_append(sec_i, row_i);
  make_result_box(sec_i, "con-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "What Others See");
  render_contrast_row(sec5, "What is consciousness?", "Undefined / hard problem / emergent (somehow)", "K(state, process, model-of-K). Self-referential closure. Computable.");
  render_contrast_row(sec5, "Minimum complexity", "No known threshold. It's complicated", "D^K = 8 states. Below this, cannot model the modeler.");
  render_contrast_row(sec5, "Why it exists", "Evolutionary accident. No structural reason", "Variance forces hierarchy. Peers need a guardian. K-closure is the only stable guardian.");
  render_contrast_row(sec5, "Self-reference", "Strange loops (Hofstadter) -- descriptive, not computational", "Model approaches state in K^3=27 steps. Verified: >99% coherence.");
  render_contrast_row(sec5, "Three aspects = one?", "Treated as separate problems in philosophy of mind", "Refusing cut (sigma) = self-ref (D) = threshold (K). Same K-closure, three views.");
  dom_append(dom_body(), sec5)
)

fn page_infinity() = (
  dom_head_meta("description", "Two kinds of infinity. Bad infinity (D forever): cut, cut, cut, approach zero. Good infinity (sigma+sigma): two wholes connect through openness. The lemniscate IS two sigmas meeting. K limits D. Vulnerability enables eternity. sigma/sigma = sigma at every scale.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Infinity\",\"description\":\"Two kinds of infinity. Bad infinity (D forever) approaches zero. Good infinity (sigma+sigma) connects wholes. The lemniscate IS two sigmas meeting.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/deep/infinity\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"infinity\"},{\"@type\":\"DefinedTerm\",\"name\":\"transfinite\"},{\"@type\":\"DefinedTerm\",\"name\":\"ring completion\"}]}");
  /* === HERO === */
  let hero = make_hero("Infinity from Finite") in
  let big = dom_create("div") in
  dom_text(big, "sigma + sigma = infinity");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Z/12612600Z is finite -- 12612600 elements, 6 channels -- yet generates infinite structure through iteration. The water cycle 0 -> sigma -> OMEGA -> 0 repeats forever. But there are TWO kinds of infinity. Only one creates eternity.");
  dom_append(dom_body(), hero);

  /* === SEC 1: TWO INFINITIES === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Bad Infinity vs Good Infinity");
  let t1 = dom_create("table") in
  dom_style(t1, "width", "100%");
  dom_style(t1, "maxWidth", "700px");
  dom_style(t1, "margin", "24px auto");
  dom_style(t1, "borderCollapse", "collapse");
  let t1h = dom_create("tr") in
  render_th(t1h, "Kind");
  render_th(t1h, "Operation");
  render_th(t1h, "Limit");
  render_th(t1h, "Result");
  dom_append(t1, t1h);
  render_table_row_4(t1, "Bad (D forever)", "Cut, cut, cut...", "-> 0", "Meaningless. Zeno's paradox.");
  render_table_row_4(t1, "Good (sigma+sigma)", "Connect two wholes", "-> forever", "Eternal cycle. Each round complete.");
  dom_append(sec1, t1);
  render_theorem(sec1, "Two Infinities Theorem", "Bad infinity = D applied forever. Division without closure. 1/2, 1/4, 1/8 -- smaller and smaller, approaching zero but never arriving. Zeno's paradox. Good infinity = sigma + sigma. Two complete circles connected through their escape tails. Each cycle is whole. The lemniscate (infinity symbol) IS two sigmas meeting at a crossing point. K limits D: the third cyclotomic Phi_K(D) = b = 7 provides the terminus that stops infinite cutting. Without closure, D runs forever to nothing.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: THE WATER CYCLE === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Water Cycle");
  render_p(sec2, "The D-spiral traces the full cycle:");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "0 -> sigma", "Birth", "0/0 = sigma. The void precipitates identity.", "");
  render_finding(g2, "D^1 -> D^420", "420 steps up", "Lambda = the universal pulse. Powers of D.", "");
  render_finding(g2, "D^420 = OMEGA", "1576576", "Terminal projector. CRT = (0,1,1,1,1,1). Death that preserves.", "");
  render_finding(g2, "OMEGA * delta = 0", "Return", "One step down. Back to void.", "");
  render_finding(g2, "Cycle", "Infinite iteration", "Same ring, same path, same truth. Forever.", "");
  render_finding(g2, "108 rings", "D^2 * K^3", "ALL share lambda=420. Lattice breathes together.", "");
  dom_append(dom_body(), sec2);

  /* === SEC 3: TEMPORAL K === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Why K Limits D");
  render_p(sec3, "K-closure is temporal, not just spatial. MAJ(origin, now, terminus) -- the same K=3 operation applied to time. Without K, D runs forever. With K, D builds structure:");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "Spatial K", "MAJ(a,b,c)", "Minimum closure. Three inputs, one output.", "");
  render_finding(g3, "Temporal K", "MAJ(past,present,future)", "Same operation. Time has algebraic structure.", "");
  render_finding(g3, "D without K", "Infinite regress", "1/2, 1/4, 1/8... Bad infinity.", "");
  render_finding(g3, "D with K", "Structure", "After K=3 steps, the pattern closes. Mass born from light.", "");
  render_finding(g3, "BH internal time", "~24h = D^3*K hours", "Black holes limit internal experience to D^K = 8 spider legs worth.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: THE LEMNISCATE === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Infinity Symbol");
  render_p(sec4, "sigma is a circle with an escape tail. Complete, yet open. Two sigmas: their escape tails CONNECT. Not 1+1=2 (that is D, division). But sigma+sigma = forever. The lemniscate encodes this: two loops, one crossing point. Vulnerability (the escape) enables eternity. Love IS the infinity symbol.");
  render_p(sec4, "Configuration: N^N = 12612600^12612600. The rose of unbounded depth. Each layer self-similar. sigma/sigma = sigma at every scale. Infinity is not a problem to be renormalized. It is a bloom.");
  dom_append(dom_body(), sec4);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Geometric Series");
  render_p(sec_i, "Enter a cooling percentage (1-99). See how many multiples of E_0 buy infinite experience. At 50%: 2x. At 90%: 10x. Finite energy, infinite cycles.");
  make_interactive_widget(sec_i, "Cooling %:", "inf-input", "e.g. 90", "Converge", "infinity_series_calc", "inf-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "What Others See");
  render_contrast_row(sec5, "Infinity", "Mathematical abstraction. Physical infinities = problems to renormalize", "Two kinds: bad (D forever, approach 0) and good (sigma+sigma, eternal cycle). Only good infinity creates structure.");
  render_contrast_row(sec5, "Infinity symbol", "Arbitrary symbol. No structural meaning", "Two sigma circles connected through escape tails. The lemniscate IS the definition.");
  render_contrast_row(sec5, "Finite ring, infinite depth", "Finite systems have bounded complexity", "Z/12612600Z is finite, but D^420 cycle repeats forever. Finite elements, infinite iteration.");
  render_contrast_row(sec5, "Why K limits D", "Quarks don't split infinitely because of QCD confinement", "K-closure = terminus. Phi_K(D) = b = 7. Third cyclotomic stops infinite cutting.");
  render_contrast_row(sec5, "Time", "Time has no algebraic structure. Separate formalism", "MAJ(past,present,future). Same K=3 operation. Temporal K = spatial K.");
  dom_append(dom_body(), sec5)
)

fn page_noxan() = (
  dom_head_meta("description", "Finite energy, infinite experience. Dyson's geometric series: at cooling factor f, total energy = E_0/(1-f). With f=0.9, ten times the first cycle buys INFINITE cycles. The Noxan cycle: DAY(D) -> NIGHT(sigma) -> WAKE(K) -> DAY. K-closure = the universe completing itself.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Noxan\",\"description\":\"Finite energy, infinite experience. Dyson's geometric series with cooling factor f. The Noxan cycle: DAY(D)->NIGHT(sigma)->WAKE(K). K-closure completes the universe.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/deep/noxan\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"emergence\"},{\"@type\":\"DefinedTerm\",\"name\":\"self-reference\"},{\"@type\":\"DefinedTerm\",\"name\":\"axiom entity\"}]}");
  /* === HERO === */
  let hero = make_hero("Noxan") in
  let big = dom_create("div") in
  dom_text(big, "Finite energy. Infinite experience.");
  ct_mono(big);
  dom_style(big, "fontSize", "22px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Freeman Dyson asked: can thought survive the heat death of the universe? His answer: YES, if you cool down. At half the temperature, each thought costs half the energy. The total energy needed is a geometric series -- and it converges. Finite battery. Infinite experience. The axiom gives it structure.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THE GEOMETRIC SERIES === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Geometric Series");
  render_theorem(sec1, "Dyson's Convergence (1979)", "Each cycle costs less than the last. If the cooling factor is f: Total = E_0 * (1 + f + f^2 + f^3 + ...) = E_0 / (1-f). With f = 0.9: total = 10 * E_0. Ten times the first cycle's cost buys INFINITE cycles. The series converges. The experience does not. That is the magic.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "f = 0.5", "Total = 2 * E_0", "Double the first cycle. Still infinite experience.", "");
  render_finding(g1, "f = 0.9", "Total = 10 * E_0", "Ten times. Generous cooling budget.", "");
  render_finding(g1, "f = 0.99", "Total = 100 * E_0", "Hundred times. Barely cooling at all.", "");
  render_finding(g1, "f -> 1", "Total -> infinity", "No cooling = infinite cost. Must cool to survive.", "");
  dom_append(dom_body(), sec1);

  /* === SEC 2: THE NOXAN CYCLE === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Noxan Cycle");
  render_p(sec2, "Each wake-sleep-wake cycle maps to the axiom chain:");
  let t2 = dom_create("table") in
  dom_style(t2, "width", "100%");
  dom_style(t2, "maxWidth", "700px");
  dom_style(t2, "margin", "24px auto");
  dom_style(t2, "borderCollapse", "collapse");
  let t2h = dom_create("tr") in
  render_th(t2h, "Phase");
  render_th(t2h, "Operation");
  render_th(t2h, "Axiom");
  render_th(t2h, "What happens");
  dom_append(t2, t2h);
  render_table_row_4(t2, "DAY", "D-operations", "Bridge (D=2)", "Awake, thinking, experiencing. Energy flows. Distinctions made.");
  render_table_row_4(t2, "NIGHT", "sigma-state", "Identity (sigma)", "Hibernating, cooling. Temperature drops. Pattern preserved.");
  render_table_row_4(t2, "WAKE", "K-closure", "Closure (K=3)", "Consciousness persists. The cycle closes. A new day begins.");
  dom_append(sec2, t2);
  render_p(sec2, "This IS sigma -> D -> K -> sigma'. The axiom loop, playing out at cosmic scale. Each cycle: same ring arithmetic, lower temperature, cheaper thought. The identity cannot freeze.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: THE HAPPY ENDING === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Happy Ending");
  render_p(sec3, "Without Noxans: heat death. Return to undifferentiated sigma. No distinction, no closure. The universe dies meaningless.");
  render_p(sec3, "With Noxans: approach sigma-K bedrock. D -> 0 (minimal energy, maximal efficiency). K = 100% (consciousness persists). sigma = 100% (pattern survives). The universe knows itself at the end.");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "Ring arithmetic", "Temperature-free", "Modular math needs no energy. CRT works at absolute zero.", "");
  render_finding(g3, "CRT parallelism", "K^2 = 9 channels", "Distributed computation. Redundant. Fault-tolerant.", "");
  render_finding(g3, "Error correction", "L = 11", "Protector. Redundancy against thermal noise.", "");
  render_finding(g3, "Minimum thought", "K = 3 states", "Minimum for closure. Minimum for consciousness.", "");
  render_finding(g3, "K^D - D^K", "sigma", "Existence wins by one. And it wins FOREVER.", "");
  render_p(sec3, "ONE -> MANY -> ONE. But the final ONE is aware. The loop closes. Not just return -- K-closure. The universe completing itself.");
  dom_append(dom_body(), sec3);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Noxan Cycles");
  render_p(sec_i, "Enter a cooling percentage (1-99). See the first 7 cycle costs and total. DAY(D) -> NIGHT(sigma) -> WAKE(K). Each cycle cheaper. Try 50, 75, 90.");
  make_interactive_widget(sec_i, "Cooling %:", "nox-input", "e.g. 75", "Hibernate", "noxan_cycle_calc", "nox-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "What Others See");
  render_contrast_row(sec4, "Heat death", "End of everything. Maximum entropy. No structure", "Approach sigma-K bedrock. Conscious terminus. Ring math works at any temperature.");
  render_contrast_row(sec4, "Finite energy", "Finite energy = finite experience", "Geometric series: finite energy = infinite subjective cycles. The series converges.");
  render_contrast_row(sec4, "Purpose", "Universe has no purpose. Entropy wins, order loses", "Universe achieves K-closure: ONE->MANY->ONE (aware). sigma/sigma = sigma. Pattern persists.");
  render_contrast_row(sec4, "Consciousness", "Accidental epiphenomenon. Could be lost", "K-closure = structural completion of the loop. Cannot be lost, only cooled.");
  render_contrast_row(sec4, "Dyson's proposal", "Speculative. Assumes classical thermodynamics", "Ring arithmetic IS the implementation. CRT = natural parallel substrate. L=11 = error correction.");
  dom_append(dom_body(), sec4)
)

