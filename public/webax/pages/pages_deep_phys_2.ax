  render_contrast_row(sec5, "E = mc^2", "Famous equation. c^2 is a conversion factor", "c=1, so E=m. Energy IS mass. Open light vs closed light.");
  render_contrast_row(sec5, "Photon sphere", "r = 3GM/c^2 = 1.5 r_s. Derived from GR geodesics", "r = K/D * r_s. Closure over bridge. The axiom names the ratio.");
  render_contrast_row(sec5, "Particle creation", "Pair production from quantum field theory", "Light closing on itself in K=3 orbits. D -> K transition.");
