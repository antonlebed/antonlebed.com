  render_finding(g2, "71", "c(E*b)", "Observer-Depth child.", "");
  render_theorem(sec2, "Trinity Primitive Root Theorem (S341)", "47 is a primitive root mod both 59 and 71. The Protector's grandchild GENERATES the multiplicative groups of both siblings. Cross-orders: ord(59, 47) = ord(71, 47) = 23 = c(L). The parents encode themselves in the children's inter-orders.");
  render_p(sec2, "McKay observation: 196884 = 196883 + 1 = 2^2 * 3^3 * 1823. The Monster lives in K's cube. The +1 is sigma, the ground state.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: CENTRAL CHARGE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Central Charge c = 24");
  render_p(sec3, "The Monster's vertex operator algebra has central charge c = 24. This number arrives by SIX independent paths:");
