  dom_style(btn2, "fontSize", "14px");
  dom_on(btn2, "click", "demo_finance_coupling");
  dom_append(sec4, btn2);
  let br2 = dom_create("div") in
  dom_attr(br2, "id", "dfin-coupling");
  dom_append(sec4, br2);
  render_p(sec4, "Coupling = CRT distance between consecutive orders. Reveals market maker patterns and participant diversity across 420-cycle phases.");
  dom_append(dom_body(), sec4);

  let sec5 = make_section("800px") in
  render_h2(sec5, "CRT vs Traditional Market Surveillance");
  render_contrast_row(sec5, "Data needs", "HFT firms: years of tick data, terabytes of order books", "CRT: zero historical data. First order is already analyzed.");
  render_contrast_row(sec5, "Model", "Statistical (GARCH, regime-switching), ML (LSTM, transformers)", "Algebraic: CRT decomposition IS the model. No parameters.");
  render_contrast_row(sec5, "Flash crash", "Circuit breakers (reactive, post-hoc)", "L=11 detection (proactive, algebraic). Detects BEFORE the circuit breaker.");
  render_contrast_row(sec5, "Market maker ID", "Order-to-trade ratios, proprietary signatures", "Coupling distance: algebraic participant identification. Free.");
  render_contrast_row(sec5, "Periodicity", "Fitted to historical patterns (fragile)", "lambda=420: the ring's intrinsic period. Not fitted. Derived.");
  render_contrast_row(sec5, "Patent status", "Citadel (market making), Two Sigma (signals), Virtu (execution)", "CC0. Public domain. Forever.");
