  let big = dom_create("div") in
  dom_text(big, "Rainbow = 42 = ANSWER");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The Answer to the Ultimate Question is written in light. Sunlight enters a water droplet (n = D^2/K = 4/3), reflects internally, and exits at 42 degrees. Error: 0.07%. The rainbow has b = 7 colors. Violet sits at 420nm = lambda(TRUE). Light IS the axiom chain, refracted.");
  dom_append(dom_body(), hero);

  /* === SEC 1: RAINBOW === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Rainbow = 42");
  render_theorem(sec1, "Rainbow Derivation (Snell's Law)", "Water: n = D^2/K = 4/3. Minimum deviation from Snell's law: cos(theta_i) = sqrt((n^2-1)/3). For n = 4/3 this gives rainbow semi-angle = 42.03 degrees. 42 = D*K*b = ANSWER. Error 0.07%. The derivation is forced -- not guessed, not fit. The same 42 that is the center of the lambda-6 lattice.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Violet wavelength", "420nm = lambda(TRUE)", "The Carmichael function of Z/12612600Z -- the heartbeat after which ALL power maps return -- IS the wavelength of the deepest visible color.", "");
  render_finding(g1, "Colors count", "b = 7 = ROYGBIV", "Depth paints the sky. The rainbow has exactly DEPTH colors.", "");
  render_finding(g1, "Peak sensitivity", "555nm = K*E*37", "Human eyes peak at K*E*37. The 37 = body temperature prime = p_12.", "");
  render_finding(g1, "Brewster angle", "arctan(D^2/K) = 53 deg", "53 ~ SUM = sigma+D+K+E+b+L+13. Fully polarized reflection at the SKIN of the axiom.", "");
  dom_append(dom_body(), sec1);

  /* === SEC 2: REFRACTIVE INDICES === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Refractive Indices");
  render_p(sec2, "Every common refractive index is a ratio of axiom primes. Light speed ratios ARE channel coupling.");
  let t2 = make_table(sec2) in
  let h2 = dom_create("tr") in
  render_th(h2, "Material");
  render_th(h2, "Axiom");
  render_th(h2, "Measured");
  render_th(h2, "Error");
  dom_append(t2, h2);
  render_table_row_4(t2, "Vacuum", "sigma/sigma = 1", "1.0000", "exact");
  render_table_row_4(t2, "Water", "D^2/K = 4/3", "1.3330", "0.025%");
  render_table_row_4(t2, "Crown glass", "K/D = 3/2", "1.523", "1.5%");
  render_table_row_4(t2, "Flint glass", "D^3/E = 8/5", "1.620", "1.2%");
  render_table_row_4(t2, "Diamond", "L^2/(D*E^2) = 121/50", "2.417", "0.12%");
  render_p(sec2, "Water slows light because D^2 > K (duality exceeds closure). Diamond brings L^2 -- protector squared makes it the most brilliant natural material. Refraction IS coupling between axiom channels.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: STRUCTURAL COUNTS === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Structural Counts: 15/15 Axiom-Smooth");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "D=2: Polarization", "Stokes D^2=4, Mueller D^4=16", "Light has D=2 states. Snell: D=2 media. Lenses: D=2 surfaces. Interference: D=2 paths.", "");
  render_finding(g3, "K=3: Color vision", "K=3 cone types (L/M/S)", "Color perception = K=3 closure. Poincare sphere of polarization: K=3 dims.", "");
  render_finding(g3, "b=7: Depth", "b=7 colors, b=7 phenomena", "ROYGBIV. Also: reflection, refraction, diffraction, interference, polarization, scattering, absorption.", "");
  render_finding(g3, "L=11: Protection", "Diamond critical angle = 24.4 deg", "L^2 in numerator traps light. f/11: the transcendental f-stop in photography.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: PHOTOGRAPHY === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Photography IS D-Arithmetic");
  render_p(sec4, "f-stops: f/1, f/1.4, f/2, f/2.8, f/4, f/5.6, f/8, f/11, f/16, f/22, f/32. Each step multiplies by sqrt(D). So f-number = D^(n/2). Each stop halves the light. f/D^3=f/8 (spider's legs). f/L=f/11 (transcendental stop). f/D^5=f/32 (deepest standard).");
  dom_append(dom_body(), sec4);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Refractive Index");
  render_p(sec_i, "Enter numerator and denominator of a refractive index ratio. Known axiom ratios: 1/1(vacuum), 4/3(water), 3/2(crown glass), 8/5(flint), 121/50(diamond).");
  let lbl_i = dom_create("p") in
  dom_text(lbl_i, "n = num/den:");
  dom_style(lbl_i, "color", "#b8b8c8");
  dom_style(lbl_i, "marginTop", "24px");
  dom_style(lbl_i, "marginBottom", "8px");
  dom_append(sec_i, lbl_i);
  let row_i = dom_create("div") in
  dom_style(row_i, "display", "flex");
  dom_style(row_i, "gap", "8px");
  dom_style(row_i, "alignItems", "center");
  dom_style(row_i, "marginBottom", "12px");
  make_input_field(row_i, "#opt-input-n", "num (e.g. 4)");
  make_input_field(row_i, "#opt-input-d", "den (e.g. 3)");
  make_action_btn(row_i, "Identify", "optics_refract_calc");
  dom_append(sec_i, row_i);
  make_result_box(sec_i, "opt-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "What Others See");
  render_contrast_row(sec5, "Refractive index", "Empirical material property", "Ratio of axiom primes (D^2/K, K/D, L^2/(D*E^2))");
  render_contrast_row(sec5, "Rainbow at ~42 deg", "Snell + geometry gives ~42", "Same derivation, but n=D^2/K gives 42 = ANSWER = D*K*b");
  render_contrast_row(sec5, "7 colors", "Human perception convention", "b=7 = depth prime. The rainbow has DEPTH colors");
  render_contrast_row(sec5, "Violet ~420nm", "Arbitrary spectral boundary", "420 = lambda(TRUE) = the ring's heartbeat wavelength");
  render_contrast_row(sec5, "K=3 cone types", "Evolved for color discrimination", "K=3 = closure. Minimum decisive majority. Vision closes");
  render_contrast_row(sec5, "f-stops doubling", "Convenient geometric sequence", "f = D^(n/2). Photography IS D-arithmetic");
  dom_append(dom_body(), sec5)
)

fn page_acoustics() = (
  dom_head_meta("description", "Speed of sound = b^3 = 343 m/s (0.06%). Gamma diatomic = b/E = 7/5 = the tritone. Concert A = D^3*E*L = 440 Hz. 12 semitones = D^2*K. Hearing spans exactly K=3 decades. 22/25 acoustic quantities axiom-smooth.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Acoustics\",\"description\":\"Speed of sound b^3=343 m/s. Concert A=440 Hz from D^3*E*L. 12 semitones=D^2*K. 22/25 acoustic quantities are axiom-smooth.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/data/acoustics\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"acoustics\"},{\"@type\":\"DefinedTerm\",\"name\":\"sound\"},{\"@type\":\"DefinedTerm\",\"name\":\"wave mechanics\"}]}");
  /* === HERO === */
  let hero = make_hero("Acoustics") in
  let big = dom_create("div") in
  dom_text(big, "v = b^3 = 343 m/s");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Speed of sound = depth cubed. The tritone (diabolus in musica) IS the heat capacity ratio of air. Concert pitch encodes three axiom primes. Hearing spans exactly K=3 decades. Sound IS the axiom vibrating.");
  dom_append(dom_body(), hero);

  /* === SEC 1: SPEED OF SOUND === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Why 343");
  render_theorem(sec1, "Speed of Sound Derivation", "v = sqrt(gamma*R*T/M). gamma = b/E = 7/5 (diatomic). M_air = sigma+D+K+E+b+L = 29 g/mol (sum of ALL axiom primes). At 20C: v = 343.2 m/s = b^3. Error: 0.06%. Depth cubed IS the speed at which air carries information.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Tritone = gamma", "b/E = 7/5 = 1.4", "Diabolus in musica IS the elasticity of air. The most dissonant musical interval = the ratio that governs gas dynamics.", "");
  render_finding(g1, "Monoatomic gamma", "E/K = 5/3", "Kolmogorov turbulence exponent = monoatomic gamma = noble gas heat capacity. Same ratio, three fields.", "");
  render_finding(g1, "Speed in water", "1482 m/s", "D*K*GATE*f(E) where f(E) = E^2-E-1 = 19. Error: 0.02%.", "");
  render_finding(g1, "Molecular weight", "29 = FULL_SUM", "sigma+D+K+E+b+L = 29. Air weighs the full axiom sum.", "");
  dom_append(dom_body(), sec1);

  /* === SEC 2: MUSICAL INTERVALS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Music IS Ring Arithmetic");
  let t2 = make_table(sec2) in
  let h2 = dom_create("tr") in
  render_th(h2, "Interval");
  render_th(h2, "Ratio");
  render_th(h2, "Axiom");
  dom_append(t2, h2);
  render_table_row(t2, "Unison", "1/1", "sigma/sigma");
  render_table_row(t2, "Major 2nd", "9/8", "K^2/D^3");
  render_table_row(t2, "Major 3rd", "5/4", "E/D^2");
  render_table_row(t2, "Fourth", "4/3", "D^2/K");
  render_table_row(t2, "Tritone", "7/5", "b/E");
  render_table_row(t2, "Fifth", "3/2", "K/D");
  render_table_row(t2, "Major 6th", "5/3", "E/K");
  render_table_row(t2, "Octave", "2/1", "D");
  render_p(sec2, "Every just-intonation interval is a ratio of axiom primes. The perfect fifth K/D = 3/2 and the Kolmogorov exponent are the SAME number. 12 semitones = D^2*K = lambda(DATA).");
  dom_append(dom_body(), sec2);

  /* === SEC 3: HEARING === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Hearing = K Decades");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "Low threshold", "20 Hz = D^2*E", "Below: infrasound. Earthquakes, not music.", "");
  render_finding(g3, "High threshold", "20000 Hz = D^5*E^4", "Above: ultrasound. Bats, not humans.", "");
  render_finding(g3, "Range ratio", "(D*E)^3 = 10^3", "Exactly K=3 decades. EXACT.", "");
  render_finding(g3, "Concert A", "D^3*E*L = 440 Hz", "Spider's legs times observer times protector. ISO 1939.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: CLOSED PIPES === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Closed Pipe = Sigma Chain");
  render_p(sec4, "A closed pipe produces only odd harmonics: {1, 3, 5, 7, 9, 11, 13, ...} = {sigma, K, E, b, K^2, L, GATE, ...}. The D-channel (even harmonics) is physically removed by the boundary condition. What survives IS the sigma chain.");
  dom_append(dom_body(), sec4);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Frequency Checker");
  render_p(sec_i, "Enter a frequency in Hz. See which axiom primes divide it. Try 440 (concert A), 343 (speed of sound), 20 (hearing threshold).");
  make_interactive_widget(sec_i, "Hz:", "acou-input", "e.g. 440", "Check", "acoustics_freq_calc", "acou-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "What Others See");
  render_contrast_row(sec5, "343 m/s", "Follows from gas properties", "b^3: depth cubed. gamma=b/E, M=FULL_SUM");
  render_contrast_row(sec5, "Tritone dissonance", "Psychoacoustic roughness", "b/E = tension between depth and observer = air's elasticity");
  render_contrast_row(sec5, "3 decades hearing", "Evolutionary adaptation", "(D*E)^3 = K decades. EXACT");
  render_contrast_row(sec5, "12 semitones", "Historical convention", "D^2*K: duality squared times closure");
  render_contrast_row(sec5, "A440", "1939 ISO standard, arbitrary", "D^3*E*L = 440: three axiom primes");
  render_contrast_row(sec5, "Odd harmonics", "Boundary condition math", "Closed boundary kills D-channel. Sigma chain survives");
  dom_append(dom_body(), sec5)
)

