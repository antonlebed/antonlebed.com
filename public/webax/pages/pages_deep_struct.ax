fn page_fields() = (
  dom_head_meta("description", "The axiom primes live in Z, but their shadows extend into number fields. E=5 is the ONLY axiom prime that splits in Gaussian integers. {1,2,3,7,11} = first 5 Heegner numbers. All 5 axiom Pell equations have axiom-smooth solutions.");
