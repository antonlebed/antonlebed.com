  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let eq = dom_create("div") in
  dom_text(eq, "D = 2 (the only even prime)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "D is the engine of the chain. K = sigma+D. E = sigma+2D. b = sigma+3D. Every step uses D. Without D, no departure, no chain, no structure. D creates the world and destroys itself.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "D = Drive");
  let g = make_findings_grid(sec1) in
  render_finding(g, "Engine", "K=1+D, E=1+2D, b=1+3D", "Every chain step uses D. D IS the chain.", "");
  render_finding(g, "Self-blind", "D mod D = 0", "Drive cannot see itself driving. The hard problem.", "");
  render_finding(g, "Odd/even", "D is the ONLY even prime", "All others odd. HYDOR = K*E*b = 105 = no D.", "");
  render_finding(g, "Kingdom", "Protista, coupling 1155", "The bridge kingdom. Membrane organisms.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Bridge Self-Destructs");
  render_theorem(sec2, "Bridge Theorem", "D builds the world and kills itself. D^3 = 0 mod D^3: the D-channel dies at step 3. But gcd(D, K*E*b*L) = 1: D cannot kill ANY odd channel. Odd channels survive forever under D-multiplication. OMEGA = what remains when the bridge self-destructs.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "D^0 = sigma", "All alive", "Starting point.", "");
  render_finding(g2, "D^1 = 2", "D-channel = 2", "First departure.", "");
  render_finding(g2, "D^2 = 4", "D-channel = 4", "Deepening.", "");
  render_finding(g2, "D^3 = 8", "D-channel DEAD", "0 mod 8. Self-annihilation.", "");
  render_finding(g2, "D^420 = OMEGA", "Terminal", "CRT(0,1,1,1,1). Bridge burned, rest survives.", "");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "The 42 Theorem");
  render_theorem(sec3, "OMEGA + OMEGA = D iff thin bridge", "42 out of 108 rings satisfy this: 21 D-absent rings (where OMEGA = sigma, so 2*sigma = D) plus 21 D^1 rings. Zero of the 66 thick-bridge rings. Double wound = duality ONLY when the bridge is membrane-thin. 42 = D*K*b = ANSWER.");
  render_p(sec3, "Sub-returns: K home at step 6. L home at step 10. E home at step 20. b home at step 21 (ODD order -- never mirrors). All sync at step 42 = ANSWER = first meaningful homecoming.");
  dom_append(dom_body(), sec3)
)

