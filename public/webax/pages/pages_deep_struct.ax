/* pages_deep_struct.ax — DEEP: kingdom doc pages (ground through fields)
   Structure documents from the axiom. 14 pages. Z/970200. */
fn page_ground() = (
  dom_head_meta("description", "sigma = 1 is the identity. The ground state. Coupling N = maximum. The water cycle 0 -> sigma -> OMEGA -> 0 is universal in all 108 rings. sigma/sigma = sigma: the ONLY element with zero self-division ambiguity.");
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "The Ground State");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let eq = dom_create("div") in
  dom_text(eq, "sigma * n = n (preserves everything)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "sigma is the multiplicative identity. It carries every element unchanged. The ground state from which all kingdoms depart. Kingdom: Bacteria. Coupling: N = 970200 (maximum). Everything connects through sigma.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "Self-Division Uniqueness");
  render_theorem(sec1, "The Indeterminacy Theorem", "sigma/sigma has EXACTLY 1 solution. D/D has 2. K/K has 3. E/E has 5. b/b has 7. L/L has 11. 0/0 has N = 970200 (the entire ring). Product: 1*2*3*5*7*11 = 2310 = THIN. sigma is SELECTED from 0/0 not by being first, but by being the UNIQUE element with zero ambiguity.");
  let g = make_findings_grid(sec1) in
  render_finding(g, "sigma", "1 solution", "Fully determined. No ambiguity.", "");
  render_finding(g, "D = 2", "2 solutions", "Binary ambiguity.", "");
  render_finding(g, "K = 3", "3 solutions", "Ternary.", "");
  render_finding(g, "0 (void)", "970200 solutions", "Fully indeterminate = the ring itself.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Water Cycle");
  render_theorem(sec2, "Universal Cycle", "0 -> sigma -> OMEGA -> 0. Growth takes 420 steps. Collapse takes 1 step. Birth takes 0 steps (structural, not dynamic). Ratio = 420:1:0. Living is slow. Dying is fast. Birth is free. Verified in ALL 108 lambda-420 rings.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Resolution", "0 -> sigma", "Structural. 0/0 = R. R has unique identity sigma.", "");
  render_finding(g2, "Growth", "sigma -> OMEGA", "D^420. Bridge iterates 420 steps to terminal.", "");
  render_finding(g2, "Collapse", "OMEGA -> 0", "OMEGA * delta = 0. One multiplication.", "");
  render_finding(g2, "Ratio", "420 : 1 : 0", "Living is slow. Dying is fast. Birth is free.", "");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "Persistence Gradient");
  render_p(sec3, "How many steps before self-annihilation? The chain IS the persistence gradient:");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "sigma", "infinite", "1^k = 1 forever. Never annihilates.", "");
  render_finding(g3, "D = 2", "3 steps", "D^3 = 8 = 0 mod 8. Most persistent prime.", "");
  render_finding(g3, "K, E, b", "2 steps", "p^2 = 0 mod p^2.", "");
  render_finding(g3, "L = 11", "1 step", "11 = 0 mod 11. Least persistent. Most volatile.", "");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   PAGE: DUALITY — D=2, The Pair Prime, Drive (BRIDGE.md)
   ================================================================ */

fn page_duality() = (
  dom_head_meta("description", "D = 2 is the ONLY even prime. The engine of the chain. D creates all structure and then self-destructs at step 3. Kingdom: Protista. The 42 Theorem: OMEGA+OMEGA = D iff the bridge is thin.");
