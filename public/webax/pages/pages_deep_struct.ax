fn fields_class_mirror() = (
  let sec = make_section("800px") in
  render_h2(sec, "Class Number Mirror");
  render_theorem(sec, "Class Number Involution (S316-S317)", "mu(p) = last exponent n with smooth h(Q(sqrt(-sqfree(2*p^n+1)))): mu(D)=L, mu(L)=D. mu(E)=b, mu(b)=E. mu(K)=D^3, mu(D^3)=K. INVOLUTION. Pair sums: {D+L, E+b, K+D^3} = {13, 12, 11} = three consecutive integers {L, L+1, L+2}. Sum = (D*K)^2 = 36.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Product sum", "D*L+K*D^3+E*b = K^4 = 81", "Products form an arithmetic progression step D*K, sum = ANSWER. Mirror sum = K*L = 33.", "");
  render_finding(g, "Breach primes", "D:13, K:13, E:23, b:31, L:43", "First h value that fails smoothness. Sum = D*E*L = 110. All intruders are axiom-named.", "");
