  render_finding(g, "Pell duality", "b = K^2-D, L = K^2+D", "SAME y = K for both! x_b+x_L = D^3+D*E = 2K^2 = ME. E excluded from near-square Pell families.", "");
  render_finding(g, "Named Pells", "HYDOR, KEY, 163", "Pell(HYDOR): (KEY,D^2). Pell(D*KEY): (163,ME). Pell(b*KEY): (288=classes,17). KEY controls 163.", "");
