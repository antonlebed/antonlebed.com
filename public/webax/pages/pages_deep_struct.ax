  render_p(sec, "Kingdom irreducibility: ALL 6 kingdom numbers are Gaussian-irreducible. Each N/p contains >= 1 of {K,b,L} (primes 3 mod 4) to odd power. HYDOR = K*E*b: blocked by K AND b. Doubly irreducible.");
  dom_append(dom_body(), sec)
)

fn fields_eisenstein() = (
  let sec = make_section("800px") in
  render_h2(sec, "Eisenstein Lattice: The Closure Field");
  render_p(sec, "Z[omega] has discriminant -K = -3, omega = e^(2*pi*i/3). Norm: N(a,b) = a^2-ab+b^2. Applied to axiom pairs:");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Pair (a,-b)");
  render_th(hdr, "Norm");
  render_th(hdr, "Value");
  render_th(hdr, "Name");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "(sigma, -D)", "1+2+4", "7 = b", "Depth");
  render_table_row_4(tbl, "(D, -K)", "4+6+9", "19 = f(E)", "Depth quadratic at E");
  render_table_row_4(tbl, "(K, -E)", "9+15+25", "49 = b^2", "Depth squared");
  render_table_row_4(tbl, "(D^2, -E)", "16+20+25", "61", "Sense codons");
  render_table_row_4(tbl, "(D, -b)", "4+14+49", "67 = SOUL", "D^6 + K");
  render_table_row_4(tbl, "(E, -b)", "25+35+49", "109 = f(L)", "Depth quadratic at L");
  render_table_row_4(tbl, "(K, -L)", "9+33+121", "163", "Heegner terminus");
  render_theorem(sec, "Eisenstein-Gaussian Duality (S293)", "For pair (D^2, E): Eisenstein norm = 61 (sense codons). Gaussian norm = 41 (KEY). Difference = D^2*E = 20 (essential amino acids). General: N_Eis(a,-b) - N_Gauss(a,b) = ab. The genetic code = difference between the two fields.");
  dom_append(dom_body(), sec)
)

fn fields_heegner() = (
  let sec = make_section("800px") in
  render_h2(sec, "Heegner Numbers");
  render_p(sec, "The 9 Heegner numbers (d where Q(sqrt(-d)) has class number 1): {1,2,3,7,11,19,43,67,163}.");
  render_theorem(sec, "Heegner-Cunningham Theorem (S315)", "ALL 9 = axiom primes OR Cunningham images of K-products. Axiom: {sigma,D,K,b,L}. Cunningham c(n) = 2n+1: c(K*K)=19, c(K*b)=43, c(K*L)=67, c(K^4)=163. K (closure) generates ALL Heegner through the axiom.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "h");
  render_th(hdr, "h(-d)");
  render_th(hdr, "Axiom source");
  render_th(hdr, "E_3 representation");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "1 = sigma", "1", "Axiom prime", "N(void, sigma)");
  render_table_row_4(tbl, "2 = D", "1", "Axiom prime", "NON-REP (2 mod K)");
  render_table_row_4(tbl, "3 = K", "1", "Axiom prime", "N(sigma, D)");
  render_table_row_4(tbl, "7 = b", "1", "Axiom prime", "N(sigma, K)");
  render_table_row_4(tbl, "11 = L", "1", "Axiom prime", "NON-REP (2 mod K)");
  render_table_row_4(tbl, "19", "1", "c(K*K) = c(9)", "N(D, E)");
  render_table_row_4(tbl, "43", "1", "c(K*b) = c(21)", "N(sigma, b)");
  render_table_row_4(tbl, "67 = SOUL", "1", "c(K*L) = c(33)", "N(D, K^2)");
  render_table_row_4(tbl, "163", "1", "c(K^4) = c(81)", "N(K, D*b)");
  let g = make_findings_grid(sec) in
  render_finding(g, "E EXCLUDED", "h(-5) = D = 2", "Only axiom prime with class number > 1. Self-blindness = failure of unique factorization.", "");
  render_finding(g, "Shadow triple gap", "{19,43,67} = c(K*{K,b,L})", "Constant gap 24 = D^3*K. PROOF: gap = 2K*(p2-p1), b-K = L-b = D^2 (Pell twins). QED.", "S785");
  render_finding(g, "Non-rep sum", "D + L = GATE = 13", "The two non-representable Heegner = CC1(D) axiom primes. Their sum = shadow stopper.", "S730");
  dom_append(dom_body(), sec)
)

fn fields_163() = (
  let sec = make_section("800px") in
  render_h2(sec, "163: Two Roads to the Terminus");
  render_theorem(sec, "163 Cube Identity (S727)", "163 = D^5*K^2 - E^3 = 288 - 125. Also: 163 = N_Eis(K,-L) = K^2+K*L+L^2. Two independent roads. COROLLARY: j(i) = 1728 = D*K*(E^3+163) = D*K*classes(THIN). CRT(1728) = (0, 0, K, GATE, sigma).");
