  let sec3 = make_section("800px") in
  render_h2(sec3, "The n Generator");
  render_p(sec3, "Every correction coefficient n has the form: n = sign * K^a / (D^d * E^e). Sign = +1 for binding (EM, baryons, cosmo). Sign = -1 for decay (leptons, weak, anomaly). K = complexity, D = scale, E = stability. The axiom corrects itself.");
  dom_append(dom_body(), sec3)
)

