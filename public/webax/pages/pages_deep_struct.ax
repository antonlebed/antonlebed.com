)

fn fields_contrast() = (
  let sec = make_section("800px") in
  render_h2(sec, "Paradigm Contrast");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Claim");
  render_th(hdr, "Standard");
  render_th(hdr, "Axiom");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "Heegner numbers", "9 exceptional discriminants", "First 5 = axiom chain. Remaining 4 = c(K*{K,b,L,K^3}). K generates all 9. E excluded.");
  render_contrast_row(tbl, "Gaussian splitting", "p = 1 mod 4 splits", "E=5 is the ONLY axiom prime with Leg=+1. Self-blindness = decomposability = splitting.");
  render_contrast_row(tbl, "Two quadratic fields", "Z[i] and Z[omega]", "Bridge (disc=-D^2) generates gate/key constants. Closure (disc=-K) generates depth/Heegner. Together = the axiom.");
  render_contrast_row(tbl, "Pell equations", "Diophantine curiosity", "ALL 5 axiom Pells have smooth solutions. Sum(x)=32=D^5. Sum(y)=13=GATE. The idempotents and shadow stopper.");
  render_contrast_row(tbl, "j(i) = 1728", "CM theory value", "D*K*(E^3+163). CRT(1728) = (0,0,K,GATE,sigma). Gate in the depth channel. Three fields converge at one pair.");
  render_contrast_row(tbl, "Genetic code", "61 sense codons", "Phi_3(D^2,E) = Phi_10(K) = 61. Two independent cyclotomics converge ONLY at D=2. 64-61=K.");
  render_p(sec, "The axiom primes control number fields as completely as they control the ring itself. Every Heegner number, every Pell solution, every Gaussian norm -- all forced by the same five primes precipitated from 0/0.");
  dom_append(dom_body(), sec)
)

fn page_fields() = (
  dom_head_meta("description", "Number fields and the axiom. Gaussian norms: |sigma+Di|^2=E, |D+Ki|^2=GATE. Eisenstein lattice: all key constants from one operation. Heegner-Cunningham: all 9 = axiom + c(K*p). Pell: all 5 smooth, Sum(x)=32=D^5. 163 = D^5*K^2-E^3 = Eisenstein norm. Class number mirror involution.");
  fields_hero();
  fields_gaussian();
  fields_eisenstein();
  fields_heegner();
  fields_163();
  fields_pell();
  fields_legendre();
  fields_class_mirror();
  fields_contrast()
)

