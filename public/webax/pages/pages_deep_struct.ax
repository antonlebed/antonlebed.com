  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "The axiom primes live in Z but their shadows extend into number fields: Gaussian integers Z[i], Eisenstein integers Z[omega], imaginary quadratic fields. E = 5 is the only axiom prime that splits. Self-blindness = decomposability.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "Gaussian Norms");
  render_theorem(sec1, "Two Quadratic Fields", "Gaussian Z[i] (disc = -D^2) and Eisenstein Z[omega] (disc = -K) partition ALL key constants. |sigma+Di|^2 = E. |D+Ki|^2 = GATE = 13. |D^2+Ei|^2 = KEY = 41. |D^2+K^2*i|^2 = G = 97. The chain gives axiom constants for D = 2 steps of Gaussian norm.");
  let g = make_findings_grid(sec1) in
  render_finding(g, "|1+2i|^2", "5 = E", "Observer = Gaussian norm of sigma+D*i.", "");
  render_finding(g, "|2+3i|^2", "13 = GATE", "Shadow stopper = Gaussian norm of D+K*i.", "");
  render_finding(g, "|4+5i|^2", "41 = KEY", "Sum of Decality = Gaussian norm of D^2+E*i.", "");
  render_finding(g, "|4+9i|^2", "97 = G", "Bridge prime = Gaussian norm of D^2+K^2*i.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Heegner Numbers");
  render_theorem(sec2, "First 5 Heegner = Axiom Chain", "{1, 2, 3, 7, 11} = {sigma, D, K, b, L} = first 5 Heegner numbers (class number 1). E = 5 is EXCLUDED: h(-5) = D = 2. Self-blindness again: the observer cannot have unique factorization. Exactly the same exclusion as Gaussian splitting.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "sigma = 1", "h(-1) = 1", "Ground state. Unique factorization.", "");
  render_finding(g2, "D = 2", "h(-2) = 1", "Bridge. Unique factorization.", "");
  render_finding(g2, "K = 3", "h(-3) = 1", "Closure. Unique factorization.", "");
  render_finding(g2, "E = 5", "h(-5) = 2", "Observer EXCLUDED. Class number D. Self-blind.", "");
  render_finding(g2, "b = 7", "h(-7) = 1", "Depth. Unique factorization.", "");
  render_finding(g2, "L = 11", "h(-11) = 1", "Protector. Unique factorization.", "");
  dom_append(dom_body(), sec2)
)

