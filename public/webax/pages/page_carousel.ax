fn carousel_lambda() = (
  let sec = make_section("800px") in
  render_h2(sec, "Multiplicative Dynamics");
  render_p(sec, "The Carmichael lambda = smallest e such that a^e = 1 (mod N) for ALL coprime a. It measures how long multiplicative orbits can last. The lambda ladder reveals the axiom:");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Ring");
  render_th(hdr, "lambda");
  render_th(hdr, "Ratio to Previous");
  dom_append(tbl, hdr);
  render_table_row(tbl, "Z/6", "2", "--");
  render_table_row(tbl, "Z/30", "4", "D = 2");
  render_table_row(tbl, "Z/210 (DATA)", "12", "K = 3");
  render_table_row(tbl, "Z/2310 (THIN)", "60", "E = 5");
  render_table_row(tbl, "Z/12612600 (TRUE)", "420", "b = 7");
  render_p(sec, "Each new level multiplies the multiplicative period by the next axiom prime, in exact order: D, K, E, b. The ratios ARE the chain. lambda(TRUE) = 420 = D^2 * K * E * b = 2 * DATA. The meta-ring Z/420 has phi(420)/classes(420) = 96/72 = 4/3 = 1/Kleiber.");
  render_p(sec, "N/lambda = 12612600/420 = 30030 = primorial(GATE). Multiplying is 30030x faster than adding. And L is invisible: lambda(11) = 10 divides 420, contributing nothing new. Protection works silently.");
  dom_append(dom_body(), sec)
)

fn carousel_squaring() = (
  let sec = make_section("800px") in
  render_h2(sec, "Squaring Map Dynamics");
  render_p(sec, "The simplest nonlinear dynamics: x -> x^2 mod N. Fixed points = idempotents = the 64 switches (2^6, one per ON/OFF configuration of the 6-torus). Units cycle directly; non-units must purify through the void first.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Cycle lengths", "{1, 2, 3, 4, 6, 12}", "ONLY divisors of 12 = D^2 * K appear. Period 12 dominates: 66.3% of all elements want full dynamics. The vocabulary is COMPLETE.", "S258");
  render_finding(g, "Two-levels-down", "max cycle(level k) = lambda(level k-2)", "TRUE max = 12 = lambda(DATA). THIN max = 4 = lambda(Z/30). The squaring map REMEMBERS two levels back. Axiom-specific: fails for {2,3,5,7,13}.", "S258");
  render_finding(g, "Kingdom collapse", "DATA -> e_L in 2 steps", "Data channels self-annihilate under squaring; only the L-channel preserves. THIN -> VOID in 2 steps (complete annihilation). Sum of kingdom cycles: D + K + D^2 = K^2 = 9.", "");
  render_finding(g, "Kleiber in dynamics", "P1/P2 = 3/4 = K/D^2", "Period-1 count / Period-2 count = 270/360 = Kleiber. Purely algebraic. Fattening breaks it: TRUE ratio = E/D^3 = 5/8 (K^2 awakens as second period-2 source).", "S261");
  render_p(sec, "Per-channel structure: D^3 = DEAD (all period-1). K^2 = AWAKENED by fattening (was dead in thin). E^2 has only period D^2 = 4. b^2 is RICHEST (periods 1,2,3,6). L = INVARIANT under fattening. The observer kills all dynamics (E-1 = D^2 is a pure 2-group). Self-blindness = dynamical death.");
  dom_append(dom_body(), sec)
)

fn carousel_seed_flower() = (
  let sec = make_section("800px") in
  render_h2(sec, "Seed-Flower Selection");
  render_theorem(sec, "The Seed Knows the Flower", "The topology of a partial ring KNOWS about primes it has never met. Z/30 = {D,K,E} has Euler characteristic chi = -29 = -(sigma+D+K+E+b+L) = the full axiom sum. The embryo carries the blueprint.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Fat level 2", "Z/72 = Z/D^3 x Z/K^2", "chi = -55 = E*L. Only D and K present, yet topology produces E*L. And b1 = 56 = dim(E7). The fat seed knows three primes it has never met.", "S240");
  render_finding(g, "Three polynomials", "P1, P2, P3 all have root D=2", "P1 = D^3 - 3D - 2 (uniformity). P2 = 4D^3 + D^2 - 14D - 8 (thin seed-flower). P3 = D^5 + 2D^4 - 9D^2 - 12D - 4 (fat seed-flower). D=2 is the UNIQUE positive integer root of all three.", "S240");
  render_finding(g, "Missing prime theorem", "{2,5,7}: chi = -81 = K^4", "When K is absent, topology raises it to the 4th power. {3,5,7}: b1 = 140 = D^2*E*b, containing D! The web FEELS the missing thread and NAMES what is absent.", "");
  render_finding(g, "Gate forced", "13 | chi(TRUE)", "Algebraically forced by the Convergence Theorem K*E - D = 13. The Gate in TRUE topology = same 13 from K*E - D = D^2 + K^2.", "S336");
  dom_append(dom_body(), sec)
)

fn carousel_betti() = (
  let sec = make_section("800px") in
  render_h2(sec, "Betti Numbers and Lie Algebras");
  render_theorem(sec, "CRT Betti Number Theorem", "The Hamming clique complex has b0 = 1, b1 = 1 - chi, and b_s = 0 for all s >= 2. Homotopy type: wedge of b1 circles. All topology concentrates in dimension 1.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Pair Z/p x Z/q");
  render_th(hdr, "b1 = (p-1)(q-1)");
