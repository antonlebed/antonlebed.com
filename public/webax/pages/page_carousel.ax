  render_table_row(tbl, "D^3 x K^2", "56", "dim(E7 fundamental)");
  render_table_row(tbl, "E^2 x L", "240", "|roots(E8)|");
  render_table_row(tbl, "K x E", "8", "dim(SU(3))");
  render_table_row(tbl, "E x b", "24", "dim(SU(5))");
  render_table_row(tbl, "b^2 x L", "480", "phi(THIN)");
  render_table_row(tbl, "K^2 x b^2", "384", "b1(DATA) = D^7 * K");
  render_p(sec, "b1-SU Theorem: b1(Z/p x Z/(p+D)) = p^2 - 1 = dim(SU(p)). Trivially forced by D = 2 (difference of squares). PSL Ladder: b1(K,b) = 12 = |PSL(2,K)|, b1(b,L) = 60 = |PSL(2,E)|, b1(D^3,E^2) = 168 = |PSL(2,b)|.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Silence Theorem", "b1 mod q_j = 0 iff condition", "b1 vanishes in channel j iff prod of OTHER factors = 1 mod q_j. Z/30 is the UNIQUE all-silent triple. D is ALWAYS silent in the thin tower (product of odds = 1 mod 2). 5888/5888 verified.", "S338");
  render_finding(g, "DATA b1/phi", "384/48 = D^3 = 8", "The spider's legs. The DATA ring's Betti-to-totient ratio IS the number of spider legs. Protected by 383 = D^7*K - 1 (prime).", "S329");
  dom_append(dom_body(), sec)
)

