fn carousel_hero() = (
  let hero = make_hero("The Carousel") in
  let eq = dom_create("div") in
  dom_text(eq, "Z/12612600 = Z/8 x Z/9 x Z/25 x Z/49 x Z/11 x Z/13 = T^6");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Think of a merry-go-round with six rings, each spinning at a different speed. The inner ring completes a full turn in 2 clicks. The next in 3. Then 5, 7, 11, 13. They all start aligned. How long until they align again? Exactly 30030 clicks -- the thin ring.");
  render_p(hero, "In the True Form, give each ring its full depth: 8, 9, 25, 49, 11, 13 positions. Now it takes 12,612,600 clicks. Adding 1 to any number advances every ring by one click. This is the carousel -- addition as rotation through a six-dimensional torus.");
  dom_append(dom_body(), hero)
)

fn carousel_frozen() = (
  let sec = make_section("800px") in
  render_h2(sec, "Frozen Ring Theorem");
  render_p(sec, "When n is divisible by a prime p, the corresponding ring is FROZEN at position 0. It cannot spin. Your composition IS your constraint: what you are made of, you cannot move past. Your MOTION is toward what you LACK.");
  let g = make_findings_grid(sec) in
  render_finding(g, "H(n)", "6 - omega(gcd(n, N))", "Hamming weight = spinning rings. H(0) = 0 (axis, all frozen). H(units) = 6 (all spinning). N = 12612600.", "");
  render_finding(g, "Reaching Theorem", "n spins what it lacks", "Water (105 = K*E*b) reaches for D, L, and GATE. DATA (210 = D*K*E*b) spins only L and GATE. The incomplete reaches for its protectors.", "");
  render_finding(g, "Mode", "H = 5 (typical)", "In the TRUE ring, each prime factor freezes one of 6 rings. phi(N) = 2419200 units at H = 6 (all spinning). The holographic split (490 = D*E*b^2) freezes DEAD channels {D,E,b}, leaving ALIVE channels {K,L,GATE} spinning.", "");
  render_finding(g, "Axis duality", "0 vs sigma", "Void: (0,0,0,0,0,0) = perfectly still. sigma: (1,1,1,1,1,1) = maximum motion. The child rests at the center while the sun revolves around him.", "");
  dom_append(dom_body(), sec)
)

fn carousel_cost() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Cost of Spinning");
  render_p(sec, "Each ring you activate costs 4*sin^2(pi/p) in phase coherence. The void (all off) has eigenvalue D*E = 10 -- maximum coherence. Every spinning ring reduces it. The hierarchy activates expensive rings first and cheap rings last.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Ring");
  render_th(hdr, "Cost 4*sin^2(pi/p)");
  render_th(hdr, "Meaning");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "D = 2", "4.000 (maximum)", "Duality costs the most. The first split is the deepest wound.");
  render_contrast_row(tbl, "K = 3", "3.000", "Closure costs as much as itself. K gates K.");
  render_contrast_row(tbl, "E = 5", "1.382", "Observation is mid-cost. phi^2 = (golden ratio)^2.");
  render_contrast_row(tbl, "b = 7", "0.753", "Suffering is surprisingly cheap. Depth is easy to spin.");
  render_contrast_row(tbl, "L = 11", "0.317", "Protection barely costs anything. The guardian is nearly free.");
  render_contrast_row(tbl, "GATE = 13", "0.229", "The skin. Cheapest to spin. The boundary that wraps everything costs almost nothing.");
  render_p(sec, "Total cost (all 6 on): 9.681. The hierarchy builds in OPPOSITE order of cost: D > K > E > b > L > GATE. The axiom activates expensive rings first. The GATE is cheapest -- the skin that wraps the organism barely costs anything to maintain.");
  dom_append(dom_body(), sec)
)

fn carousel_braid() = (
  let sec = make_section("800px") in
  render_h2(sec, "The CRT Braid");
  render_p(sec, "Six CRT channels = 6 strands cycling at rates 2, 3, 5, 7, 11, 13. Walking n = 0 to N-1 makes each strand wrap at its prime period. The interleaving of these six rhythms IS a braid -- not metaphorically, but literally in the mathematical sense.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Crossings", "11822 per walk", "EXACT BEAT FORMULA: net per beat = -gcd(p_i - 1, p_j - 1). Total signed chirality: -gcd(p_i-1, p_j-1) * N/(p_i*p_j). All 10 pairs verified.", "");
  render_finding(g, "Density", "[143, 151] per 30-step window", "Uniform. No clustering. The braid has no preferred location -- crossings spread evenly through the walk.", "");
  render_finding(g, "CRT Neighbors", "97 = TRUE Hamming degree", "In the TRUE ring, every element shares 5 of 6 channels with exactly 97 others. Degree = sum(q_i - 1) = 7+8+24+48+10+12 = 97. The topology IS the algebra.", "S238");
  render_finding(g, "Chirality", "LEFT-HANDED at all levels", "Larger primes dominate smaller. Verified at Z/6, Z/30, Z/210, Z/2310. Nature's handedness.", "");
  render_p(sec, "Twist ratios between strands: K/D = 3/2 (the musical fifth), E/K = 5/3 (Kolmogorov turbulence ratio), b/E = 7/5, L/b = 11/7, GATE/L = 13/11. The braid's internal rhythm IS music and turbulence.");
  dom_append(dom_body(), sec)
)

fn carousel_strand_height() = (
  let sec = make_section("800px") in
  render_h2(sec, "Strand Height Order");
  render_theorem(sec, "Depth Rises Highest", "Row sums of the interleaving matrix: b(+457) > L(+389) > E(+323) > K(-283) > D(-886). Sum = 0 (conservation). Depth surfaces. Suffering rises highest on the carousel.");
  render_p(sec, "D sinks deepest (-886), b rises highest (+457). The bridge that started everything gets pushed down; the suffering that came last rises above all others. Conservation: the total signed displacement is exactly zero. What goes down must come up.");
  dom_append(dom_body(), sec)
)

fn carousel_torus_knots() = (
  let sec = make_section("800px") in
  render_h2(sec, "10 Torus Knots");
  render_p(sec, "C(5,2) = 10 pairs from {2,3,5,7,11} give 10 torus knots T(p_i, p_j). Seifert matrix eigenvalues = grid Laplacian on (p-1) x (q-1). ALL 10 have NEGATIVE signature (left-handed, consistent with chirality).");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Level");
  render_th(hdr, "Total Signature");
  render_th(hdr, "Factorization");
  render_th(hdr, "Note");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "Z/6 (D*K)", "-2", "D", "Trefoil. Simplest nontrivial knot.");
  render_table_row_4(tbl, "Z/30 (D*K*E)", "-12", "D^2 * K", "Trinity heart number.");
  render_table_row_4(tbl, "Z/210 (D*K*E*b)", "-42", "D * K * b = ANSWER", "The answer. Not arbitrary.");
  render_table_row_4(tbl, "Z/2310 (D*K*E*b*L)", "-132", "D^2 * K * L", "Full thin ring.");
  render_p(sec, "Crossing number ladder: Level 2 has K=3 crossings, Level 3 has ME=18, Level 4 has SOUL=67, Level 5 has DATA=210. Torus knot complexity at each level IS the hierarchy's catalog.");
  dom_append(dom_body(), sec)
)

fn carousel_hamming_graph() = (
  let sec = make_section("800px") in
  render_h2(sec, "CRT Hamming Graph");
  render_p(sec, "The CRT neighbor graph -- elements sharing k-1 of k channels -- IS the Hamming graph H = K_q1 [] K_q2 [] ... [] K_qk (Cartesian product of complete graphs). This is provably the topology of the product.");
  render_theorem(sec, "Hamming Spectrum Theorem", "Eigenvalues: lambda_S = sum_{i in S} q_i - k, for each subset S of factors. Multiplicity: prod_{i not in S}(q_i - 1). Max eigenvalue = degree = sum(q_i - 1). Min eigenvalue = -k. 2^k = 32 distinct eigenvalues in the TRUE FORM -- no eigenvalue merging.");
  let g = make_findings_grid(sec) in
  render_finding(g, "THIN degree", "23 (self-referencing)", "Number of distinct eigenvalues = max eigenvalue = degree = 23 = CC1(D) prime.", "S238");
  render_finding(g, "TRUE degree", "97 = G (bridge)", "7+8+24+48+10 = 97. Hamming-Lie Bridge: each channel Z/q_i has Lie algebra A_{q_i-1}. deg(Hamming) = sum(Lie ranks) = G.", "S237");
  render_finding(g, "TRUE separation", "All 32 subset sums distinct", "Factors are superlacunary: 25 > 8+9, 49 > 8+9+25. No two subsets collide. Perfect 1:1 switch-to-eigenvalue map.", "S238");
  render_finding(g, "D-Gap Theorem", "gap = min(q_i) = D-power", "THIN: 23-21 = D. TRUE: 97-89 = D^3 = 8. Duality controls topology.", "");
  dom_append(dom_body(), sec)
)

fn carousel_shell_polynomial() = (
  let sec = make_section("800px") in
  render_h2(sec, "Shell Polynomial and Chromatic Depth");
  render_p(sec, "The shell polynomial E(x) = prod(1 + (q_i-1)*x) counts elements at each CRT distance. Coefficient e_d = number at distance d from any fixed point.");
  let g = make_findings_grid(sec) in
  render_finding(g, "DATA shells", "e_2 = 56 = dim(E7)", "e_0=1(sigma), e_1=13(shadow stopper), e_2=56(E7 fundamental), e_3=92, e_4=48(SEES). Distance-2 shell IS the Lie dimension.", "");
  render_finding(g, "THIN shells", "e_3 = 652 = D^2*163", "163 = Heegner prime. e_4 = 968 = D^3*L^2. Shell sizes ARE axiom constants.", "");
  render_finding(g, "Chromatic number", "chi = max(q_i)", "DATA: chi=b=7. THIN: chi=L=11. TRUE: chi=b^2=49. Hamming graphs are perfect: chi=omega. The deepest channel decides coloring.", "");
  render_finding(g, "THIN alpha = DATA", "210 = DATA ring", "Largest non-conflicting set in the thin Hamming IS the data ring. Independence number alpha = N/max(q_i).", "");
  render_finding(g, "Kleiber null", "360/480 = 3/4 = K/D^2", "Null eigenvalue exists BECAUSE E = D+K. Two subsets: {E=5} and {D+K=2+3=5}. Merged multiplicity 360. Kleiber's 3/4 from observer = duality + closure.", "");
  dom_append(dom_body(), sec)
)

fn carousel_shadow() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Shadow Descent");
  render_p(sec, "Every odd prime has a shadow: s(p) = (p-1)/2. This maps each prime to a previous value in the chain. Two branches emerge:");
  let g = make_findings_grid(sec) in
  render_finding(g, "Branch 1 (L-descent)", "11 -> 5 -> 2", "Product: D*E*L = 110. Sum: D+E+L = 18 = ME (the axiom sum sigma+D+K+E+b).", "");
  render_finding(g, "Branch 2 (b-descent)", "7 -> 3 -> 1", "Product: sigma*K*b = 21. Sum: sigma+K+b = 11 = L.", "");
  render_p(sec, "Each branch's sum equals the other branch's defining value. Branch 1 sums to ME = 18. Branch 2 sums to L = 11. coupling(110) = 21. coupling(21) = 110. Coupling duals! The two readings of the chain ARE the two descent branches, each carrying the other's secret.");
  dom_append(dom_body(), sec)
)

