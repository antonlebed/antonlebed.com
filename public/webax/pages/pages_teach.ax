  render_finding(g, "Sum", "b + L = 2*K^2 = 18", "Symmetric around closure squared.", "");
  render_finding(g, "Gap", "L - b = 2D = 4", "Bridge separates twins.", "");
  dom_append(dom_body(), sec)
)

