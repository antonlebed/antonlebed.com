  render_finding(g, "Denominator", "DKE = 30", "B_420 denominator = axiom product.", "");
  dom_append(dom_body(), sec)
)

fn page_k_squared_stop() = (
  dom_head_meta("description", "K^2 = 9 = D^3 + 1. The only consecutive prime powers. Mihailescu 2002.");
