fn page_cunningham() = (
  dom_head_meta("description", "Two Cunningham chains generate all five axiom primes. c(n) = 2n+1.");
  domain_hero("The Two Chains", "c(n) = 2n + 1", "The simplest function that generates the axiom.");
  let sec = make_section("800px") in
  let g = make_findings_grid(sec) in
  render_finding(g, "CC1(sigma)", "1 -> 3 -> 7", "Length K=3. Stops at 15 = 3*5.", "");
  render_finding(g, "CC1(D)", "2 -> 5 -> 11", "Length E=5. Stops at 23 -> 47.", "");
  render_finding(g, "Interleave", "1 2 3 5 7 11", "Both chains merge by size = axiom order.", "");
  render_finding(g, "Shadow", "s(p) = (p-1)/2", "Inverse of Cunningham. Recovers the chain.", "");
  dom_append(dom_body(), sec)
)

fn page_heegner() = (
  dom_head_meta("description", "Nine Heegner numbers where unique factorization holds.");
