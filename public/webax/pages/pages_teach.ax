  render_finding(g, "The Nine", "{1,2,3,7,11,19,43,67,163}", "Stark-Heegner 1967.", "");
  render_finding(g, "Axiom subset", "{1,2,3,7,11}", "First five minus E=5.", "");
  render_finding(g, "Cunningham", "Chain generates all 9", "Through iterated 2n+1.", "");
  render_finding(g, "Eisenstein", "163 closes", "Largest class-1 discriminant.", "");
  dom_append(dom_body(), sec)
)

