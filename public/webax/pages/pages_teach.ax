  let sec = make_section("800px") in
  let g = make_findings_grid(sec) in
  render_finding(g, "Catalan", "9 = 8 + 1", "Only consecutive prime powers.", "");
  render_finding(g, "Three proofs", "(D,K) = (2,3)", "Forced by independent arguments.", "");
  render_finding(g, "Pascal row 13", "Run lengths = axiom", "GATE row spells the chain.", "");
  render_finding(g, "Spider", "D^3 + sigma = K^2", "8 legs + 1 body = 9 strands.", "");
  dom_append(dom_body(), sec)
)

fn page_pell_twins() = (
  dom_head_meta("description", "b=7 and L=11 are Pell twins. Both solve x^2 - py^2 = 1 with y = K = 3.");
  domain_hero("The Pell Twins", "b = K^2 - D; L = K^2 + D", "Depth and Protector. Mirror pair.");
  let sec = make_section("800px") in
  let g = make_findings_grid(sec) in
  render_finding(g, "b = 7", "x^2 - 7y^2 = 1", "Fundamental y = K = 3. (x=8).", "");
  render_finding(g, "L = 11", "x^2 - 11y^2 = 1", "Fundamental y = K = 3. (x=10).", "");
  render_finding(g, "Sum", "b + L = 2*K^2 = 18", "Symmetric around closure squared.", "");
  render_finding(g, "Gap", "L - b = 2D = 4", "Bridge separates twins.", "");
  dom_append(dom_body(), sec)
)

