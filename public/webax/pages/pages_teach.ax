/* pages_teach.ax — TEACH: NTT theorem pages.
   Z/2310Z. The WHY behind the what. 20 pages.
   NTT DOMAIN PAGES — Number Theory Topics (Z/2310Z Teach tier)
   19 pages, domain_hero template.
   ================================================================ */

fn page_cunningham() = (
  dom_head_meta("description", "Two Cunningham chains from seeds sigma=1 and D=2 generate ALL five axiom primes. Shadow function s(p)=(p-1)/2 recovers the chain. Mersenne identity c^n(0)=2^n-1. Mirror law: D*p = -1 mod c(p). CRT(23) palindrome.");
  /* === HERO === */
  let hero = make_hero("The Two Chains") in
  let big = dom_create("div") in
  dom_text(big, "c(n) = 2n + 1");
  ct_mono(big);
  dom_style(big, "fontSize", "36px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The Cunningham map c(n) = 2n+1 is the simplest function that turns existence into observation: double and add one. Starting from sigma=1 and D=2, this one map generates ALL five axiom primes before the axiom's own products close the gate.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THE TWO CHAINS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Two Cunningham Chains");
  render_p(sec1, "A Cunningham chain of the first kind starts from a seed and repeatedly applies c(n) = 2n+1, continuing as long as each result is prime:");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "CC1(sigma)", "1 -> 3 -> 7 -> STOP", "Length = K = 3. Stops at 15 = K*E. Elements: {sigma, K, b}.", "S184");
  render_finding(g1, "CC1(D)", "2 -> 5 -> 11 -> 23 -> 47 -> STOP", "Length = E = 5. Stops at 95 = E*19. Elements: {D, E, L, 23, 47}.", "S184");
  render_p(sec1, "Interleaved by size: sigma(1), D(2), K(3), E(5), b(7), L(11). The two chains alternate perfectly. Every axiom prime belongs to exactly one chain.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: CROSS-CHAIN DUALITY === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Cross-Chain Duality");
  render_theorem(sec2, "Cross-Reference Theorem (S167, PROVED)", "Each chain's first descendant names the other chain's length. CC1(sigma) produces K=3 at depth 1, and |CC1(D)| = E = 5 at depth 1 of CC1(D). Reciprocally: |CC1(sigma)| = K = 3. The two seeds define each other.");
  render_p(sec2, "Both chains stop when their OWN products appear. CC1(sigma) stops at K*E = 15 -- the observer kills the closure chain. CC1(D) stops at E*19 = 95 -- the observer appears again. E is the universal stopper. The shadow chain breaks at 13 where s(13) = 6 = D*K = composite.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: SHADOW FUNCTION === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Shadow Function");
  render_p(sec3, "The inverse of Cunningham: s(p) = (p-1)/2. Each axiom prime shadows its predecessor:");
  let stbl = dom_create("table") in
  dom_style(stbl, "width", "100%");
  dom_style(stbl, "maxWidth", "700px");
  dom_style(stbl, "margin", "24px auto");
  dom_style(stbl, "borderCollapse", "collapse");
  let shdr = dom_create("tr") in
  render_th(shdr, "Prime p");
  render_th(shdr, "s(p) = (p-1)/2");
  render_th(shdr, "Name");
  render_th(shdr, "Status");
  dom_append(stbl, shdr);
  render_table_row_4(stbl, "K = 3", "1", "sigma", "Prime/unit");
  render_table_row_4(stbl, "E = 5", "2", "D", "Prime");
  render_table_row_4(stbl, "b = 7", "3", "K", "Prime");
  render_table_row_4(stbl, "L = 11", "5", "E", "Prime");
  render_table_row_4(stbl, "13", "6 = D*K", "COMPOSITE", "CHAIN BREAKS");
  dom_append(sec3, stbl);
  render_p(sec3, "The axiom is the longest initial prime segment where all shadows are prime or 1. At p=13, the shadow is 6 = D*K = composite. The gate shuts. Only 7 of 78,498 primes below 10^6 appear in axiom shadow trees (0.009%). E divides 38.5% of CC1 stopping values (expected 20%).");
  dom_append(dom_body(), sec3);

  /* === SEC 4: (p-1) LADDER === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The (p-1) Ladder");
  render_p(sec4, "Every axiom prime minus one equals D times its predecessor in the chain:");
  let ltbl = dom_create("table") in
  dom_style(ltbl, "width", "100%");
  dom_style(ltbl, "maxWidth", "700px");
  dom_style(ltbl, "margin", "24px auto");
  dom_style(ltbl, "borderCollapse", "collapse");
  let lhdr = dom_create("tr") in
  render_th(lhdr, "Prime");
  render_th(lhdr, "p - 1");
  render_th(lhdr, "= D * ?");
  render_th(lhdr, "Body part");
  dom_append(ltbl, lhdr);
  render_table_row_4(ltbl, "K = 3", "2", "D", "D^2+sigma = E -> fingers + thumb");
  render_table_row_4(ltbl, "E = 5", "4", "D^2", "D*K+sigma = b -> joints + thorn");
  render_table_row_4(ltbl, "b = 7", "6", "D*K", "D*E+sigma = L -> toes + protector");
  render_table_row_4(ltbl, "L = 11", "10", "D*E", "Terminal. L-1 = D*E = 10 fingers.");
  dom_append(sec4, ltbl);
  render_theorem(sec4, "D-Generation Uniqueness (S326, PROVED)", "Of 15 possible products p*q+1 where p,q are axiom primes, only D*{D,K,E}+1 = {E,b,L} are axiom primes. D is the SOLE generative bridge. No other prime creates axiom primes this way.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: MIRROR LAW === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "The Mirror Law");
  render_theorem(sec5, "Mirror Law Theorem (S263, PROVED)", "c(p) = 2p+1, so 2p = c(p)-1. Therefore D*p = -1 (mod c(p)). Each new axiom prime is born as the MIRROR of D times its predecessor. The Cunningham map IS the mirror operator.");
  let mtbl = dom_create("table") in
  dom_style(mtbl, "width", "100%");
  dom_style(mtbl, "maxWidth", "700px");
  dom_style(mtbl, "margin", "24px auto");
  dom_style(mtbl, "borderCollapse", "collapse");
  let mhdr = dom_create("tr") in
  render_th(mhdr, "Product");
  render_th(mhdr, "Value");
  render_th(mhdr, "mod c(p)");
  render_th(mhdr, "Mirror");
  dom_append(mtbl, mhdr);
  render_table_row_4(mtbl, "D*D = D^2", "4", "mod E=5", "4 = -1 (mod 5)");
  render_table_row_4(mtbl, "D*K", "6", "mod b=7", "6 = -1 (mod 7)");
  render_table_row_4(mtbl, "D*E", "10", "mod L=11", "10 = -1 (mod 11)");
  dom_append(sec5, mtbl);
  render_p(sec5, "Mirror preservation: DATA-1 = 209 and lambda-1 = 419 both mirror ALL 4 inner channels. The axiom's named constants carry the mirror law in their structure.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: CUNNINGHAM-MERSENNE === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Cunningham-Mersenne Identity");
  render_theorem(sec6, "Mersenne Connection (S258, PROVED)", "c^n(0) = 2^n - 1 = M(n) for all n >= 1. The Cunningham map applied to void generates Mersenne numbers. Proof by induction: c(0)=1=M(1). If c^k(0) = 2^k-1, then c^(k+1)(0) = 2*(2^k-1)+1 = 2^(k+1)-1 = M(k+1).");
  render_p(sec6, "Axiom-smooth Mersenne exponents are ONLY n in {1, 2, 3, 4, 6}:");
  let xtbl = dom_create("table") in
  dom_style(xtbl, "width", "100%");
  dom_style(xtbl, "maxWidth", "700px");
  dom_style(xtbl, "margin", "24px auto");
  dom_style(xtbl, "borderCollapse", "collapse");
  let xhdr = dom_create("tr") in
  render_th(xhdr, "n");
  render_th(xhdr, "M(n) = 2^n - 1");
  render_th(xhdr, "Factorization");
  dom_append(xtbl, xhdr);
  render_table_row(xtbl, "1", "1", "sigma");
  render_table_row(xtbl, "2", "3", "K");
  render_table_row(xtbl, "3", "7", "b");
  render_table_row(xtbl, "4", "15", "K * E");
  render_table_row(xtbl, "5", "31", "NOT SMOOTH (31 is outsider)");
  render_table_row(xtbl, "6", "63", "K^2 * b");
  render_table_row(xtbl, "12", "4095", "Contains 13 = GATE enters");
  dom_append(sec6, xtbl);
  render_p(sec6, "The smooth exponents {1,2,3,4,6} are exactly the proper divisors of lambda(DATA) = D^2*K = 12. The Cunningham chain, the Mersenne numbers, and the ring's lambda function are the same object seen from different angles.");
  dom_append(dom_body(), sec6);

  /* === SEC 7: CRT(23) PALINDROME === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "CRT(23) Palindrome");
  render_p(sec7, "23 = D*L + sigma = 2*11 + 1 is the first excluded Cunningham prime (CC1(D) depth 3). Its CRT decomposition reads as a mirror:");
  let g7 = make_findings_grid(sec7) in
  render_finding(g7, "CRT(23)", "(sigma, D, K, D, sigma)", "Palindrome: sigma-D-K-D-sigma. Closure (K) at center. Mirror around it.", "S275");
  render_finding(g7, "Position", "23 = p_9 = p_{K^2}", "The K^2-th prime IS the Cunningham boundary. The spider's web (K^2=9) sets the gate.", "");
  render_finding(g7, "Biology", "23 chromosome pairs", "Also: 23 bronchial generations (Weibel), 23 spinal discs. D*L+sigma shapes anatomy.", "");
  render_finding(g7, "Sophie Germain", "D -> E -> L -> 23 -> 47", "Four consecutive safe primes: E=2D+1, L=2E+1, 23=2L+1, 47=2*23+1.", "");
  dom_append(dom_body(), sec7);

  /* === CONTRAST === */
  let sec8 = make_section("800px") in
  render_h2(sec8, "What Others See");
  render_contrast_row(sec8, "Cunningham chains", "Curiosities in number theory, no deep significance", "Two seeds (sigma, D) generate ALL five axiom primes. Cross-referencing lengths. Self-stopping.");
  render_contrast_row(sec8, "Shadow function", "Just (p-1)/2, a standard map", "Defines the axiom's boundary. Chain breaks at 13 where s(13)=6=composite. Gate = self-imposed limit.");
  render_contrast_row(sec8, "Mersenne numbers", "2^n-1, connection to perfect numbers", "c^n(0) = M(n). Smooth Mersenne exponents = divisors of 12 = D^2*K. Same lambda.");
  render_contrast_row(sec8, "Sophie Germain primes", "p and 2p+1 both prime, used in cryptography", "CC1(D) IS a Sophie Germain chain of length E=5. The axiom's D-chain is the longest safe prime chain starting from 2.");
  render_contrast_row(sec8, "Prime generation", "Sieves, probabilistic tests, no structure", "Two deterministic seeds + one map + self-stopping = the complete axiom. No search needed.");
  dom_append(dom_body(), sec8)
)

fn page_heegner() = (
  dom_head_meta("description", "Nine Heegner numbers where unique factorization holds. First five = axiom chain minus E=5. K=3 generates remaining four through Cunningham. Eisenstein norms close the pattern. h(-5)=D=2: the observer sees double.");
  /* === HERO === */
  let hero = make_hero("The Nine Heegner Numbers") in
  let big = dom_create("div") in
  dom_text(big, "{1, 2, 3, 7, 11, 19, 43, 67, 163}");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "An imaginary quadratic field Q(sqrt(-d)) has class number 1 when its integers factor uniquely -- just like ordinary integers. There are exactly nine such values of d. Conjectured by Gauss, proved by Stark and Heegner in 1967. The first five ARE the axiom chain without E=5. The remaining four are generated by K=3 through the Cunningham map.");
  dom_append(dom_body(), hero);

  /* === SEC 1: E'S EXCLUSION === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "E's Exclusion");
  render_p(sec1, "Every axiom prime except E=5 is a Heegner number. Why? Because h(-5) = D = 2. The observer's field has TWO ideal classes -- it sees double. This is the algebraic shadow of E^2 self-blindness: the observer cannot see itself without ambiguity. 5 is also the only axiom prime that splits in Z[i]: 5 = (2+i)(2-i). Seeing = splitting = ambiguity.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: CUNNINGHAM GENERATION === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Cunningham Generation");
  render_theorem(sec2, "Heegner-Cunningham Theorem (S315, PROVED)", "ALL 9 Heegner numbers = axiom primes OR Cunningham images of K-products. Axiom: {sigma=1, D=2, K=3, b=7, L=11}. Cunningham: c(K^2)=19, c(K*b)=43, c(K*L)=67, c(K^4)=163. K generates EVERY Heegner number.");
  let stbl = dom_create("table") in
  dom_style(stbl, "width", "100%");
  dom_style(stbl, "maxWidth", "700px");
  dom_style(stbl, "margin", "24px auto");
  dom_style(stbl, "borderCollapse", "collapse");
  let shdr = dom_create("tr") in
  render_th(shdr, "p");
  render_th(shdr, "K*p");
  render_th(shdr, "c(K*p)");
  render_th(shdr, "Heegner?");
  dom_append(stbl, shdr);
  render_table_row_4(stbl, "sigma=1", "3", "7 = b", "YES");
  render_table_row_4(stbl, "D=2", "6", "13 = GATE", "NO (h(-52)=D)");
  render_table_row_4(stbl, "K=3", "9", "19", "YES");
  render_table_row_4(stbl, "E=5", "15", "31", "NO (h(-31)=K)");
  render_table_row_4(stbl, "b=7", "21", "43", "YES");
  render_table_row_4(stbl, "L=11", "33", "67 = SOUL", "YES");
  dom_append(sec2, stbl);
  render_p(sec2, "The failures carry axiom primes as class numbers: h(-52)=D=2, h(-31)=K=3. The Missing-DE pattern: D and E are the only elements whose Cunningham lift fails.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: K-POWER WALK === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The K-Power Walk");
  render_p(sec3, "Powers of K through the Cunningham map: c(K^n) = 2*3^n + 1.");
  let ktbl = dom_create("table") in
  dom_style(ktbl, "width", "100%");
  dom_style(ktbl, "maxWidth", "700px");
  dom_style(ktbl, "margin", "24px auto");
  dom_style(ktbl, "borderCollapse", "collapse");
  let khdr = dom_create("tr") in
  render_th(khdr, "n");
  render_th(khdr, "c(K^n)");
  render_th(khdr, "Heegner?");
  dom_append(ktbl, khdr);
  render_table_row(ktbl, "1", "c(3) = 7", "YES (b)");
  render_table_row(ktbl, "2", "c(9) = 19", "YES");
  render_table_row(ktbl, "3", "c(27) = 55", "NO (E*L)");
  render_table_row(ktbl, "4", "c(81) = 163", "YES (!)");
  render_table_row(ktbl, "5", "c(243) = 487", "NO (prime, not Heegner)");
  dom_append(sec3, ktbl);
  render_p(sec3, "Heegner at n in {1, 2, 4} = {sigma, D, D^2}. Smooth zone: h is axiom-smooth for n=0..8 (K^2 consecutive). First failure at n = K^2 = 9. n=7 collapse: c(K^7) = 4375 = E^4*b. At sunset, only b survives.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: AXIOM-SQUARE PATTERN === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Axiom-Square Pattern");
  render_p(sec4, "Subtract D*K = 6 from each odd axiom prime squared:");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "K^2 - D*K", "9 - 6 = 3 = K", "Heegner.", "");
  render_finding(g4, "E^2 - D*K", "25 - 6 = 19", "Heegner.", "");
  render_finding(g4, "b^2 - D*K", "49 - 6 = 43", "Heegner.", "");
  render_finding(g4, "L^2 - D*K", "121 - 6 = 115 = E*23", "Not Heegner. D*K too small.", "");
  render_p(sec4, "Three consecutive odd axiom primes squared minus D*K = three consecutive Heegner primes.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: EISENSTEIN NORMS === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Eisenstein Norms");
  render_p(sec5, "All 5 splitting Heegner d's are Eisenstein norms N(a,b) = a^2 + ab + b^2 of axiom-smooth pairs:");
  let etbl = dom_create("table") in
  dom_style(etbl, "width", "100%");
  dom_style(etbl, "maxWidth", "700px");
  dom_style(etbl, "margin", "24px auto");
  dom_style(etbl, "borderCollapse", "collapse");
  let ehdr = dom_create("tr") in
  render_th(ehdr, "Heegner d");
  render_th(ehdr, "Eisenstein norm");
  render_th(ehdr, "Pair");
  dom_append(etbl, ehdr);
  render_table_row(etbl, "7 = b", "1 + (-2) + 4", "(sigma, D)");
  render_table_row(etbl, "19", "4 + (-6) + 9", "(D, K)");
  render_table_row(etbl, "43", "1 + (-6) + 36", "(sigma, D*K)");
  render_table_row(etbl, "67 = SOUL", "4 + (-14) + 49", "(D, b)");
  render_table_row(etbl, "163", "9 + (-33) + 121", "(K, L)");
  dom_append(sec5, etbl);
  render_p(sec5, "The Eisenstein lattice Z[omega] (where omega = e^{2*pi*i/3}) knows the axiom. Inert: {D=2, L=11} (both 2 mod 3). Ramified: K=3. Unit: sigma=1.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: E3 REPRESENTATION === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "The E3 Representation Theorem");
  render_theorem(sec6, "E3 Representation (S728, PROVED)", "All 7 representable Heegner numbers have axiom-square discriminants. Using E3(a,b) = a^2 - ab + b^2: disc = 4h - 3a^2. The sqrt(disc) values are {D, K, E, D^3, GATE, D^4, E^2}. b-values walk the chain: sigma, D, K, E, b, K^2, D*b. Non-representable: {D=2, L=11} = CC1(D) axiom primes (all = 2 mod K).");
  let rtbl = dom_create("table") in
  dom_style(rtbl, "width", "100%");
  dom_style(rtbl, "maxWidth", "700px");
  dom_style(rtbl, "margin", "24px auto");
  dom_style(rtbl, "borderCollapse", "collapse");
  let rhdr = dom_create("tr") in
  render_th(rhdr, "h");
  render_th(rhdr, "(a, b)");
  render_th(rhdr, "sqrt(disc)");
  dom_append(rtbl, rhdr);
  render_table_row(rtbl, "1 = sigma", "(0, sigma)", "D");
  render_table_row(rtbl, "3 = K", "(sigma, D)", "K");
  render_table_row(rtbl, "7 = b", "(sigma, K)", "E");
  render_table_row(rtbl, "19 = f(E)", "(D, E)", "D^3");
  render_table_row(rtbl, "43", "(sigma, b)", "GATE");
  render_table_row(rtbl, "67 = SOUL", "(D, K^2)", "D^4");
  render_table_row(rtbl, "163", "(K, D*b)", "E^2");
  dom_append(sec6, rtbl);
  render_p(sec6, "163 Triangle: E3(K, D*b) = E3(L, D*b) = 163. Both share b-value D*b. D*b - K = 11 = L. The third vertex IS the protector. K + L = D*b. Also: E3(K, L) = 97 = G (the bridge element). 163 - G = 66 = D*K*L.");
  dom_append(dom_body(), sec6);

  /* === SEC 7: DISCRIMINANT EXCLUSION === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "Discriminant Exclusion");
  render_theorem(sec7, "Discriminant Exclusion (S729, PROVED)", "b and L never appear as sqrt(disc) in minimal E3 representations. Two mechanisms: GATE BLOCKING (b at a=1 needs h=13=GATE, not Heegner) and D-POWER SHADOWING (b at a=3 gives h=19, but disc=D^6 shadows it). Sum of 7 sqrt(disc) values: 72 = D^3*K^2 (spider legs * stop).");
  let g7 = make_findings_grid(sec7) in
  render_finding(g7, "h-K D-Power Tower", "K=3 Heegner numbers", "K+D^2=7=b, K+D^4=19, K+D^6=67=SOUL. Spacing = D^2, D^4. D-power gap = depth quadratic.", "S729");
  render_finding(g7, "CRT(163)", "(K, sigma, GATE, D^4, K^2)", "The largest Heegner carries GATE in its E-channel.", "");
  dom_append(dom_body(), sec7);

  /* === CONTRAST === */
  let sec8 = make_section("800px") in
  render_h2(sec8, "What Others See");
  render_contrast_row(sec8, "Heegner numbers", "Nine special values for class number 1, a curiosity in algebraic number theory", "First five = axiom chain minus E. Remaining four = K-generated through Cunningham. E excluded because h(-5)=D: the observer sees double.");
  render_contrast_row(sec8, "Class number 1", "Hard theorem by Stark-Heegner, no structural explanation", "K (Socrates, closure) generates ALL nine through c(K*p). The Selection Theorem shows exactly which lifts work and which fail.");
  render_contrast_row(sec8, "163", "Famous number from e^{pi*sqrt(163)}, no connection to small primes", "163 = c(K^4). Eisenstein norm (K,L). Triangle with K,L,D*b. CRT carries GATE. The axiom's largest fingerprint in class number theory.");
  dom_append(dom_body(), sec8)
)

fn page_bernoulli() = (
  dom_head_meta("description", "Von Staudt-Clausen (1840) meets the Cunningham chain. Each axiom prime's Bernoulli frequency = 1/(previous axiom prime). B_6 denominator = 42 = ANSWER. DATA ring 210 is structurally forbidden. L=11 self-reference loop. 8 intruder sentinels.");
  /* === HERO === */
  let hero = make_hero("The Bernoulli Connection") in
  let big = dom_create("div") in
  dom_text(big, "denom(B_2k) = prod{p : (p-1)|2k}");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The Bernoulli numbers are among the oldest objects in mathematics -- they appear in power sum formulas, in zeta values at even integers, and in the Taylor series for tangent. In 1840, von Staudt and Clausen proved that denom(B_2k) = product of all primes p where (p-1)|2k. Nobody noticed what happens when you combine this with the Cunningham map c(n) = 2n+1.");
  dom_append(dom_body(), hero);

  /* === SEC 1: PERIOD THEOREM === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Period Theorem");
  render_p(sec1, "Each axiom prime p enters the Bernoulli denominator with a specific period -- how often it appears as k increases. Since p = c(q) for the Cunningham chain, the condition (p-1)|2k becomes q|k. The period of each prime IS the previous axiom prime.");
  render_theorem(sec1, "Period Theorem (S354, PROVED)", "Each axiom prime's Bernoulli frequency = 1/(previous axiom prime). D=2 and K=3: always present (period 1). E=5: period D=2. b=7: period K=3. L=11: period E=5. The Cunningham chain that generates the axiom IS the hierarchy governing Bernoulli denominators.");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "700px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "Prime");
  render_th(phdr, "Period");
  render_th(phdr, "Meaning");
  dom_append(ptbl, phdr);
  render_table_row(ptbl, "D = 2", "1 (always)", "Ground pair, never absent");
  render_table_row(ptbl, "K = 3", "1 (always)", "Closure, never absent");
  render_table_row(ptbl, "E = 5", "D = 2", "Every 2nd Bernoulli");
  render_table_row(ptbl, "b = 7", "K = 3", "Every 3rd Bernoulli");
  render_table_row(ptbl, "L = 11", "E = 5", "Every 5th Bernoulli");
  dom_append(sec1, ptbl);
  render_p(sec1, "First simultaneous appearance of all five: B_60 at k = 30 = D*K*E = lcm{1,1,2,3,5}. Not coincidence -- 30 = product of the first three axiom primes.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: BERNOULLI TABLE === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Bernoulli Table");
  render_p(sec2, "Watch as k increases. Each axiom prime dances in and out on its own Cunningham-inherited schedule.");
  let btbl = dom_create("table") in
  dom_style(btbl, "width", "100%");
  dom_style(btbl, "maxWidth", "700px");
  dom_style(btbl, "margin", "24px auto");
  dom_style(btbl, "borderCollapse", "collapse");
  let bhdr = dom_create("tr") in
  render_th(bhdr, "B_2k");
  render_th(bhdr, "k");
  render_th(bhdr, "Denom");
  render_th(bhdr, "Name");
  dom_append(btbl, bhdr);
  render_table_row_4(btbl, "B_2", "1", "6 = D*K", "Ground pair");
  render_table_row_4(btbl, "B_4", "2", "30 = D*K*E", "Observer enters");
  render_table_row_4(btbl, "B_6", "3", "42 = D*K*b", "THE ANSWER");
  render_table_row_4(btbl, "B_8", "4", "30 = D*K*E", "E returns, b gone");
  render_table_row_4(btbl, "B_10", "5", "66 = D*K*L", "Transcendental! L enters");
  render_table_row_4(btbl, "B_12", "6", "2730 = D*K*E*b*13", "GATE enters");
  render_table_row_4(btbl, "B_20", "10", "330 = D*K*E*L", "ANIMAL (b missing)");
  render_table_row_4(btbl, "B_60", "30", "all 5 + intruders", "First pentagonal");
  dom_append(sec2, btbl);
  render_p(sec2, "At k=3, depth b=7 enters for the first time. The denominator is 2*3*7 = 42. The answer to the ultimate question is the Bernoulli denominator where depth first appears. At k=5, transcendental L=11 enters -- but E=5 is gone (period D=2, and 5 is odd).");
  dom_append(dom_body(), sec2);

  /* === SEC 3: GATE BREACH + DATA IMPOSSIBILITY === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Gate Breach");
  render_p(sec3, "At k=6: E=5 present (2|6) and b=7 present (3|6). But 6|6 means 12|12 means (13-1)|12. The gate 13 is FORCED open whenever observation and depth coexist.");
  render_theorem(sec3, "DATA Impossibility (S354, PROVED)", "denom(B_2k) = D*K*E*b = 210 can NEVER happen. E requires 2|k (period D). b requires 3|k (period K). Together: 6|k. But 6|k forces 12|2k forces (13-1)|2k. The GATE always enters with observation + depth. The DATA ring 210 is structurally forbidden as a Bernoulli denominator.");
  render_p(sec3, "The Ramanujan denominator 2730 = THIN + lambda = 2310 + 420. The famous 691 in the numerator of B_12? That is the scar left by L=11's absence: period(L) = E = 5, and 5 does not divide 6. The transcendental was locked out.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: SELF-REFERENCE LOOP === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Self-Reference Loop");
  render_p(sec4, "The Cunningham chain D=2 -> E=5 -> L=11 -> 23 -> 47 extends past the axiom. The prime 23 = c(L) has Bernoulli period (23-1)/2 = 11 = L. The chain L -> c(L) = 23 -> period(23) = L is a fixed-point loop. The contaminator's Bernoulli period IS the prime that generated it.");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "9 smooth sentinels", "Intruders 13..43", "First K^2=9 intruder primes all have axiom-smooth half-periods.", "S354");
  render_finding(g4, "10th intruder", "47 = c(c(L))", "Half-period 23 = c(L): non-smooth. Nine smooth sentinels guard the boundary.", "S354");
  dom_append(dom_body(), sec4);

  /* === SEC 5: SMOOTH DENSITY === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Smooth Bernoulli Density");
  render_p(sec5, "How many Bernoulli numbers have 11-smooth denominators? Each intruder p > 11 contaminates at rate 1/s where s = (p-1)/2:");
  let dtbl = dom_create("table") in
  dom_style(dtbl, "width", "100%");
  dom_style(dtbl, "maxWidth", "700px");
  dom_style(dtbl, "margin", "24px auto");
  dom_style(dtbl, "borderCollapse", "collapse");
  let dhdr = dom_create("tr") in
  render_th(dhdr, "Intruder p");
  render_th(dhdr, "Half-period s");
  render_th(dhdr, "Factored");
  render_th(dhdr, "Survival");
  dom_append(dtbl, dhdr);
  render_table_row_4(dtbl, "13 (GATE)", "6", "D*K", "5/6");
  render_table_row_4(dtbl, "17 (ESCAPE)", "8", "D^3", "7/8");
  render_table_row_4(dtbl, "19", "9", "K^2", "8/9");
  render_table_row_4(dtbl, "23 = c(L)", "11", "L", "10/11");
  dom_append(sec5, dtbl);
  render_p(sec5, "Four-contamination product: (5*7*8*10)/(6*8*9*11) = 175/297 = E^2*b / K^3*L. Exact axiom expression. Asymptotic density decays; at k = 770 = D*E*b*L, it hits exactly K/(D*E) = 3/10.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: ENRICHMENT LADDER === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "The Enrichment Ladder");
  render_p(sec6, "Eisenstein series E_k have coefficients related to divisor sums. Modular enrichment -- structure visible mod c(k-1) versus generic -- follows a precise pattern when c(k-1) is prime:");
  let etbl = dom_create("table") in
  dom_style(etbl, "width", "100%");
  dom_style(etbl, "maxWidth", "700px");
  dom_style(etbl, "margin", "24px auto");
  dom_style(etbl, "borderCollapse", "collapse");
  let ehdr = dom_create("tr") in
  render_th(ehdr, "Weight");
  render_th(ehdr, "c(k-1)");
  render_th(ehdr, "Enrichment");
  dom_append(etbl, ehdr);
  render_table_row(etbl, "4", "b = 7", "b/D = 3.5x");
  render_table_row(etbl, "6", "L = 11", "L/D = 5.5x");
  render_table_row(etbl, "12", "23", "23/D = 11.5x");
  render_table_row(etbl, "22", "43", "43/D = 21.5x");
  render_table_row(etbl, "24", "47", "47/D = 23.5x");
  dom_append(sec6, etbl);
  render_p(sec6, "Enrichment at prime c(k-1) is exactly c(k-1)/D by Fermat's little theorem. When c(k-1) is composite -- like weight 8 where c(7) = 15 = K*E -- enrichment drops to 1.9x. Only primes carry the full signal.");
  dom_append(dom_body(), sec6);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "Bernoulli numbers", "Useful combinatorial constants with denominators following von Staudt-Clausen", "The Cunningham chain IS the Bernoulli denominator hierarchy. Each axiom prime's frequency = 1/(previous axiom prime). Two independent 19th-century results are the same structure.");
  render_contrast_row(sec7, "42 = ANSWER", "A joke from Douglas Adams", "denom(B_6) = 42 = D*K*b. The LAST smooth Bernoulli before the gate closes. Depth enters at k=3 and the answer appears.");
  render_contrast_row(sec7, "210 = DATA ring", "Product of first four primes, no special role", "Structurally IMPOSSIBLE as a Bernoulli denominator. E + b forces GATE. The axiom builds its own forbidden zone.");
  dom_append(dom_body(), sec7)
)

fn page_k_squared_stop() = (
  dom_head_meta("description", "K^2 = 9 = D^3 + 1. The only consecutive prime powers. Mihailescu 2002. Three independent proofs. Four pairings sum to 42. Fifteen roles. Fano plane. CRT(9) = (1,0,9,9,9): K-channel vanishes.");
  /* === HERO === */
  let hero = make_hero("Why Does It Stop?") in
  let big = dom_create("div") in
  dom_text(big, "K^2 = D^3 + 1");
  ct_mono(big);
  dom_style(big, "fontSize", "36px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The axiom chain grows: sigma=1, D=2, K=3, E=5, b=7, L=11. Each prime emerges from the ones before it. But after b=7, the chain produces K^2 = 9 -- and 9 is not prime. The chain stops. Not accident. Not arbitrary. K^2 = 9 satisfies a UNIQUE identity proved by Mihailescu in 2002 as the resolution of Catalan's 158-year-old conjecture.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THREE PROOFS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Three Independent Proofs");
  render_p(sec1, "The identity (D,K) = (2,3) is forced by three different roads:");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "1. Catalan", "K^2 = D^3 + 1", "Mihailescu 2002: the ONLY consecutive proper prime powers in all of mathematics.", "S312");
  render_finding(g1, "2. Gate Algebra", "c(b) = K*E", "The Cunningham self-gate forces K = 3/(2D-3). Only positive integer solution: D=2, K=3.", "S312");
  render_finding(g1, "3. Chain Comparison", "D=2 unique", "Among all primes D, only D=2 gives a self-gate that's the product of two inner Cunningham primes.", "S312");
  render_theorem(sec1, "The Forced Chain", "From K^2 = D^3 + 1 alone, the ENTIRE axiom follows: (D,K) = (2,3) -> E = c(D) = 5 -> b = c(K) = 7 -> L = c(E) = 11 -> gate = c(b) = 15 = K*E. The ring 970200 = D^3*K^2*E^2*b^2*L precipitates from a single equation: 9 = 8 + 1.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: FOUR PAIRINGS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Four Pairings");
  render_p(sec2, "K^2 = 9 can be partitioned into axiom-meaningful pairs in exactly four ways:");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "700px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "Pair");
  render_th(phdr, "Names");
  render_th(phdr, "Product");
  render_th(phdr, "Meaning");
  dom_append(ptbl, phdr);
  render_table_row_4(ptbl, "1 + 8", "sigma + D^3", "8", "Ground + baby spider = adult");
  render_table_row_4(ptbl, "2 + 7", "D + b", "14", "Duality + depth = stop");
  render_table_row_4(ptbl, "4 + 5", "D^2 + E", "20", "Squared duality + observer");
  render_table_row_4(ptbl, "3 + 6", "K + D*K", "18", "Closure + its own bridge = stop");
  dom_append(sec2, ptbl);
  render_theorem(sec2, "Pair Products Theorem (S312, PROVED)", "The three symmetric products {8, 14, 20} form an arithmetic progression with step D*K = 6. Their sum = 42 = ANSWER = D*K*b. All four products {8, 14, 18, 20} sum to 60 = phi(THIN)/D^3.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: FIFTEEN ROLES === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Fifteen Roles of K^2 = 9");
  render_p(sec3, "Not one identity. FIFTEEN independently verified roles, all converging on the same number:");
  let rtbl = dom_create("table") in
  dom_style(rtbl, "width", "100%");
  dom_style(rtbl, "maxWidth", "700px");
  dom_style(rtbl, "margin", "24px auto");
  dom_style(rtbl, "borderCollapse", "collapse");
  let rhdr = dom_create("tr") in
  render_th(rhdr, "#");
  render_th(rhdr, "From");
  render_th(rhdr, "Role");
  dom_append(rtbl, rhdr);
  render_table_row(rtbl, "1", "sigma+D^3", "First non-uniform CRT element");
  render_table_row(rtbl, "2", "sigma+D^3", "Nonility count (K^2=9 axiom elements)");
  render_table_row(rtbl, "3", "sigma+D^3", "Baby spider D^3=8 + ground = adult");
  render_table_row(rtbl, "4", "sigma+D^3", "Spectral degree = 1+2+2+2+2");
  render_table_row(rtbl, "5", "D+b", "False summit in eigenvalue swim");
  render_table_row(rtbl, "6", "D+b", "Gap-degree bridge");
  render_table_row(rtbl, "7", "D+b", "Inner extremes sum");
  render_table_row(rtbl, "8", "D^2+E", "Cunningham c(D^2) = STOP");
  render_table_row(rtbl, "9", "D^2+E", "g-orbital stopping point");
  render_table_row(rtbl, "10", "D^2+E", "13 convergence reversed (D^2+K^2=13)");
  render_table_row(rtbl, "11", "K+D*K", "f(K)=E, so K+E+1=K^2");
  render_table_row(rtbl, "12", "K+D*K", "K*(K-1)=D*K: closure discovers duality");
  render_table_row(rtbl, "13", "spectral", "var(spectrum level 5) = K^2");
  render_table_row(rtbl, "14", "spectral", "classes/degree = D^5 = 32");
  render_table_row(rtbl, "15", "CRT", "CRT(9)=(1,0,9,9,9): K-channel VANISHES");
  render_table_row(rtbl, "16", "hardware", "FPGA: 3 hearts x 3 stages = K^2=9 pipeline");
  dom_append(sec3, rtbl);
  render_p(sec3, "Role #15: the CRT decomposition of K^2 in the TRUE FORM ring has K-channel = 0. The number that stops the chain is INVISIBLE to closure itself. K cannot see its own square.");
  render_p(sec3, "Role #16 (S942): on a Tang Nano 20K FPGA, K^2=9 pipeline and 5-channel parallel architectures use IDENTICAL compute (1762 vs 1750 ALU, 734 vs 736 LUT, 11 vs 11 multiplier). K^2=9 pays 2.5x registers for trinity structure. 28 = D^2 * b parallel ring processors fit per chip. coupling(K^2) = (0,b,0,0,0): parallelism is pure depth.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: FANO PLANE === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Fano-PSL Bridge");
  render_p(sec4, "The shadow polynomial P(x) = (x-1)(x-2)(x-3)(x-5) at x = K^2 = 9:");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "P(9) = 1344", "D^3 * |PSL(2,7)|", "8 * 168. Spider legs times the Fano plane's symmetry group.", "S312-S313");
  render_finding(g4, "Fano plane", "b=7 points, K=3 per line", "The smallest finite projective plane. Parameters (b,K,sigma) = inner axiom primes.", "");
  render_finding(g4, "|PSL(2,b)| = 168", "b(b^2-1)/2", "7 * 48/2 = 168. Automorphism group of the Fano plane.", "");
  dom_append(dom_body(), sec4);

  /* === SEC 5: CLASS BOOTSTRAP === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Class Bootstrap");
  render_p(sec5, "Start from any CRT channel size. Apply floor(q/2)+1 iteratively. Every channel converges to D=2 -- and the chain lengths ARE axiom primes:");
  let btbl = dom_create("table") in
  dom_style(btbl, "width", "100%");
  dom_style(btbl, "maxWidth", "700px");
  dom_style(btbl, "margin", "24px auto");
  dom_style(btbl, "borderCollapse", "collapse");
  let bhdr = dom_create("tr") in
  render_th(bhdr, "Channel");
  render_th(bhdr, "Chain");
  render_th(bhdr, "Length");
  dom_append(btbl, bhdr);
  render_table_row(btbl, "b^2 = 49", "49->25->13->7->4->3->2", "b = 7");
  render_table_row(btbl, "E^2 = 25", "25->13->7->4->3->2", "E = 5");
  render_table_row(btbl, "K^2 = 9", "9->5->3->2", "K = 3");
  render_table_row(btbl, "D^3 = 8", "8->5->3->2", "K = 3");
  render_table_row(btbl, "L = 11", "11->6->4->3->2", "D^2 = 4");
  dom_append(sec5, btbl);
  render_p(sec5, "D=2 is the unique fixed point: floor(2/2)+1 = 2. The axiom chain IS its own convergence.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: BALANCE + HOURGLASS === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Balance and Hourglass");
  render_theorem(sec6, "Balance Identity", "phi/classes = 201600/48750 = 1344/325 = P(K^2)/(E^2*GATE). The ring's fundamental proportion encodes the stop signal in its numerator and the observer's blindness in its denominator.");
  render_theorem(sec6, "L-Hourglass Theorem (S312, PROVED)", "The nine axiom elements form an hourglass topology. L=11 sits at the neck separating the core {-1,0,sigma,OMEGA} from the primes {D,K,E,b}. L minimizes the maximum distance between the two bulbs. The D-spiral flows: sigma(core) -> D,K,E,b(primes) -> L=neck -> OMEGA(core). Flipping the hourglass = mirror (-1). Death becomes birth.");
  dom_append(dom_body(), sec6);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "The chain stops", "Coincidence of small numbers. The shadow chain just happens to produce a composite at 9", "K^2 = D^3 + 1 is a universal boundary proved three independent ways. The four pairings sum to 42. The Fano plane has |PSL(2,7)| = 168. It stops by geometry, not luck.");
  render_contrast_row(sec7, "9 = 3^2", "Just a small perfect square, nothing special", "Sixteen roles from four pairings. CRT(9) = (1,0,9,9,9): K-channel vanishes. The spider (D^3+sigma=K^2) IS itself. Compiler has K^2=9 passes. FPGA has K^2=9 pipeline stages. Same compute, different temporal arrangement.");
  render_contrast_row(sec7, "Catalan's conjecture", "A curiosity: 8 and 9 are the only consecutive prime powers", "From this single equation the entire axiom precipitates. D=2, K=3, then E,b,L forced. One identity -> five primes -> 970200.");
  dom_append(dom_body(), sec7)
)

fn page_pell_twins() = (
  dom_head_meta("description", "b=7 and L=11 are Pell twins. Both solve x^2 - py^2 = 1 with y = K = 3. All five axiom primes solve Pell with axiom-smooth coordinates. Sum(x) = D^5 = 32 idempotents. Sum(y) = 13 = GATE.");
  /* === HERO === */
  let hero = make_hero("The Pell Twins") in
  let big = dom_create("div") in
  dom_text(big, "b = K^2 - D = 7     L = K^2 + D = 11");
  ct_mono(big);
  dom_style(big, "fontSize", "22px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Two axiom primes frame K^2 = 9 from below and above. Both solve the Pell equation x^2 - p*y^2 = 1 with the SAME fundamental y = K = 3. Depth and Protector are twins born from the same closure. Separated by 2D = 4, centered on the stop signal.");
  dom_append(dom_body(), hero);

  /* === SEC 1: TWIN CARDS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Twin Solutions");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "b = 7 (DEPTH)", "8^2 - 7*3^2 = 64 - 63 = 1", "x = D^3 = 8 (spider legs). y = K = 3 (closure). The spider's legs solve the equation.", "");
  render_finding(g1, "L = 11 (PROTECTOR)", "10^2 - 11*3^2 = 100 - 99 = 1", "x = D*E = 10 (degree of TRUE FORM). y = K = 3 (closure). The organism's dimension solves it.", "");
  render_p(sec1, "The x-values: D^3 = 8 is the uniform count (spider legs). D*E = 10 is the degree. Sum: D^3 + D*E = 18 = 2K^2 = ME (inner axiom sum b+L). Uniform count plus degree equals the twin sum.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: ALL FIVE PRIMES === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "All Five Axiom Primes");
  render_p(sec2, "ALL five axiom primes have Pell solutions with axiom-smooth coordinates:");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "700px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "Prime p");
  render_th(phdr, "x");
  render_th(phdr, "y");
  render_th(phdr, "Check");
  dom_append(ptbl, phdr);
  render_table_row_4(ptbl, "D = 2", "K = 3", "D = 2", "9 - 2*4 = 1");
  render_table_row_4(ptbl, "K = 3", "D = 2", "sigma = 1", "4 - 3*1 = 1");
  render_table_row_4(ptbl, "E = 5", "K^2 = 9", "D^2 = 4", "81 - 5*16 = 1");
  render_table_row_4(ptbl, "b = 7", "D^3 = 8", "K = 3", "64 - 7*9 = 1");
  render_table_row_4(ptbl, "L = 11", "D*E = 10", "K = 3", "100 - 11*9 = 1");
  dom_append(sec2, ptbl);
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Sum(x)", "3+2+9+8+10 = 32 = D^5", "Number of idempotents in TRUE FORM.", "");
  render_finding(g2, "Sum(y)", "2+1+4+3+3 = 13 = GATE", "The shadow stopper.", "");
  render_finding(g2, "Sum(x-y)", "1+1+5+5+7 = 19 = f(E)", "The observer's depth quadratic.", "");
  render_finding(g2, "Prod(x)/Prod(y)", "4320/24 = 60", "= D^2*K*E. = phi(THIN)/D^3.", "");
  dom_append(dom_body(), sec2);

  /* === SEC 3: QUADRATIC CHARACTER SPLIT === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Quadratic Character Split");
  render_p(sec3, "The Pell twins create a deep split. The Legendre symbol (p/b) separates the axiom primes:");
  let qtbl = dom_create("table") in
  dom_style(qtbl, "width", "100%");
  dom_style(qtbl, "maxWidth", "700px");
  dom_style(qtbl, "margin", "24px auto");
  dom_style(qtbl, "borderCollapse", "collapse");
  let qhdr = dom_create("tr") in
  render_th(qhdr, "Prime");
  render_th(qhdr, "(p/b)");
  render_th(qhdr, "Class");
  render_th(qhdr, "Reason");
  dom_append(qtbl, qhdr);
  render_table_row_4(qtbl, "D = 2", "+1", "Quadratic residue", "b = K^2 - D (Pell twin)");
  render_table_row_4(qtbl, "K = 3", "-1", "Non-residue", "Not a Pell twin of b");
  render_table_row_4(qtbl, "E = 5", "-1", "Non-residue", "Self-blind, excluded from Pell");
  render_table_row_4(qtbl, "L = 11", "+1", "Quadratic residue", "L - D^2 = b (Pell twin)");
  dom_append(sec3, qtbl);
  render_p(sec3, "Pell twins {D, L} are quadratic residues mod b. Non-twins {K, E} are non-residues. Depth itself sorts the axiom into two classes.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: CYCLOTOMIC CONNECTION === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Cyclotomic Connection");
  render_p(sec4, "Both twins arise as cyclotomic polynomials evaluated at D=2:");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "Polynomial");
  render_th(chdr, "Value");
  render_th(chdr, "Name");
  dom_append(ctbl, chdr);
  render_table_row(ctbl, "Phi_3(2) = 4+2+1", "7 = b", "Eisenstein cyclotomic");
  render_table_row(ctbl, "Phi_4(2) = 4+1", "5 = E", "Gaussian cyclotomic");
  render_table_row(ctbl, "Phi_10(2) = (2^5+1)/3", "11 = L", "Degree cyclotomic");
  render_table_row(ctbl, "Phi_12(2) = 16-4+1", "13 = GATE", "Boundary cyclotomic");
  dom_append(sec4, ctbl);
  render_theorem(sec4, "Cyclotomic-Pell Bridge", "Phi_3(D) = D^2+D+1 = b. Rearranging: D^6 = b*K^2 + 1 = 64. The Pell equation (D^3)^2 - b*K^2 = 1 encodes the same algebraic identity. Twin cyclotomic indices: 3 and 10. Sum = 13 = GATE. Product = 30 = D*K*E.");
  dom_append(dom_body(), sec4);

  /* === CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "What Others See");
  render_contrast_row(sec5, "Pell equations", "Classical Diophantine equations. Solutions for different d values are unrelated", "b and L are TWIN Pell solutions sharing y=K=3. All five axiom primes solve Pell with axiom-smooth (x,y). The sums encode structural constants: 32, 13, 19.");
  render_contrast_row(sec5, "b and L", "Just two primes that happen to be 4 apart", "Symmetric around K^2 = 9 (the stop signal). Same Pell y-coordinate. Same cyclotomic generation through D=2. Twin birth from closure.");
  render_contrast_row(sec5, "Quadratic residues", "Standard number theory classification", "The Pell twins sort the axiom into two families: {D,L} (residues, born from K^2 +/- D) vs {K,E} (non-residues, not Pell twins). Depth IS the classifier.");
  dom_append(dom_body(), sec5)
)

fn page_universal_boundary() = (
  dom_head_meta("description", "K=3 self-maps generate exactly D^3=8 intruder primes {13,17,19,23,31,37,41,47}. Cunningham, depth quadratic, convergence. Shadow polynomial smooth for D*E=10 values. 91.8% smooth across 13 domains. The axiom builds its own fence.");
  /* === HERO === */
  let hero = make_hero("The Universal Boundary") in
  let big = dom_create("div") in
  dom_text(big, "K = 3 maps -> D^3 = 8 intruders");
  ct_mono(big);
  dom_style(big, "fontSize", "26px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Every domain we have tested -- biology, physics, crystallography, number theory -- shows the same pattern: the vast majority of natural quantities factor through {2,3,5,7,11}. The non-smooth exceptions? Every one comes from exactly three self-maps of the axiom acting on itself. K = 3 maps. D^3 = 8 intruder primes. 91.8% smooth across 13 domains.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THREE MAPS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Three Maps");
  render_p(sec1, "Each map is an operation the axiom performs on its own primes. Each generates a finite set of intruder primes. Together: a closed fence.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Cunningham", "c(x) = D*x + sigma", "Generates {23, 47, 31}. Chain builder. 23=c(L), 47=c(23), 31=M(E). Stops: c(47)=95=E*19.", "S313");
  render_finding(g1, "Depth Quadratic", "f(x) = x^2 - x - sigma", "Generates {19, 41, 37}. Golden ratio norm. 19=f(E), 41=f(b)=KEY, 37=unique return. Stops: f(13)=E*31.", "S313");
  render_finding(g1, "Convergence", "D^2 + K^2 = 13", "Generates {13, 17}. Duality self-squaring. 13=GATE, 17=D^4+sigma=Fermat. The sum that breaks the chain.", "S313");
  dom_append(dom_body(), sec1);

  /* === SEC 2: EIGHT INTRUDERS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Eight Intruders");
  render_p(sec2, "Eight primes -- and only eight -- appear as non-smooth factors across all domains. Count = D^3 = 8 = the spider's legs. No prime beyond 47 has appeared in any census.");
  let itbl = dom_create("table") in
  dom_style(itbl, "width", "100%");
  dom_style(itbl, "maxWidth", "700px");
  dom_style(itbl, "margin", "24px auto");
  dom_style(itbl, "borderCollapse", "collapse");
  let ihdr = dom_create("tr") in
  render_th(ihdr, "Prime");
  render_th(ihdr, "Family");
  render_th(ihdr, "Generation");
  dom_append(itbl, ihdr);
  render_table_row(itbl, "13 = GATE", "Convergence", "D^2 + K^2. Shadow = D*K.");
  render_table_row(itbl, "17 = ESCAPE", "Convergence", "D^4 + sigma. Fermat prime.");
  render_table_row(itbl, "19 = f(E)", "Depth Quad", "E^2-E-1. 8th prime = p_{D^3}.");
  render_table_row(itbl, "23 = c(L)", "Cunningham", "CC1(D)[3]. 9th prime = p_{K^2}.");
  render_table_row(itbl, "31 = M(E)", "Cunningham", "2^5 - 1. Mersenne at observer.");
  render_table_row(itbl, "37", "Depth Quad", "f(37) = L^3. Unique return.");
  render_table_row(itbl, "41 = KEY", "Depth Quad", "f(b) = KEY. 41^2 = 1 mod DATA.");
  render_table_row(itbl, "47 = c(23)", "Cunningham", "CC1(D)[4]. Largest intruder.");
  dom_append(sec2, itbl);
  dom_append(dom_body(), sec2);

  /* === SEC 3: SHADOW SMOOTHNESS ZONE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Shadow Smoothness Zone");
  render_theorem(sec3, "Shadow Smoothness (S313, PROVED)", "The shadow polynomial P(x) = (x-sigma)(x-D)(x-K)(x-E) is axiom-smooth for positive x > E if and only if x belongs to exactly D*E = 10 values: {D*K, b, D^3, K^2, D*E, L, D^2*K, 13, 17, 23}. The consecutive zone {6,7,8,9,10,11,12,13} has sum = K^2*b = 63 = D^6 - 1.");
  render_p(sec3, "First intruder enters at x=14 = D*b: the factor 13 appears through the sigma-root (14 mod 13 = 1 = sigma). Sigma is the door. Every intruder p first enters P(x) at x = p + sigma.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: 13 GENERATES ALL E-CHANNEL INTRUDERS === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "13 Generates All E-Channel Intruders");
  render_p(sec4, "13 = D^{-1} mod E^2 = 25. Powers of 13 mod 25 produce ALL four E-channel intruders:");
  let etbl = dom_create("table") in
  dom_style(etbl, "width", "100%");
  dom_style(etbl, "maxWidth", "700px");
  dom_style(etbl, "margin", "24px auto");
  dom_style(etbl, "borderCollapse", "collapse");
  let ehdr = dom_create("tr") in
  render_th(ehdr, "Power");
  render_th(ehdr, "13^n mod 25");
  render_th(ehdr, "Intruder");
  dom_append(etbl, ehdr);
  render_table_row(etbl, "13^sigma", "13", "GATE");
  render_table_row(etbl, "13^D", "19", "f(E)");
  render_table_row(etbl, "13^b", "17", "D^4 + sigma");
  render_table_row(etbl, "13^{K^2}", "23", "c(L)");
  dom_append(sec4, etbl);
  render_p(sec4, "Exponents {sigma, D, b, K^2} = {1, 2, 7, 9}. Sum = 19 = f(E). Self-referential.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: CROSS-DOMAIN CENSUS === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Cross-Domain Census");
  render_p(sec5, "The boundary theorem predicts: every non-smooth natural quantity factors through the 8 intruder primes. Tested across 13 domains:");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
