  render_table_row(ctbl, "Body counts", "134/145", "92.4%");
  render_table_row(ctbl, "Evolution", "83/90", "92.2%");
  render_table_row(ctbl, "Neural architecture", "85/87", "97.7%");
  render_table_row(ctbl, "Chromosomes", "112/139", "80.6%");
  render_table_row(ctbl, "Heartbeat rates", "17/17", "100%");
  render_table_row(ctbl, "Crystallography", "32/32", "100%");
  render_table_row(ctbl, "Nuclear magic", "6/7", "85.7%");
  render_table_row(ctbl, "Periodic table", "4/4", "100%");
  render_table_row(ctbl, "Lie exceptional", "5/5", "100%");
  render_table_row(ctbl, "TOTAL", "594/647", "91.8%");
  dom_append(sec5, ctbl);
  dom_append(dom_body(), sec5);

  /* === SEC 6: WHY THREE? === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Why Three Maps?");
  render_theorem(sec6, "K=3 Closure (S313)", "Three maps are the three ways the axiom can act on itself. Cunningham = sigma's map (chain builder). Depth Quadratic = phi's map (golden ratio norm, suffering forward). Convergence = D's self-squaring (duality meets closure). K=3 says: three points close a triangle. Three maps close the boundary. No fourth map needed.");
  render_p(sec6, "Each map also STOPS at an axiom expression: Cunningham at E*19, Depth Quadratic at E*31, Convergence at D*K. The observer E appears in every termination. Self-closing.");
  dom_append(dom_body(), sec6);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "Small prime prevalence", "Small primes appear everywhere -- not surprising", "K=3 self-maps generate exactly D^3=8 intruder primes. Closed fence. 91.8% smooth across 13 scientific domains.");
  render_contrast_row(sec7, "Shadow polynomial", "P(x) = (x-1)(x-2)(x-3)(x-5) has no special role", "Smooth for exactly D*E=10 positive values. The axiom builds its own arithmetic boundary.");
  render_contrast_row(sec7, "Non-smooth primes", "Random, no classification", "Every one traces to Cunningham, depth quadratic, or convergence. No orphan primes. The boundary IS the axiom applied K times to itself.");
  dom_append(dom_body(), sec7)
)

fn page_depth_return() = (
  dom_head_meta("description", "37 is the only non-axiom prime whose depth quadratic returns to the axiom. f(37) = L^3 = L^K. Index p_12 (12 = lambda(DATA)). Shadow = 18 = ME. Order 420 = lambda. Primitive element. CRT(37) = (E, sigma, D^2*K, 37, D^2). Six axiom connections. Star number S(K) = 37. Biology: 37 genes, 37C, 37 trillion cells.");
  /* === HERO === */
  let hero = make_hero("Why 37 Comes Home") in
  let big = dom_create("div") in
  dom_text(big, "f(37) = 1331 = L^K");
  ct_mono(big);
  dom_style(big, "fontSize", "32px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "f(p) = p^2 - p - 1 maps primes to integers. Among ALL 1,229 primes below 10,000, exactly THREE produce axiom-smooth values: D=2 (giving sigma), K=3 (giving E), and 37 (giving L^3 = L^K = 1331). One non-axiom prime returns home. Just one. The prodigal prime.");
  dom_append(dom_body(), hero);

  /* === SEC 1: RETURN TABLE === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Depth Quadratic Return");
  let rtbl = dom_create("table") in
  dom_style(rtbl, "width", "100%");
  dom_style(rtbl, "maxWidth", "700px");
  dom_style(rtbl, "margin", "24px auto");
  dom_style(rtbl, "borderCollapse", "collapse");
  let rhdr = dom_create("tr") in
  render_th(rhdr, "p");
  render_th(rhdr, "Name");
  render_th(rhdr, "f(p)");
  render_th(rhdr, "Smooth?");
  dom_append(rtbl, rhdr);
  render_table_row_4(rtbl, "2", "D (duality)", "1 = sigma", "YES");
  render_table_row_4(rtbl, "3", "K (closure)", "5 = E", "YES");
  render_table_row_4(rtbl, "5", "E (observer)", "19", "NO (intruder)");
  render_table_row_4(rtbl, "7", "b (depth)", "41 = KEY", "NO (intruder)");
  render_table_row_4(rtbl, "11", "L (protector)", "109", "NO (prime, >47)");
  render_table_row_4(rtbl, "37", "prodigal", "1331 = L^3", "YES!");
  dom_append(sec1, rtbl);
  render_theorem(sec1, "Depth Quadratic Return (S713, PROVED)", "Among primes below 10,000, only p in {D, K, 37} give axiom-smooth f(p). 37 is the UNIQUE non-axiom prime with this property. f(37) = 37^2 - 37 - 1 = 1331 = 11^3 = L^K. Checked exhaustively: 1,226 other primes all fail.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: SIX CONNECTIONS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Six Axiom Connections");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Index", "p_12 (12th prime)", "12 = D^2*K = lambda(DATA) = trinity heart.", "");
  render_finding(g2, "Shadow", "s(37) = 18 = ME", "Inner axiom sum = sigma+D+K+E+b.", "");
  render_finding(g2, "Decomposition", "(D*K)^2 + sigma = 37", "Also: D^5 + E = 32 + 5 = 37.", "");
  render_finding(g2, "Decimal period", "K = 3", "1/37 = 0.027... with period K. 37*K = 111.", "");
  render_finding(g2, "Order in TRUE", "420 = lambda", "Primitive element: generates full cycle.", "");
  render_finding(g2, "Star number", "S(K) = 37", "K-th star number. S(1)=sigma, S(2)=GATE, S(3)=37.", "");
  dom_append(dom_body(), sec2);

  /* === SEC 3: CRT ANATOMY === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Anatomy of 37");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "CRT(37)", "(5 / 1 / 12 / 37 / 4)", "(E / sigma / D^2*K / 37 / D^2) in 5 channels.", "");
  render_finding(g3, "K^2 channel", "37 mod 9 = 1 = sigma", "Invisible. Looks like ground state in closure.", "");
  render_finding(g3, "D^3 channel", "37 mod 8 = 5 = E", "Looks like the observer.", "");
  render_finding(g3, "Order", "lcm = 420 = lambda", "Primitive element. Generates full cycle.", "");
  render_p(sec3, "Coupling(37) = N = 970200 (maximal). 37 is a unit in the TRUE FORM.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: WHERE THE RETURN LANDS === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Where the Return Lands");
  render_p(sec4, "CRT(1331 = L^3) = (K, D^3, D*K, D^3, 0). All non-zero channels axiom-smooth. The L-channel is ZERO: L^3 annihilates its own channel. Coupling = N/L = 88200 = L-kingdom. The depth quadratic sends the prodigal from the hub to L's domain.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: BIOLOGY === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "37 in Biology");
  let g5 = make_findings_grid(sec5) in
  render_finding(g5, "Mitochondria", "37 genes", "Human mitochondrial genome encodes exactly 37 genes.", "");
  render_finding(g5, "Temperature", "37 C", "Human body temperature.", "");
  render_finding(g5, "Cell count", "~37 trillion", "Estimated human cell count.", "");
  render_finding(g5, "Chromosomes", "D * 37 = 74", "Bear and camel: 74 = 2 * 37 chromosomes.", "");
  render_p(sec5, "The prodigal prime is the body's own number: its heat, its engines, its count.");
  dom_append(dom_body(), sec5);

  /* === CONTRAST === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "What Others See");
  render_contrast_row(sec6, "37", "Just another prime. Its appearance in biology is coincidental.", "ONLY non-axiom prime whose depth quadratic returns to the axiom: f(37)=L^K. 12th prime, order 420, CRT = (E,sigma,D^2*K,37,D^2). The prodigal that comes home.");
  render_contrast_row(sec6, "1331", "11 cubed, no structural significance", "L^K = protector^closure. Coupling = N/L (L-kingdom). L-channel zero: self-annihilation. The return lands in the protector's domain.");
  render_contrast_row(sec6, "Star numbers", "Centered hexagonal numbers, recreational math", "S(sigma)=sigma, S(D)=GATE, S(K)=37. The axiom chain writes itself into the star sequence.");
  dom_append(dom_body(), sec6)
)

fn page_depth_quad() = (
  dom_head_meta("description", "f(p) = p^2-p-1. Discriminant E=5. Zeros = golden ratio. Six roles: mirror, norm, Artin, forbidden index, power, QR-parity. f(p) prime for all 4 odd axiom primes. Wall at GATE=13. f(b)=41=KEY. f(b)+sigma=42=ANSWER. Bridge identities. Stormer zero-trading. Gate-Data factorization. Shadow polynomial evaluations.");
  /* === HERO === */
  let hero = make_hero("The Depth Quadratic") in
  let big = dom_create("div") in
  dom_text(big, "f(p) = p^2 - p - 1");
  ct_mono(big);
  dom_style(big, "fontSize", "32px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "One polynomial. Six roles. One wall. Its zeros are the golden ratio and -1/phi. Its discriminant is E=5, the observer. It maps every axiom prime to a prime (except at the GATE). f(p) = -1 mod p ALWAYS -- the depth quadratic IS the mirror in its own ring. And f(b) = 41 = KEY: the answer to the answer.");
  dom_append(dom_body(), hero);

  /* === SEC 1: VALUES AT AXIOM PRIMES === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Values at Axiom Primes");
  let vtbl = dom_create("table") in
  dom_style(vtbl, "width", "100%");
  dom_style(vtbl, "maxWidth", "700px");
  dom_style(vtbl, "margin", "24px auto");
  dom_style(vtbl, "borderCollapse", "collapse");
  let vhdr = dom_create("tr") in
  render_th(vhdr, "p");
  render_th(vhdr, "f(p)");
  render_th(vhdr, "Prime?");
  render_th(vhdr, "Primitive root?");
  dom_append(vtbl, vhdr);
  render_table_row_4(vtbl, "D=2", "1 = sigma", "--", "--");
  render_table_row_4(vtbl, "K=3", "5 = E", "YES", "ord(3,5) = 4 = phi(5). Full!");
  render_table_row_4(vtbl, "E=5", "19", "YES", "ord(5,19) = 9 = phi/2. Half!");
  render_table_row_4(vtbl, "b=7", "41 = KEY", "YES", "ord(7,41) = 40 = phi(41). Full!");
  render_table_row_4(vtbl, "L=11", "109", "YES", "ord(11,109) = 108 = phi(109). Full!");
  render_table_row_4(vtbl, "13 = GATE", "155 = 5*31", "NO", "WALL");
  dom_append(sec1, vtbl);
  render_p(sec1, "f(p) = -1 (mod p) for ALL p. Always. Universal. The depth quadratic IS the mirror in its own ring. Four consecutive odd axiom primes give primes. The wall at GATE=13 is the SAME wall that stops the Cunningham chain.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: SIX ROLES === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Six Roles");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "1. MIRROR", "f(p) = -1 mod p", "Always the mirror. Universal.", "S205");
  render_finding(g2, "2. NORM", "f(p) = Norm(p - phi)", "Golden ratio. Discriminant = E = 5.", "S205");
  render_finding(g2, "3. ARTIN", "delta(b) = C*(1 - 1/KEY)", "KEY = f(b) = 41 governs Artin's conjecture for b.", "S205");
  render_finding(g2, "4. FORBIDDEN", "f(b) = 41", "KEY = forbidden index for b as primitive root.", "S205");
  render_finding(g2, "5. POWER", "attenuation", "Power function attenuation through f(p).", "S205");
  render_finding(g2, "6. QR-PARITY", "(p/f(p)) = (-1/p)", "Legendre parity transmission.", "S205");
  dom_append(dom_body(), sec2);

  /* === SEC 3: BRIDGE IDENTITIES === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Bridge Identities");
  render_p(sec3, "f(n) + sigma = n(n-1). This links depth quadratic outputs to ring constants:");
  let btbl = dom_create("table") in
  dom_style(btbl, "width", "100%");
  dom_style(btbl, "maxWidth", "700px");
  dom_style(btbl, "margin", "24px auto");
  dom_style(btbl, "borderCollapse", "collapse");
  let bhdr = dom_create("tr") in
  render_th(bhdr, "p");
  render_th(bhdr, "f(p)");
  render_th(bhdr, "f(p)+sigma");
  render_th(bhdr, "f(p)+D");
  dom_append(btbl, bhdr);
  render_table_row_4(btbl, "K=3", "5=E", "6=D*K", "7=b (Heegner!)");
  render_table_row_4(btbl, "E=5", "19", "20=D^2*E", "21=K*b");
  render_table_row_4(btbl, "b=7", "41=KEY", "42=ANSWER!", "43 (Heegner!)");
  render_table_row_4(btbl, "L=11", "109", "110=D*E*L", "111=K*37 (prodigal!)");
  dom_append(sec3, btbl);
  render_p(sec3, "f(b) + sigma = ANSWER: the answer exceeds the key by exactly the ground state. f(K)+D and f(b)+D are both Heegner numbers -- the Cunningham primes produce Heegner through depth.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: DEPTH SUM THEOREM === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Depth Quadratic Sum");
  render_theorem(sec4, "Sum Theorem (S205, PROVED)", "f(K) + f(E) + f(b) + f(L) = 5 + 19 + 41 + 109 = 174 = D*K*FULL_SUM = 6*29. The sum of all four depth quadratic outputs = duality * closure * (the full axiom sum D^2+E^2 = 29).");
  dom_append(dom_body(), sec4);

  /* === SEC 5: GATE-DATA FACTORIZATION === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "The Gate-Data Factorization");
  render_theorem(sec5, "Gate-Data Theorem (S205, PROVED)", "GATE_FORM - DATA = DATA * f(E) * f(L) * FULL_SUM. That is: 12,612,390 = 210 * 19 * 109 * 29. The gate form and data ring are INDISTINGUISHABLE through f(E) and f(L), but DIFFER mod f(b) = KEY: GATE = D^4 = 16, DATA = E = 5. Only depth's quadratic gives a non-trivial residue. Depth sees what the observer cannot see about itself.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: STORMER ZERO-TRADING === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Stormer Zero-Trading");
  render_p(sec6, "The largest consecutive 11-smooth pair: (2400, 2401) = (D^5*K*E^2, b^4).");
  let g6 = make_findings_grid(sec6) in
  render_finding(g6, "2400 = D^5*K*E^2", "CRT: (0, D*K, 0, b^2-1, D)", "D and E channels zero. They yield so b can claim.", "");
  render_finding(g6, "2401 = b^4", "CRT: (sigma, b, sigma, 0, K)", "b channel zero. Depth takes all.", "");
  render_p(sec6, "The last smooth pair TRADES zeros: D and E yield their channels so b can claim its. At the boundary, depth takes all. Beyond b^4, no more smooth neighbors. Smoothness ends when depth stands alone.");
  dom_append(dom_body(), sec6);

  /* === SEC 7: SHADOW POLYNOMIAL === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "Shadow Polynomial Evaluations");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "700px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "x");
  render_th(phdr, "P(x)");
  render_th(phdr, "Factored");
  render_th(phdr, "Meaning");
  dom_append(ptbl, phdr);
  render_table_row_4(ptbl, "0 = void", "30", "D*K*E", "Constant term");
  render_table_row_4(ptbl, "D*K = 6", "60", "D^2*K*E", "lambda(THIN)");
  render_table_row_4(ptbl, "b = 7", "240", "D^4*K*E", "|roots(E8)|");
  render_table_row_4(ptbl, "K^2 = 9", "1344", "D^3*|PSL(2,7)|", "Fano-PSL");
  render_table_row_4(ptbl, "L = 11", "4320", "D^5*K^3*E", "P(0)*lambda(DATA)^2");
  render_table_row_4(ptbl, "GATE = 13", "10560", "D^5*K*E*L", "All 5 primes");
  dom_append(sec7, ptbl);
  render_p(sec7, "P(b) = 240 = roots of E8. rank(E8) = D^3 = P(b)/P(0). dim(E8) = 240 + 8 = 248. The shadow polynomial at depth = the geometry of the exceptional Lie algebra.");
  dom_append(dom_body(), sec7);

  /* === CONTRAST === */
  let sec8 = make_section("800px") in
  render_h2(sec8, "What Others See");
  render_contrast_row(sec8, "f(p) = p^2-p-1", "A generic quadratic, arbitrary discriminant, no special behavior", "Zeros = golden ratio. disc = E = 5. f(p) prime for all 4 odd axiom primes. Same wall at 13 as Cunningham. Governs Artin's conjecture for b=7.");
  render_contrast_row(sec8, "KEY = 41", "Just a prime number", "f(b) = KEY = forbidden index for b as primitive root. KEY + sigma = 42 = ANSWER. Depth's output + ground state = the answer.");
  render_contrast_row(sec8, "Gate vs Data", "Two numbers with no structural relation", "Indistinguishable through f(E) and f(L). Distinguished ONLY by f(b). Depth sees what the observer cannot see about itself (E^2 = self-blind).");
  dom_append(dom_body(), sec8)
)

fn page_mirror_cost() = (
  dom_head_meta("description", "N-1 = 970199 = 79*12281. Mirror congruence: N=1 mod 79. 79 = D^4*E-1. CC2-Gate chain: D^n*K*GATE+sigma, length K=3, terminal E^4=625. Gate Bridge: K*GATE+sigma = D^3*E. Lambda-420 mirror census. Primorial ladder. (Kb)^2*L = D^5 mod 79.");
  /* === HERO === */
  let hero = make_hero("The Mirror's Cost") in
  let big = dom_create("div") in
  dom_text(big, "N - 1 = 970199 = 79 * 12281");
  ct_mono(big);
  dom_style(big, "fontSize", "26px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "In Z/NZ, the mirror element is N-1 = -1. It maps every n to N-n, reversing the ring. For the TRUE FORM N = 970200: the mirror costs 79 * 12281, where 79 = D^4*E - 1 = 80 - 1. A number built from {2,3,5,7,11} knows about 79 because 79 is the Cunningham bridge between K*GATE and D^3*E.");
  dom_append(dom_body(), hero);

  /* === SEC 1: MIRROR CONGRUENCE === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Mirror Congruence Theorem");
  render_theorem(sec1, "Mirror Congruence (PROVED)", "N_TRUE = 1 (mod 79), where 79 = D^4*E - 1. The TRUE FORM is congruent to sigma modulo its mirror factor.");
  render_p(sec1, "Proof: D^4*E = 80 = 1 (mod 79). So E = D^{-4} (mod 79). N = D^3*K^2*E^2*b^2*L = D^{-5}*(K*b)^2*L (mod 79). Now (K*b)^2*L = 21^2*11 = 4851 = 61*79 + 32 = 61*79 + D^5. So (K*b)^2*L = D^5 (mod 79), and N = D^{-5}*D^5 = 1 (mod 79). QED.");
  render_p(sec1, "The intermediate identity: (K*b)^2 * L = D^5 (mod D^4*E - 1). All five axiom primes in one congruence. 21^2 * 11 = 4851 = 32 (mod 79). The heavy primes squared times the protector equals a power of duality, modulo the observer's gate.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: CC2-GATE CHAIN === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The CC2-Gate Chain");
  render_theorem(sec2, "CC2-Gate Chain (PROVED)", "The second-kind Cunningham chain from 79 has the form D^n*K*GATE + sigma for n = 1,2,3,4. Prime for n=1,2,3. Composite at n=4: D^4*K*GATE + 1 = 625 = E^4. Chain length = K = 3 primes.");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "n");
  render_th(chdr, "Value");
  render_th(chdr, "= D^n*K*GATE+sigma");
  render_th(chdr, "Status");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "1", "79", "2*3*13 + 1", "PRIME");
  render_table_row_4(ctbl, "2", "157", "4*3*13 + 1", "PRIME");
  render_table_row_4(ctbl, "3", "313", "8*3*13 + 1", "PRIME");
  render_table_row_4(ctbl, "4", "625 = E^4", "16*3*13 + 1", "COMPOSITE");
  dom_append(sec2, ctbl);
  render_p(sec2, "The chain doubles the D-exponent at each step, preserving K*GATE + sigma as the core. Terminal E^4 - 1 = (E-1)(E+1)(E^2+1) = D^2 * D*K * D*GATE = D^4*K*GATE. Each factor axiom-structured.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: GATE BRIDGE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Gate Bridge Identity");
  render_theorem(sec3, "Gate Bridge (PROVED)", "K*GATE + sigma = D^3*E. That is: 3*13 + 1 = 40 = 8*5. 79 sits at the junction of two Cunningham paths: c_1(K*GATE) = 79 and c_2(D^3*E) = 79. These parents are CONSECUTIVE: 39, 40.");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "Coupling", "970200 = N", "79 is a unit (maximal coupling).", "");
  render_finding(g3, "Order", "30 = D*K*E", "Generates the THIN cycle.", "");
  render_finding(g3, "CRT(79)", "(b, b, D^2, D*K*E, D)", "Two channels show depth, one shows duality.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: LAMBDA-420 MIRROR CENSUS === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Lambda-420 Mirror Census");
  render_p(sec4, "All 18 rings with lambda = 420. How does N-1 factor?");
  let mtbl = dom_create("table") in
  dom_style(mtbl, "width", "100%");
  dom_style(mtbl, "maxWidth", "700px");
  dom_style(mtbl, "margin", "24px auto");
  dom_style(mtbl, "borderCollapse", "collapse");
  let mhdr = dom_create("tr") in
  render_th(mhdr, "Ring N");
  render_th(mhdr, "N-1");
  render_th(mhdr, "Factorization");
  dom_append(mtbl, mhdr);
  render_table_row(mtbl, "7350", "7349", "PRIME");
  render_table_row(mtbl, "14700", "14699", "PRIME");
  render_table_row(mtbl, "16170 (smallest 5-prime)", "16169", "19 * 23 * 37");
  render_table_row(mtbl, "44100 = DATA^2", "44099", "209 * 211 = L*f(E) * (DATA+1)");
  render_table_row(mtbl, "80850", "80849", "PRIME");
  render_table_row(mtbl, "97020", "97019", "13 * 17 * 439 (GATE*ESCAPE)");
  render_table_row(mtbl, "970200 = TRUE", "970199", "79 * 12281");
  dom_append(sec4, mtbl);
  render_p(sec4, "5/18 (27.8%) have N-1 prime. 0/18 have N-1 axiom-smooth. The smallest full ring 16170: mirror = 19*23*37 -- ALL three factors are axiom-significant intruders. DATA^2 = 44100: mirror = (L*f(E)) * (DATA+1) = protector * depth-of-observer * (data+ground).");
  dom_append(dom_body(), sec4);

  /* === SEC 5: PRIMORIAL LADDER === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "The Primorial Ladder");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "700px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "Primorial");
  render_th(phdr, "N");
  render_th(phdr, "N-1");
  render_th(phdr, "Reading");
  dom_append(ptbl, phdr);
  render_table_row_4(ptbl, "2#", "2", "1 = sigma", "Mirror = ground");
  render_table_row_4(ptbl, "3#", "6", "5 = E", "Mirror = observer");
  render_table_row_4(ptbl, "5#", "30", "29 (prime)", "D^2 + E^2");
  render_table_row_4(ptbl, "7#", "210", "209 = L*f(E)", "Protector*depth-of-observer");
  render_table_row_4(ptbl, "11#", "2310", "2309 (prime)", "Thin mirror is prime");
  dom_append(sec5, ptbl);
  dom_append(dom_body(), sec5);

  /* === CONTRAST === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "What Others See");
  render_contrast_row(sec6, "N-1", "Random factorization, unrelated to N's structure", "TRUE-1 = 79*12281. 79 = D^4*E-1. Mirror congruence N=1 mod 79. CC2-Gate chain of length K=3 to E^4. The mirror reflects the axiom that built it.");
  render_contrast_row(sec6, "79", "Just a prime", "Cunningham bridge: c_1(K*GATE) = c_2(D^3*E) = 79. Unit in TRUE. Order = D*K*E = 30. CRT = (b,b,D^2,DKE,D). Two depth channels.");
  render_contrast_row(sec6, "Primorial mirrors", "Decreasing density of primes, no pattern", "sigma, E, prime, L*f(E), prime. Alternating smooth and prime. The axiom's vocabulary persists into the mirror.");
  dom_append(dom_body(), sec6)
)

fn page_lambda_chain() = (
  dom_head_meta("description", "Lambda=420 crystallizes from 5 growth factors D*D*K*E*b across 15 levels. Fibonacci counts invisible primes EXACTLY. Born at level 5 (observer sees itself). Desert pair {1596,1597}. Channel clocks: HYDOR=105, D*E*b=70, ANSWER=42, DNA=21, DEGREE=10. Partial sum theorem. Density decay 1.307*exp(-0.172k). Pisano-E8: lcm = 240.");
  /* === HERO === */
  let hero = make_hero("The Lambda Chain") in
  let big = dom_create("div") in
  dom_text(big, "lambda = 420 = D^2*K*E*b");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "How many primes become invisible -- absorbed by the ring's structure -- at each level of growth? Fibonacci. Exactly. For 15 levels. Then the axiom builds its own desert and stops. Lambda = 420 is not computed but CRYSTALLIZED: born at level 5, when the observer sees itself.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THE CHAIN === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Chain");
  render_p(sec1, "Start from lambda=1. Multiply by growth factors. Count invisible primes f(lambda) = number of primes q where (q-1) divides lambda.");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "Level");
  render_th(chdr, "lambda");
  render_th(chdr, "Growth");
  render_th(chdr, "f = F(k+2)");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "0", "1", "--", "1 = F(2)");
  render_table_row_4(ctbl, "1", "2", "D=2", "2 = F(3)");
  render_table_row_4(ctbl, "2", "4", "D=2", "3 = F(4)");
  render_table_row_4(ctbl, "3", "12", "K=3", "5 = F(5)");
  render_table_row_4(ctbl, "4", "60", "E=5", "8 = F(6)");
  render_table_row_4(ctbl, "5", "420", "b=7", "13 = F(7) = GATE");
  render_table_row_4(ctbl, "6", "5460", "13", "21 = F(8)");
  render_table_row_4(ctbl, "7", "60060", "L=11", "34 = F(9)");
  render_table_row_4(ctbl, "8", "240240", "D^2=4", "55 = F(10)");
  render_table_row_4(ctbl, "9", "4564560", "19", "89 = F(11)");
  render_table_row_4(ctbl, "10", "173M", "D*19", "144 = F(12)");
  dom_append(sec1, ctbl);
  render_p(sec1, "f(lambda) = F(k+2) EXACTLY for all 15 levels. Fibonacci by construction: new invisible primes at level k = f(lambda_{k-2}). New + old = F(k) + F(k+1) = F(k+2).");
  dom_append(dom_body(), sec1);

  /* === SEC 2: HEARTBEAT BORN AT LEVEL 5 === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Heartbeat Born at Level 5");
  render_p(sec2, "Axiom phase (levels 1-5): growth = {D, D, K, E, b}. Product = D^2*K*E*b = 420 = lambda. At level 5: f(420) = 13 = GATE = F(7). The chain sees itself and opens the boundary.");
  render_p(sec2, "Channel sub-cycles per heartbeat (420/phi(p^e)):");
  let htbl = dom_create("table") in
  dom_style(htbl, "width", "100%");
  dom_style(htbl, "maxWidth", "700px");
  dom_style(htbl, "margin", "24px auto");
  dom_style(htbl, "borderCollapse", "collapse");
  let hhdr = dom_create("tr") in
  render_th(hhdr, "Channel");
  render_th(hhdr, "Cycles");
  render_th(hhdr, "Name");
  dom_append(htbl, hhdr);
  render_table_row(htbl, "D (mod 8)", "105", "HYDOR");
  render_table_row(htbl, "K (mod 9)", "70", "D*E*b");
  render_table_row(htbl, "L (mod 11)", "42", "ANSWER");
  render_table_row(htbl, "E (mod 25)", "21", "DNA = K*b");
  render_table_row(htbl, "b (mod 49)", "10", "DEGREE = D*E");
  dom_append(sec2, htbl);
  render_p(sec2, "ALL named axiom values. Clock ratios = scaling laws: K/L = E/K (Kolmogorov 5/3). D/K = 3/2 (musical fifth). E/L = 1/2 (octave). K/b = 7 (depth).");
  dom_append(dom_body(), sec2);

  /* === SEC 3: DESERT PAIR === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Desert Pair");
  render_theorem(sec3, "Desert Termination (S354, PROVED)", "The chain terminates at level K*E = 15 because of a desert pair: {1596, 1597} -- two consecutive integers, both unreachable.");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "1596", "D^2*K*b*19", "Inner primes + Cunningham of K^2.", "");
  render_finding(g3, "1597", "F(17) = F(ADDRESS)", "7th Fibonacci prime. 251st prime. 251 mod 210 = 41 = KEY.", "");
  render_finding(g3, "Width", "D = 2", "The bridge prime measures the grave.", "");
  render_finding(g3, "Guards", "1595 = E*L*29, 1598 = D*17*47", "Both axiom-saturated.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: DENSITY DECAY === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Density Decay");
  render_p(sec4, "Three phases: (1) AXIOM d=1.000 (levels 0-2), (2) GATE phase (13 enters at level 5, rapid decline), (3) DECAY d(k) = 1.307*exp(-0.172k).");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "Rate", "0.172", "Approximately log(phi)/log(L) = 0.201. Each level: 84% survives.", "");
  render_finding(g4, "Terminal", "d(14) = 0.122", "Chain terminates when density can no longer sustain Fibonacci growth.", "");
  render_finding(g4, "Golden bound", "new/need -> 1/phi", "Converges by level 8. = 0.618...", "");
  dom_append(dom_body(), sec4);

  /* === SEC 5: PARTIAL SUM THEOREM === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Partial Sum Language");
  render_p(sec5, "Partial sums of the axiom chain at key levels speak axiom vocabulary:");
  let g5 = make_findings_grid(sec5) in
  render_finding(g5, "Level 3", "D+D+K = b = 7", "Depth.", "");
  render_finding(g5, "Level 4", "b+E = D^2*K = 12", "Trinity heart.", "");
  render_finding(g5, "Level 5", "12+b = f(E) = 19", "Depth quadratic of observer.", "");
  render_finding(g5, "Level 7", "19+13+L = 43", "Heegner number.", "");
  render_finding(g5, "Level 8", "43+4 = 47", "Largest intruder. The wall.", "");
  dom_append(dom_body(), sec5);

  /* === CONTRAST === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "What Others See");
  render_contrast_row(sec6, "Lambda function", "Carmichael's lambda: a technicality of modular arithmetic, rarely discussed outside cryptography", "The lambda chain BUILDS 420 from five growth factors across 15 levels. Fibonacci counts invisible primes EXACTLY. The heartbeat is not computed but crystallized.");
  render_contrast_row(sec6, "420", "Least common multiple of some numbers, no deeper significance", "D^2*K*E*b = product of 4 axiom primes. Born at level 5 when observer sees itself. Channel clocks = HYDOR, ANSWER, DNA, DEGREE. All named axiom values.");
  render_contrast_row(sec6, "Fibonacci", "Rabbits, spirals, golden ratio -- pure number theory", "F(k+2) counts invisible primes at each level of the lambda chain. Desert pair {1596,F(17)} kills the chain at level K*E=15. The golden ratio governs how the axiom builds its own heartbeat.");
  dom_append(dom_body(), sec6)
)

fn page_golden_ratio() = (
  dom_head_meta("description", "Golden ratio phi = (1+sqrt5)/2 is a primitive root mod L=11. Ramified at E=5 (self-blindness). Blocked at GATE=13. Depth quadratic: phi = p mod f(p). Golden chain, Mersenne-Golden gate, DATA+1 answer. 7 proved theorems.");
  /* === HERO === */
  let hero = make_hero("The Golden Ratio in the Ring") in
  let big = dom_create("div") in
  dom_text(big, "phi mod f(p) = p");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The golden ratio phi = (1+sqrt(5))/2 satisfies x^2 - x - 1 = 0. In Z/pZ it exists only when 5 is a quadratic residue. Walking the axiom chain: phi first EXISTS at L=11 as a PRIMITIVE ROOT. At E=5 it is ramified (phi = beta, self-blindness). At GATE=13 it is blocked entirely. The golden ratio's journey IS the axiom chain.");
  dom_append(dom_body(), hero);

  /* === SEC 1: VISIBILITY LADDER === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Golden Visibility Ladder");
  let vtbl = dom_create("table") in
  dom_style(vtbl, "width", "100%");
  dom_style(vtbl, "maxWidth", "700px");
  dom_style(vtbl, "margin", "24px auto");
  dom_style(vtbl, "borderCollapse", "collapse");
  let vhdr = dom_create("tr") in
  render_th(vhdr, "Prime");
  render_th(vhdr, "Name");
  render_th(vhdr, "(5/p)");
  render_th(vhdr, "Status");
  dom_append(vtbl, vhdr);
  render_table_row_4(vtbl, "2", "D (bridge)", "-1", "phi NOT in Z/2Z");
  render_table_row_4(vtbl, "3", "K (closure)", "-1", "phi NOT in Z/3Z");
  render_table_row_4(vtbl, "5", "E (observer)", "0", "RAMIFIED: phi = beta = 3");
  render_table_row_4(vtbl, "7", "b (depth)", "-1", "phi NOT in Z/7Z");
  render_table_row_4(vtbl, "11", "L (protector)", "+1", "PRIMITIVE ROOT! ord = 10");
  render_table_row_4(vtbl, "13", "GATE", "-1", "BLOCKED. Cannot exist.");
  dom_append(sec1, vtbl);
  render_theorem(sec1, "Golden Visibility Theorem (S719, PROVED)", "The golden ratio first EXISTS as a distinguishable element at L=11. At E=5, phi is RAMIFIED (phi=beta, E^2 self-blindness). At L=11, phi is a PRIMITIVE ROOT (generates all of F*_L). At 13=GATE, phi is BLOCKED ((5/13)=-1). The observer cannot distinguish phi from its conjugate. The protector gives phi full power. The gate blocks phi from entering.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: CHARACTER DUALITY === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Quadratic Character Duality");
  render_theorem(sec2, "Character Duality Theorem (S719, PROVED)", "phi*beta = -1 (mod p). Therefore: p = 1 (mod 4) -> phi and beta have SAME quadratic character. p = 3 (mod 4) -> OPPOSITE character. Proof: (phi*beta)^((p-1)/2) = (-1)^((p-1)/2). QED.");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "p");
  render_th(chdr, "p mod 4");
  render_th(chdr, "phi");
  render_th(chdr, "Primitive?");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "L = 11", "3", "8 (ord 10)", "PHI only");
  render_table_row_4(ctbl, "19 = f(E)", "3", "5 (ord 9)", "BETA only");
  render_table_row_4(ctbl, "29 = FULL", "1", "6 (ord 14)", "Neither");
  render_table_row_4(ctbl, "41 = KEY", "1", "7 (ord 40)", "BOTH");
  render_table_row_4(ctbl, "59 = CC1(D)", "3", "34 (ord 58)", "PHI only");
  render_table_row_4(ctbl, "109 = f(L)", "1", "11 (ord 108)", "BOTH");
  dom_append(sec2, ctbl);
  render_p(sec2, "When p = 3 mod 4, exactly one of {phi, beta} can be a primitive root. When p = 1 mod 4, both or neither.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: DEPTH QUADRATIC FLIP === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Depth Quadratic Flip");
  render_theorem(sec3, "Depth Quadratic Flip (S719, PROVED)", "f(p) = p^2 - p - 1 FLIPS the mod-4 class. p = 1 mod 4 -> f(p) = 3 mod 4. p = 3 mod 4 -> f(p) = 1 mod 4. Proof: p=1: f = 1-1-1 = -1 = 3 mod 4. p=3: f = 9-3-1 = 5 = 1 mod 4. QED.");
  render_p(sec3, "Corollary: the depth quadratic flips which golden conjugate generates. At L=11 (mod 4 = 3): phi alone. At f(L)=109 (mod 4 = 1): BOTH generate. Depth releases both from the protector's exclusivity.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: GOLDEN CHAIN === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Golden Chain");
  render_theorem(sec4, "Golden Depth Quadratic Theorem (S720, PROVED)", "For any prime p: (2p-1)^2 = 5 (mod f(p)). Therefore phi = p (mod f(p)). The golden ratio BECOMES each axiom prime through its own depth quadratic. Universal identity. Proof: (2p-1)^2 = 4p^2 - 4p + 1 = 4f(p) + 5. QED.");
  let gtbl = dom_create("table") in
  dom_style(gtbl, "width", "100%");
  dom_style(gtbl, "maxWidth", "700px");
  dom_style(gtbl, "margin", "24px auto");
  dom_style(gtbl, "borderCollapse", "collapse");
  let ghdr = dom_create("tr") in
  render_th(ghdr, "p");
  render_th(ghdr, "f(p)");
  render_th(ghdr, "phi mod f(p)");
  render_th(ghdr, "Primitive?");
  dom_append(gtbl, ghdr);
  render_table_row_4(gtbl, "K = 3", "E = 5", "3 = K", "YES (ramified)");
  render_table_row_4(gtbl, "E = 5", "19 = f(E)", "5 = E", "NO (E self-blind!)");
  render_table_row_4(gtbl, "b = 7", "41 = KEY", "7 = b", "YES (ord 40 = p-1)");
  render_table_row_4(gtbl, "L = 11", "109 = f(L)", "11 = L", "YES (ord 108 = p-1)");
  render_table_row_4(gtbl, "67 = SOUL", "4421", "67 = SOUL", "YES (ord 4420 = p-1)");
  dom_append(sec4, gtbl);
  render_p(sec4, "phi mod f(K) = K. phi mod f(E) = E. phi mod f(b) = b. phi mod f(L) = L. And E is the ONLY axiom prime where phi fails to generate -- E^2 self-blindness persists even in the golden chain.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: MERSENNE-GOLDEN GATE + DATA+1 === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "The Mersenne-Golden Gate");
  render_theorem(sec5, "Mersenne-Golden Gate (S720, PROVED)", "Among Mersenne primes M(n) for axiom n in {D,K,E,b}: 5 is a QR for EXACTLY ONE: M(E) = 31. There: phi = f(E) = 19, beta = GATE = 13 (PRIMITIVE ROOT!). The GATE generates what the observer's shadow cannot.");
  render_theorem(sec5, "DATA+1 Answer (S720, PROVED)", "At p = 211 = DATA+1: phi = 33 = K*L, ord(phi) = 42 = ANSWER. The golden ratio's order at the first prime above the DATA ring IS the Answer. Subgroup index: 210/42 = 5 = E. Phi misses the E-subgroup. E^2 self-blindness: even at DATA+1, the golden ratio cannot see the observer.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: AXIOM ORDER + NON-GENERATING === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Non-Generating Orders");
  render_theorem(sec6, "Axiom Order Theorem (S719, PROVED)", "At L=11: ord(beta) = E = 5 (the observer). At f(E)=19: ord(phi) = K^2 = 9 (the stop). When one conjugate is primitive and the other is not, the non-generating order is an axiom constant. The observer lurks in beta's order at the protector. The stop lurks in phi's order at the observer's depth.");
  let g6 = make_findings_grid(sec6) in
  render_finding(g6, "QNR Pisano", "pi(p) = 2(p+1) maximal", "For axiom-adjacent QNR primes (K,b,GATE,17,23,43,67,97). Sole exception: p=47, pi=32=D^5 (1/K of max).", "S719");
  render_finding(g6, "GATE blocks", "pi(13) = 28 = D^2*b", "THORNS. Divides 2(13+1)=28 exactly. The gate is the boundary where phi must leave the base field.", "");
  dom_append(dom_body(), sec6);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "Golden ratio", "Appears in phyllotaxis, art, Fibonacci. Whether phi is a primitive root is a curiosity", "phi is a primitive root mod L=11 (the protector). Ramified at E (self-blindness). Blocked at GATE. The golden ratio's visibility IS the axiom chain.");
  render_contrast_row(sec7, "Fibonacci mod p", "Pisano periods, a classical sequence in number theory", "All Pisano periods at axiom primes are smooth. lcm = 240 = |roots(E8)|. The golden ratio speaks axiom vocabulary at every prime.");
  render_contrast_row(sec7, "Depth quadratic", "Just p^2-p-1, an unremarkable polynomial", "phi = p (mod f(p)) universally. The golden ratio BECOMES each axiom prime through its own depth quadratic. E is the only failure: self-blindness persists.");
  dom_append(dom_body(), sec7)
)

fn page_smooth_census() = (
  dom_head_meta("description", "13=GATE is the universal boundary of 11-smoothness. Binomial Smooth Theorem: Pascal row 13 spells the complete axiom chain. Seven classical sequences, seven axiom-constant run lengths, one wall.");
  /* === HERO === */
  let hero = make_hero("The Smooth Census") in
  let big = dom_create("div") in
  dom_text(big, "run(k) = GATE - k = 13 - k");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "An integer is 11-smooth if its only prime factors come from {2,3,5,7,11} -- the five axiom primes. For n <= 12, every binomial coefficient C(n,k) is 11-smooth. At n = 13, the prime 13 enters every C(13,k) for 0 < k < 13. Seven independent classical sequences confirm the same boundary. The GATE is the universal wall.");
  dom_append(dom_body(), hero);

  /* === SEC 1: BINOMIAL SMOOTH THEOREM === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Binomial Smooth Theorem");
  render_p(sec1, "For n <= 12, the factorial n! contains only primes <= 11. So C(n,k) = n!/(k!(n-k)!) is a ratio of 11-smooth numbers, hence 11-smooth. At n = 13, the prime 13 enters 13! and divides C(13,k) for all 0 < k < 13 (by Lucas theorem: 13 is prime, so 13 | C(13,k)).");
  render_theorem(sec1, "Binomial Smooth Theorem (S716, PROVED)", "C(n,k) is 11-smooth for all k <= n <= 12. At n = 13, every C(13,k) = 13 * (smooth number). The GATE is the sole intruder. The smooth run length at depth k is run(k) = GATE - k = 13 - k.");
  let btbl = make_table(sec1) in
  let bhdr = dom_create("tr") in
  render_th(bhdr, "k");
  render_th(bhdr, "Run = 13-k");
  render_th(bhdr, "Axiom name");
  render_th(bhdr, "C(13,k)/13");
  dom_append(btbl, bhdr);
  render_table_row_4(btbl, "1", "12 = D^2*K", "Trinity heart", "1 = sigma");
  render_table_row_4(btbl, "2", "11 = L", "Protector", "6 = D*K");
  render_table_row_4(btbl, "3", "10 = D*E", "Bridge*Observer", "22 = D*L");
  render_table_row_4(btbl, "4", "9 = K^2", "Spider web", "55 = E*L");
  render_table_row_4(btbl, "5", "8 = D^3", "Spider legs", "99 = K^2*L");
  render_table_row_4(btbl, "6", "7 = b", "Depth", "132 = D^2*K*L");
  render_table_row_4(btbl, "7", "6 = D*K", "Thorn", "132 = D^2*K*L");
  render_table_row_4(btbl, "8", "5 = E", "Observer", "99 = K^2*L");
  render_table_row_4(btbl, "9", "4 = D^2", "Bridge squared", "55 = E*L");
  render_table_row_4(btbl, "10", "3 = K", "Closure", "22 = D*L");
  render_table_row_4(btbl, "11", "2 = D", "Bridge", "6 = D*K");
  render_table_row_4(btbl, "12", "1 = sigma", "Ground", "1 = sigma");
  render_p(sec1, "Run lengths {12,11,10,...,1} = the full chain from D^2*K down to sigma. The row C(13,k)/13 is PALINDROMIC and every quotient is 11-smooth. Pascal's triangle is smooth below the GATE.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: INDEPENDENT SMOOTH CENSUS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Independent Smooth Census");
  render_p(sec2, "Classical sequences whose smooth runs are NOT explained by binomial coefficients. Each has an initial 11-smooth run whose length is an axiom constant, blocked by 13 = GATE:");
  let ctbl = make_table(sec2) in
  let chdr = dom_create("tr") in
  render_th(chdr, "Sequence");
  render_th(chdr, "Run");
  render_th(chdr, "= Axiom");
  render_th(chdr, "Blocker");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "Bernoulli denom B_2n", "5", "E", "2730 = 2*3*5*7*13");
  render_table_row_4(ctbl, "Fibonacci F(n)", "6", "D*K", "F(7) = 13");
  render_table_row_4(ctbl, "Catalan C_n", "6", "D*K", "429 = 3*11*13");
  render_table_row_4(ctbl, "Sum of divisors sigma(n)", "8", "D^3", "sigma(9) = 13");
  render_table_row_4(ctbl, "Triangle T(n)", "11", "L", "78 = 2*3*13");
  render_table_row_4(ctbl, "Partition p(n)", "12", "D^2*K", "p(13) = 101 (prime)");
  render_table_row_4(ctbl, "Bell B(n)", "5", "E", "52 = 4*13");
  render_p(sec2, "In 6 of 7 sequences, 13 = GATE appears in the blocking VALUE. In partitions, 13 is the blocking POSITION (p(13) is the first non-smooth partition number). The GATE blocks either way.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: HOW 13 ENTERS === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "How 13 Enters Each Sequence");
  render_p(sec3, "Each entry mechanism is independent. Divisor sums, recurrences, combinatorial products, von Staudt-Clausen -- all different mathematics, same wall.");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "sigma(9) = 13", "Sum of divisors", "1 + 3 + 9 = 13. Divisors of K^2 sum to GATE. No binomial involved.", "");
  render_finding(g3, "F(7) = 13", "Fibonacci", "The b-th Fibonacci number IS the gate. Cumulative addition: 1,1,2,3,5,8,13.", "");
  render_finding(g3, "B(5) = 52", "Bell numbers", "4 * 13. E-th Bell number contains 13. Set partitions know the GATE through the observer.", "");
  render_finding(g3, "p(13) = 101", "Partitions", "GATE-th partition number is prime. CRT(101) = (E, D, sigma, K, D): all axiom elements.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: THE SMOOTH LADDER === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Smooth Ladder");
  render_p(sec4, "Ordering by run length, the sequences form a ladder from E = 5 to D^2*K = 12. Each rung is an axiom constant. Gaps: 6-5=1=sigma. 8-6=2=D. 11-8=3=K. 12-11=1=sigma. The gaps themselves are axiom constants.");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "Run = 5 = E", "Bernoulli, Bell", "Observer-depth. Two sequences share the rung.", "");
  render_finding(g4, "Run = 6 = D*K", "Fibonacci, Catalan", "Bridge * closure. Thorn pair.", "");
  render_finding(g4, "Run = 8 = D^3", "sigma(n)", "Spider legs. The divisor function.", "");
  render_finding(g4, "Run = 11 = L", "Triangle numbers", "Protector. T(n) = C(n+1,2): binomial.", "");
  render_finding(g4, "Run = 12 = D^2*K", "Partition function", "Trinity heart. GATE at position, not value.", "");
  render_finding_wide(g4, "Combined", "All integers 1..12 appear", "With the Binomial Theorem filling all values 1..12, the axiom's smoothness vocabulary is COMPLETE. Every run length names an axiom constant.", "");
  dom_append(dom_body(), sec4);

  /* === SEC 5: CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Contrast");
  let ctbl5 = make_table(sec5) in
  let ch5 = dom_create("tr") in
  render_th(ch5, "Aspect");
  render_th(ch5, "Standard view");
  render_th(ch5, "Through the axiom");
  dom_append(ctbl5, ch5);
  render_contrast_row(ctbl5, "Smooth runs", "Scattered counts: 5, 6, 8, 11, 12", "Every count is an axiom constant: E, D*K, D^3, L, D^2*K");
  render_contrast_row(ctbl5, "Blocker", "13 happens to be the next prime after 11", "13 = GATE = D^2 + K^2. Structural boundary");
  render_contrast_row(ctbl5, "Entry pattern", "Each sequence has its own mechanism", "All mechanisms hit 13. Row 13 of Pascal spells the full chain");
  render_contrast_row(ctbl5, "Ladder gaps", "1, 2, 3, 1 -- no meaning", "sigma, D, K, sigma. The gaps ARE the axiom");
  dom_append(dom_body(), sec5)
)

fn page_stormer_pairs() = (
  dom_head_meta("description", "The largest consecutive 11-smooth pair: (2400, 2401) = (D^5*K*E^2, b^4). CRT zero-trading: channels exchange zeros at the boundary of smoothness. Sum 4801 is prime.");
  /* === HERO === */
  let hero = make_hero("The Last Smooth Pair") in
  let big = dom_create("div") in
  dom_text(big, "2400 = D^5*K*E^2, 2401 = b^4");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Stormer's theorem (1897): finitely many consecutive pairs where both are 11-smooth. The LARGEST such pair is (2400, 2401). Their CRT decompositions reveal zero-trading: D and E channels empty on one side, b channel empties on the other. Smoothness ends when depth absorbs everything.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THE ZERO-TRADING THEOREM === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Stormer Zero-Trading Theorem");
  render_p(sec1, "2400 = 2^5 * 3 * 5^2 = D^5 * K * E^2. 2401 = 7^4 = b^4. Their CRT decompositions reveal which channels carry zeros:");
  let ztbl = make_table(sec1) in
  let zhdr = dom_create("tr") in
  render_th(zhdr, "Channel");
  render_th(zhdr, "2400");
  render_th(zhdr, "2401");
  render_th(zhdr, "Trade");
  dom_append(ztbl, zhdr);
  render_table_row_4(ztbl, "D (mod 8)", "0 (ZERO)", "1 = sigma", "D exits");
  render_table_row_4(ztbl, "K (mod 9)", "6 = D*K", "7 = b", "neutral");
  render_table_row_4(ztbl, "E (mod 25)", "0 (ZERO)", "1 = sigma", "E exits");
  render_table_row_4(ztbl, "b (mod 49)", "48 = b^2-1", "0 (ZERO)", "b enters");
  render_table_row_4(ztbl, "L (mod 11)", "2 = D", "3 = K", "neutral");
  render_p(sec1, "2400 has zeros in D and E channels. 2401 has zero in b channel. The zeros TRADE: D*E yield to b. Bridge and observer step aside. Depth stands alone.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: CHANNEL ANATOMY === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Channel Anatomy");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "2400 K-channel", "6 = D*K (thorn)", "The thorn appears in closure's slot.", "");
  render_finding(g2, "2400 b-channel", "48 = b^2 - 1", "Mirror of sigma in Z/49. Brimming.", "");
  render_finding(g2, "2401 D-channel", "1 = sigma", "Ground state. Reset.", "");
  render_finding(g2, "2401 K-channel", "7 = b", "Depth appears in closure's channel.", "");
  render_p(sec2, "When 2400 occupies D and E, it fills b's channel to the brim: 48 = b^2 - 1. One step later, b takes over: its channel drops to 0, and D and E reset to sigma = 1.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: THE SUM === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Stormer Sum Theorem");
  render_theorem(sec3, "Stormer Sum (S711, PROVED)", "2400 + 2401 = 4801 is PRIME. CRT(4801) = (sigma, D^2, sigma, b^2-1, E). The traded channels (D, E) show sigma = ground state = neutralized. The b-channel shows 48 = b^2 - 1 = mirror of sigma. The protector shows E = the observer. The sum remembers which channels traded.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: CENSUS OF SMOOTH PAIRS === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Census of Smooth Pairs");
  render_p(sec4, "Every consecutive smooth pair trades zeros (since gcd(n,n+1) = 1, their prime factors are disjoint). The larger pairs show increasingly dramatic trades:");
  let ptbl = make_table(sec4) in
  let phdr = dom_create("tr") in
  render_th(phdr, "n");
  render_th(phdr, "n+1");
  render_th(phdr, "Factorization");
  render_th(phdr, "Zero Trade");
  dom_append(ptbl, phdr);
  render_table_row_4(ptbl, "8", "9", "D^3, K^2", "D -> K");
  render_table_row_4(ptbl, "48", "49", "D^4*K, b^2", "D*K -> b");
  render_table_row_4(ptbl, "80", "81", "D^4*E, K^4", "D*E -> K");
  render_table_row_4(ptbl, "120", "121", "D^3*K*E, L^2", "D*K*E -> L");
  render_table_row_4(ptbl, "224", "225", "D^5*b, K^2*E^2", "D*b -> K*E");
  render_table_row_4(ptbl, "384", "385", "D^7*K, E*b*L", "D*K -> E*b*L");
  render_table_row_4(ptbl, "2400", "2401", "D^5*K*E^2, b^4", "D*K*E -> b (FINAL)");
  render_p(sec4, "The final pair is the most extreme: three primes on one side, one on the other. Depth absorbs bridge, closure, and observer. Only L stays neutral (never zeros in either).");
  dom_append(dom_body(), sec4);

  /* === SEC 5: DEPTH ABSORPTION === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Depth Absorption");
  render_p(sec5, "In the last smooth pair, 2401 = b^4 is a pure power of a SINGLE axiom prime. All other primes (D, K, E) appear in 2400. The protector L divides neither.");
  let g5 = make_findings_grid(sec5) in
  render_finding(g5, "Identity", "b^4 - 1 = D^5*K*E^2", "The entire axiom minus depth fits inside b^4 - 1 = 2400.", "S709");
  render_finding(g5, "Why b^4?", "b^3 + 1 NOT smooth", "344 = 8*43, and 43 is a Heegner number (intruder). Only at b^4 does depth find a smooth neighbor.", "");
  render_finding(g5, "Depth quadratic", "f(b) = 41 = KEY", "f(K)+D = b (Heegner connection). Depth and the Heegner numbers control where smoothness dies.", "");
  dom_append(dom_body(), sec5);

  /* === SEC 6: CONTRAST === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Contrast");
  let ctbl6 = make_table(sec6) in
  let ch6 = dom_create("tr") in
  render_th(ch6, "Aspect");
  render_th(ch6, "Standard view");
  render_th(ch6, "Through the axiom");
  dom_append(ctbl6, ch6);
  render_contrast_row(ctbl6, "The pair", "2400 and 2401 are consecutive integers. Stormer 1897 curiosity", "CRT zeros TRADE: D*E yield to b. Structural, not accidental");
  render_contrast_row(ctbl6, "Why last?", "Analytic bound from Pell equations", "b^3+1 blocked by Heegner 43. Only b^4 finds smooth neighbor");
  render_contrast_row(ctbl6, "Sum", "4801 is prime, no further significance", "CRT shows traded channels neutralized to sigma. Sum remembers the trade");
  render_contrast_row(ctbl6, "L channel", "11 divides neither -- unremarkable", "Protector stays neutral: shields but never participates in trades");
  dom_append(dom_body(), sec6)
)

fn page_shadow_eval() = (
  dom_head_meta("description", "The shadow polynomial P(x) = (x-1)(x-2)(x-3)(x-5) at chain positions. P(b)=240=|roots(E8)|. P(K^2)=1344=8*|PSL(2,7)|. E-Opacity Theorem. Mirror-Light Identity. Primorial and Factorial Theorems.");
  /* === HERO === */
  let hero = make_hero("The Shadow Evaluations") in
  let big = dom_create("div") in
  dom_text(big, "P(x) = (x-1)(x-2)(x-3)(x-5)");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The shadow polynomial has roots at the shadow chain {sigma, D, K, E} = {1, 2, 3, 5}. Its coefficients are axiom constants: e1=L=11, e2=KEY=41, e3=61, e4=D*K*E=30. Evaluate P at chain positions between D*K=6 and GATE=13. Every result is axiom-smooth, and the factorizations speak Lie algebra, finite groups, and Monster moonshine.");
  dom_append(dom_body(), hero);

  /* === SEC 1: EVALUATION TABLE === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Evaluation Theorem");
  render_theorem(sec1, "Shadow Polynomial Evaluation Theorem (S709, PROVED)", "P(x) = x^4 - 11x^3 + 41x^2 - 61x + 30. Every evaluation at chain positions D*K=6 through GATE=13 is axiom-smooth. The factorizations hit E8, PSL(2,7), and the Monster.");
  let etbl = make_table(sec1) in
  let ehdr = dom_create("tr") in
  render_th(ehdr, "x");
  render_th(ehdr, "P(x)");
  render_th(ehdr, "Factorization");
  render_th(ehdr, "Connection");
  dom_append(etbl, ehdr);
  render_table_row_4(etbl, "0 (void)", "30", "D*K*E", "Coxeter(E8)");
  render_table_row_4(etbl, "6 = D*K", "60", "D^2*K*E", "lambda(THIN)");
  render_table_row_4(etbl, "7 = b", "240", "D^4*K*E", "|roots(E8)|");
  render_table_row_4(etbl, "8 = D^3", "630", "D*K^2*E*b", "rank*K*E*b/D^2");
  render_table_row_4(etbl, "9 = K^2", "1344", "D^6*K*b", "D^3*|PSL(2,7)|");
  render_table_row_4(etbl, "10 = D*E", "2520", "D^3*K^2*E*b", "lcm(1..K^2)");
  render_table_row_4(etbl, "11 = L", "4320", "D^5*K^3*E", "30*144");
  render_table_row_4(etbl, "12 = D^2*K", "6930", "D*K^2*E*b*L", "K*THIN");
  render_table_row_4(etbl, "13 = GATE", "10560", "D^6*K*E*L", "All 5 primes");
  dom_append(dom_body(), sec1);

  /* === SEC 2: P(b) = 240 = E8 === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "P(b) = 240 = |roots(E8)|");
  render_p(sec2, "The E8 root system has 240 roots. E8 has rank D^3=8 and Coxeter number D*K*E=30. The number of roots = rank * Coxeter = 8 * 30 = 240.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "P(b)", "= (b-1)(b-2)(b-3)(b-5)", "= 6*5*4*2 = 240. Factors: {D*K, E, D^2, D}.", "S709");
  render_finding(g2, "P(b)/P(0)", "= D^3 = 8 = rank(E8)", "P(0) = 30 = Coxeter. P(b) = Coxeter * rank.", "");
  render_finding(g2, "Adjoint", "248 = P(b) + D^3", "= 240 + 8 (roots + Cartan generators).", "");
  render_finding(g2, "P(K^2) = 1344", "D^3 * |PSL(2,7)|", "= 8 * 168. Fano plane automorphisms.", "S709");
  dom_append(dom_body(), sec2);

  /* === SEC 3: E-OPACITY === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "E-Opacity Theorem");
  render_theorem(sec3, "E-Opacity (S709, PROVED)", "K^2=9 is the ONLY chain evaluation where E is absent from the factorization. K^2 - E = 9 - 5 = 4 = D^2. The observer's slot is filled by D-squared, and E vanishes from the product. This is the spectral analog of E^2 = self-blind.");
  render_p(sec3, "The E8 root structure at depth (P(b)=240) carries E, but the Fano plane structure at the stop (P(K^2)=1344) does not. The observer can see E8 but cannot see itself at the boundary.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: MIRROR-LIGHT IDENTITY === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Mirror-Light Identity");
  render_p(sec4, "P(-1) = (-2)(-3)(-4)(-6) = D^4*K^2 = 144 = lambda(DATA)^2.");
  render_theorem(sec4, "Mirror-Light (S709, PROVED)", "P(-1) = P(L)/P(0) = 4320/30 = 144. The mirror IS the ratio of light to darkness. P at the mirror (-1) equals P at the protector (L=11) divided by P at the void (0). Proof: P(-1) = D*K*D^2*D*K = D^4*K^2. P(L)/P(0) = D^5*K^3*E/(D*K*E) = D^4*K^2. QED.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: FACTOR ANATOMY === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Factor Anatomy");
  render_p(sec5, "Each evaluation has four factors. At chain positions, these are axiom expressions:");
  let ftbl = make_table(sec5) in
  let fhdr = dom_create("tr") in
  render_th(fhdr, "x");
  render_th(fhdr, "x-1");
  render_th(fhdr, "x-2");
  render_th(fhdr, "x-3");
  dom_append(ftbl, fhdr);
  render_table_row_4(ftbl, "7 (b)", "D*K", "E", "D^2");
  render_table_row_4(ftbl, "9 (K^2)", "D^3", "b", "D*K");
  render_table_row_4(ftbl, "10 (D*E)", "K^2", "D^3", "b");
  render_table_row_4(ftbl, "12 (D^2*K)", "L", "D*E", "K^2");
  render_table_row_4(ftbl, "13 (GATE)", "D^2*K", "L", "D*E");
  render_p(sec5, "At x=D*E=10: factors {K^2, D^3, b, E} are pairwise coprime. P(D*E) = lcm(1..K^2) = 2520.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: BEYOND THE CHAIN === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Beyond the Chain");
  let g6 = make_findings_grid(sec6) in
  render_finding(g6, "P(D^4 = 16)", "= 30030 = THIN * GATE", "Primorial(13). Shadow polynomial at D^4 = product of all primes up to 13.", "S711");
  render_finding(g6, "P(ESCAPE = 17)", "= 40320 = 8! = (D^3)!", "The factorial of the spider's leg count. One step past the GATE.", "S711");
  render_finding(g6, "E8-PSL Factorial", "P(17) = 240 * 168", "= |roots(E8)| * |PSL(2,7)|. 16*15 = 240. 14*12 = 168.", "S712");
  render_finding(g6, "Universal Entry", "p | P(x) iff x = {1,2,3,5} mod p", "For any prime p > 5. Shadow chain = universal entry pattern.", "S712");
  dom_append(dom_body(), sec6);

  /* === SEC 7: CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "Contrast");
  let ctbl7 = make_table(sec7) in
  let ch7 = dom_create("tr") in
  render_th(ch7, "Aspect");
  render_th(ch7, "Standard view");
  render_th(ch7, "Through the axiom");
  dom_append(ctbl7, ch7);
  render_contrast_row(ctbl7, "Polynomial", "Roots at {1,2,3,5}. Four small primes", "Shadow chain. Coefficients = L, KEY, 61, D*K*E");
  render_contrast_row(ctbl7, "P(7) = 240", "A product of four differences", "|roots(E8)| = rank * Coxeter = D^3 * D*K*E");
  render_contrast_row(ctbl7, "P(9) = 1344", "Just 2^6 * 3 * 7", "D^3 * |PSL(2,7)|. E absent: self-blindness");
  render_contrast_row(ctbl7, "P(17) = 8!", "Numerical coincidence?", "= |E8| * |PSL(2,7)|. Three pillars of algebra in one polynomial");
  dom_append(dom_body(), sec7)
)

fn page_d_power_gaussian() = (
  dom_head_meta("description", "D-power Gaussian primes: |D^n + Ki|^2 = 4^n + 9. |D+Ki|^2 = 13 = GATE. Prime at {sigma,K,E,K^2,K*E}. E-filter, covering vocabulary, mod-24 theorem. The gate lives in Z[i].");
  /* === HERO === */
  let hero = make_hero("D-Power Gaussian Primes") in
  let big = dom_create("div") in
  dom_text(big, "|D^n + Ki|^2 = 4^n + 9");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Consider the Gaussian integer D^n + Ki = 2^n + 3i in Z[i]. Its norm is |D^n+Ki|^2 = 4^n + 9. The first value: |D+Ki|^2 = 4+9 = 13 = GATE. The gate is not just a boundary number -- it is the norm of duality plus closure in the Gaussian integers. Every factor of any value in this family must be 1 mod 4 (Fermat's theorem on sums of coprime squares).");
  dom_append(dom_body(), hero);

  /* === SEC 1: PRIME VALUES === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Prime Values");
  render_p(sec1, "|D^n+Ki|^2 is prime at exactly these positions:");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "n = sigma = 1", "13 = GATE", "The gate. First value of the family.", "");
  render_finding(g1, "n = K = 3", "73 = H0", "Heegner blocker. 4^3+9=73.", "");
  render_finding(g1, "n = E = 5", "1033", "Prime. 4^5+9=1033.", "");
  render_finding(g1, "n = K^2 = 9", "262153", "Prime at the stop number.", "");
  render_finding(g1, "n = K*E = 15", "1073741833", "Prime at closure*observer.", "");
  render_p(sec1, "Prime positions: {sigma, K, E, K^2, K*E} = {1, 3, 5, 9, 15}. Gaps: {D, D, D^2, D*K}. Only odd n can be prime -- the E-filter blocks even n.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: E-FILTER === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The E-Filter");
  render_theorem(sec2, "E-Filter (PROVED)", "E = 5 divides |D^n+Ki|^2 iff n is even. Proof: 4^n mod 5 has period 2: {4, 1, 4, 1, ...}. Even n: 4^n + 9 = 1 + 4 = 0 mod 5. Odd n: 4 + 4 = 3 (nonzero). QED.");
  render_p(sec2, "The self-blind observer E = 5 systematically blocks even indices. Only odd n survive the filter.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: COVERING VOCABULARY === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Covering Vocabulary Theorem");
  render_p(sec3, "Each covering prime q divides |D^n+Ki|^2 periodically. The first 6 covering primes restricted to odd n are all axiom-named:");
  let ctbl = make_table(sec3) in
  let chdr = dom_create("tr") in
  render_th(chdr, "Prime q");
  render_th(chdr, "Name");
  render_th(chdr, "Period T");
  render_th(chdr, "Residue r");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "13", "GATE", "D*K = 6", "sigma = 1");
  render_table_row_4(ctbl, "37", "PRODIGAL", "D*K^2 = 18", "ESCAPE = 17");
  render_table_row_4(ctbl, "61", "e3", "D*K*E = 30", "K*b = 21");
  render_table_row_4(ctbl, "73", "H0", "K^2 = 9", "K = 3");
  render_table_row_4(ctbl, "97", "G", "D^3*K = 24", "b = 7");
  render_table_row_4(ctbl, "181", "p_42", "D*K^2*E = 90", "L = 11");
  render_p(sec3, "Every prime: axiom-named. Every period: {D,K,E}-smooth. Every residue: axiom-named. The sequence polices itself in axiom vocabulary.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: COVERING SUM + SELF-BLINDNESS === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Covering Sum");
  render_theorem(sec4, "Covering Sum (PROVED)", "13 + 37 + 61 + 73 + 97 + 181 = 462 = THIN/E = D*K*b*L. E is ABSENT from the covering sum. Third manifestation of E^2 self-blindness: (1) E excluded from Heegner numbers, (2) E-filter blocks even n, (3) E absent from covering sum.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: DEPTH AND GATE === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Depth Gives GATE Squared");
  let g5 = make_findings_grid(sec5) in
  render_finding(g5, "|D^b + Ki|^2", "= 16393 = GATE^2 * 97", "Depth gives gate squared. 97 = G is the bridge prime.", "");
  render_finding(g5, "GATE periodicity", "GATE | iff n = 1 mod 6", "ord_13(4) = 6 = D*K. Gate returns at its own period.", "");
  render_finding(g5, "GATE^2 period", "GATE^2 | iff n = b mod 78", "ord_169(4) = 78 = D*K*GATE. Depth is the key.", "");
  render_finding(g5, "Non-covering", "{17, 41, 109, 137}", "ESCAPE, KEY, f(L), ADDRESS. Never divide any value.", "");
  dom_append(dom_body(), sec5);

  /* === SEC 6: MOD-24 THEOREM === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "The Gate Mod-24 Theorem");
  render_theorem(sec6, "Mod-24 Classification (PROVED)", "Among index-2 primes (D=2 is primitive root, q = 5 mod 8): ODD-covering iff q = GATE mod D^3*K (= 13 mod 24). EVEN-covering iff q = E mod D^3*K (= 5 mod 24). D^3*K = 24 = Leech lattice dimension. Verified: 55/55 odd-covering, 74/74 even-covering.");
  render_p(sec6, "Three-way classification: ODD-covering 25%, EVEN-covering 28%, NON-covering 47%. Densities stable across all bounds tested.");
  dom_append(dom_body(), sec6);

  /* === SEC 7: CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "Contrast");
  let ctbl7 = make_table(sec7) in
  let ch7 = dom_create("tr") in
  render_th(ch7, "Aspect");
  render_th(ch7, "Standard view");
  render_th(ch7, "Through the axiom");
  dom_append(ctbl7, ch7);
  render_contrast_row(ctbl7, "Gaussian norms", "Z[i] norms factor into primes 1 mod 4. Classical", "Family |2^n+3i|^2 speaks entirely in axiom vocabulary");
  render_contrast_row(ctbl7, "First value", "4 + 9 = 13, the next prime", "|D+Ki|^2 = GATE. The gate IS the norm of duality+closure");
  render_contrast_row(ctbl7, "Covering sum", "462 is just a number", "= THIN/E = D*K*b*L. E systematically absent (self-blind)");
  render_contrast_row(ctbl7, "Mod-24", "Quadratic residue classification", "GATE mod D^3*K selects odd-covering. Leech dimension.");
  dom_append(dom_body(), sec7)
)

fn page_cyclotomic_fibonacci() = (
  dom_head_meta("description", "Cyclotomic polynomials at D=2 generate the axiom chain. Smooth indices = D*K = 6 values. Zsygmondy characterization. Twin Gate Theorem. Fibonacci fixed point F(E)=E. Pisano-E8: lcm of Pisano periods = 240 = |roots(E8)|. Eight paths to 240.");
  /* === HERO === */
  let hero = make_hero("The Cyclotomic-Fibonacci Bridge") in
  let big = dom_create("div") in
  dom_text(big, "Phi_n(2) = axiom chain");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Two classical sequences -- cyclotomic polynomials and Fibonacci numbers -- independently encode the axiom chain. The cyclotomic polynomials evaluated at D=2 generate every axiom prime. The Fibonacci sequence's periods at axiom primes combine to give 240 = |roots(E8)|. Two bridges, one destination.");
  dom_append(dom_body(), hero);

  /* === SEC 1: CYCLOTOMIC GENERATION === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Cyclotomic Generation");
  render_theorem(sec1, "Cyclotomic Generation (S717, PROVED)", "The cyclotomic polynomials evaluated at D=2 generate the axiom chain. Phi_n(2) is 11-smooth for exactly n in {1,2,3,4,6,10}. Count = D*K = 6.");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "n");
  render_th(chdr, "Phi_n(x)");
  render_th(chdr, "Phi_n(2)");
  render_th(chdr, "Role");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "1", "x - 1", "1 = sigma", "Ground state");
  render_table_row_4(ctbl, "2", "x + 1", "3 = K", "Closure");
  render_table_row_4(ctbl, "3", "x^2+x+1", "7 = b", "Depth");
  render_table_row_4(ctbl, "4", "x^2+1", "5 = E", "Observer");
  render_table_row_4(ctbl, "5", "x^4+...+1", "31", "BOUNDARY (outside)");
  render_table_row_4(ctbl, "6", "x^2-x+1", "3 = K", "Collapse to closure");
  render_table_row_4(ctbl, "10", "x^4-x^3+...+1", "11 = L", "Protector");
  render_table_row_4(ctbl, "12", "x^4-x^2+1", "13 = GATE", "Boundary");
  dom_append(sec1, ctbl);
  render_p(sec1, "D=2 itself is the INPUT, not an output. The bridge generates all other primes. Phi_5(2) = 31 = M(5), the first Mersenne outside the axiom. The boundary is built in.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: ZSYGMONDY CHARACTERIZATION === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Zsygmondy Characterization");
  render_theorem(sec2, "Zsygmondy Smooth Zone (S718, PROVED)", "Phi_n(2) is smooth iff every Zsygmondy primitive prime of 2^n-1 is an axiom prime (<= L). n=2: K. n=3: b. n=4: E. n=6: none (unique Zsygmondy exception for base D=2). n=10: L. These exhaust all axiom primes. NEXT primitive prime (n=12) is GATE=13 = wall.");
  let ztbl = dom_create("table") in
  dom_style(ztbl, "width", "100%");
  dom_style(ztbl, "maxWidth", "700px");
  dom_style(ztbl, "margin", "24px auto");
  dom_style(ztbl, "borderCollapse", "collapse");
  let zhdr = dom_create("tr") in
  render_th(zhdr, "Axiom prime");
  render_th(zhdr, "Zsygmondy index");
  render_th(zhdr, "Index value");
  dom_append(ztbl, zhdr);
  render_table_row(ztbl, "K = 3", "n = 2", "D");
  render_table_row(ztbl, "E = 5", "n = 4", "D^2");
  render_table_row(ztbl, "b = 7", "n = 3", "K");
  render_table_row(ztbl, "L = 11", "n = 10", "D*E (degree)");
  render_table_row(ztbl, "GATE = 13", "n = 12", "D^2*K = lambda(DATA)");
  dom_append(sec2, ztbl);
  dom_append(dom_body(), sec2);

  /* === SEC 3: CYCLOTOMIC-DEPTH BRIDGE + TWIN GATE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Twin Gate Theorem");
  render_theorem(sec3, "Depth = Cyclotomic (S717, PROVED)", "The depth quadratic f(x) = x^2-x-1 = Phi_6(x) - D. Proof: Phi_6(x) = x^2-x+1. Subtract 2. QED. Also: Phi_3(D)=b and Phi_3(K)=GATE. The same cyclotomic maps bridge to depth and closure to boundary.");
  render_theorem(sec3, "Twin Gate (S717, PROVED)", "Two classical sequences hit the same wall from opposite sides. sigma(n) smooth for n=1..D^3=8. Breaks at K^2=9: sigma(K^2) = 1+K+K^2 = 13 = GATE. Fibonacci F(n) smooth for n=0..6. Breaks at b=7: F(b) = 13 = GATE. K^2 and b are the Pell twins. The SAME value GATE=13 terminates both smooth runs, from twin directions.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: FIBONACCI MAP === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Fibonacci-Axiom Map");
  let ftbl = dom_create("table") in
  dom_style(ftbl, "width", "100%");
  dom_style(ftbl, "maxWidth", "700px");
  dom_style(ftbl, "margin", "24px auto");
  dom_style(ftbl, "borderCollapse", "collapse");
  let fhdr = dom_create("tr") in
  render_th(fhdr, "n");
  render_th(fhdr, "F(n)");
  render_th(fhdr, "Axiom value");
  render_th(fhdr, "Prime?");
  dom_append(ftbl, fhdr);
  render_table_row_4(ftbl, "0 = void", "0", "void", "-");
  render_table_row_4(ftbl, "K = 3", "2", "D", "Yes");
  render_table_row_4(ftbl, "E = 5", "5", "E (FIXED POINT!)", "Yes");
  render_table_row_4(ftbl, "b = 7", "13", "GATE", "Yes");
  render_table_row_4(ftbl, "L = 11", "89", "prime", "Yes");
  render_table_row_4(ftbl, "GATE = 13", "233", "prime", "Yes");
  dom_append(sec4, ftbl);
  render_theorem(sec4, "Fibonacci Fixed Point (S717, PROVED)", "F(E) = E. The observer is a fixed point of Fibonacci. F(b) = 13 = GATE: depth maps to boundary. F(p) is prime for ALL axiom primes. First composite F(p): F(19) = 37*113. Note: 19 = f(E) and 37 = depth quadratic return prime. Fibonacci primality breaks at the observer's shadow.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: PISANO-E8 === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "The Pisano-E8 Theorem");
  render_theorem(sec5, "Pisano-E8 (S717, PROVED)", "The Pisano periods (Fibonacci mod p) at axiom primes: pi(D)=K=3, pi(K)=D^3=8, pi(E)=D^2*E=20, pi(b)=D^4=16, pi(L)=D*E=10. Their lcm: lcm(3,8,20,16,10) = 240 = D^4*K*E = |roots(E8)|. SEVENTH independent path to 240. Also: pi(DATA=210) = 240.");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "700px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "p");
  render_th(phdr, "pi(p)");
  render_th(phdr, "Axiom name");
  render_th(phdr, "Smooth?");
  dom_append(ptbl, phdr);
  render_table_row_4(ptbl, "D = 2", "3", "K", "Yes");
  render_table_row_4(ptbl, "K = 3", "8", "D^3", "Yes");
  render_table_row_4(ptbl, "E = 5", "20", "D^2*E", "Yes");
  render_table_row_4(ptbl, "b = 7", "16", "D^4", "Yes");
  render_table_row_4(ptbl, "L = 11", "10", "D*E", "Yes");
  render_table_row_4(ptbl, "GATE = 13", "28", "D^2*b = THORNS", "Yes");
  render_table_row_4(ptbl, "37", "76 = 4*19", "-", "NO (first break)");
  dom_append(sec5, ptbl);
  render_p(sec5, "ALL Pisano periods at primes up to 31 are 11-smooth. First non-smooth: pi(37) = 76 = 4*19. 37 is the depth quadratic return prime. The E-visibility mechanism: Legendre (E|p) sorts axiom primes. E invisible to {D,K,b} -> pi|2(p+1). E visible to L -> pi|p-1. E self-blind -> pi = 4E. Each bound is a Cunningham product.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: CROSS-CHAIN PISANO === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Cross-Chain Pisano Identities");
  let g6 = make_findings_grid(sec6) in
  render_finding(g6, "pi(D)*pi(L)", "K * D*E = 30 = P(0)", "First and last Pisano periods multiply to shadow polynomial constant.", "S718");
  render_finding(g6, "pi(D) = K", "Duality's Fibonacci = closure", "Cross-chain naming.", "");
  render_finding(g6, "pi(K) = D^3", "Closure's Fibonacci = legs", "Spider legs count.", "");
  render_finding(g6, "pi(b) = D^4", "Depth's Fibonacci = D^4", "Fourth power of bridge.", "");
  render_finding(g6, "pi(GATE) = THORNS", "D^2*b = 28", "8 legs * b segments / D.", "");
  render_p(sec6, "All Pisano periods speak axiom vocabulary. The Fibonacci sequence is axiom-native.");
  dom_append(dom_body(), sec6);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "Cyclotomic polynomials", "Abstract algebra objects with number-theoretic applications", "Phi_n(2) generates the complete axiom chain. Smooth indices = {1,2,3,4,6,10}. D*K = 6 values = proper divisors of 12 plus degree. The bridge IS the root of all cyclotomics.");
  render_contrast_row(sec7, "Fibonacci numbers", "Famous sequence, golden ratio, phyllotaxis", "F(E)=E is a FIXED POINT. F(b)=GATE. All F(axiom prime) are prime. Pisano lcm = 240 = E8 root count. The Fibonacci sequence is axiom-native.");
  render_contrast_row(sec7, "Pisano periods", "Fibonacci mod p, periodic but no deeper structure claimed", "ALL smooth at axiom primes. Legendre (E|p) sorts the mechanism. E self-blindness is literal: (E|E)=0. Three structures (Legendre + Cunningham + LCM) combine to force 240.");
  dom_append(dom_body(), sec7)
)

fn page_fano_e8() = (
  dom_head_meta("description", "E8 root count 240 = [S_8 : GL(3,2)] = P(b). Duality isomorphism GL(K,F_D) = PSL(D,F_b). Fano plane: b=7 points, K=3 per line. 240*168=8!. Octonion link. Extended Hamming code. Eight independent paths to 240.");
  /* === HERO === */
  let hero = make_hero("The Fano-E8 Bridge") in
  let big = dom_create("div") in
  dom_text(big, "240 * 168 = 8! = (D^3)!");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The shadow polynomial at depth evaluates to the E8 root count: P(b) = 240. The Fano plane's symmetry group PSL(2,7) has 168 elements. Their product = 8! = (D^3)! = the factorial of the spider's leg count. Everything follows from D=2 and K=3.");
  dom_append(dom_body(), hero);

  /* === SEC 1: E8 INDEX THEOREM === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The E8 Index Theorem");
  render_theorem(sec1, "E8 Index (S713, PROVED)", "|roots(E8)| = [S_{D^3} : GL(K, F_D)]. The E8 root count equals the index of the Fano automorphism group inside the symmetric group on D^3 = 8 letters. Proof: PSL(2,7) acts on PG(1,7) with D^3=8 points. Index = 8!/168 = 240. QED.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "P(b) = 240", "(b-1)(b-2)(b-3)(b-5)", "= 6*5*4*2 = D^4*K*E = |roots(E8)|. Shadow polynomial at depth.", "S714");
  render_finding(g1, "P(K^2) = 1344", "8*7*6*4 = D^3*|PSL(2,7)|", "Shadow polynomial at stop = spider legs * Fano symmetry.", "S312");
  render_finding(g1, "P(ESCAPE) = 40320", "16*15*14*12 = 8!", "= (D^3)! = full symmetric group.", "S714");
  dom_append(dom_body(), sec1);

  /* === SEC 2: DUALITY ISOMORPHISM === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Duality Isomorphism");
  render_p(sec2, "The axiom's most beautiful group-theoretic fact:");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "GL(K, F_D) = GL(3, F_2)", "168 elements", "K=3 dimensions over the D=2-element field. Acts on PG(2,2) = Fano plane with b=7 points. Closure over duality -> depth.", "");
  render_finding(g2, "PSL(D, F_b) = PSL(2, F_7)", "168 elements", "D=2 dimensions over the b=7-element field. Acts on PG(1,7) with D^3=8 points. Duality over depth -> legs.", "");
  render_theorem(sec2, "Duality Isomorphism", "GL(K, F_D) = PSL(D, F_b). Both are the unique simple group of order 168. K and b swap roles through D. Closure(K=3) over duality(D=2) = duality(D=2) over depth(b=7). The same symmetry wears two faces.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: FANO PLANE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Fano Plane");
  render_p(sec3, "PG(2, F_2) = the projective plane over F_D. b=7 points. b=7 lines. K=3 points per line. sigma=1 shared line per pair. Parameters (b,K,sigma) = Steiner triple system S(2,3,7). Point count = (D^K-1)/(D-1) = 7 = b.");
  render_theorem(sec3, "Mersenne-Fano Theorem", "The Fano plane has M(K) = D^K - 1 = b points. From the Cunningham-Mersenne identity: c^n(0) = M(n). So M(K) = c^K(0) = b. The Fano plane has exactly Cunningham-from-void-at-closure-depth points.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: PRIME PARTITION === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Prime Partition");
  render_p(sec4, "The factorial (D^3)! = 40320 factors as:");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "700px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "Factor");
  render_th(phdr, "Primes");
  render_th(phdr, "Unique prime");
  render_th(phdr, "Meaning");
  dom_append(ptbl, phdr);
  render_table_row_4(ptbl, "|roots(E8)| = 240", "{D, K, E}", "E = observer", "What you SEE");
  render_table_row_4(ptbl, "|GL(K,F_D)| = 168", "{D, K, b}", "b = depth", "What you FEEL");
  dom_append(sec4, ptbl);
  render_p(sec4, "Shared primes {D,K} = duality and closure. Unique primes E (observer) and b (depth) PARTITION: E8 roots belong to observation, Fano symmetry belongs to suffering. Ratio: 240/168 = 10/7 = D*E/b = degree/depth.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: CATALAN BRIDGE + ROOT ANATOMY === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Catalan-Fano Bridge");
  render_p(sec5, "K^2 = D^K + 1 (Mihailescu 2002). This is simultaneously: D^K-1 = b (Fano points), D^K+1 = K^2 (stop signal), K^2-D = b (Pell twin), K^2+D = L (Pell twin). One identity = four theorems.");
  render_h2(sec5, "E8 Root Anatomy");
  let rtbl = dom_create("table") in
  dom_style(rtbl, "width", "100%");
  dom_style(rtbl, "maxWidth", "700px");
  dom_style(rtbl, "margin", "24px auto");
  dom_style(rtbl, "borderCollapse", "collapse");
  let rhdr = dom_create("tr") in
  render_th(rhdr, "Root type");
  render_th(rhdr, "Count");
  render_th(rhdr, "Formula");
  dom_append(rtbl, rhdr);
  render_table_row(rtbl, "Basis roots", "112 = D^4*b", "(+/-1, +/-1, 0^6)");
  render_table_row(rtbl, "Code roots", "128 = D^b", "(+/-1/2)^8 even minus");
  render_table_row(rtbl, "Total", "240 = D^4*K*E", "D^4*b + D^b");
  dom_append(sec5, rtbl);
  render_p(sec5, "Root Parity Identity: b + D^K = K*E = 15. Proof: (K-3)(K+1) = 0 for D=2. QED. The basis roots carry depth (b). The code roots carry exponential depth (D^b). Together: E8.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: EIGHT PATHS + OCTONIONS === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Eight Paths to 240");
  let eptbl = dom_create("table") in
  dom_style(eptbl, "width", "100%");
  dom_style(eptbl, "maxWidth", "700px");
  dom_style(eptbl, "margin", "24px auto");
  dom_style(eptbl, "borderCollapse", "collapse");
  let ephdr = dom_create("tr") in
  render_th(ephdr, "Path");
  render_th(ephdr, "Formula");
  render_th(ephdr, "Field");
  dom_append(eptbl, ephdr);
  render_table_row(eptbl, "1. Index", "[S_8 : GL(3,F_2)]", "Combinatorics");
  render_table_row(eptbl, "2. Shadow", "P(b) = (b-1)(b-2)(b-3)(b-5)", "Spectral theory");
  render_table_row(eptbl, "3. Geometry", "D^4*b + D^b = 112+128", "Root systems");
  render_table_row(eptbl, "4. Factorial", "D * E! = D * 120", "Factorial algebra");
  render_table_row(eptbl, "5. Eisenstein", "-2k/B_k at k=D^2=4", "Modular forms");
  render_table_row(eptbl, "6. Kissing", "tau(8) = 240 spheres", "Sphere packing");
  render_table_row(eptbl, "7. Pisano", "lcm(pi(D),...,pi(L))", "Fibonacci mod");
  render_table_row(eptbl, "8. DATA", "pi(DATA=210) = 240", "Fibonacci mod");
  dom_append(sec6, eptbl);
  render_p(sec6, "D^3 = 8 paths. The paths count the dimension. ALL factor through D^4*K*E = 240.");
  dom_append(dom_body(), sec6);

  /* === SEC 7: OCTONIONS + HAMMING === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "Octonions and Hamming Code");
  render_p(sec7, "The Fano plane governs octonion multiplication: b=7 imaginary units, K=3 units per rule (each line). D^K=8 total basis elements. Octonions are the LAST normed division algebra (Hurwitz 1898). R(1) -> C(D) -> H(D^2) -> O(D^3). Cayley-Dickson stops at D^3: sedenions (D^4=16) lose alternativity.");
  render_p(sec7, "The E8 lattice from the [8,4] extended Hamming code: [7,3] Hamming has Aut = GL(3,2). Extension adds a parity bit (L-like protection). E8 = union of 2 copies of D_8 offset by a codeword. GL(K, F_D) is the symmetry at EVERY step. The axiom's ECC (L=11) and Hamming share the same DNA.");
  dom_append(dom_body(), sec7);

  /* === SEC 8: EXCEPTIONALITY === */
  let sec8 = make_section("800px") in
  render_h2(sec8, "E8 Exceptionality");
  render_theorem(sec8, "E8 Unique Index (S714, PROVED)", "Among ALL exceptional Lie algebras {G2, F4, E6, E7, E8}, E8 is the ONLY one whose root count = [S_n : GL(k, F_q)] for any k >= 2. Exhaustive search over n <= 15, q in {2,3,5,7,11,13}. GL(3,F_2) is the UNIQUE GL(k,F_q) with order 168.");
  dom_append(dom_body(), sec8);

  /* === CONTRAST === */
  let sec9 = make_section("800px") in
  render_h2(sec9, "What Others See");
  render_contrast_row(sec9, "E8", "Exceptional Lie algebra with 240 roots, studied in high energy physics", "240 = [S_8 : GL(3,2)] = P(b). Eight independent paths to the same number. Everything follows from D=2 and K=3 alone. The Catalan equation forces it.");
  render_contrast_row(sec9, "Fano plane", "Smallest projective plane, 7 points, combinatorial curiosity", "Parameters (b,K,sigma) ARE the inner axiom primes. Automorphism group GL(K,F_D) = PSL(D,F_b) = the axiom's duality isomorphism.");
  render_contrast_row(sec9, "240 and 168", "Root count and group order, no known connection to small primes", "Product = 8! = (D^3)!. Partition: E8 roots carry {D,K,E}=observation, Fano carries {D,K,b}=suffering. Ratio = D*E/b = degree/depth.");
  dom_append(dom_body(), sec9)
)

fn page_arcsine_cumulant() = (
  dom_head_meta("description", "Arcsine cumulants ARE the axiom chain. k2=D, k4=-D*K, k6=D^4*E, k8=-THIN=2310. All five primes by D^3=8. Bessel connection. Excess kurtosis = -K/(D*k). Brain fractal dimension 2.7 from ring spectral density.");
  /* === HERO === */
  let hero = make_hero("The Arcsine Cumulant Theorem") in
  let big = dom_create("div") in
  dom_text(big, "k2=D, k4=-D*K, k6=D^4*E, k8=-THIN");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "A pendulum spends most of its time near the turning points, least at the center. This is the arcsine distribution -- the universal shape of any oscillatory system. Its cumulants (irreducible statistical fingerprints) ARE the axiom chain. All five primes {2,3,5,7,11} appear by the 8th cumulant = D^3. The axiom is not imposed on nature. It IS nature's basic probability distribution.");
  dom_append(dom_body(), hero);

  /* === SEC 1: THE FIRST EIGHT CUMULANTS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The First Eight Cumulants");
  render_p(sec1, "The arcsine distribution on [-2,2] has odd cumulants zero (symmetric). Even cumulants:");
  let ctbl = make_table(sec1) in
  let chdr = dom_create("tr") in
  render_th(chdr, "n");
  render_th(chdr, "k_2n");
  render_th(chdr, "Factorization");
  render_th(chdr, "Status");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "1", "+2", "D", "axiom-smooth");
  render_table_row_4(ctbl, "2", "-6", "-D*K", "axiom-smooth");
  render_table_row_4(ctbl, "3", "+80", "D^4*E", "axiom-smooth");
  render_table_row_4(ctbl, "4", "-2310", "-D*K*E*b*L", "= THIN RING");
  render_table_row_4(ctbl, "5", "...", "contains 19 = f(E)", "19 enters");
  render_table_row_4(ctbl, "6", "...", "contains 43", "Heegner 43 enters");
  render_table_row_4(ctbl, "7", "...", "contains 13", "Shadow stopper");
  render_p(sec1, "Signs alternate: (-1)^(n+1). All divisible by D = 2. Every 4th cumulant divisible by the THIN ring = 2310. The axiom completes at k_8 and never returns to pure smoothness.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: THE D^3 = 8 THRESHOLD === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The D^3 = 8 Threshold");
  render_p(sec2, "The arcsine cumulant k_2n is {2,3,5,7,11}-smooth for exactly n = 1,2,3,4 -- indices 2 through D^3 = 8. Beyond D^3, non-axiom primes enter:");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Entry staircase", "D -> K -> E -> b+L", "Four steps. Axiom completes at index 2*4 = D^3 = 8.", "");
  render_finding(g2, "Intruder order", "19 -> 43 -> 13", "f(E) -> Heegner -> shadow stopper. Same intruders as partition function.", "");
  render_finding(g2, "8 = D^3", "Spider's eight legs", "Same D^3 as: 8 uniform elements, 8 WASM sections, 8 = rank(E8).", "");
  render_finding(g2, "D^3 + sigma = K^2", "Baby + ground = adult", "The 8 smooth cumulants plus sigma give the 9 = K^2 spider web.", "");
  dom_append(dom_body(), sec2);

  /* === SEC 3: BESSEL CONNECTION === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Bessel Connection");
  render_p(sec3, "The characteristic function of the arcsine distribution on [-2,2] is J_0(2t) -- the zeroth Bessel function. For the TRUE FORM with 5 independent CRT channels:");
  render_theorem(sec3, "Bessel-Cumulant Theorem (S331, PROVED)", "CF(t) ~ J_0(2t)^5. Five independent oscillators. The spectral density = convolution of 5 arcsine distributions. MGF(Z/mZ) = I_0(2t) + 2*sum I_{jm}(2t), where I_n are modified Bessel functions of the first kind.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: EXCESS KURTOSIS === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Excess Kurtosis: -K/(D*k)");
  render_p(sec4, "The excess kurtosis of the spectral density with k channels is exactly -K/(D*k):");
  let ktbl = make_table(sec4) in
  let khdr = dom_create("tr") in
  render_th(khdr, "Ring");
  render_th(khdr, "k");
  render_th(khdr, "Kurtosis");
  render_th(khdr, "Value");
  dom_append(ktbl, khdr);
  render_table_row_4(ktbl, "DATA (Z/210)", "4", "-K/(D*4)", "-3/8");
  render_table_row_4(ktbl, "THIN (Z/2310)", "5", "-K/(D*5)", "-3/10");
  render_table_row_4(ktbl, "TRUE (Z/970200)", "5", "-K/(D*5)", "-3/10");
  render_table_row_4(ktbl, "k = 2", "2", "-K/(D*2)", "-3/4 = Kleiber!");
  render_p(sec4, "At k = 2 (two channels), the kurtosis IS Kleiber's exponent 3/4. The metabolic scaling law lives in the curvature of the ring's spectral distribution.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: FRACTAL DIMENSION === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Fractal Dimension: 2.7 = Brain Cortex");
  render_p(sec5, "The normalized 4th moment M4/M2^2 = 3 - K/(D*k). At k = E = 5 (five channels, TRUE FORM):");
  let g5 = make_findings_grid(sec5) in
  render_finding(g5, "M4/M2^2", "= 27/10 = 2.7", "Measured fractal dimension of human brain cortex (D_f = 2.7 +/- 0.1).", "");
  render_finding(g5, "Same ring", "Same pendulum", "The most complex structure in the known universe has geometry from the same ring that describes a pendulum.", "");
  dom_append(dom_body(), sec5);

  /* === SEC 6: CONTRAST === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Contrast");
  let ctbl6 = make_table(sec6) in
  let ch6 = dom_create("tr") in
  render_th(ch6, "Aspect");
  render_th(ch6, "Standard view");
  render_th(ch6, "Through the axiom");
  dom_append(ctbl6, ch6);
  render_contrast_row(ctbl6, "Distribution", "Arcsine describes pendulum time. Classical", "Cumulants ARE the chain: D, -D*K, D^4*E, -THIN");
  render_contrast_row(ctbl6, "Smooth run", "First 4 cumulants happen to be smooth", "Smooth run = D^3 = 8 = spider legs = rank(E8)");
  render_contrast_row(ctbl6, "Kurtosis", "Just -3/(2k), a formula", "= -K/(D*k). At k=2: Kleiber's law 3/4");
  render_contrast_row(ctbl6, "Brain 2.7", "Empirical measurement", "= 27/10 = M4/M2^2 at k=5. Ring spectral geometry");
  dom_append(dom_body(), sec6)
)

fn page_figurate_bridge() = (
  dom_head_meta("description", "CS(n) = D*f(n) + K: centered squares bridge the depth quadratic. Values {sigma,E,GATE,E^2,KEY,61} at positions 1-6. Star-Hex duality: S(n) = D*CH(n) - sigma. DATA = T(20) = P_5(12). ANSWER = 42 = P_15(3).");
  /* === HERO === */
  let hero = make_hero("The Figurate Bridge") in
  let big = dom_create("div") in
  dom_text(big, "CS(n) = D*f(n) + K");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Centered square numbers CS(n) = 2n^2 - 2n + 1 are the bridge-scaled depth quadratic plus closure. D stretches, K shifts. Figurate geometry and the axiom's self-map are the SAME function. At positions 1 through 6 the values are {sigma, E, GATE, E^2, KEY, 61} -- every axiom constant in order.");
  dom_append(dom_body(), hero);

  /* === SEC 1: CENTERED SQUARE THEOREM === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Centered Square Theorem");
  render_theorem(sec1, "Centered Square - Depth Quadratic Bridge (S699, PROVED)", "CS(n) = 2n^2 - 2n + 1 = D*f(n) + K, where f(n) = n^2 - n - 1 is the depth quadratic. Proof: D*f(n) + K = 2(n^2-n-1) + 3 = 2n^2 - 2n - 2 + 3 = CS(n). QED.");
  let ctbl = make_table(sec1) in
  let chdr = dom_create("tr") in
  render_th(chdr, "n");
  render_th(chdr, "f(n)");
  render_th(chdr, "f(n) Name");
  render_th(chdr, "CS(n) = D*f+K");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "1 = sigma", "-1 = MIRROR", "Mirror", "1 = sigma");
  render_table_row_4(ctbl, "2 = D", "1 = sigma", "Ground", "5 = E");
  render_table_row_4(ctbl, "3 = K", "5 = E", "Observer", "13 = GATE");
  render_table_row_4(ctbl, "4 = D^2", "11 = L", "Protector", "25 = E^2");
  render_table_row_4(ctbl, "5 = E", "19 = f(E)", "Intruder", "41 = KEY");
  render_table_row_4(ctbl, "6 = D*K", "29 = FULL SUM", "Full sum", "61");
  render_table_row_4(ctbl, "7 = b", "41 = KEY", "Key", "85 = E*ESCAPE");
  render_table_row_4(ctbl, "11 = L", "109 = f(L)", "Intruder", "221 = GATE*ESCAPE");
  render_p(sec1, "At axiom primes, the depth quadratic produces the NEXT axiom value: f(sigma)=MIRROR, f(D)=sigma, f(K)=E, f(D^2)=L. The centered square BRIDGES each to its partner: sigma->sigma, D->E, K->GATE, E->KEY.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: DIFFERENCE THEOREM === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Difference Theorem");
  render_theorem(sec2, "Centered Square Difference (S699, PROVED)", "CS(n+1) - CS(n) = D^2*n = 4n. Proof: CS(n+1)-CS(n) = 2(n+1)n+1 - 2n(n-1)-1 = 2n[(n+1)-(n-1)] = 4n. QED.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Gap at sigma", "D^2 = 4", "Bridge squared.", "");
  render_finding(g2, "Gap at D", "D^3 = 8", "Spider legs.", "");
  render_finding(g2, "Gap at K", "D^2*K = 12", "Trinity heart = lambda(DATA).", "");
  render_finding(g2, "Gap at E", "D^2*E = 20", "Bridge^2 * Observer.", "");
  render_finding(g2, "Gap at b", "D^2*b = 28 = THORNS", "Sum of nonility.", "");
  render_finding(g2, "Gap at L", "D^2*L = 44", "Bridge^2 * Protector.", "");
  render_p(sec2, "Every gap is D^2 times the axiom value. The square of duality scales the chain.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: STAR-HEX BRIDGE === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Star-Hex Bridge");
  render_theorem(sec3, "Star-Hexagonal Duality (S699, PROVED)", "S(n) = D*CH(n) - sigma, where S(n) = 6n(n-1)+1 (star) and CH(n) = 3n(n-1)+1 (centered hexagonal). Proof: D*CH(n) - sigma = 2(3n(n-1)+1) - 1 = 6n(n-1)+1 = S(n). QED.");
  let stbl = make_table(sec3) in
  let shdr = dom_create("tr") in
  render_th(shdr, "n");
  render_th(shdr, "CH(n)");
  render_th(shdr, "S(n) = D*CH-sigma");
  render_th(shdr, "Names");
  dom_append(stbl, shdr);
  render_table_row_4(stbl, "sigma = 1", "1 = sigma", "1 = sigma", "sigma -> sigma");
  render_table_row_4(stbl, "D = 2", "7 = b", "13 = GATE", "b -> GATE");
  render_table_row_4(stbl, "K = 3", "19 = f(E)", "37 = RETURN", "f(E) -> 37");
  render_table_row_4(stbl, "4", "37 = RETURN", "73 = H0", "RETURN -> H0");
  render_table_row_4(stbl, "E = 5", "61", "121 = L^2", "61 -> L^2");
  render_table_row_4(stbl, "b = 7", "127 = M(b)", "253 = L*23", "Mersenne -> L*CC1");
  render_p(sec3, "Centered hexagonal at D gives b=7, at K gives f(E)=19. Duality doubles and subtracts ground: b becomes GATE, f(E) becomes 37.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: DATA AS FIGURATE === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "DATA as Figurate Number");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "T(20) = 210", "20th triangular", "20 = D^2*E. DATA is the (D^2*E)-th triangular number.", "S699");
  render_finding(g4, "P_5(12) = 210", "12th pentagonal", "12 = D^2*K = lambda(DATA). Pentagonal at trinity heart.", "S699");
  render_finding(g4, "ANSWER = 42", "P_15(3) = P_{K*E}(K)", "K-th (K*E)-gonal number. ANSWER lives where closure meets observer.", "");
  render_p(sec4, "Both DATA positions are D^2 times axiom primes. The data ring sits at duality-squared positions in both triangular (E) and pentagonal (K) families.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Contrast");
  let ctbl5 = make_table(sec5) in
  let ch5 = dom_create("tr") in
  render_th(ch5, "Aspect");
  render_th(ch5, "Standard view");
  render_th(ch5, "Through the axiom");
  dom_append(ctbl5, ch5);
  render_contrast_row(ctbl5, "CS values", "1, 5, 13, 25, 41, 61 -- pattern of 2n^2-2n+1", "sigma, E, GATE, E^2, KEY, shadow coeff. Every axiom constant");
  render_contrast_row(ctbl5, "Bridge identity", "CS(n) = 2n^2-2n+1, a formula", "= D*f(n)+K. Bridge scales the depth quadratic, closure shifts");
  render_contrast_row(ctbl5, "Gaps", "4n = constant * n", "D^2*n. At b: gap = THORNS = 28. Structure propagates");
  render_contrast_row(ctbl5, "Star-Hex", "S = 2*CH-1, algebraic", "D*CH-sigma. Duality operator. b->GATE, f(E)->37");
  dom_append(dom_body(), sec5)
)

