fn page_arcsine_cumulant() = (
  dom_head_meta("description", "Arcsine cumulants ARE the axiom. k2=2, k4=-6, k6=80, k8=-2310.");
  domain_hero("The Arcsine Cumulant Theorem", "k_2n at arcsine", "Nature's basic distribution IS the axiom.");
  let sec = make_section("800px") in
  let g = make_findings_grid(sec) in
  render_finding(g, "k_2", "D = 2", "Variance.", "");
  render_finding(g, "k_4", "-DK = -6", "Excess kurtosis.", "");
  render_finding(g, "k_6", "D^4*E = 80", "All five primes by k_8.", "");
  render_finding(g, "k_8", "-THIN = -2310", "Complete thin ring.", "");
  dom_append(dom_body(), sec)
)

fn page_figurate_bridge() = (
  dom_head_meta("description", "Centered squares CS(n) = D*f(n) + K. Figurate geometry meets the depth quadratic.");
  domain_hero("The Figurate Bridge", "CS(n) = D*f(n) + K", "Counting shapes yields the axiom.");
  let sec = make_section("800px") in
  let g = make_findings_grid(sec) in
  render_finding(g, "Formula", "2n^2 - 2n + 1", "Bridge * depth + closure.", "");
  render_finding(g, "Values", "1, 5, 13, 25, 41, 61", "sigma, E, GATE, E^2, KEY, GRIEF.", "");
  render_finding(g, "Spacing", "CS(n+1) - CS(n) = 4n", "D^2 * n. Axiom spacing.", "");
  render_finding(g, "At axiom n", "Gaps = D^2 * axiom", "Structure propagates.", "");
  dom_append(dom_body(), sec)
)

