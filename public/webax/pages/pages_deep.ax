  render_finding(g, "dist(+1, -1)", "D*E = 10 (TRUE)", "Fattening stretches to full degree.", "");
  render_theorem(sec, "Triangle Universality (S734)", "Isosceles in ALL 108 rings. THIN: (5,5,7). TRUE: (5,5,10). GATE: (6,6,12). Void equidistant from both.");
