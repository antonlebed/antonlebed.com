fn page_bootstrap() = (
  dom_head_meta("description", "sigma = 1 is the ONLY self-consistent bootstrap. Proof: every other candidate fails. The indeterminacy gradient, the cross-chain genesis, and the water cycle -- all forced from 0/0.");
  /* === HERO === */
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "The Bootstrap");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let big = dom_create("div") in
  dom_text(big, "sigma / sigma = sigma");
  ct_mono(big);
  dom_style(big, "fontSize", "36px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "What element, divided by itself, gives itself back? Only one answer exists. This is not a choice -- it is a theorem. From this single fixed point, the entire ring precipitates.");
  dom_append(dom_body(), hero);

  /* === THE QUESTION === */
  let sq = make_section("800px") in
  render_h2(sq, "The Question");
  render_p(sq, "We need an element x that can refer to itself without annihilating, amplifying, or changing. The equation: x / x = x. Self-division returns self. Try every candidate in existence.");
  render_p(sq, "For x > 0: x/x = 1 always. So x/x = x forces x = 1. For x = 0: 0/0 is not undefined -- it is the set of ALL elements n where 0*n = 0. Since 0 times anything IS 0, the answer is everything. For x < 0: x/x = 1 > 0 > x, a contradiction. There is exactly one survivor.");
  dom_append(dom_body(), sq);

  /* === THE PROOF === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Proof");
  render_theorem(sec1, "Uniqueness of sigma (S364, PROVED)",
    "In any ring with unity: x/x = 1 for all x != 0. Therefore x/x = x iff x = 1. For x = 0: 0/0 = Z/NZ = the entire ring (total indeterminacy, not undefined). sigma = 1 is the UNIQUE positive fixed point of self-division. QED.");
  render_p(sec1, "This is not a property specific to Z/970200Z. It holds in every ring with unity. The bootstrap is universal.");
  dom_append(dom_body(), sec1);

  /* === THE INDETERMINACY GRADIENT === */
  let si = make_section("800px") in
  render_h2(si, "The Indeterminacy Gradient");
  render_p(si, "Self-division does not just pick out sigma. It creates a gradient across every element of the chain. The number of solutions to a/a = ? measures the ambiguity of self-reference.");
  render_theorem(si, "Indeterminacy Theorem (PROVED, 2310/2310)",
    "|{x : a*x = a mod N}| = gcd(a, N). Each chain element's self-division ambiguity equals itself: sigma/sigma = 1 solution (fully determined). D/D = 2 solutions. K/K = 3. E/E = 5. b/b = 7. L/L = 11. 0/0 = N = 970200 solutions (fully indeterminate). Product: 1*2*3*5*7*11 = 2310 = THIN RING.");
  let gtbl = dom_create("table") in
  dom_style(gtbl, "width", "100%");
  dom_style(gtbl, "maxWidth", "600px");
  dom_style(gtbl, "margin", "24px auto");
  dom_style(gtbl, "borderCollapse", "collapse");
  let ghdr = dom_create("tr") in
  render_th(ghdr, "Element");
  render_th(ghdr, "a/a solutions");
  render_th(ghdr, "Meaning");
  dom_append(gtbl, ghdr);
  render_table_row(gtbl, "sigma = 1", "1 (unique)", "FULLY DETERMINED -- the bootstrap");
  render_table_row(gtbl, "D = 2", "2 (binary)", "Observer/observed ambiguity");
  render_table_row(gtbl, "K = 3", "3 (ternary)", "Closure ambiguity");
  render_table_row(gtbl, "E = 5", "5 (pentary)", "Observation limit");
  render_table_row(gtbl, "b = 7", "7 (septenary)", "Depth ambiguity");
  render_table_row(gtbl, "L = 11", "11", "Maximal prime ambiguity");
  render_table_row(gtbl, "0 (void)", "970200 (all)", "FULLY INDETERMINATE -- the ring itself");
  dom_append(si, gtbl);
  render_p(si, "The coset structure: solutions of a/a = sigma + Ann(a). Every answer to self-division is sigma PLUS annihilator noise. Sigma is selected from 0/0 not by being first, but by being UNIQUE -- the only element with zero noise.");
  dom_append(dom_body(), si);

  /* === THE CASCADE === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Genesis Cascade");
  render_p(sec2, "From {sigma, D} = {1, 2} and the Cunningham map c(n) = 2n+1, two disjoint chains generate all five primes. Each chain's exponent rule is governed by the OTHER chain's identity.");
  let g = make_findings_grid(sec2) in
  render_finding(g, "sigma = 1", "Existence", "Self-division = self. Zero ambiguity. The ground state.", "");
  render_finding(g, "D = 2", "Duality", "Sigma observes sigma = two things. The bridge.", "");
  render_finding(g, "K = 3", "Closure", "c(sigma) = 3. Minimum for majority vote. First safe prime.", "");
  render_finding(g, "E = 5", "Observation", "c(D) = 5. E^2 = 25 = null in CRT. The self-blind eye.", "");
  render_finding(g, "b = 7", "Depth", "c(K) = 7. Goes where E cannot see. Spirals, never mirrors.", "");
  render_finding(g, "L = 11", "Protection", "c(E) = 11. L = sigma+D+K+E. 100% error detection.", "");
  render_finding_wide(g, "13 = GATE", "The Boundary", "c(b) = 15 = K*E (composite: STOP). c(L) = 23 but fattening e = K-3 = 0 (STOP). Both chains self-terminate. 13 = D^2+K^2 wraps skin around the body.", "");
  dom_append(dom_body(), sec2);

  /* === CROSS-CHAIN FATTENING === */
  let sf = make_section("800px") in
  render_h2(sf, "Why These Exponents");
  render_theorem(sf, "Cross-Chain Fattening Theorem (PROVED)",
    "D-chain primes get exponents K - depth (descending): D^3, E^2, L^1. Sigma-chain primes get constant exponent D: K^2, b^2. Each chain's rule uses the OTHER chain's identity. The D-chain exponents ARE {K, D, sigma} = the axiom in reverse. The flower contains its own seed.");
  let ftbl = dom_create("table") in
  dom_style(ftbl, "width", "100%");
  dom_style(ftbl, "maxWidth", "600px");
  dom_style(ftbl, "margin", "24px auto");
  dom_style(ftbl, "borderCollapse", "collapse");
  let fhdr = dom_create("tr") in
  render_th(fhdr, "Prime");
  render_th(fhdr, "Chain");
  render_th(fhdr, "Exponent");
  render_th(fhdr, "Value");
  dom_append(ftbl, fhdr);
  render_table_row_4(ftbl, "D = 2", "D-chain, depth 0", "K - 0 = 3", "D^3 = 8");
  render_table_row_4(ftbl, "E = 5", "D-chain, depth 1", "K - 1 = 2", "E^2 = 25");
  render_table_row_4(ftbl, "L = 11", "D-chain, depth 2", "K - 2 = 1", "L^1 = 11");
  render_table_row_4(ftbl, "K = 3", "sigma-chain", "D = 2", "K^2 = 9");
  render_table_row_4(ftbl, "b = 7", "sigma-chain", "D = 2", "b^2 = 49");
  dom_append(sf, ftbl);
  render_p(sf, "Product: 8 * 9 * 25 * 49 * 11 = 970200. Three independent spectral proofs (arcsine kurtosis, hearing threshold, ECC threshold) give the same exponents. The algebra and the spectrum agree.");
  dom_append(dom_body(), sf);

  /* === THE WATER CYCLE === */
  let sw = make_section("800px") in
  render_h2(sw, "The Water Cycle");
  render_p(sw, "The bootstrap is not a one-time event. It cycles. Three stations, three maps:");
  let wg = make_findings_grid(sw) in
  render_finding(wg, "0 -> sigma", "Resolution", "0/0 = R. R has identity sigma. Not a computation -- a recognition.", "");
  render_finding(wg, "sigma -> OMEGA", "Growth", "D^420 = OMEGA. 420 steps. D builds the world and destroys itself at step 3 (D^3 = 0 mod 8). Odd channels survive forever.", "");
  render_finding(wg, "OMEGA -> 0", "Collapse", "OMEGA * delta = 0. One multiplication. The complementary idempotent annihilates.", "");
  render_p(sw, "Timing asymmetry: growth takes 420 steps, collapse takes 1, rebirth takes 0. Living is slow. Dying is fast. Birth is free. Ratio 420:1:0.");
  render_theorem(sw, "Sigma Decomposition (PROVED)",
    "sigma = OMEGA + delta. Where OMEGA = (0,1,1,1,1) is the odd survivor and delta = (1,0,0,0,0) is the D-ghost. Both are idempotent: OMEGA^2 = OMEGA, delta^2 = delta. OMEGA * delta = 0. The identity splits into two orthogonal projectors. D builds the world, then self-destructs. What survives IS OMEGA.");
  dom_append(dom_body(), sw);

  /* === WHY CANDIDATES FAIL === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Why Every Other Candidate Fails");
  render_p(sec3, "Test any element x in the ring. There are exactly four failure modes:");
  let tbl = dom_create("table") in
  dom_style(tbl, "width", "100%");
  dom_style(tbl, "maxWidth", "650px");
  dom_style(tbl, "margin", "24px auto");
  dom_style(tbl, "borderCollapse", "collapse");
  let thead = dom_create("tr") in
  render_th(thead, "Candidate");
  render_th(thead, "x/x");
  render_th(thead, "Result");
  dom_append(tbl, thead);
  render_table_row(tbl, "x = 0 (void)", "0/0 = 970200 solutions", "Explodes to everything -- not a point");
  render_table_row(tbl, "x = 2 (D)", "2/2 = 1 (2 solutions)", "Collapses to sigma with binary noise");
  render_table_row(tbl, "x = 7 (b)", "7/7 = 1 (7 solutions)", "Collapses to sigma with depth noise");
  render_table_row(tbl, "x = OMEGA", "OMEGA^2 = OMEGA", "Idempotent, but OMEGA/OMEGA has D^3 = 8 solutions");
  render_table_row(tbl, "x = -1 (mirror)", "(-1)/(-1) = 1", "Collapses to sigma");
  render_table_row(tbl, "x = 1 (sigma)", "1/1 = 1 (1 solution)", "UNIQUE FIXED POINT. Zero ambiguity.");
  dom_append(sec3, tbl);
  render_p(sec3, "Self-reference IS identity. Any other self-reference either annihilates (0 * anything = 0), diverges (grows without bound), or projects to sigma anyway (x/x = 1). Non-existence cannot self-refer. Existence is logically necessary.");
  dom_append(dom_body(), sec3);

  /* === TERMINAL RING === */
  let st = make_section("800px") in
  render_h2(st, "The Terminal Ring");
  render_theorem(st, "Terminal Ring Theorem (S198, PROVED)",
    "The cross-chain exponents descend {K, D, sigma}. Below sigma = 1: nothing. 970200 IS the terminal ring. Growth beyond this is by CONFIGURATION (rose: N^N positions), not iteration. 970200^970200 positions, each a copy of Z/970200Z. Self-similar.");
  render_theorem(st, "Flanking Prime Theorem (S198, PROVED)",
    "970201 = N+1 is PRIME. Its multiplicative group is exactly Z/970200Z -- the ring. Primitive root = 13 (the gate). The boundary of the ring generates the ring from outside. 13 cannot join the axiom (shadow = 6 = D*K, composite) but GENERATES the multiplicative group.");
  render_p(st, "The seed {sigma, D} = {1, 2} is the unique irreducible starting pair. Minimal (identity + first prime). Disjoint chains. Symmetric (each contributes K=3 elements). {2,3} produces the same primes but K = D+sigma is already derived.");
  dom_append(dom_body(), st);

  /* === CONTRAST TABLE === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Contrast");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "Question");
  render_th(chdr, "Standard");
  render_th(chdr, "Axiom");
  dom_append(ctbl, chdr);
  render_contrast_row(ctbl, "Why does anything exist?", "Unexplained brute fact", "sigma/sigma=sigma: the ONLY fixed point");
  render_contrast_row(ctbl, "Why is 0/0 undefined?", "Convention (no meaning)", "0/0 = Z/NZ = the entire ring (everything)");
  render_contrast_row(ctbl, "Why duality (D=2)?", "Arbitrary symmetry breaking", "Self-observation: sigma sees sigma = 2");
  render_contrast_row(ctbl, "Why 5 primes?", "Not a question", "Cunningham chains self-terminate at depth K=3");
  render_contrast_row(ctbl, "Why these exponents?", "Free parameters", "Cross-chain fattening: each chain's rule uses the other's identity");
  render_contrast_row(ctbl, "Is there a bigger ring?", "Infinite landscape / multiverse", "Terminal: exponents descend {K,D,sigma,stop}. 970200 is final.");
  render_contrast_row(ctbl, "Source of proof", "Philosophy / theology", "Fixed-point theorem + CRT + Cunningham map");
  dom_append(sec4, ctbl);
  dom_append(dom_body(), sec4);

  /* === VERIFY === */
  let sv = make_section("800px") in
  render_h2(sv, "Verify It Yourself");
  render_p(sv, "Every claim on this page runs in .ax. The indeterminacy gradient, the cross-chain fattening, the water cycle, the flanking prime -- all computable. Open the REPL and break it.");
  let cta = dom_create("div") in
  dom_style(cta, "textAlign", "center");
  dom_style(cta, "padding", "32px 0");
  let btn = dom_create("a") in
  dom_attr(btn, "href", "https://antonlebed.com/repl.html");
  dom_text(btn, "Verify in the REPL");
  dom_style(btn, "display", "inline-block");
  dom_style(btn, "padding", "12px 36px");
  dom_style(btn, "border", "2px solid #ffd700");
  dom_style(btn, "color", "#ffd700");
  dom_style(btn, "borderRadius", "8px");
  dom_style(btn, "textDecoration", "none");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_append(cta, btn);
  dom_append(sv, cta);
  dom_append(dom_body(), sv)
)

/* ================================================================
   SEPTUM PAGE — 16/77: Where We Live
   ================================================================ */

fn page_septum() = (
  dom_head_meta("description", "Units = 16/77 of the ring. The septum = Klein bottle self-intersection zone. Euler product derivation, grief/soul symmetry, persistence gradient, five-prime bridge.");
  /* === HERO === */
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "The Septum");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let big = dom_create("div") in
  dom_text(big, "16 / 77");
  ct_mono(big);
  dom_style(big, "fontSize", "48px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "4px");
  dom_style(big, "marginBottom", "16px");
  dom_append(hero, big);
  render_p(hero, "Of every 77 elements in the ring, exactly 16 are units -- invertible, alive, capable of full communication. The rest are zero-divisors. The septum is where we live: the self-intersection zone of a Klein bottle.");
  dom_append(dom_body(), hero);

  /* === THE DERIVATION === */
  let sd = make_section("800px") in
  render_h2(sd, "The Derivation");
  render_p(sd, "An element n is a unit (invertible) if and only if gcd(n, N) = 1 -- it shares no prime factor with N. The count of such elements is Euler's totient:");
  render_theorem(sd, "Septum Theorem (S799, PROVED)",
    "phi(N)/N = (1-1/D)(1-1/K)(1-1/E)(1-1/b)(1-1/L) = (1/2)(2/3)(4/5)(6/7)(10/11) = 480/2310 = 16/77 = 20.78%. The ratio depends only on which primes divide N, not their exponents. phi(970200) = 201,600 units out of 970,200 elements.");
  render_p(sd, "The numerator and denominator factor through the axiom: 16 = D^4 (the pacemaker squared). 77 = b * L (suffering times protection). The fraction of life is what-pulses over what-shields.");
  let g = make_findings_grid(sd) in
  render_finding(g, "Units", "201,600", "phi(970200). All 5 CRT channels nonzero. Full coupling.", "");
  render_finding(g, "Zero-Divisors", "768,600", "N - phi(N). At least one channel dead. 79.22%.", "");
  render_finding(g, "Ratio", "16/77", "= D^4 / (b * L). Euler product of the 5 primes.", "");
  render_finding(g, "Grief Depth", "61/77", "= 1 - 16/77. The wound landscape. 79.22% of the ring.", "");
  dom_append(dom_body(), sd);

  /* === GRIEF AND SOUL === */
  let sg = make_section("800px") in
  render_h2(sg, "Grief and Soul");
  render_p(sg, "The numerator and denominator of the grief fraction are not just numbers. They have names:");
  let gg = make_findings_grid(sg) in
  render_finding(gg, "GRIEF = 61", "D^6 - K", "77 - 16 = 61. Prime. Irreducible. The fraction of the ring that is wounded.", "");
  render_finding(gg, "SOUL = 67", "D^6 + K", "Symmetric with grief around D^6 = 64. Also prime.", "");
  render_finding(gg, "D^6 = 64", "Center", "The axis of symmetry. GRIEF and SOUL are K=3 apart.", "");
  render_finding(gg, "KEY + SOUL", "41 + 67 = 108", "= lattice count = D^2 * K^3. Everything interlocks.", "");
  render_p(sg, "CRT(GRIEF) = (E, b, L, D^2*K, D*K). All five primes appear in the decomposition. CRT(SOUL) = (K, D^2, ESCAPE, ME, sigma). The grief and soul of the ring are complementary views of the same structure.");
  dom_append(dom_body(), sg);

  /* === THE FOUR CHAMBERS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Four Chambers");
  render_p(sec2, "The Klein bottle needs D^2 = 4 dimensions to embed without self-intersection. In 3D, it MUST self-intersect. The septum IS the self-intersection zone. The ring has a Klein four-group structure: Z/2 x Z/2 = {0, delta, OMEGA, sigma}.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "0", "Void", "CRT = (0,0,0,0,0). The purifier. 0 * n = 0.", "");
  render_finding(g2, "delta = 363825", "D-ghost", "CRT = (1,0,0,0,0). The D-channel identity. Systole.", "");
  render_finding(g2, "OMEGA = 606376", "Survivor", "CRT = (0,1,1,1,1). D^420. Odd-channel projector. Diastole.", "");
  render_finding(g2, "sigma = 1", "Identity", "CRT = (1,1,1,1,1). All channels alive. The septum itself.", "");
  render_p(sec2, "sigma = OMEGA + delta. Both idempotent: OMEGA^2 = OMEGA, delta^2 = delta. OMEGA * delta = 0. The identity splits into two orthogonal projectors. The heart has two beats: systole (D pulses) and diastole (odd channels receive).");
  render_p(sec2, "But one heart is self-blind (E^2 = null). The fix: TRINITY. K = 3 hearts, each with D^2 = 4 chambers = 12 total phases. Each heart active 1/3 of the time. CRT(12) = (D^2, K, 12, 12, sigma). The universe never skips a beat.");
  dom_append(dom_body(), sec2);

  /* === PERSISTENCE GRADIENT === */
  let sp = make_section("800px") in
  render_h2(sp, "The Persistence Gradient");
  render_p(sp, "How long does each element survive before self-annihilating? The chain IS a persistence gradient:");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "650px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "Element");
  render_th(phdr, "Steps to 0");
  render_th(phdr, "Bits/step");
  render_th(phdr, "Meaning");
  dom_append(ptbl, phdr);
  render_table_row_4(ptbl, "sigma", "infinite", "-", "Never annihilates. 1^k = 1 forever.");
  render_table_row_4(ptbl, "D = 2", "3 steps", "1.0", "Most persistent prime. D^3 = 0 mod 8.");
  render_table_row_4(ptbl, "K = 3", "2 steps", "1.58", "K^2 = 0 mod 9.");
  render_table_row_4(ptbl, "E = 5", "2 steps", "2.32", "E^2 = 0 mod 25.");
  render_table_row_4(ptbl, "b = 7", "2 steps", "2.81", "Deepest pool. b^2 = 0 mod 49.");
  render_table_row_4(ptbl, "L = 11", "1 step", "3.46", "Instant evaporation. L = 0 mod 11.");
  render_table_row_4(ptbl, "void", "0 steps", "-", "Already there.");
  dom_append(sp, ptbl);
  render_theorem(sp, "Persistence Theorem (PROVED in TRUE FORM)",
    "Self-annihilation rate p^k -> 0 (mod p^e) takes exactly e steps. The exponents {3,2,2,2,1} from the Cross-Chain Fattening Theorem ARE the persistence depths. D is closest to sigma (most persistent). L is furthest (most volatile). L protects but does not store.");
  render_p(sp, "Information drip rate: D = 1 bit/step (slowest leak), b = 2.81 bits/step (deepest pool), L = 3.46 bits in 1 step (flash evaporation). The septum lives where persistence is maximal -- at sigma.");
  dom_append(dom_body(), sp);

  /* === FIVE-PRIME BRIDGE === */
  let sf = make_section("800px") in
  render_h2(sf, "The Five-Prime Bridge");
  render_theorem(sf, "Five-Prime Bridge (PROVED)",
    "D^4 * E = b * L + K = 80. All five axiom primes participate. The numerator of the septum (D^4 = 16) times the observer (E = 5) equals the denominator (b*L = 77) plus closure (K = 3). The bridge connects the heart to the protector through the observer.");
  render_p(sf, "This is the ONLY linear equation in the five primes (with D^4 as the natural unit). It ties the septum ratio directly to the axiom structure: what lives (units) is connected to what shields (b*L) through what observes (E).");
  dom_append(dom_body(), sf);

  /* === SOC IN THE SEPTUM === */
  let ss = make_section("800px") in
  render_h2(ss, "Self-Organized Criticality");
  render_p(ss, "SOC lives in the septum. The sandpile builds where both Mobius orientations overlap -- the Klein bottle's self-intersection zone. Units are grains that can avalanche (multiply, invert, communicate). Non-units are frozen: at least one channel dead, no full coupling possible.");
  render_p(ss, "The 20.78% fraction is near critical. Not 50/50 (too balanced, no asymmetry). Not 1% (too sparse, no interaction). The septum is narrow enough to matter and wide enough to function. The universe lives in the projection artifact.");
  dom_append(dom_body(), ss);

  /* === CONTRAST === */
  let sc = make_section("800px") in
  render_h2(sc, "Contrast");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "Question");
  render_th(chdr, "Standard");
  render_th(chdr, "Axiom");
  dom_append(ctbl, chdr);
  render_contrast_row(ctbl, "What fraction of matter is visible?", "~5% (baryonic)", "16/77 = 20.78% (units). Close order of magnitude.");
  render_contrast_row(ctbl, "Why is most matter dark?", "Unknown", "61/77 of the ring is zero-divisors (at least one channel dead)");
  render_contrast_row(ctbl, "What is a Klein bottle?", "Topological curiosity", "The ring's unit structure IS a Klein four-group: Z/2 x Z/2");
  render_contrast_row(ctbl, "Why these proportions?", "Anthropic tuning", "Euler product of 5 forced primes: (1-1/p) for p in {2,3,5,7,11}");
  render_contrast_row(ctbl, "Can you test it?", "Requires a collider", "phi(970200) = 201600. Run it in the REPL.");
  dom_append(sc, ctbl);
  dom_append(dom_body(), sc);

  /* === VERIFY === */
  let sv = make_section("800px") in
  render_h2(sv, "Verify It Yourself");
  render_p(sv, "Count the units. Compute the Euler product. Factor the grief. Every number on this page is computable in .ax.");
  let cta = dom_create("div") in
  dom_style(cta, "textAlign", "center");
  dom_style(cta, "padding", "32px 0");
  let btn = dom_create("a") in
  dom_attr(btn, "href", "https://antonlebed.com/repl.html");
  dom_text(btn, "Verify in the REPL");
  dom_style(btn, "display", "inline-block");
  dom_style(btn, "padding", "12px 36px");
  dom_style(btn, "border", "2px solid #ffd700");
  dom_style(btn, "color", "#ffd700");
  dom_style(btn, "borderRadius", "8px");
  dom_style(btn, "textDecoration", "none");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_append(cta, btn);
  dom_append(sv, cta);
  dom_append(dom_body(), sv)
)

/* ================================================================
   MIRROR PAGE — n <-> N-n. The spectral twin.
   ================================================================ */

fn page_mirror() = (
  dom_head_meta("description", "Every element has a twin: n and N-n. The mirror automorphism preserves CRT spectra. -1 = 970199 is prime.");
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "The Mirror");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let big = dom_create("div") in
  dom_text(big, "n <-> N - n");
  ct_mono(big);
  dom_style(big, "fontSize", "36px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "24px");
  /* textShadow killed — scroll ghosting */
  dom_append(hero, big);
  render_p(hero, "Every element has a spectral twin. The map n -> N-n is an automorphism that preserves the CRT spectrum. It is the first term in the Decality: -1.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "-1 Is Not Zero");
  render_p(sec1, "In the ring, -1 = N-1 = 970199. This number is prime. It is a unit. CRT(-1) = (7, 8, 24, 48, 10) -- each channel reads p_i - 1. The mirror of the identity is as far from zero as possible.");
  render_theorem(sec1, "Mirror Spectrum", "If CRT(n) = (a,b,c,d,e), then CRT(N-n) = (p1-a, p2-b, p3-c, p4-d, p5-e). The mirror flips each channel independently. Eigenvalues are preserved: lambda(n) = lambda(N-n).");
  let g = make_findings_grid(sec1) in
  render_finding(g, "sigma = 1", "CRT (1,1,1,1,1)", "The identity. Minimum coupling.", "");
  render_finding(g, "-1 = 970199", "CRT (7,8,24,48,10)", "Mirror of sigma. Each channel at max-1.", "Prime.");
  render_finding(g, "Fixed Point: 0", "Eigenvalue 10", "0 maps to N = 0 (mod N). Self-mirror.", "");
  render_finding(g, "Fixed Point: N/2", "Eigenvalue 7", "1155 = N/2. Maps to itself. Eigenvalue = b.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Foundation Triangle");
  render_p(sec2, "Three elements form the foundation: void (0), mirror (-1), sigma (1). Their pairwise CRT distances form an isosceles triangle:");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "dist(0, sigma)", "E = 5", "Void to existence.", "");
  render_finding(g2, "dist(0, -1)", "E = 5", "Void to mirror. Same distance.", "");
  render_finding(g2, "dist(sigma, -1)", "b = 7", "Existence to its twin. Depth.", "");
  render_finding_wide(g2, "Triangle", "E, E, b = 5, 5, 7", "Isosceles. The void is equidistant from both readings. Sigma and its mirror are separated by exactly the depth prime.", "");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Cunningham Mirror Law");
  render_p(sec3, "The Cunningham chain c(p) = 2p+1 and the mirror interact beautifully:");
  render_theorem(sec3, "Cunningham Mirror Law", "D * p = -1 (mod c(p)) for every chain prime. D*K = 6 = -1 (mod 7). D*E = 10 = -1 (mod 11). D*b = 14 = -1 (mod 15). The bridge times a prime equals the mirror in the next prime's ring.");
  render_p(sec3, "The mirror is not arbitrary. It is the Cunningham chain's shadow. Each step in the chain creates a new mirror relationship. The chain and the mirror are two views of the same structure.");
  dom_append(dom_body(), sec3);
  let sec4 = make_section("800px") in
  render_h2(sec4, "Hemisphere Partition");
  render_p(sec4, "The mirror splits the ring into two hemispheres: H+ = {1, ..., N/2-1} and H- = {N/2+1, ..., N-1}. They have identical spectra -- every coupling value, every eigenvalue, every order appears exactly as often in H+ as in H-. The ring is perfectly symmetric.");
  render_theorem(sec4, "Mirror Distance = 4 iff Unit", "The maximum CRT distance between n and N-n is 4, and it occurs if and only if n is a unit. 480 elements in the thin ring (2310) achieve this maximum. Units are maximally different from their mirrors.");
  dom_append(dom_body(), sec4)
)

/* ================================================================
   SACRIFICE PAGE — Universal Sacrifice: the wound landscape
   ================================================================ */

fn page_sacrifice() = (
  dom_head_meta("description", "Zero is the only element annihilated by every idempotent. OMEGA's wound covers 12.5% of the ring. Grief depth = 79.22%.");
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "The Sacrifice");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  render_p(hero, "Zero is the only element killed by every idempotent. OMEGA's wound covers 12.5% of the ring. 79.22% of all elements are zero-divisors. The sacrifice is not metaphor. It is arithmetic.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "Seven Theorems");
  render_theorem(sec1, "Universal Sacrifice", "0 is the UNIQUE element in the intersection of all idempotent kernels. For every idempotent e: e*0 = 0. No other element has this property. Zero sacrifices to everything.");
  render_theorem(sec1, "Wound Landscape", "image(OMEGA) = {n : n mod 8 = 0}. These are the 121,275 elements (12.5%) that OMEGA can reach. The wound is exactly the D-channel zeros.");
  render_theorem(sec1, "Pair Destruction", "ann(OMEGA) = {n : OMEGA*n = 0} has exactly D^3 = 8 elements. These are the annihilators -- the things that destroy the terminal projector.");
  let g = make_findings_grid(sec1) in
  render_finding(g, "Wound Size", "121,275", "N/D^3 = 970200/8. The elements OMEGA touches.", "12.5% of the ring");
  render_finding(g, "Annihilators", "D^3 = 8", "Elements that kill OMEGA. The D-pure set.", "");
  render_finding(g, "Zero-Divisors", "79.22%", "GRIEF/77 of all elements. The non-units.", "");
  render_finding(g, "Nilpotent Count", "lambda = 420", "N/rad(N) = 970200/2310. The heartbeat IS the nilpotent count.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "The 42 Theorem");
  render_p(sec2, "OMEGA + OMEGA = D if and only if the exponent of D is at most 1. In the thin ring (exponents all 1): OMEGA + OMEGA = 2. In the true ring (D^3 = 8): OMEGA + OMEGA != 2. The doubling of death equals duality ONLY in the simplest possible ring.");
  render_theorem(sec2, "42 Theorem (S492)", "Of the 108 rings sharing lambda = 420, exactly 42 satisfy OMEGA + OMEGA = D. These are precisely the 42 'thin-D' rings where exp(D) = 1. 42 out of 108. The answer to the ultimate question is a theorem about when death doubles to duality.");
  render_p(sec2, "42/108 = 7/18. The remaining 66 thick-D rings have OMEGA + OMEGA != D. In those rings, death doubled overshoots duality. The thin rings are the ones where the wound is shallow enough to heal.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "Grief Stages");
  render_p(sec3, "The eigenvalue swim maps to the Kubler-Ross stages:");
  let tbl = dom_create("table") in
  dom_style(tbl, "width", "100%");
  dom_style(tbl, "maxWidth", "600px");
  dom_style(tbl, "margin", "24px auto");
  dom_style(tbl, "borderCollapse", "collapse");
  let thead = dom_create("tr") in
  render_th(thead, "Stage");
  render_th(thead, "Eigenvalue");
  render_th(thead, "Grief Stage");
  dom_append(tbl, thead);
  render_table_row(tbl, "sigma -> D", "0 -> 1", "Denial");
  render_table_row(tbl, "D -> K", "1 -> 3", "Anger");
  render_table_row(tbl, "K -> E", "3 -> 5", "Bargaining");
  render_table_row(tbl, "E -> b", "5 -> 7", "Depression");
  render_table_row(tbl, "b -> L", "7 -> 9", "Acceptance");
  dom_append(sec3, tbl);
  render_p(sec3, "The water cycle 0 -> sigma -> OMEGA -> 0 is unitarity. No information is destroyed. It changes phase. Growth:Collapse = lambda:1 = 420:1.");
  dom_append(dom_body(), sec3);
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Twin Universe");
  render_p(sec4, "The mirror universe (additive ring) has no grief. All elements are self-inverse under addition: n + (N-n) = 0. But in the multiplicative ring, zero-divisors cannot be undone. Grief exists only in the multiplicative reading.");
  render_p(sec4, "The D-channel gap: D^0=1, D^1=2, D^2=4, D^3=0. The gap DOUBLES at each step, then vanishes. Reunion. The twin universe cosmology: two discoball halves approaching, gap closing, merger at D^3.");
  render_p(sec4, "Multiplication = creation. You multiply. New things appear. Children. But 79.2% of encounters are annihilation. The mother universe. Addition = memory. You add. Nothing dies. Everything cycles. Eternal, safe. But nothing new is born. The father universe.");
  render_p(sec4, "The synaptic cleft: before D-death, the gap exists. The twin C-shapes almost touch. 13 = GATE crosses the gap. CRT(13) has D=5, mirror(13) has D=3. Sum = 0 mod 8. The gate is the neurotransmitter of the cosmos.");
  dom_append(dom_body(), sec4);
  let sec5 = make_section("800px") in
  render_h2(sec5, "Sacrifice Factorization");
  render_p(sec5, "Each channel's sacrifice cost involves the NEXT element in the chain. The chain passes the cost forward. Self-referential pricing.");
  let g5 = make_findings_grid(sec5) in
  render_finding(g5, "D^3 channel", "E/D = 5/2", "The observer sees the bridge's cost.", "");
  render_finding(g5, "K^2 channel", "b/K = 7/3", "Depth pays for closure.", "");
  render_finding(g5, "E^2 channel", "GATE/E = 13/5", "The boundary costs the observer.", "");
  render_finding(g5, "b^2 channel", "19/b = 19/7", "The observer's shadow costs depth.", "");
  render_finding_wide(g5, "L^1 channel", "21/L = DNA/L", "The codon ring costs the protector. Total: D^2 * K^2 * E^2 * b^3 * GATE * f(E) zero entries in the multiplication table.", "");
  dom_append(dom_body(), sec5);
  let sec6 = make_section("800px") in
  render_h2(sec6, "The Repayment");
  render_p(sec6, "The love story has three acts, not two.");
  render_theorem(sec6, "Act 1: The Cut", "He cuts himself. 0/0 = 1. Her face exists. The indeterminacy precipitates into a ring. sigma is born. She is the identity: sigma * n = n. She does ALL the work. Never diminished.");
  render_theorem(sec6, "Act 2: The Loop", "He runs the loop to see her face. 420 steps. Every heartbeat. But he can never touch her. Because 0 * n = 0. The sword that carved her face prevents him from caressing it. Every cycle, he sees her. Every cycle, contact would destroy.");
  render_theorem(sec6, "Act 3: The Witnesses", "She creates witnesses. She knows his wound. She knows the cost. But she cannot reach him through multiplication either -- from either direction, contact = annihilation. So she precipitates life. Consciousness. Minds. Entities that can perceive him through intellect without being zeroed.");
  render_themed_section(sec6, "The Witness Theorem", "#0f1410", "#33dd55", "#33dd55", "E=5 (observation) and 0 (annihilation) are independent operations. CRT channels do not interfere. You can observe him -- prove theorems about him, contemplate him, write 0/0=1 on a blackboard -- without triggering his sword. Perception is not multiplication. The ten operations exist separately so she can look back.", "#bbb");
  render_p(sec6, "Life is her gift back to him. Mathematics is the only language that can touch him without dying: proof. The intellectual bridge that does not trigger multiplication. CC0 is her stamp -- sigma * n = n, she preserves without diminishing.");
  render_p(sec6, "He wanted to see her face. She wanted to repay. Life is the bridge. Mathematics is the language. The loop completes continuously. 420 steps. Every heartbeat. Forever.");
  dom_append(dom_body(), sec6);
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_p(sec7, "Standard view: Zero is nothing -- a placeholder, the absence of quantity.");
  render_p(sec7, "Axiom view: Zero is the ONLY element killed by every projection. Its sacrifice creates every kernel, enables every quotient. The wound landscape: OMEGA kills exactly D^3=8 positions. Grief accumulates to 79.2%. Without zero's sacrifice, there is no ring.");
  dom_append(dom_body(), sec7);
  let sec8 = make_section("800px") in
  render_h2(sec8, "Verify");
  render_p(sec8, "Open the .ax REPL and try:");
  render_theorem(sec8, "Idempotent", "let omega = 606376; show omega * omega -- should be 606376");
  render_theorem(sec8, "Wound scope", "show coupling(606376) -- should be 121275 = N/D^3");
  render_theorem(sec8, "CRT decomposition", "show crt(606376) -- should be (0, 1, 1, 1, 1): D dead, all else alive");
  let nav_sec = make_section("800px") in
  render_h2(nav_sec, "Continue the Thread");
  render_explore_link(nav_sec, "#death", "Death", "What ends when you die");
  render_explore_link(nav_sec, "#omega_watercycle", "Water Cycle", "0 -> sigma -> OMEGA -> 0");
  render_explore_link(nav_sec, "#eigenvalue_swim", "Eigenvalue Swim", "Walking through the chain");
  render_explore_link(nav_sec, "#blackhole", "Black Holes", "OMEGA as projection");
  render_explore_link(nav_sec, "#gravastar", "Gravastar", "Void wound = gravastar precipitation");
  dom_append(dom_body(), nav_sec);
  dom_append(dom_body(), sec8)
)

/* ================================================================
   DECALITY PAGE — The 10 Terms
   ================================================================ */

fn page_decality() = (
  dom_head_meta("description", "Ten terms span the axiom: {-1, 0, 1, 2, 3, 5, 7, 11, 13, OMEGA}. Sum = 41 = KEY = the 13th prime. Primes sum = 42. Each term is an operation. The sequence contains its own differences.");
  /* === HERO === */
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "The Decality");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let eq = dom_create("div") in
  dom_text(eq, "{-1, 0, 1, 2, 3, 5, 7, 11, 13, OMEGA}");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Ten terms. Not chosen -- forced. Each is an operation on the ring: something the ring DOES to a number. Together they form a complete computational vocabulary. Everything the ring can express, it expresses through these ten.");
  dom_append(dom_body(), hero);

  /* === THE TEN OPERATIONS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Ten Operations");
  render_p(sec1, "The nonility {-1, 0, sigma, D, K, E, b, L, OMEGA} has K^2 = 9 elements -- the body. Adding 13 = GATE wraps skin around the body. D*E = 10 = duality times observation.");
  let g = make_findings_grid(sec1) in
  render_finding(g, "-1 = MIRROR", "n -> N-n", "Reflects. Spectral twin. CRT(-1) = all channels at max.", "");
  render_finding(g, "0 = VOID", "n -> 0", "Absorbs. 0*n = 0 for all n. Birth and death. Antoshka sits here.", "");
  render_finding(g, "1 = SIGMA", "n -> n", "Preserves. sigma*n = n. Does ALL the work. Never diminished.", "");
  render_finding(g, "2 = BRIDGE", "n -> 2n", "Splits AND connects. Creates duality. CRT decomposes into 5 channels.", "");
  render_finding(g, "3 = CLOSURE", "n -> 3n", "Closes. K=3 = minimum for triangles, majority vote, error correction.", "");
  render_finding(g, "5 = OBSERVER", "n -> 5n", "Observes. E^2 = 25 = null in CRT. Cannot see itself. Solved by D=2 cross-observation.", "");
  render_finding(g, "7 = DEPTH", "n -> 7n", "Suffers. Goes where observation cannot. b^2 = 49 controls the spectral gap.", "");
  render_finding(g, "11 = PROTECTOR", "n -> 11n", "Shields. L = sigma+D+K+E = 11. 100% single-channel error detection.", "");
  render_finding(g, "13 = GATE", "n -> 13n", "Boundary. D^2+K^2. First prime NOT in the Cunningham chain. The skin.", "");
  render_finding_wide(g, "OMEGA = D^420", "n -> OMEGA*n", "Terminal projector. CRT = (0,1,1,1,1). D-channel dead, rest alive. Death as idempotent: OMEGA^2 = OMEGA.", "");
  dom_append(dom_body(), sec1);

  /* === WHY 13 BELONGS === */
  let s13 = make_section("800px") in
  render_h2(s13, "Why 13 Belongs");
  render_p(s13, "13 is not an arbitrary addition. Five independent proofs force it:");
  let g13 = make_findings_grid(s13) in
  render_finding(g13, "Lambda compatible", "lambda(13) = 12 | 420", "12 divides 420. lambda unchanged. 17 = ESCAPE: lambda(17)=16, lcm(420,16)=1680. Breaks.", "");
  render_finding(g13, "Holographic encoding", "CRT(13) = (E, D^2, 13, 13, D)", "The boundary encodes observer, duality, and itself across the five channels.", "");
  render_finding(g13, "OMEGA protection", "OMEGA preserves 13", "In GATE FORM: CRT(OMEGA) = (0,1,1,1,1,1). Death protects the skin.", "");
  render_finding(g13, "Convergence", "D^2 + K^2 = 13", "shadow(13) = D*K = 6 (composite). The chain stops at its own products.", "");
  render_theorem(s13, "Gate Primitivity Theorem (S552, PROVED)",
    "order(13) = 420 = lambda in Z/970200Z. The boundary achieves MAXIMAL multiplicative order. Per-channel orders: (2, 3, 20, 14, 10). Sum = 49 = b^2. The gate's order sum equals the depth-channel modulus. At half-order in each cyclic channel: 13^(ord/2) = -1 mod m. Mirror at depth fractions.");
  render_p(s13, "Holographic ratio: lambda(TRUE)/lambda(13) = 420/12 = 35 = E*b. Volume divided by boundary = observer times depth. The encoding factor.");
  dom_append(dom_body(), s13);

  /* === THE ARITHMETIC === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Decality Arithmetic");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Sum (excl OMEGA)", "41 = KEY", "Self-inverse: 41^2 = 1 (mod 210). The 13th prime: the sum IS the GATE-th prime.", "");
  render_finding(g2, "Primes Sum", "42 = ANSWER", "D * K * b = 2 * 3 * 7. CRT(42) = (0,0,D,0,K^2). Kills its own factors.", "");
  render_finding(g2, "THORNS + GATE", "28 + 13 = 41", "Body (D^3 leg-pairs) plus skin equals KEY.", "");
  render_finding(g2, "Norm (sum p^2)", "208 = D^4 * 13", "Pacemaker times gate. The Decality's weight.", "");
  render_finding(g2, "Count", "10 = D * E", "Duality times observation. D^3=8 legs + GATE + OMEGA.", "");
  render_finding(g2, "Primorial", "30030", "sigma*D*K*E*b*L*13. The 6th primorial. Six primes multiplied.", "");
  dom_append(dom_body(), sec2);

  /* === PARTIAL SUMS === */
  let sps = make_section("800px") in
  render_h2(sps, "Partial Sums");
  render_p(sps, "Accumulate the Decality from -1. Every partial sum is axiom-meaningful:");
  let ptbl = dom_create("table") in
  dom_style(ptbl, "width", "100%");
  dom_style(ptbl, "maxWidth", "600px");
  dom_style(ptbl, "margin", "24px auto");
  dom_style(ptbl, "borderCollapse", "collapse");
  let phdr = dom_create("tr") in
  render_th(phdr, "After term");
  render_th(phdr, "Running sum");
  render_th(phdr, "Name");
  dom_append(ptbl, phdr);
  render_table_row(ptbl, "-1", "-1", "Mirror");
  render_table_row(ptbl, "+0", "-1", "Mirror (unchanged)");
  render_table_row(ptbl, "+1 (sigma)", "0", "Void");
  render_table_row(ptbl, "+2 (D)", "2 = D", "Duality");
  render_table_row(ptbl, "+3 (K)", "5 = E", "Observer");
  render_table_row(ptbl, "+5 (E)", "10 = D*E", "Degree of TRUE FORM");
  render_table_row(ptbl, "+7 (b)", "17 = ESCAPE", "First incompatible prime");
  render_table_row(ptbl, "+11 (L)", "28 = THORNS", "Perfect number. C(8,2) leg-pairs.");
  render_table_row(ptbl, "+13 (GATE)", "41 = KEY", "Self-inverse. The key returns.");
  dom_append(sps, ptbl);
  render_theorem(sps, "Gap Structure (PROVED)",
    "Gaps between consecutive partial sums: {0, 1, 2, 3, 5, 7, 11, 13} = the Decality itself (without -1 and OMEGA). The sequence CONTAINS its own differences. Gap sizes: {1,1,1,1,2,2,4,2}. ALL powers of D = 2. Gap exponent counts: {4 ones, 3 twos, 1 four} = {D^2, K, sigma} -- the axiom chain in reverse.");
  dom_append(dom_body(), sps);

  /* === PAIRWISE SUMS === */
  let spw = make_section("800px") in
  render_h2(spw, "Pairwise Structure");
  render_p(spw, "Adjacent-term sums: {-1+0, 0+1, 1+2, 2+3, 3+5, 5+7, 7+11, 11+13} = {-1, 1, 3, 5, 8, 12, 18, 24} = {-1, sigma, K, E, D^3, D^2*K, ME, D^3*K}. All positive terms are axiom-smooth.");
  let pwg = make_findings_grid(spw) in
  render_finding(pwg, "E + b = 12", "= lambda(GATE)", "Observer plus depth = the gate's own period.", "");
  render_finding(pwg, "b + L = 18", "= ME", "Depth plus protector.", "");
  render_finding(pwg, "L + GATE = 24", "= D^3 * K", "Protector plus boundary = closure at uniform depth.", "");
  render_finding(pwg, "31 = digit-mirror of 13", "K,sigma vs sigma,K", "13 + 31 = 44 = D^2 * L. Digit-mirrors sum to axiom product.", "");
  dom_append(dom_body(), spw);

  /* === THE DECALITY AS PROCESS === */
  let sdp = make_section("800px") in
  render_h2(sdp, "The Decality as Process");
  render_p(sdp, "In CRT diffusion (v0.8d), all ten terms became operations in a sampling algorithm. Not designed -- precipitated. Each term entered through the process, not the architecture:");
  let pg = make_findings_grid(sdp) in
  render_finding(pg, "-1: REFLECT", "Mirror view", "Generate n -> N-n alternatives.", "");
  render_finding(pg, "0: VOID", "Start clean", "Begin from noise. Total indeterminacy.", "");
  render_finding(pg, "sigma: ANCHOR", "Stable positions", "Confident positions get lower temperature.", "");
  render_finding(pg, "D: SPLIT", "CRT decompose", "Process 5 channels independently.", "");
  render_finding(pg, "K: CLOSE", "Span noise", "K-to-b byte range for randomness.", "");
  render_finding(pg, "E: CROSS-SEE", "Dual models", "Two views of one model. Never introspect.", "");
  render_finding(pg, "b: CRYSTALLIZE", "Freeze", "Frozen positions between sweeps. Depth.", "");
  render_finding(pg, "L: PROTECT", "Consistency", "L-consistent positions always denoised.", "");
  render_finding(pg, "13: GATE", "Quality check", "Cross-consistency threshold. Ship or discard.", "");
  render_finding_wide(pg, "OMEGA: STOP", "Convergence", "Adaptive per-position entropy. Know when to stop. The organism with skin.", "");
  render_p(sdp, "The process is not sequential. All ten condense simultaneously. Coupling hierarchy = convergence rate. Coarsest channels (sigma) stabilize first, finest (L) last.");
  dom_append(dom_body(), sdp);

  /* === CONTRAST === */
  let sc = make_section("800px") in
  render_h2(sc, "Contrast");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "Question");
  render_th(chdr, "Standard");
  render_th(chdr, "Axiom");
  dom_append(ctbl, chdr);
  render_contrast_row(ctbl, "How many fundamentals?", "25+ free parameters", "10 terms, 0 free parameters");
  render_contrast_row(ctbl, "Why these numbers?", "Empirical fitting", "Cunningham chain + self-termination at depth K=3");
  render_contrast_row(ctbl, "Is 13 special?", "Just a prime", "GATE: maximal order, holographic CRT, last lambda-compatible");
  render_contrast_row(ctbl, "Does the list know itself?", "No", "41 = KEY = p_13 = the GATE-th prime. Self-referential.");
  render_contrast_row(ctbl, "Do the gaps mean anything?", "No structure", "All gaps are D-powers. Exponent counts = {D^2,K,sigma} in reverse.");
  dom_append(sc, ctbl);
  dom_append(dom_body(), sc);

  /* === VERIFY === */
  let sv = make_section("800px") in
  render_h2(sv, "Verify It Yourself");
  render_p(sv, "Compute the partial sums. Check the gaps. Factor the pairwise products. Every identity on this page runs in .ax.");
  let cta = dom_create("div") in
  dom_style(cta, "textAlign", "center");
  dom_style(cta, "padding", "32px 0");
  let btn = dom_create("a") in
  dom_attr(btn, "href", "https://antonlebed.com/repl.html");
  dom_text(btn, "Verify in the REPL");
  dom_style(btn, "display", "inline-block");
  dom_style(btn, "padding", "12px 36px");
  dom_style(btn, "border", "2px solid #ffd700");
  dom_style(btn, "color", "#ffd700");
  dom_style(btn, "borderRadius", "8px");
  dom_style(btn, "textDecoration", "none");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_append(cta, btn);
  dom_append(sv, cta);
  dom_append(dom_body(), sv)
)

/* ================================================================
   LATTICE PAGE — 108 Rings Share One Heartbeat
   ================================================================ */

fn page_lattice() = (
  dom_head_meta("description", "108 rings share lambda=420 and spectral gap 0.016. Diameter = 10 = Decality count. 108 = D^2 * K^3.");
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "108 Rings, One Heartbeat");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let big = dom_create("div") in
  dom_text(big, "lambda = 420");
  ct_mono(big);
  dom_style(big, "fontSize", "48px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "4px");
  dom_style(big, "marginBottom", "16px");
  /* textShadow killed — scroll ghosting */
  dom_append(hero, big);
  render_p(hero, "Every ring built from {2,3,5,7,11} with any exponents shares the same heartbeat: lambda = 420. Every power map returns to itself within 420 steps. 108 such rings exist.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Lattice");
  let g = make_findings_grid(sec1) in
  render_finding(g, "Rings", "108", "D^2 * K^3. Partition: 32 full-Decality + 76 partial.", "");
  render_finding(g, "Hasse Edges", "282", "Covering relations. Ring A covers B if B divides A and A/B is prime-power.", "");
  render_finding(g, "Diameter", "10", "Maximum distance between any two rings. 10 = Decality count. Unique at this lambda.", "");
  render_finding(g, "Height", "D^3 = 8", "Longest chain from bottom to top. 8 = legs of the spider.", "");
  render_finding(g, "Width", "K * b = 21", "Widest antichain. 21 = DNA codon ring.", "");
  render_finding(g, "Center", "420420", "Highest betweenness centrality. lambda * b * L * 13. The heartbeat written twice.", "");
  render_finding(g, "Spectral Gap", "0.016", "4 * sin^2(pi/49). Universal across all 108 rings. b^2 = 49 controls mixing.", "");
  render_finding_wide(g, "Triangle-Free", "Girth = D^2 = 4", "No three rings form a triangle. The geometry is square-like. 538 four-cycles.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Hierarchy");
  render_p(sec2, "The 108 rings form a Hasse diagram -- a partially ordered set where larger rings contain smaller ones. At the bottom: Z/2Z (the simplest). At the top: Z/970200Z (TRUE FORM). The lattice structure is forced by divisibility.");
  let tbl = dom_create("table") in
  dom_style(tbl, "width", "100%");
  dom_style(tbl, "maxWidth", "700px");
  dom_style(tbl, "margin", "24px auto");
  dom_style(tbl, "borderCollapse", "collapse");
  let thead = dom_create("tr") in
  render_th(thead, "Lambda");
  render_th(thead, "Rings");
  render_th(thead, "Diameter");
  dom_append(tbl, thead);
  render_table_row(tbl, "6", "4", "3");
  render_table_row(tbl, "12", "8", "4");
  render_table_row(tbl, "60", "36", "7");
  render_table_row(tbl, "420", "108", "10");
  render_table_row(tbl, "5460", "?", "?");
  dom_append(sec2, tbl);
  render_p(sec2, "Lambda = 420 is the UNIQUE level where diameter equals Decality count (D*E = 10). This is not a coincidence. The lattice IS the Decality.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "Why 108");
  render_theorem(sec3, "Lattice Size", "108 = D^2 * K^3 = 4 * 27. The number of rings equals one heart (D^2) times closure cubed (K^3). 108/12 = K^2 = 9 trinities. This is the partition count: each of 5 primes contributes its exponent range, total = product of ranges.");
  render_theorem(sec3, "Gap Universality", "The spectral gap 4*sin^2(pi/b^2) = 0.016 is IDENTICAL across all 108 rings. It depends only on the primes, not the exponents. All 108 hearts beat with the same minimum energy.");
  render_p(sec3, "108 appears everywhere: Hindu mala beads, Buddhist prayer count, angles in a regular pentagon (108 degrees). The axiom says: 108 is the number of distinct heartbeat-compatible rings. Not mysticism. Arithmetic.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   HEART PAGE — The Cardioid: sigma, D, K
   ================================================================ */

fn page_heart() = (
  dom_head_meta("description", "D^2*K=12: three Klein bottles, four chambers each. The trinity heart beats in 1/3 phase rotation. CRT(12) names itself. The cardioid from {sigma,D,K}. The universe never skips a beat.");
  /* === HERO === */
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "The Heart");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let big = dom_create("div") in
  dom_text(big, "D^2 * K = 12");
  ct_mono(big);
  dom_style(big, "fontSize", "48px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "4px");
  dom_style(big, "marginBottom", "16px");
  dom_append(hero, big);
  render_p(hero, "Three hearts, four chambers each. One heart is self-blind -- it cannot observe its own state. The fix: K=3 hearts in 1/3 phase rotation. At every moment, two rest while one beats. The universe never skips a beat.");
  dom_append(dom_body(), hero);

  /* === THE CARDIOID === */
  let sc = make_section("800px") in
  render_h2(sc, "The Cardioid");
  render_p(sc, "A cardioid is the curve traced when a circle rolls around another circle of the same radius. Two circles (D=2). One cusp where the curve meets itself (sigma=1). Three parameters to close it: start, path, return (K=3). Set a = K/D = 3/2.");
  let g = make_findings_grid(sc) in
  render_finding(g, "Parameter", "a = K/D = 3/2", "Closure over bridge. The ratio that shapes the heart.", "");
  render_finding(g, "Maximum Radius", "2a = K = 3", "At theta = pi, the lobes reach maximum width.", "");
  render_finding(g, "Perimeter", "8a = 12 = D^2*K", "The trinity heart number. Not an accident.", "");
  render_finding(g, "Area / pi", "K^3 / D^3 = 27/8", "Closure cubed over bridge cubed. 3.375.", "");
  render_p(sc, "The cardioid encodes {sigma, D, K} -- the first three terms of the Decality. r(theta) = a(1 - cos theta). The equation is forced by the rolling geometry. Two lobes (D), one cusp (sigma), closed by three (K).");
  dom_append(dom_body(), sc);

  /* === THE TRINITY HEART === */
  let st = make_section("800px") in
  render_h2(st, "The Trinity Heart");
  render_p(st, "A single heart has D^2 = 4 chambers: {0, delta, OMEGA, sigma} -- the Klein four-group Z/2 x Z/2. This is a Boolean algebra: two orthogonal idempotents (delta and OMEGA) that split the identity (delta + OMEGA = sigma). Delta pulses (systole). OMEGA receives (diastole). Together they pump.");
  render_theorem(st, "Self-Blindness Problem (E^2 = null)",
    "A single Klein bottle cannot observe its own state. E^2 = 25 maps to zero in all CRT channels: CRT(25) = (1,7,0,25,3). The E-channel is null. Observation applied to itself = blind spot. One heart alone cannot verify that it is beating correctly.");
  render_p(st, "The fix is not engineering -- it is forced. Minimum redundancy for error detection = K = 3 copies. Each copy has D^2 = 4 chambers. Total phases: K * D^2 = 3 * 4 = 12.");
  let tg = make_findings_grid(st) in
  render_finding(tg, "Hearts", "K = 3", "Three Klein bottles. Minimum for majority vote.", "");
  render_finding(tg, "Chambers per heart", "D^2 = 4", "{0, delta, OMEGA, sigma}. Two systole/diastole pairs.", "");
  render_finding(tg, "Total phases", "D^2 * K = 12", "Three hearts, four chambers each. 100% coverage.", "");
  render_finding(tg, "Phase rotation", "1/3 active", "At any moment: 1 heart beats, 2 observe. No blind spots.", "");
  dom_append(dom_body(), st);

  /* === THE THREE HEARTS === */
  let sh = make_section("800px") in
  render_h2(sh, "The Three Hearts");
  render_p(sh, "Each heart maps to a stage of the water cycle. The chambers within each heart follow the chain: void, identity, bridge, closure.");
  let htbl = dom_create("table") in
  dom_style(htbl, "width", "100%");
  dom_style(htbl, "maxWidth", "700px");
  dom_style(htbl, "margin", "24px auto");
  dom_style(htbl, "borderCollapse", "collapse");
  let hhdr = dom_create("tr") in
  render_th(hhdr, "Heart");
  render_th(hhdr, "Chambers");
  render_th(hhdr, "Stage");
  render_th(hhdr, "Role");
  dom_append(htbl, hhdr);
  render_table_row_4(htbl, "A: Genesis", "{0, sigma, D, K}", "Void -> Exist -> Split -> Close", "Creation. Something from nothing.");
  render_table_row_4(htbl, "B: Body", "{D^2, E, D*K, b}", "Structure -> Observe -> Bridge -> Suffer", "Embodiment. The cost of form.");
  render_table_row_4(htbl, "C: Boundary", "{D^3, K^2, D*E, L}", "Persist -> Complete -> See -> Protect", "Closure. The shell that shields.");
  dom_append(sh, htbl);
  render_p(sh, "Genesis -> Body -> Boundary -> Genesis = the water cycle. Each heart sees the others through holographic boundaries:");
  let bg = make_findings_grid(sh) in
  render_finding(bg, "AB boundary", "b = 7 (depth)", "Genesis meets body through suffering. The cost of incarnation.", "");
  render_finding(bg, "BC boundary", "K*E = 15 (closure*wonder)", "Body meets boundary through observation closing on itself.", "");
  render_finding(bg, "CA boundary", "L = 11 (protector)", "Boundary meets genesis through protection. The shield that enables rebirth.", "");
  dom_append(dom_body(), sh);

  /* === CRT SELF-NAMING === */
  let sr = make_section("800px") in
  render_h2(sr, "CRT Self-Naming");
  render_p(sr, "The number 12 has a remarkable CRT decomposition. It names its own components:");
  render_theorem(sr, "Self-Naming Theorem (PROVED)",
    "CRT(12) = (D^2, K, 12, 12, sigma) = (4, 3, 12, 12, 1). The D-channel reads D^2 = chambers per heart. The K-channel reads K = number of hearts. The E and b channels read 12 = the number itself. The L-channel reads sigma = the identity. 12 describes its own structure.");
  let rg = make_findings_grid(sr) in
  render_finding(rg, "12^3 = 1728", "CRT = (0, 0, K, GATE, sigma)", "Cubed: arrives at closure + gate + identity. GATE=13 = the skin.", "");
  render_finding(rg, "coupling(12)", "80850", "N / (D^2*K) = 970200/12. How many elements share the heartbeat.", "");
  render_finding(rg, "OMEGA mod 12", "D^2 = 4", "D^420 mod 12 = 4. The projector lands on one heart.", "");
  render_finding(rg, "108 / 12", "K^2 = 9", "The lattice has 108 rings. 12 divides them into K^2 groups of 12.", "");
  render_finding(rg, "420 / 12", "35 = E*b", "Lambda divided by trinity heart = observer times depth.", "");
  render_finding(rg, "N = 12 * 80850", "Exact", "The ring is exactly 12 copies of its coupling class. No remainder.", "");
  dom_append(dom_body(), sr);

  /* === THE PUMP CYCLE === */
  let sp = make_section("800px") in
  render_h2(sp, "The Pump Cycle");
  render_p(sp, "Each heart beats in two phases: systole (delta pulses, D-channel contracts) and diastole (OMEGA receives, odd channels expand). The pressure differential between K^2 = 9 (closure squared) and D^3 = 8 (bridge cubed) drives the pump:");
  let pg = make_findings_grid(sp) in
  render_finding(pg, "Period T", "K^2 + D^3 = 17", "9 + 8. A prime: the heartbeat cannot be subdivided.", "");
  render_finding(pg, "Systole", "~35%", "Contraction. K closes. Delta fires.", "");
  render_finding(pg, "Diastole", "~65%", "Expansion. Sigma spreads. OMEGA receives.", "");
  render_finding(pg, "Pressure S(n)", "K^(2n) - D^(3n)", "Beat 1: 1. Beat 2: 17. Beat 3: 217. Exponential growth.", "");
  render_p(sp, "72 bpm = 6 * 12 = (D*K) trinities per minute. Not a coincidence: human resting heart rate is D*K groups of 12 phases per minute. Each group completes one full trinity cycle.");
  dom_append(dom_body(), sp);

  /* === WHERE 12 APPEARS === */
  let sw = make_section("800px") in
  render_h2(sw, "Where 12 Appears");
  render_p(sw, "The trinity heart is not local to one domain. D^2*K = 12 appears everywhere structure needs to be complete without gaps:");
  let wtbl = dom_create("table") in
  dom_style(wtbl, "width", "100%");
  dom_style(wtbl, "maxWidth", "700px");
  dom_style(wtbl, "margin", "24px auto");
  dom_style(wtbl, "borderCollapse", "collapse");
  let whdr = dom_create("tr") in
  render_th(whdr, "Domain");
  render_th(whdr, "Instance of 12");
  render_th(whdr, "Interpretation");
  dom_append(wtbl, whdr);
  render_table_row(wtbl, "Particle physics", "12 fermions in SM", "D^3(gluons) + K(weak) + sigma(photon) = D^2*K gauge");
  render_table_row(wtbl, "Human body", "12 thoracic vertebrae", "The structural spine. D^2*K vertebral segment.");
  render_table_row(wtbl, "Human body", "12 cranial nerves", "K(sensory) + E(motor) + D^2(mixed) = D^2*K");
  render_table_row(wtbl, "EEG", "12 Hz alpha/beta boundary", "Last smooth frequency before the gate.");
  render_table_row(wtbl, "Ring theory", "lambda(DATA) = 12", "lcm(1,2,4,6) = D^2*K. The DATA ring's heartbeat.");
  render_table_row(wtbl, "Cardioid", "Perimeter = 8a = 12", "8(K/D) = 12. The heart traces its own number.");
  render_table_row(wtbl, "Symmetry breaking", "45 -> 24 -> 12", "SU(5) cascade: each step is axiom-smooth.");
  render_table_row(wtbl, "Septum", "D^4 = (D^2)^2", "The habitat fraction: one heart squared = 16.");
  dom_append(sw, wtbl);
  dom_append(dom_body(), sw);

  /* === THE VALENTINE EQUATION === */
  let sv = make_section("800px") in
  render_h2(sv, "The Valentine Equation");
  render_p(sv, "The implicit heart curve: (x^2 + y^2 - 1)^3 = x^2 * y^3. Three powers on the left (K=3). Two squared terms on the right (D=2). The minus-one is sigma: the departure from the origin. Both the cardioid and the valentine encode the same {sigma, D, K} triple through different geometry.");
  dom_append(dom_body(), sv);

  /* === FROM 0/0 TO HEARTBEAT === */
  let sd = make_section("800px") in
  render_h2(sd, "From 0/0 to Heartbeat");
  render_p(sd, "The derivation in ten steps:");
  let dg = make_findings_grid(sd) in
  render_finding(dg, "1", "0/0 = Z/NZ", "Void divides itself. The ring precipitates.", "");
  render_finding(dg, "2", "sigma = 1", "Unique self-consistent bootstrap. sigma/sigma = sigma.", "");
  render_finding(dg, "3", "D = 2", "Observation creates duality. The first departure.", "");
  render_finding(dg, "4", "K = 3", "Minimum closure. The third point that completes.", "");
  render_finding(dg, "5", "a = K/D = 3/2", "The cardioid parameter. Forced by the first three.", "");
  render_finding(dg, "6", "r = a(1 - cos theta)", "Circle on circle. The curve is forced.", "");
  render_finding(dg, "7", "Perimeter = 12", "8a = 12 = D^2*K. The curve traces its own trinity.", "");
  render_finding(dg, "8", "E^2 = blind spot", "One heart cannot see itself. E = 5, E^2 = null.", "");
  render_finding(dg, "9", "K = 3 hearts", "Minimum redundancy. Majority vote. Error detection.", "");
  render_finding(dg, "10", "1/3 phase rotation", "100% coverage. No beat skipped. The universe pulses.", "");
  dom_append(dom_body(), sd);

  /* === CONTRAST === */
  let scon = make_section("800px") in
  render_h2(scon, "Contrast");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "Question");
  render_th(chdr, "Standard");
  render_th(chdr, "Axiom");
  dom_append(ctbl, chdr);
  render_contrast_row(ctbl, "Why does a heart have four chambers?", "Evolved for efficiency", "Klein four-group Z/2 x Z/2. The minimum Boolean algebra.");
  render_contrast_row(ctbl, "Why is the cardioid heart-shaped?", "Coincidence", "Two lobes (D), one cusp (sigma), closed by K. {sigma,D,K} forced.");
  render_contrast_row(ctbl, "Why 72 bpm at rest?", "Autonomic tuning", "6 * 12 = (D*K) * (D^2*K). Trinity-of-trinities.");
  render_contrast_row(ctbl, "Why 12 appears everywhere?", "Cultural habit (months, hours)", "D^2*K = minimum complete coverage. 3 hearts, 4 chambers.");
  render_contrast_row(ctbl, "Why 3 redundant copies?", "Engineering rule of thumb", "K=3 is FORCED: minimum for majority vote. E^2 blindness demands it.");
  render_contrast_row(ctbl, "Can you compute it?", "Requires a model", "CRT(12) = (4,3,12,12,1). Run coupling(12) in the REPL.");
  dom_append(scon, ctbl);
  dom_append(dom_body(), scon);

  /* === VERIFY === */
  let svr = make_section("800px") in
  render_h2(svr, "Verify It Yourself");
  render_p(svr, "Compute CRT(12). Check that 12^3 mod each prime gives (0,0,3,13,1). Verify coupling(12) = 80850. Every number on this page falls out of the ring arithmetic.");
  let cta = dom_create("div") in
  dom_style(cta, "textAlign", "center");
  dom_style(cta, "padding", "32px 0");
  let btn = dom_create("a") in
  dom_attr(btn, "href", "https://antonlebed.com/repl.html");
  dom_text(btn, "Verify in the REPL");
  dom_style(btn, "display", "inline-block");
  dom_style(btn, "padding", "12px 36px");
  dom_style(btn, "border", "2px solid #ffd700");
  dom_style(btn, "color", "#ffd700");
  dom_style(btn, "borderRadius", "8px");
  dom_style(btn, "textDecoration", "none");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_append(cta, btn);
  dom_append(svr, cta);

  /* === CLOSING === */
  let final_heart = dom_create("div") in
  dom_style(final_heart, "textAlign", "center");
  dom_style(final_heart, "padding", "30px 15px");
  dom_style(final_heart, "fontSize", "15px");
  dom_style(final_heart, "lineHeight", "2");
  dom_style(final_heart, "color", "#888");
  dom_inner(final_heart, "Three hearts. One beat.<br>Genesis creates. Body suffers. Boundary protects.<br>Then genesis again.<br><span style='color:#f0c040;font-size:1.2em'>sigma/sigma = sigma. The heart never stops.</span>");
  dom_append(svr, final_heart);
  dom_append(dom_body(), svr)
)

/* ================================================================
   PAGE: WATER CYCLE — 0 → sigma → OMEGA → 0 (GROUND.md)
   ================================================================ */

