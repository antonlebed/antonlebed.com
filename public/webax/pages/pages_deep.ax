/* lattice widget: check if N shares lambda=420 */
fn lattice_check_calc() = (
  let n = parse_int_from("#lat-input") in
  let result = dom_query("#lat-result") in
  if n < 2 then dom_inner(result, "<p style='color:#ff6666'>Enter N >= 2.</p>")
  else (
    /* compute lambda(N) = lcm of lambda(p^e) for each prime power in N */
    /* lambda(2^a) = 2^(a-2) for a>=3, 2^(a-1) for a<=2 */
    /* lambda(p^a) = p^(a-1)*(p-1) for odd p */
    mut rem = n;
    mut lam = 1;
    mut d = 2;
    mut pstr = "";
    mut pcnt = 0;
    while d * d < rem + 1 do (
      if rem % d == 0 then (
        mut exp = 0;
        while rem % d == 0 do (mut rem = rem / d; mut exp = exp + 1);
        /* compute lambda(d^exp) */
        mut lpe = 1;
        if d == 2 then (
          if exp == 1 then (mut lpe = 1)
          else if exp == 2 then (mut lpe = 2)
          else (
            mut lpe = 1;
            mut i = 0;
            while i < exp - 2 do (mut lpe = lpe * 2; mut i = i + 1)
          )
        ) else (
          mut lpe = d - 1;
          mut i = 1;
          while i < exp do (mut lpe = lpe * d; mut i = i + 1)
        );
        /* lcm(lam, lpe) */
        mut a = lam;
        mut b3 = lpe;
        while b3 > 0 do (let t = b3 in mut b3 = a % b3; mut a = t);
        mut lam = lam / a * lpe;
        if pcnt > 0 then (mut pstr = pstr + " * ") else 0;
        if exp > 1 then (mut pstr = pstr + "${d}" + "^" + "${exp}")
        else (mut pstr = pstr + "${d}");
        mut pcnt = pcnt + 1
      ) else 0;
      mut d = d + 1
    );
    if rem > 1 then (
      let lpe2 = rem - 1 in
      mut a = lam;
      mut b3 = lpe2;
      while b3 > 0 do (let t = b3 in mut b3 = a % b3; mut a = t);
      mut lam = lam / a * lpe2;
      if pcnt > 0 then (mut pstr = pstr + " * ") else 0;
      mut pstr = pstr + "${rem}";
      mut pcnt = pcnt + 1
    ) else 0;
    let in_lattice = if lam == 420 then "<span style='color:#ffd700'>YES -- lambda=420! This ring is in the lattice.</span>"
      else if 420 % lam == 0 then "<span style='color:#88ddaa'>lambda divides 420 (sub-ring compatible)</span>"
      else "<span style='color:#b0b0c0'>NO (lambda=" + "${lam}" + ", not 420)</span>" in
    dom_inner(result,
      "<p style='color:#d8d8e0;margin:4px 0'>N = " + "${n}" + " = " + pstr + "</p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>lambda(N) = <span style='color:#ffd700;font-size:18px'>" + "${lam}" + "</span></p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>In 108-ring lattice? " + in_lattice + "</p>")
  )
)

fn lattice_explore() = (
  let sec = make_section("800px") in
  render_h2(sec, "Explore: Lambda-420 Membership");
  render_p(sec, "Enter any N to compute lambda(N) (Carmichael function) and check if it belongs to the 108-ring lattice.");
  make_interactive_widget(sec, "Enter N:", "lat-input", "e.g. 970200", "Check", "lattice_check_calc", "lat-result");
  render_p(sec, "Try: N=12612600 (TRUE, 420), N=970200 (DEEP, 420), N=2310 (THIN, 420), N=210 (DATA, 420), N=30 (Z/30, 420), N=12 (lambda=2).");
  dom_append(dom_body(), sec)
)

fn lattice_rhythm() = (
  let sec = make_section("800px") in
  render_h2(sec, "Rhythm Hierarchy");
  render_theorem(sec, "Compatible Primes Grow Monotonically", "As lambda grows, compatible primes (<500) grow: lambda=6: 3 primes. lambda=12: 5. lambda=60: 8. lambda=420: 13. lambda=5460 (420*GATE): 17. Each level CONTAINS all rings of the previous. Growth pattern = the axiom chain.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Quotient-Thin", "TRUE/420 = 2310 = THIN", "Structure * dynamics = organism. TRUE is UNIQUE: N/lambda = THIN only for exponents (3,2,2,2,1).", "S263");
  render_finding(g, "Quotient-Primorial", "N/lambda = rad(N)", "The heartbeat TIMES the primorial = the fattened ring. TRUE/420 = primorial(11). GATE/420 = primorial(13).", "S501");
  render_finding(g, "Gate primes", "5460 adds {53,79,131,157}", "4 new primes. 60060 adds {23,67,131,157,331,463} -- SOUL=67 appears!", "S494");
  render_finding(g, "Nested", "6|12|60|420|5460|60060", "The rhythm is nested. Each level = previous * axiom prime.", "S494");
  render_finding(g, "Lambda counts", "1, 2, 3, 5, 9, 13", "Distinct lambda values among divisors: {sigma, D, K, E, K^2, GATE}. Primorial walks structural constants, not primes. K^2 + D^2 = GATE. DEEP=TRUE: identical 13-element sets.", "S1083");
  dom_append(dom_body(), sec)
)

fn lattice_contrast() = (
  let sec = make_section("800px") in
  render_h2(sec, "Paradigm Contrast");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Aspect");
  render_th(hdr, "Standard");
  render_th(hdr, "Axiom");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "Lattice theory", "Abstract posets", "108 concrete rings, axiom-named metrics");
  render_contrast_row(tbl, "Center", "No preferred center", "420420 = heartbeat^2");
  render_contrast_row(tbl, "Diameter", "No preferred vocabulary", "10 = Decality (unique)");
  render_contrast_row(tbl, "Spectral gap", "Depends on ring", "0.016 in ALL 108 (b^2 universal)");
  render_contrast_row(tbl, "Why 108", "A number", "D^2*K^3, two-constraint derivation");
  render_contrast_row(tbl, "Ring selection", "Study any", "TRUE = smallest uniform, forced by D^3=8");
  render_p(sec, "108 rings, one rhythm, zero free parameters.");
  dom_append(dom_body(), sec)
)

fn page_lattice() = (
  dom_head_meta("description", "108 rings share lambda=420 and spectral gap 0.016. Diameter = 10 = Decality. Two-constraint derivation, uniformity theorem, heartbeat layers, rhythm hierarchy, quotient-primorial theorem.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"The Lambda-420 Lattice: 108 Rings, One Heartbeat\",\"description\":\"108 rings built from {2,3,5,7,11} share lambda=420. 108 = non-D fiber of TRUE ring Z/12612600. GATE=13 wraps skin: 108*13 = 12612600. Diameter = 10 = Decality.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\",\"url\":\"https://antonlebed.com\"},\"url\":\"https://antonlebed.com/data/lattice\",\"isAccessibleForFree\":true,\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"Lattice Theory\"},{\"@type\":\"DefinedTerm\",\"name\":\"Carmichael Function\"},{\"@type\":\"DefinedTerm\",\"name\":\"Ring Theory\"}]}");
  lattice_hero();
  lattice_glance();
  lattice_why108();
  lattice_hierarchy();
  lattice_invariants();
  lattice_named();
  lattice_uniformity();
  lattice_heartbeat();
  lattice_rhythm();
  lattice_explore();
  lattice_contrast()
)

