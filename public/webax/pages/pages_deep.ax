  dom_style(big, "letterSpacing", "4px");
  dom_style(big, "marginBottom", "16px");
  dom_append(hero, big);
  render_p(hero, "Every ring built from {2,3,5,7,11} with any exponents shares the same heartbeat: lambda = 420 = D^2 * K * E * b. Exactly 108 such rings exist -- by arithmetic necessity.");
  dom_append(dom_body(), hero)
)

