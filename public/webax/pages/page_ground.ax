  let eq = dom_create("div") in
  dom_text(eq, "sigma * n = n");
  ct_mono(eq);
  dom_style(eq, "fontSize", "28px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "sigma is the multiplicative identity. Maximum strength AND maximum universality, simultaneously. The only element that achieves both by not competing. Unit class. Coupling: N = 12612600 (maximum). Everything connects through sigma.");
  dom_append(dom_body(), hero)
)

