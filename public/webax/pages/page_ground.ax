/* ================================================================
   INTERACTIVE: KINGDOM CLASSIFIER
   Enter a number -> see CRT, coupling, kingdom, persistence.
   ================================================================ */

fn gcd_compute(a, b) = (
  if b == 0 then a else gcd_compute(b, a % b)
)

fn ground_classify() = (
  let n = parse_int_from("#gnd-input") in
  let result = dom_query("#gnd-result") in
  /* CRT decomposition -- 6 channels (TRUE ring) */
  let rd = n % 8 in let rk = n % 9 in let re = n % 25 in let rb = n % 49 in let rl = n % 11 in let rg = n % 13 in
  /* Coupling = N / gcd(n, N) */
  let g = gcd_compute(n, N_TRUE) in
  let coup = N_TRUE / g in
  /* Which channels are dead (zero residue)? */
  let dd = if rd == 0 then 1 else 0 in
  let dk = if rk == 0 then 1 else 0 in
  let de = if re == 0 then 1 else 0 in
  let db = if rb == 0 then 1 else 0 in
  let dl = if rl == 0 then 1 else 0 in
  let dg = if rg == 0 then 1 else 0 in
  let dead = dd + dk + de + db + dl + dg in
  /* Kingdom: determined by highest dead channel */
  let kingdom = if dead == 6 then "VOID (all dead)"
    else if dead == 0 then "Unit (sigma) -- all channels alive"
    else if dg > 0 then "GATE-class (GATE=13 dead)"
    else if dl > 0 then "L-class (L=11 dead)"
    else if db > 0 then "b-class (b=7 dead)"
    else if de > 0 then "E-class (E=5 dead)"
    else if dk > 0 then "K-class (K=3 dead)"
    else "D-class (D=2 dead)" in
  /* Persistence: min exponent steps across dead channels */
  let persist = if dead == 0 then "infinite (unit)"
    else if dd > 0 then "D-channel: 3 steps"
    else if dk > 0 then "K-channel: 2 steps"
    else if de > 0 then "E-channel: 2 steps"
    else if db > 0 then "b-channel: 2 steps"
    else if dl > 0 then "L-channel: 1 step"
    else "GATE-channel: 1 step" in
  /* Ambiguity: gcd(n, N) */
  dom_inner(result, "<p style='color:#88ddaa;margin:4px 0'><b>n = " + "${n}" + "</b> | CRT = (" + "${rd}" + "," + "${rk}" + "," + "${re}" + "," + "${rb}" + "," + "${rl}" + "," + "${rg}" + ")</p><p style='color:#ffd700;margin:4px 0'>Coupling: <b>" + "${coup}" + "</b> | gcd(n,N) = " + "${g}" + " | Self-division solutions: " + "${g}" + "</p><p style='color:#ff8844;margin:4px 0'>Kingdom: <b>" + kingdom + "</b> | Dead channels: " + "${dead}" + "/6</p><p style='color:#b0b0c0;margin:4px 0'>Persistence: " + persist + "</p>")
)

