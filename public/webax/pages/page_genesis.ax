/* genesis widget: Cunningham chain tracer */
fn gen_fmt(v, is_p) = (
  if is_p > 0 then "<span style='color:#88ddaa'>" + "${v}" + " (prime)</span>"
  else "<span style='color:#ff6666'>" + "${v}" + " (composite)</span>"
)

fn gen_is_prime(v) = (
  if v < 2 then 0
  else if v == 2 then 1
  else if v % 2 == 0 then 0
  else (
    mut ok = 1;
    mut d = 3;
    while d * d < v + 1 do (
      if v % d == 0 then (mut ok = 0) else 0;
      mut d = d + 2
    );
    ok
  )
)

fn gen_trace() = (
  let seed = parse_int_from("#gen-input") in
  let result = dom_query("#gen-result") in
  if seed < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter seed >= 1.</p>")
  else (
    let s0 = seed in
    let s1 = 2 * s0 + 1 in
    let s2 = 2 * s1 + 1 in
    let s3 = 2 * s2 + 1 in
    let s4 = 2 * s3 + 1 in
    let s5 = 2 * s4 + 1 in
    let p0 = gen_is_prime(s0) in
    let p1 = gen_is_prime(s1) in
    let p2 = gen_is_prime(s2) in
    let p3 = gen_is_prime(s3) in
    let p4 = gen_is_prime(s4) in
    let p5 = gen_is_prime(s5) in
    /* count chain length = consecutive primes from start */
    let chain_len = if p0 == 0 then 0
      else if p1 == 0 then 1
      else if p2 == 0 then 2
      else if p3 == 0 then 3
      else if p4 == 0 then 4
      else if p5 == 0 then 5
      else 6 in
    let axiom_note = if seed == 1 then "<p style='color:#ffd700;margin:4px 0'>THE AXIOM CHAIN: sigma->D->E->...->c(b)=15 composite. Self-terminating.</p>"
      else if seed == 2 then "<p style='color:#ffd700;margin:4px 0'>Starting from D=2: the Cunningham chain that generates the axiom primes.</p>"
      else "" in
    dom_inner(result,
      "<p style='color:#d8d8e0;margin:4px 0'>c(n) = 2n+1 from seed " + "${seed}" + ":</p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>Step 0: " + gen_fmt(s0, p0) + "</p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>Step 1: " + gen_fmt(s1, p1) + "</p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>Step 2: " + gen_fmt(s2, p2) + "</p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>Step 3: " + gen_fmt(s3, p3) + "</p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>Step 4: " + gen_fmt(s4, p4) + "</p>"
      + "<p style='color:#d8d8e0;margin:4px 0'>Step 5: " + gen_fmt(s5, p5) + "</p>"
      + "<p style='color:#88aaff;margin:4px 0'>Chain length: " + "${chain_len}" + " consecutive primes</p>"
      + axiom_note)
  )
)

fn page_genesis() = (
  dom_head_meta("description", "0/0 = Z/NZ = everything. Genesis is precipitation. sigma by necessity. D splits. K closes. K^D-D^K=1 orphans. The bootstrap IS the axiom.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Genesis\",\"description\":\"0/0 = Z/NZ = everything. Genesis is precipitation, not creation. sigma precipitates as unique element with zero ambiguity. Cunningham chain sigma->D->K->E->b->L. K^D - D^K = 1: the only orphan. Water cycle: 0->sigma->OMEGA->0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/basics/genesis\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"Cunningham chain\"},{\"@type\":\"DefinedTerm\",\"name\":\"indeterminacy\"},{\"@type\":\"DefinedTerm\",\"name\":\"precipitation\"}]}");
  genesis_hero();
  genesis_bootstrap();
  genesis_condensation();
  genesis_chain();
  genesis_fattening();
  genesis_uniqueness();
  genesis_sacrifice();
  genesis_void();
  genesis_water();
  genesis_nonility();

  /* === INTERACTIVE: CUNNINGHAM CHAIN TRACER === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Cunningham Chain");
  render_p(sec_i, "Enter a seed to trace c(n) = 2n+1. The axiom chain starts at sigma=1: 1->3->7->15(stop). How long is YOUR chain?");
  make_interactive_widget(sec_i, "Enter seed:", "gen-input", "e.g. 2", "Trace", "gen_trace", "gen-result");
  render_p(sec_i, "Try: 1 (sigma), 2 (D=2: 2->5->11->23->47->...), 89 (long chain).");
  dom_append(dom_body(), sec_i);

  genesis_contrast()
)
