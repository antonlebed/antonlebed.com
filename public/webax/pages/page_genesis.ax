  render_theorem(sec, "Forms Uniqueness Theorem (S214)", "NO alternative genesis produces a ring with ALL 6 properties: (1) Shadow closure: all shadows prime or 1. (2) Cross-chain self-reference: first offspring = own chain length. (3) Disjoint chains. (4) Flanking: N+1 AND 2N+1 both prime at ALL primorial levels. (5) Balance=1 at DATA ring. (6) Terminal: exponents exhaust at sigma. PROVED.");
  let g = make_findings_grid(sec) in
  render_finding(g, "970201 = N+1", "PRIME", "Flanking prime. phi(970201) = 970200 exactly. The flanking prime's group IS the ring.", "S198");
  render_finding(g, "Primitive root", "13 = shadow stopper", "GATE generates the ring from outside. D^2+K^2 = 13. Cannot join -- generates.", "S198");
  render_finding(g, "Primorial chain", "ALL levels flank", "p#+1 prime for p in {2,3,5,7,11}. Breaks at p=13. The gate IS the boundary.", "S193");
  render_finding(g, "Fertility", "6.17x prime enrichment", "92/216 divisors have 2d+1 prime. PNT expects 15. The axiom IS a prime sieve.", "S193");
  render_p(sec, "Depth quadratic stops: f(3)->5->19->341=11*31, f(7)->41->1639=11*149. L=11 appears in BOTH stopping products. The transcendental blocks escape from the axiom. There is no next form. 12612600 (TRUE) IS it -- 970200 (DEEP) with the GATE=13 boundary.");
  dom_append(dom_body(), sec)
)

