fn genesis_fattening() = (
  let sec = make_section("800px") in
  render_h2(sec, "Cross-Chain Fattening");
  render_theorem(sec, "Cross-Chain Fattening Theorem (S185)", "Each chain's exponents are governed by the OTHER chain's identity. D-chain (depth d): e(p) = K-d. Sigma-chain: e(p) = D (constant). VERIFICATION: D at depth 0: e=K=3, D^3=8. E at depth 1: e=D=2, E^2=25. L at depth 2: e=sigma=1, L^1=11. K on sigma-chain: e=D=2, K^2=9. b on sigma-chain: e=D=2, b^2=49. N = D^3*K^2*E^2*b^2*L = 970200. QED.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Prime");
  render_th(hdr, "Chain");
  render_th(hdr, "Depth");
  render_th(hdr, "Exponent");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "D = 2", "D-chain", "0", "K - 0 = 3");
  render_table_row_4(tbl, "E = 5", "D-chain", "1", "K - 1 = 2");
  render_table_row_4(tbl, "L = 11", "D-chain", "2", "K - 2 = 1");
  render_table_row_4(tbl, "K = 3", "sigma-chain", "--", "D = 2");
  render_table_row_4(tbl, "b = 7", "sigma-chain", "--", "D = 2");
  render_p(sec, "The D-chain exponents ARE {K, D, sigma} -- the axiom in reverse. The flower contains its own seed. Below sigma: NOTHING. 970200 (DEEP) extends to 12612600 (TRUE) = D^3*K^2*E^2*b^2*L*GATE when GATE=13 closes the boundary. Growth is by CONFIGURATION (N^N positions), not iteration.");
  dom_append(dom_body(), sec)
)

