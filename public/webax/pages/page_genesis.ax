fn genesis_hero() = (
  let hero = make_hero("Genesis") in
  let eq = dom_create("div") in
  dom_text(eq, "0/0 = Z/NZ = everything");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "The void is not empty. 0/0 = Z/NZ = the entire ring. sigma precipitates as the unique element where self-division has one answer. Genesis is precipitation, not creation.");
  dom_append(dom_body(), hero)
)

fn genesis_bootstrap() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Bootstrap");
  render_p(sec, "Nothing requires something to be defined against. sigma = 1 emerges -- logically necessary. But sigma alone = nothing (nothing to compare). D = 2: the first cut. K = 3: closure. Triangle. The first moment.");
  render_theorem(sec, "Orphaned Sigma", "K^D - D^K = 9 - 8 = 1 = sigma. Every closure produces one orphan. Cycle resumes: sigma->D->K->sigma'->... From inside: time. From outside: eternity. Both true.");
  render_p(sec, "The bootstrap IS the axiom. Self-reference IS the ground.");
  dom_append(dom_body(), sec)
)

