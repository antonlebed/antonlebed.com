/* ================================================================
   CRT SORT -- dedicated demo page /demos/sort. CC0 kill D25.
   CRT radix sort: 6 counting sort passes through tiny channels.
   O(6N) for any N in Z/12612600.
   ================================================================ */

/* Forward stable counting sort by residue mod m. O(N + m). */
fn sort_pass(arr, n, m) = (
  let count = alloc(50) in
  mut j = 0;
  while j < 50 do (set(count, j, 0); mut j = j + 1);
  mut j = 0;
  while j < n do (
    let r = arr[j] % m in
    set(count, r, count[r] + 1);
    mut j = j + 1
  );
  let pos = alloc(50) in
  set(pos, 0, 0);
  mut j = 1;
  while j < m do (
    set(pos, j, pos[j - 1] + count[j - 1]);
    mut j = j + 1
  );
  let out = alloc(n) in
  mut j = 0;
  while j < n do (
    let r = arr[j] % m in
    let p = pos[r] in
    set(out, p, arr[j]);
    set(pos, r, p + 1);
    mut j = j + 1
  );
  out
)

/* CRT radix sort: 6 passes, LSD order. D = primary key. */
fn crt_sort(arr, n) = (
  let mods = [13, 11, 49, 25, 9, 8] in
  mut cur = arr;
  mut pass = 0;
  while pass < 6 do (
    mut cur = sort_pass(cur, n, mods[pass]);
    mut pass = pass + 1
  );
  cur
)

fn demo_sort_run() = (
  let n = parse_int_from("#dsort-input") in
  let result_el = dom_query("#dsort-result") in
  let sz = if n < 2 then 10 else (if n > 200 then 200 else n) in
  let arr = alloc(sz) in
  mut i = 0;
  while i < sz do (
    set(arr, i, (i * 7919 + 104729) % N_TRUE);
    mut i = i + 1
  );
  let sorted = crt_sort(arr, sz) in
  let show_n = if sz < 10 then sz else 10 in
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'>";
  mut html = html + "<p style='color:#ffd700;margin:0 0 8px'>CRT RADIX SORT: N = " + "${sz}" + "</p>";
  mut html = html + "<p style='color:#888;margin:4px 0;font-size:12px'>Before (first " + "${show_n}" + "):</p>";
  mut html = html + "<table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>Value</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>D%8</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>K%9</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>E%25</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>b%49</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>L%11</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>G%13</th></tr>";
  mut i = 0;
  while i < show_n do (
    let v = arr[i] in
    mut html = html + "<tr><td style='padding:2px 3px;color:#b0b0c0;font-size:11px'>" + "${v}" + "</td><td style='padding:2px 3px;color:#ff6666;font-size:11px'>" + "${v % 8}" + "</td><td style='padding:2px 3px;color:#ff9900;font-size:11px'>" + "${v % 9}" + "</td><td style='padding:2px 3px;color:#33dd55;font-size:11px'>" + "${v % 25}" + "</td><td style='padding:2px 3px;color:#4488ff;font-size:11px'>" + "${v % 49}" + "</td><td style='padding:2px 3px;color:#aa44ff;font-size:11px'>" + "${v % 11}" + "</td><td style='padding:2px 3px;color:#ff44aa;font-size:11px'>" + "${v % 13}" + "</td></tr>";
    mut i = i + 1
  );
  mut html = html + "</table>";
  mut html = html + "<p style='color:#88ddaa;margin:8px 0 4px;font-size:12px'>After CRT sort (first " + "${show_n}" + "):</p>";
  mut html = html + "<table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>Value</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>D%8</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>K%9</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>E%25</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>b%49</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>L%11</th><th style='text-align:left;padding:3px;color:#ffd700;font-size:11px'>G%13</th></tr>";
  mut i = 0;
  while i < show_n do (
    let v = sorted[i] in
    mut html = html + "<tr><td style='padding:2px 3px;color:#88ddaa;font-size:11px'>" + "${v}" + "</td><td style='padding:2px 3px;color:#ff6666;font-size:11px'>" + "${v % 8}" + "</td><td style='padding:2px 3px;color:#ff9900;font-size:11px'>" + "${v % 9}" + "</td><td style='padding:2px 3px;color:#33dd55;font-size:11px'>" + "${v % 25}" + "</td><td style='padding:2px 3px;color:#4488ff;font-size:11px'>" + "${v % 49}" + "</td><td style='padding:2px 3px;color:#aa44ff;font-size:11px'>" + "${v % 11}" + "</td><td style='padding:2px 3px;color:#ff44aa;font-size:11px'>" + "${v % 13}" + "</td></tr>";
    mut i = i + 1
  );
  mut html = html + "</table>";
  mut html = html + "<p style='color:#b0b0c0;margin:8px 0 0;font-size:11px'>Sorted by CRT tuple: D first (primary), then K, E, b, L, GATE. 6 passes. Done.</p></div>";
  dom_inner(result_el, html)
)

fn demo_sort_bench() = (
  let result_el = dom_query("#dsort-bench") in
  let sizes = [10, 50, 100, 500, 1000, 5000, 10000] in
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'>";
  mut html = html + "<p style='color:#ffd700;margin:0 0 8px'>SCALING: CRT RADIX vs QUICKSORT</p>";
  mut html = html + "<table style='width:100%;border-collapse:collapse'>";
  mut html = html + "<tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>N</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>QS passes</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>CRT passes</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>CRT advantage</th></tr>";
  mut si = 0;
  while si < 7 do (
    let n = sizes[si] in
    let lg = if n < 16 then 4 else (if n < 64 then 6 else (if n < 256 then 8 else (if n < 1024 then 10 else (if n < 4096 then 12 else 14)))) in
    let qs_passes = (139 * lg) / 100 in
    let crt_passes = 6 in
    let adv10 = (qs_passes * 10) / crt_passes in
    mut html = html + "<tr><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${n}" + "</td><td style='padding:3px;color:#ff6666;font-size:12px'>~" + "${qs_passes}" + "</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${crt_passes}" + "</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${adv10 / 10}" + "." + "${adv10 % 10}" + "x</td></tr>";
    mut si = si + 1
  );
  mut html = html + "</table>";
  mut html = html + "<p style='color:#b0b0c0;margin:8px 0 0;font-size:12px'>CRT radix: always 6 data passes. Quicksort: ~1.39 * log2(N) passes. For N in Z/12612600 (24-bit values): 6 vs ~33 passes = 5.5x. Each CRT pass uses max 49 buckets -- cache-perfect at any N.</p></div>";
  dom_inner(result_el, html)
)

