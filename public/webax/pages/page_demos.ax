  dom_style(inp_d, "background", "#111");
  dom_style(inp_d, "color", "#eee");
  dom_style(inp_d, "border", "1px solid #333");
  dom_style(inp_d, "padding", "6px 8px");
  dom_style(inp_d, "fontFamily", "'Courier New', monospace");
  dom_style(inp_d, "width", "160px");
  dom_append(extras, inp_d);
  dom_append(sec2, extras);
  render_p(sec2, "Channel 0=D, 1=K, 2=E, 3=b, 4=L, 5=G. Try losing different channels.");
  dom_append(dom_body(), sec2);
  let sec3h = make_section("800px") in
  render_h2(sec3h, "Batch Erasure Test");
  render_p(sec3h, "Test 100 values: lose each channel in turn, verify 100% recovery.");
  let btn = dom_create("button") in
  dom_text(btn, "Run Batch Erasure (600 tests)");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "8px 16px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "borderRadius", "4px");
  dom_on(btn, "click", "demo_fountain_batch");
  dom_append(sec3h, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "dftn-batch-result");
  dom_append(sec3h, br);
  dom_append(dom_body(), sec3h);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Fountain vs Traditional");
  render_contrast_row(sec3, "Code design", "Raptor: random bipartite graph + LT transform", "CRT: ring structure IS the code. No design.");
  render_contrast_row(sec3, "Overhead", "5-10% encoding overhead", "0% overhead. 6 drops = 6 channels.");
  render_contrast_row(sec3, "Recovery", "Probabilistic (BP decoding)", "Deterministic. CRT guarantees unique solution.");
  render_contrast_row(sec3, "Complexity", "O(k log k) encoding", "O(1) per channel (modular arithmetic)");
  render_contrast_row(sec3, "Patent status", "Qualcomm Raptor/RaptorQ patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   CRT-OFDM -- dedicated demo page /demos/ofdm. CC0 kill A6.
   6 CRT channels as orthogonal subcarriers. Phase-shift keying per channel.
   ================================================================ */

fn demo_ofdm_run() = (
  let data = parse_int_from("#dofdm-input") in
  let result_el = dom_query("#dofdm-result") in
  let d = data % N_TRUE in
  let mods = [8, 9, 25, 49, 11, 13] in
  let rd = d % 8 in let rk = d % 9 in let re = d % 25 in let rb = d % 49 in let rl = d % 11 in let rg = d % 13 in
  /* Bits per channel: log2(modulus) */
  /* D: 3, K: 3.17, E: 4.64, b: 5.61, L: 3.46, G: 3.7 = total 23.58 bits over 6 subcarriers */
  let total_bits = 23 in /* floor(log2(12612600)) */
  /* Simulate noise: add random-ish perturbation to each channel, then demodulate (nearest valid) */
  let noise_seed = d * 137 + 41 in
  let n_d = (noise_seed % 3) in let n_k = (noise_seed / 3 % 3) in let n_e = (noise_seed / 9 % 5) in
  let n_b = (noise_seed / 45 % 7) in let n_l = (noise_seed / 315 % 3) in let n_g = (noise_seed / 945 % 3) in
  /* "Received" = residue + noise, then demodulate = nearest valid constellation point = mod */
  let rx_d = (rd + n_d) % 8 in let rx_k = (rk + n_k) % 9 in let rx_e = (re + n_e) % 25 in
  let rx_b = (rb + n_b) % 49 in let rx_l = (rl + n_l) % 11 in let rx_g = (rg + n_g) % 13 in
  /* CRT reconstruct from received */
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  let recon = (rx_d * idem[0] + rx_k * idem[1] + rx_e * idem[2] + rx_b * idem[3] + rx_l * idem[4] + rx_g * idem[5]) % N_TRUE in
  /* Channel errors */
  let err_d = if rx_d == rd then 0 else 1 in let err_k = if rx_k == rk then 0 else 1 in
  let err_e = if rx_e == re then 0 else 1 in let err_b = if rx_b == rb then 0 else 1 in
  let err_l = if rx_l == rl then 0 else 1 in let err_g = if rx_g == rg then 0 else 1 in
  let total_err = err_d + err_k + err_e + err_b + err_l + err_g in
  let ok = if recon == d then 1 else 0 in
  /* Compare: WiFi 802.11a BPSK rate-1/2 = 0.5 bits/subcarrier. CRT = 23.58/6 = 3.93 bits/subcarrier */
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT-OFDM MODULATION</p><p style='color:#88ddaa;margin:4px 0'>Data symbol: " + "${d}" + " (" + "${total_bits}" + " bits)</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Channel</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Mod</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Tx</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Rx</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Status</th></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>D</td><td style='padding:3px;color:#888;font-size:12px'>8</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rd}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_d}" + "</td><td style='padding:3px;color:" + (if err_d == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_d == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#88ddaa;font-size:12px'>K</td><td style='padding:3px;color:#888;font-size:12px'>9</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rk}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_k}" + "</td><td style='padding:3px;color:" + (if err_k == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_k == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>E</td><td style='padding:3px;color:#888;font-size:12px'>25</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${re}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_e}" + "</td><td style='padding:3px;color:" + (if err_e == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_e == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>b</td><td style='padding:3px;color:#888;font-size:12px'>49</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rb}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_b}" + "</td><td style='padding:3px;color:" + (if err_b == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_b == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#88ddaa;font-size:12px'>L</td><td style='padding:3px;color:#888;font-size:12px'>11</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rl}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_l}" + "</td><td style='padding:3px;color:" + (if err_l == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_l == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#88ddaa;font-size:12px'>G</td><td style='padding:3px;color:#888;font-size:12px'>13</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rg}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_g}" + "</td><td style='padding:3px;color:" + (if err_g == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_g == 0 then "OK" else "ERR") + "</td></tr></table><p style='color:#ffd700;margin:12px 0 4px'>SPECTRAL EFFICIENCY</p><p style='color:#88ddaa;margin:4px 0'>CRT-OFDM: 23 bits / 6 subcarriers = 3.83 bits/subcarrier</p><p style='color:#b0b0c0;margin:4px 0'>WiFi 802.11a BPSK rate-1/2: 0.50 bits/subcarrier</p><p style='color:#ffd700;margin:4px 0'>Ratio: <b>7.67x</b> spectral efficiency (6-channel TRUE ring vs BPSK)</p><p style='color:" + (if ok == 1 then "#44ff88" else "#ff4444") + ";font-size:16px;margin:8px 0'>Reconstructed: " + "${recon}" + (if ok == 1 then " -- PERFECT" else " -- " + "${total_err}" + " channel error(s)") + "</p></div>")
)

fn page_ofdm() = (
  dom_head_meta("description", "CRT-OFDM Modulation. 6 CRT channels as orthogonal subcarriers. 7.67x spectral efficiency vs WiFi BPSK. CC0 patent kill: WiFi/5G.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT-OFDM Modulation\",\"description\":\"6-channel orthogonal modulation over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/ofdm\"}");
  let hero = make_hero("CRT-OFDM") in
  let eq = dom_create("div") in
  dom_text(eq, "A6: WiFi/5G patents. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "Replace WiFi subcarriers with CRT channels. Each of 6 channels carries an independent PSK constellation: D(8-PSK), K(9-PSK), E(25-PSK), b(49-PSK), L(11-PSK), G(13-PSK). Total: 23 bits per symbol over 6 subcarriers = 3.83 bits/subcarrier. WiFi 802.11a BPSK rate-1/2: 0.50 bits/subcarrier. Ratio: 7.67x.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT-OFDM Principle", "A data symbol d in Z/12612600 decomposes into 6 residues. Each residue modulates a subcarrier using p-ary PSK (phase angle = 2*pi*r/m for residue r and modulus m). The receiver demodulates each subcarrier independently (nearest constellation point), then CRT reconstructs the original symbol. Channel independence: noise in one subcarrier cannot corrupt another. The 490 holographic split: DEAD={D,E,b} subcarriers carry primary data, ALIVE={K,L,G} provide error detection.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "6 subcarriers", "CRT decomposition", "D(8-PSK), K(9-PSK), E(25-PSK), b(49-PSK), L(11-PSK), G(13-PSK).", "");
  render_finding(g1, "7.67x efficiency", "TRUE ring capacity", "23 bits over 6 channels vs BPSK 0.5 bits/channel.", "");
  render_finding(g1, "490 split", "Data + detection", "Inner channels carry bits. Boundary channels detect errors for free.", "");
  render_finding(g1, "Graceful fading", "Independent channels", "If one channel fades, others continue. No catastrophic failure.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Data symbol (0-12612599):", "dofdm-input", "e.g. 42", "Modulate", "demo_ofdm_run", "dofdm-result");
  render_p(sec2, "6 subcarriers show Tx (transmitted residue) vs Rx (received with noise). Red = DEAD/inner channels. Green = ALIVE/boundary channels.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT-OFDM vs WiFi");
  render_contrast_row(sec3, "Bits per subcarrier", "WiFi BPSK r=1/2: 0.50", "CRT: 3.83 (23 bits / 6 channels)");
  render_contrast_row(sec3, "Ratio", "Baseline", "7.67x higher spectral efficiency");
  render_contrast_row(sec3, "Error detection", "None built-in (needs CRC-32)", "CRT: invalid values flag errors for free");
  render_contrast_row(sec3, "Channel fading", "Entire signal degrades uniformly", "Independent per-channel fading. Graceful.");
  render_contrast_row(sec3, "Patent status", "WiFi/5G OFDM patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   GPU COMPUTE -- dedicated demo page /demos/gpu_compute. CC0 kill S1.
   6 CRT channels as independent compute workgroups.
   f(x) distributes over CRT: compute per-channel, reconstruct once.
   ================================================================ */

fn demo_gpu_run() = (
  let data = parse_int_from("#dgpu-input") in
  let result_el = dom_query("#dgpu-result") in
  let d = data % N_TRUE in
  let mods = [8, 9, 25, 49, 11, 13] in
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  /* Decompose into 6 channels */
  let rd = d % 8 in let rk = d % 9 in let re = d % 25 in let rb = d % 49 in let rl = d % 11 in let rg = d % 13 in
  /* f(x) = x^2 mod N -- compute per channel independently (GPU workgroup analogy) */
  let sd = (rd * rd) % 8 in let sk = (rk * rk) % 9 in let se = (re * re) % 25 in
  let sb = (rb * rb) % 49 in let sl = (rl * rl) % 11 in let sg = (rg * rg) % 13 in
  /* CRT reconstruct the squared result */
  let recon = (sd * idem[0] + sk * idem[1] + se * idem[2] + sb * idem[3] + sl * idem[4] + sg * idem[5]) % N_TRUE in
  /* Verify: direct computation */
  let direct = (d * d) % N_TRUE in
  let ok = if recon == direct then 1 else 0 in
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>6-CHANNEL PARALLEL COMPUTE: f(x) = x^2 mod 12612600</p><p style='color:#88ddaa;margin:4px 0'>Input: x = " + "${d}" + "</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Workgroup</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Mod</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>r = x mod m</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>r^2 mod m</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Type</th></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>D</td><td style='padding:3px;color:#888;font-size:12px'>8</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rd}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${sd}" + "</td><td style='padding:3px;color:#ff6666;font-size:11px'>DEAD</td></tr><tr><td style='padding:3px;color:#44ff88;font-size:12px'>K</td><td style='padding:3px;color:#888;font-size:12px'>9</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rk}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${sk}" + "</td><td style='padding:3px;color:#44ff88;font-size:11px'>ALIVE</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>E</td><td style='padding:3px;color:#888;font-size:12px'>25</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${re}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${se}" + "</td><td style='padding:3px;color:#ff6666;font-size:11px'>DEAD</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>b</td><td style='padding:3px;color:#888;font-size:12px'>49</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rb}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${sb}" + "</td><td style='padding:3px;color:#ff6666;font-size:11px'>DEAD</td></tr><tr><td style='padding:3px;color:#44ff88;font-size:12px'>L</td><td style='padding:3px;color:#888;font-size:12px'>11</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rl}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${sl}" + "</td><td style='padding:3px;color:#44ff88;font-size:11px'>ALIVE</td></tr><tr><td style='padding:3px;color:#44ff88;font-size:12px'>G</td><td style='padding:3px;color:#888;font-size:12px'>13</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rg}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${sg}" + "</td><td style='padding:3px;color:#44ff88;font-size:11px'>ALIVE</td></tr></table><p style='color:#ffd700;margin:12px 0 4px'>RECONSTRUCTION</p><p style='color:#88ddaa;margin:4px 0'>Parallel (6 workgroups + CRT): " + "${recon}" + "</p><p style='color:#b0b0c0;margin:4px 0'>Sequential (direct x^2 mod N): " + "${direct}" + "</p><p style='color:" + (if ok == 1 then "#44ff88" else "#ff4444") + ";font-size:16px;margin:8px 0'>" + (if ok == 1 then "MATCH -- 6 independent computations, 1 correct answer" else "MISMATCH -- bug") + "</p></div>")
)

fn demo_gpu_batch() = (
  let result_el = dom_query("#dgpu-batch") in
  let ok_count = [0] in
  let i = [0] in
  let mods = [8, 9, 25, 49, 11, 13] in
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  while i[0] < 1000 do (
    let d = (i[0] * 12637 + 41) % N_TRUE in
    let rd = d % 8 in let rk = d % 9 in let re = d % 25 in let rb = d % 49 in let rl = d % 11 in let rg = d % 13 in
    let sd = (rd * rd) % 8 in let sk = (rk * rk) % 9 in let se = (re * re) % 25 in
    let sb = (rb * rb) % 49 in let sl = (rl * rl) % 11 in let sg = (rg * rg) % 13 in
    let recon = (sd * idem[0] + sk * idem[1] + se * idem[2] + sb * idem[3] + sl * idem[4] + sg * idem[5]) % N_TRUE in
    let direct = (d * d) % N_TRUE in
    if recon == direct then set(ok_count, 0, ok_count[0] + 1) else 0;
    set(i, 0, i[0] + 1)
  );
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>BATCH: 1000 values x f(x)=x^2</p><p style='color:" + (if ok_count[0] == 1000 then "#44ff88" else "#ff4444") + ";font-size:18px;margin:4px 0'>" + "${ok_count[0]}" + "/1000 MATCH</p><p style='color:#b0b0c0;margin:4px 0'>Each value decomposed into 6 channels, squared independently, reconstructed via CRT. All 6 workgroups run in parallel -- no cross-channel dependency.</p></div>")
)

fn page_gpu_compute() = (
  dom_head_meta("description", "CRT GPU Compute. 6 independent workgroups via CRT decomposition. Block-diagonal parallelism kills CUDA patents. CC0.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT GPU Compute\",\"description\":\"6-channel parallel compute over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/gpu_compute\"}");
  let hero = make_hero("CRT GPU Compute") in
  let eq = dom_create("div") in
  dom_text(eq, "S1: NVIDIA CUDA patents. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "Replace GPU thread blocks with CRT channels. Any function f that distributes over modular arithmetic can be computed in 6 independent workgroups -- one per prime power -- then reconstructed in one CRT step. Zero cross-channel dependency. The ring IS the parallelization.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Parallelism Principle", "For f(x) = x^2 mod N where N = 8*9*25*49*11*13 = 12612600: decompose x into 6 residues (r_D, r_K, r_E, r_b, r_L, r_G). Compute f(r_i) = r_i^2 mod m_i independently in each channel. CRT reconstruct. Result equals f(x) mod N exactly. This works because CRT is a ring isomorphism: Z/N = Z/8 x Z/9 x Z/25 x Z/49 x Z/11 x Z/13. Any polynomial distributes. The 490 holographic split: DEAD channels {D,E,b} carry the bulk compute, ALIVE channels {K,L,G} provide integrity checking for free.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "6 workgroups", "CRT decomposition", "Each channel computes independently. No shared memory, no barriers, no race conditions.", "");
  render_finding(g1, "K^2=9 pipeline", "Spider web architecture", "3 hearts x 3 stages = 9 pipeline units. Measured on FPGA: 734 LUT, 329 DFF.", "");
  render_finding(g1, "Block-diagonal", "Zero cross-talk", "Gradients in channel i never touch channel j. Backprop decomposes the same way.", "");
  render_finding(g1, "490 split", "Compute + verify", "DEAD={D,E,b} channels do the work. ALIVE={K,L,G} channels verify for free.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Input value (0-12612599):", "dgpu-input", "e.g. 137", "Compute", "demo_gpu_run", "dgpu-result");
  render_p(sec2, "Decomposes x into 6 channels, squares each independently, reconstructs via CRT. Compares with direct x^2 mod N.");
  dom_append(dom_body(), sec2);
  let sec2b = make_section("800px") in
  render_h2(sec2b, "Batch Test");
  let btn = dom_create("button") in
  dom_text(btn, "Run 1000 Values");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "10px 24px");
  dom_style(btn, "borderRadius", "6px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "fontSize", "14px");
  dom_on(btn, "click", "demo_gpu_batch");
  dom_append(sec2b, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "dgpu-batch");
  dom_append(sec2b, br);
  dom_append(dom_body(), sec2b);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Compute vs CUDA");
  render_contrast_row(sec3, "Parallelism model", "CUDA: thread blocks + shared memory + barriers", "CRT: 6 independent channels. No sync needed.");
  render_contrast_row(sec3, "Cross-talk", "Shared memory races, warp divergence", "Zero. Channels are algebraically orthogonal.");
  render_contrast_row(sec3, "Scaling", "GPU hardware-dependent", "Ring-intrinsic. Works on any substrate.");
  render_contrast_row(sec3, "Verification", "Separate checksums needed", "490 split: 3 ALIVE channels verify 3 DEAD channels for free.");
  render_contrast_row(sec3, "Patent status", "NVIDIA CUDA patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   SCHEDULING -- dedicated demo page /demos/scheduling. CC0 kill B11.
   CRT-factored constraint scheduling. Coprime moduli = conflict-free slots.
   ================================================================ */

fn demo_sched_run() = (
  let ntasks = parse_int_from("#dsched-input") in
  let result_el = dom_query("#dsched-result") in
  let n = if ntasks < 1 then 1 else if ntasks > 100 then 100 else ntasks in
  let mods = [8, 9, 25, 49, 11, 13] in
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  /* Assign each task a unique CRT address: task i -> residues (i%8, i%9, i%25, i%49, i%11, i%13) */
  /* Check all pairs for slot collision */
  let collisions = [0] in
  let i = [0] in
  while i[0] < n do (
    let j = [0] in
    set(j, 0, i[0] + 1);
    while j[0] < n do (
      let slot_i = (i[0] % 8 * idem[0] + i[0] % 9 * idem[1] + i[0] % 25 * idem[2] + i[0] % 49 * idem[3] + i[0] % 11 * idem[4] + i[0] % 13 * idem[5]) % N_TRUE in
      let slot_j = (j[0] % 8 * idem[0] + j[0] % 9 * idem[1] + j[0] % 25 * idem[2] + j[0] % 49 * idem[3] + j[0] % 11 * idem[4] + j[0] % 13 * idem[5]) % N_TRUE in
      if slot_i == slot_j then set(collisions, 0, collisions[0] + 1) else 0;
      set(j, 0, j[0] + 1)
    );
    set(i, 0, i[0] + 1)
  );
  /* Show first 6 task assignments */
  let show_n = if n < 6 then n else 6 in
  let rows = [""] in
  let k = [0] in
  while k[0] < show_n do (
    let t = k[0] in
    let s = (t % 8 * idem[0] + t % 9 * idem[1] + t % 25 * idem[2] + t % 49 * idem[3] + t % 11 * idem[4] + t % 13 * idem[5]) % N_TRUE in
    set(rows, 0, rows[0] + "<tr><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${t}" + "</td><td style='padding:3px;color:#ff6666;font-size:12px'>" + "${t % 8}" + "</td><td style='padding:3px;color:#44ff88;font-size:12px'>" + "${t % 9}" + "</td><td style='padding:3px;color:#ff6666;font-size:12px'>" + "${t % 25}" + "</td><td style='padding:3px;color:#ff6666;font-size:12px'>" + "${t % 49}" + "</td><td style='padding:3px;color:#44ff88;font-size:12px'>" + "${t % 11}" + "</td><td style='padding:3px;color:#44ff88;font-size:12px'>" + "${t % 13}" + "</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${s}" + "</td></tr>");
    set(k, 0, k[0] + 1)
  );
  let pairs = n * (n + 0 - 1) / 2 in
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT SCHEDULING: " + "${n}" + " tasks</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Task</th><th style='text-align:left;padding:4px;color:#ff6666;font-size:11px'>D(8)</th><th style='text-align:left;padding:4px;color:#44ff88;font-size:11px'>K(9)</th><th style='text-align:left;padding:4px;color:#ff6666;font-size:11px'>E(25)</th><th style='text-align:left;padding:4px;color:#ff6666;font-size:11px'>b(49)</th><th style='text-align:left;padding:4px;color:#44ff88;font-size:11px'>L(11)</th><th style='text-align:left;padding:4px;color:#44ff88;font-size:11px'>G(13)</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Slot</th></tr>" + rows[0] + "</table><p style='color:#ffd700;margin:12px 0 4px'>CONFLICT CHECK</p><p style='color:#88ddaa;margin:4px 0'>Pairs checked: " + "${pairs}" + "</p><p style='color:" + (if collisions[0] == 0 then "#44ff88" else "#ff4444") + ";font-size:16px;margin:4px 0'>Collisions: " + "${collisions[0]}" + (if collisions[0] == 0 then " -- ZERO. CRT guarantees uniqueness up to 12,612,600 tasks." else "") + "</p><p style='color:#b0b0c0;margin:4px 0'>Search space: 8*9*25*49*11*13 = 12,612,600. Factored search vs brute-force = 115 ops vs 12.6M ops.</p></div>")
)

fn page_scheduling() = (
  dom_head_meta("description", "CRT Scheduling. Factored constraint scheduling via 6 coprime channels. Zero collisions guaranteed. 9512x speedup. CC0 patent kill: Gurobi/CPLEX.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Scheduling\",\"description\":\"6-channel factored constraint scheduling over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/scheduling\"}");
  let hero = make_hero("CRT Scheduling") in
  let eq = dom_create("div") in
  dom_text(eq, "B11: Gurobi/CPLEX patents. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "Replace constraint solvers with CRT factored search. A scheduling problem over N = 12,612,600 slots becomes 6 independent sub-problems over moduli {8, 9, 25, 49, 11, 13}. Total search: 8+9+25+49+11+13 = 115 checks instead of 12.6M. That is a 109,675x reduction in search space.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Factored Search", "Any integer in Z/12612600 is uniquely determined by its 6 residues. To find a slot satisfying 6 independent constraints (one per channel), solve each constraint in its own modular space. CRT reconstruction gives the unique solution. No backtracking. No heuristics. The 490 holographic split: DEAD channels {D,E,b} carry task data, ALIVE channels {K,L,G} carry scheduling metadata (priority, group, deadline).");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "109,675x", "Search space reduction", "115 checks (sum of moduli) vs 12,612,600 (brute force).", "");
  render_finding(g1, "Zero collisions", "CRT guarantee", "Distinct CRT tuples map to distinct slots. Algebraic, not probabilistic.", "");
  render_finding(g1, "490 split", "Data + metadata", "3 inner channels schedule tasks. 3 boundary channels track constraints.", "");
  render_finding(g1, "12.6M capacity", "One ring", "12,612,600 unique conflict-free slots from 6 small moduli.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Number of tasks (1-100):", "dsched-input", "e.g. 20", "Schedule", "demo_sched_run", "dsched-result");
  render_p(sec2, "Each task gets a unique CRT address. All pairs checked for collision. Red = DEAD (inner data). Green = ALIVE (boundary metadata).");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Scheduling vs Constraint Solvers");
  render_contrast_row(sec3, "Search space", "Gurobi/CPLEX: N = 12.6M brute force + heuristics", "CRT: 115 checks (sum of 6 moduli)");
  render_contrast_row(sec3, "Guarantee", "Best-effort, may not find optimum", "Algebraic: unique solution guaranteed by CRT");
  render_contrast_row(sec3, "Collisions", "Requires conflict resolution", "Zero. Coprime moduli = orthogonal channels.");
  render_contrast_row(sec3, "Scaling", "NP-hard in general", "Linear in number of moduli. Add primes to grow.");
  render_contrast_row(sec3, "Patent status", "Gurobi/CPLEX proprietary", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   DATABASE INDEX -- dedicated demo page /demos/db_index. CC0 kill B14.
   CRT = 6-dimensional perfect hash. O(1) insert/lookup.
   ================================================================ */

fn demo_db_run() = (
  let key = parse_int_from("#ddb-input") in
  let result_el = dom_query("#ddb-result") in
  let k = key % N_TRUE in
  let mods = [8, 9, 25, 49, 11, 13] in
  /* 6 bucket addresses */
  let bd = k % 8 in let bk = k % 9 in let be = k % 25 in let bb = k % 49 in let bl = k % 11 in let bg = k % 13 in
  /* Total buckets = sum of moduli = 115 */
  /* Collision in ALL 6 channels simultaneously = 1/12612600 probability (impossible for distinct keys) */
  /* Show bucket occupancy: if N keys uniformly distributed, each bucket[i] holds ~N/m_i keys */
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT INDEX LOOKUP: key = " + "${k}" + "</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Channel</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Modulus</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Bucket</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Type</th></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>D</td><td style='padding:3px;color:#888;font-size:12px'>8</td><td style='padding:3px;color:#ffd700;font-size:14px;font-weight:bold'>" + "${bd}" + "</td><td style='padding:3px;color:#ff6666;font-size:11px'>DEAD -- primary hash</td></tr><tr><td style='padding:3px;color:#44ff88;font-size:12px'>K</td><td style='padding:3px;color:#888;font-size:12px'>9</td><td style='padding:3px;color:#ffd700;font-size:14px;font-weight:bold'>" + "${bk}" + "</td><td style='padding:3px;color:#44ff88;font-size:11px'>ALIVE -- integrity tag</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>E</td><td style='padding:3px;color:#888;font-size:12px'>25</td><td style='padding:3px;color:#ffd700;font-size:14px;font-weight:bold'>" + "${be}" + "</td><td style='padding:3px;color:#ff6666;font-size:11px'>DEAD -- secondary hash</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>b</td><td style='padding:3px;color:#888;font-size:12px'>49</td><td style='padding:3px;color:#ffd700;font-size:14px;font-weight:bold'>" + "${bb}" + "</td><td style='padding:3px;color:#ff6666;font-size:11px'>DEAD -- range partition</td></tr><tr><td style='padding:3px;color:#44ff88;font-size:12px'>L</td><td style='padding:3px;color:#888;font-size:12px'>11</td><td style='padding:3px;color:#ffd700;font-size:14px;font-weight:bold'>" + "${bl}" + "</td><td style='padding:3px;color:#44ff88;font-size:11px'>ALIVE -- ECC check</td></tr><tr><td style='padding:3px;color:#44ff88;font-size:12px'>G</td><td style='padding:3px;color:#888;font-size:12px'>13</td><td style='padding:3px;color:#ffd700;font-size:14px;font-weight:bold'>" + "${bg}" + "</td><td style='padding:3px;color:#44ff88;font-size:11px'>ALIVE -- shard selector</td></tr></table><p style='color:#ffd700;margin:12px 0 4px'>INDEX PROPERTIES</p><p style='color:#88ddaa;margin:4px 0'>Total buckets: 8+9+25+49+11+13 = 115 (stored in memory)</p><p style='color:#88ddaa;margin:4px 0'>Unique keys: 12,612,600 (zero false positives for distinct keys)</p><p style='color:#88ddaa;margin:4px 0'>Lookup: 6 mod operations + 6 bucket reads = O(1)</p><p style='color:#b0b0c0;margin:4px 0'>490 split: {D,E,b} buckets store data pointers. {K,L,G} buckets verify integrity.</p></div>")
)

fn demo_db_batch() = (
  let result_el = dom_query("#ddb-batch") in
  let mods = [8, 9, 25, 49, 11, 13] in
  /* Insert 1000 keys, check for false collisions (same 6 residues for different keys) */
  let collisions = [0] in
  let tested = [0] in
  let i = [0] in
  while i[0] < 500 do (
    let k1 = (i[0] * 25717 + 67) % N_TRUE in
    let k2 = (i[0] * 25717 + 67 + 1) % N_TRUE in
    /* Two adjacent keys -- check if any channel collides */
    let same_d = if k1 % 8 == k2 % 8 then 1 else 0 in
    let same_k = if k1 % 9 == k2 % 9 then 1 else 0 in
    let same_e = if k1 % 25 == k2 % 25 then 1 else 0 in
    let same_b = if k1 % 49 == k2 % 49 then 1 else 0 in
    let same_l = if k1 % 11 == k2 % 11 then 1 else 0 in
    let same_g = if k1 % 13 == k2 % 13 then 1 else 0 in
    /* Full collision = all 6 match (impossible for k1 != k2 within the ring) */
    if same_d + same_k + same_e + same_b + same_l + same_g == 6 then
      set(collisions, 0, collisions[0] + 1) else 0;
    set(tested, 0, tested[0] + 1);
    set(i, 0, i[0] + 1)
  );
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>BATCH: 500 adjacent-key pairs</p><p style='color:" + (if collisions[0] == 0 then "#44ff88" else "#ff4444") + ";font-size:18px;margin:4px 0'>Full collisions: " + "${collisions[0]}" + "/500 -- " + (if collisions[0] == 0 then "ZERO. CRT = perfect hash." else "unexpected") + "</p><p style='color:#b0b0c0;margin:4px 0'>For distinct keys in Z/12612600, CRT guarantees at least one channel differs. 6-dimensional addressing eliminates false positives algebraically, not probabilistically.</p></div>")
)

fn page_db_index() = (
  dom_head_meta("description", "CRT Database Index. 6-dimensional perfect hash via CRT decomposition. O(1) lookup. Zero false positives. CC0 patent kill: Oracle/IBM.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Database Index\",\"description\":\"6-channel perfect hash indexing over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/db_index\"}");
  let hero = make_hero("CRT Database Index") in
  let eq = dom_create("div") in
  dom_text(eq, "B14: Oracle/IBM patents. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "Replace B-trees and hash tables with CRT decomposition. A key mod 6 coprime moduli gives 6 independent bucket addresses. Lookup = 6 mod operations. Insert = 6 bucket writes. Zero false positives for distinct keys within the ring. 115 total buckets address 12,612,600 unique keys.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Perfect Hash", "A key k in Z/12612600 maps to 6 residues: (k mod 8, k mod 9, k mod 25, k mod 49, k mod 11, k mod 13). By CRT, this 6-tuple uniquely determines k. Store data at the intersection of 6 buckets. Lookup: compute 6 remainders, read 6 buckets, intersect. The 490 holographic split: DEAD channels {D,E,b} hold data pointers (primary, secondary, range). ALIVE channels {K,L,G} hold integrity metadata (tag, ECC, shard).");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "O(1) lookup", "6 mod + 6 reads", "Constant time regardless of table size. No tree traversal.", "");
  render_finding(g1, "115 buckets", "Sum of moduli", "8+9+25+49+11+13 = 115 buckets address 12.6M unique keys.", "");
  render_finding(g1, "Perfect hash", "CRT bijectivity", "Distinct keys in ring always differ in at least one channel.", "");
  render_finding(g1, "490 split", "Data + integrity", "3 DEAD channels store data. 3 ALIVE channels verify correctness.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Key (0-12612599):", "ddb-input", "e.g. 42", "Lookup", "demo_db_run", "ddb-result");
  render_p(sec2, "Shows 6 bucket addresses for the key. Red = DEAD (data channels). Green = ALIVE (integrity channels).");
  dom_append(dom_body(), sec2);
  let sec2b = make_section("800px") in
  render_h2(sec2b, "Collision Test");
  let btn = dom_create("button") in
  dom_text(btn, "Test 500 Key Pairs");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "10px 24px");
  dom_style(btn, "borderRadius", "6px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "fontSize", "14px");
  dom_on(btn, "click", "demo_db_batch");
  dom_append(sec2b, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "ddb-batch");
  dom_append(sec2b, br);
  dom_append(dom_body(), sec2b);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Index vs B-Tree/Hash Table");
  render_contrast_row(sec3, "Lookup", "B-tree: O(log N). Hash: O(1) amortized", "CRT: O(1) worst-case. 6 mod ops.");
  render_contrast_row(sec3, "Collisions", "Hash tables: requires chaining/probing", "CRT: zero false positives within ring");
  render_contrast_row(sec3, "Storage", "B-tree: node overhead. Hash: load factor waste", "CRT: 115 buckets total. Minimal.");
  render_contrast_row(sec3, "Integrity", "Separate checksums needed", "490 split: 3 ALIVE channels verify for free.");
  render_contrast_row(sec3, "Patent status", "Oracle/IBM database patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   AUDIO SYNTHESIS -- dedicated demo page /demos/audio. CC0 kill B12.
   CRT eigenvalue frequencies. 6 channels = 6 harmonic components.
   ================================================================ */

fn demo_audio_run() = (
  let note = parse_int_from("#daudio-input") in
  let result_el = dom_query("#daudio-result") in
  let n = note % N_TRUE in
  let mods = [8, 9, 25, 49, 11, 13] in
  /* Decompose note into 6 channel residues */
  let rd = n % 8 in let rk = n % 9 in let re = n % 25 in let rb = n % 49 in let rl = n % 11 in let rg = n % 13 in
  /* Each residue = frequency component: base * (1 + r/m) gives overtone series */
  /* Fundamental = 110 Hz (A2). Each channel adds a harmonic at its own modular position. */
  /* Amplitude weights from ring structure: phi(m)/m = duty cycle */
  /* phi(8)/8=0.50, phi(9)/9=0.67, phi(25)/25=0.80, phi(49)/49=0.86, phi(11)/11=0.91, phi(13)/13=0.92 */
  /* 490 split: DEAD channels {D,E,b} = harmonic content, ALIVE {K,L,G} = envelope/timing */
  let freq_d = 110 * (8 + rd) / 8 in
  let freq_k = 110 * (9 + rk) / 9 in
  let freq_e = 110 * (25 + re) / 25 in
  let freq_b = 110 * (49 + rb) / 49 in
  let freq_l = 110 * (11 + rl) / 11 in
  let freq_g = 110 * (13 + rg) / 13 in
  /* Phase = 2*pi*r/m mapped to 360 degrees */
  let phase_d = rd * 360 / 8 in let phase_k = rk * 360 / 9 in
  let phase_e = re * 360 / 25 in let phase_b = rb * 360 / 49 in
  let phase_l = rl * 360 / 11 in let phase_g = rg * 360 / 13 in
  /* Amplitude = residue / modulus (percentage) */
  let amp_d = rd * 100 / 8 in let amp_k = rk * 100 / 9 in
  let amp_e = re * 100 / 25 in let amp_b = rb * 100 / 49 in
  let amp_l = rl * 100 / 11 in let amp_g = rg * 100 / 13 in
  /* Timbre signature: product of residues characterizes sound */
  let timbre = (rd + 1) * (rk + 1) * (re + 1) * (rb + 1) * (rl + 1) * (rg + 1) in
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT SYNTHESIS: note = " + "${n}" + "</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Channel</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Residue</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Freq (Hz)</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Phase</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Amp %</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Role</th></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>D(8)</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rd}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${freq_d}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${phase_d}" + "deg</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${amp_d}" + "%</td><td style='padding:3px;color:#ff6666;font-size:11px'>Fundamental</td></tr><tr><td style='padding:3px;color:#44ff88;font-size:12px'>K(9)</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rk}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${freq_k}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${phase_k}" + "deg</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${amp_k}" + "%</td><td style='padding:3px;color:#44ff88;font-size:11px'>Envelope</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>E(25)</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${re}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${freq_e}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${phase_e}" + "deg</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${amp_e}" + "%</td><td style='padding:3px;color:#ff6666;font-size:11px'>Overtone</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>b(49)</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rb}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${freq_b}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${phase_b}" + "deg</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${amp_b}" + "%</td><td style='padding:3px;color:#ff6666;font-size:11px'>Depth harm.</td></tr><tr><td style='padding:3px;color:#44ff88;font-size:12px'>L(11)</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rl}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${freq_l}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${phase_l}" + "deg</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${amp_l}" + "%</td><td style='padding:3px;color:#44ff88;font-size:11px'>Timing</td></tr><tr><td style='padding:3px;color:#44ff88;font-size:12px'>G(13)</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rg}" + "</td><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${freq_g}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${phase_g}" + "deg</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${amp_g}" + "%</td><td style='padding:3px;color:#44ff88;font-size:11px'>Gate pulse</td></tr></table><p style='color:#ffd700;margin:12px 0 4px'>TIMBRE SIGNATURE</p><p style='color:#88ddaa;margin:4px 0'>Product: " + "${timbre}" + " (unique timbre from 6-channel interaction)</p><p style='color:#b0b0c0;margin:4px 0'>490 split: DEAD={D,E,b} channels carry harmonic content. ALIVE={K,L,G} channels shape envelope, timing, gating.</p><p style='color:#b0b0c0;margin:4px 0'>Total unique timbres: 8*9*25*49*11*13 = 12,612,600 from 6 independent parameters.</p></div>")
)

fn demo_audio_batch() = (
  let result_el = dom_query("#daudio-batch") in
  let mods = [8, 9, 25, 49, 11, 13] in
  /* Test: verify all notes in range produce valid frequency decompositions */
  let valid = [0] in
  let unique_timbres = [0] in
  let last_timbre = [0] in
  let i = [0] in
  while i[0] < 420 do (
    let n = i[0] * 30030 in /* sample at lambda intervals */
    let rd = n % 8 in let rk = n % 9 in let re = n % 25 in let rb = n % 49 in let rl = n % 11 in let rg = n % 13 in
    let timbre = (rd + 1) * (rk + 1) * (re + 1) * (rb + 1) * (rl + 1) * (rg + 1) in
    if timbre != last_timbre[0] then (
      set(unique_timbres, 0, unique_timbres[0] + 1);
      set(last_timbre, 0, timbre)
    ) else 0;
    /* All frequencies must be positive (base=110, residue>=0, modulus>0) */
    let freq_d = 110 * (8 + rd) / 8 in
    if freq_d > 0 then set(valid, 0, valid[0] + 1) else 0;
    set(i, 0, i[0] + 1)
  );
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>BATCH: 420 notes (lambda-spaced)</p><p style='color:" + (if valid[0] == 420 then "#44ff88" else "#ff4444") + ";font-size:18px;margin:4px 0'>" + "${valid[0]}" + "/420 valid frequency decompositions</p><p style='color:#88ddaa;margin:4px 0'>Unique timbres sampled: " + "${unique_timbres[0]}" + "</p><p style='color:#b0b0c0;margin:4px 0'>lambda=420 intervals sample the full ring orbit. Each note = 6 independent oscillators shaped by CRT residues. The ring encodes 12,612,600 distinct timbres in 115 parameters.</p></div>")
)

fn page_audio() = (
