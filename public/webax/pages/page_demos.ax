/* ================================================================
   CRT CLUSTERING -- dedicated demo page /demos/cluster. CC0 kill F41.
   Kingdom = O(1) cluster assignment. No iteration. No hyperparameters.
   ================================================================ */

fn cl_gcd(a, b) = if b == 0 then a else cl_gcd(b, a % b)

/* Kingdom index: 0=void, 1=sigma, 2=D, 3=K, 4=E, 5=b, 6=L, 7=GATE, 8=mixed */
fn cl_kingdom(n) = (
  let r = n % N_TRUE in
  if r == 0 then 0
  else (
    let g = cl_gcd(r, N_TRUE) in
    if g == 1 then 1
    else (
      /* Count which primes divide g */
      let d2 = if g % 2 == 0 then 1 else 0 in
      let d3 = if g % 3 == 0 then 1 else 0 in
      let d5 = if g % 5 == 0 then 1 else 0 in
      let d7 = if g % 7 == 0 then 1 else 0 in
      let d11 = if g % 11 == 0 then 1 else 0 in
      let d13 = if g % 13 == 0 then 1 else 0 in
      let cnt = d2 + d3 + d5 + d7 + d11 + d13 in
      if cnt > 1 then 8
      else if d2 == 1 then 2
      else if d3 == 1 then 3
      else if d5 == 1 then 4
      else if d7 == 1 then 5
      else if d11 == 1 then 6
      else 7
    )
  )
)

fn cl_name(k) = (
  if k == 0 then "void" else if k == 1 then "sigma"
  else if k == 2 then "D (bridge)" else if k == 3 then "K (closure)"
  else if k == 4 then "E (observer)" else if k == 5 then "b (depth)"
  else if k == 6 then "L (transcend)" else if k == 7 then "GATE (boundary)"
  else "mixed"
)

fn cl_color(k) = (
  if k == 0 then "#666666" else if k == 1 then "#ffdd44"
  else if k == 2 then "#4488ff" else if k == 3 then "#33dd55"
  else if k == 4 then "#ff9900" else if k == 5 then "#ff4040"
  else if k == 6 then "#aa44ff" else if k == 7 then "#ff4466"
  else "#888888"
)

fn demo_cluster_run() = (
  let n = parse_int_from("#dclust-input") in
  let result_el = dom_query("#dclust-result") in
  let sz = if n < 10 then 100 else (if n > 1000 then 1000 else n) in
  /* Count per kingdom */
  let counts = alloc(9) in
  mut j = 0;
  while j < 9 do (set(counts, j, 0); mut j = j + 1);
  mut i = 0;
  while i < sz do (
    let val = (i * 7919 + 104729 + i * i * 13) % N_TRUE in
    let k = cl_kingdom(val) in
    set(counts, k, counts[k] + 1);
    mut i = i + 1
  );
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'>";
  mut html = html + "<p style='color:#ffd700;margin:0 0 8px'>CRT CLUSTERING: N = " + "${sz}" + " points. O(1) per point.</p>";
  /* Kingdom distribution */
  mut html = html + "<table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Kingdom</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Count</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>%</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Bar</th></tr>";
  mut k = 0;
  while k < 9 do (
    let c = counts[k] in
    let pct = (c * 100) / sz in
    let bar_w = (c * 300) / sz in
    let color = cl_color(k) in
    let name = cl_name(k) in
    mut html = html + "<tr><td style='padding:3px;color:" + color + ";font-size:12px'>" + name + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${c}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${pct}" + "%</td><td style='padding:3px'><div style='background:" + color + ";height:12px;width:" + "${bar_w}" + "px;border-radius:2px'></div></td></tr>";
    mut k = k + 1
  );
  mut html = html + "</table>";
  /* Show first 20 assignments */
  let show_n = if sz < 20 then sz else 20 in
  mut html = html + "<p style='color:#ffd700;margin:12px 0 4px;font-size:12px'>First " + "${show_n}" + " assignments:</p>";
  mut html = html + "<div style='display:flex;flex-wrap:wrap;gap:4px'>";
  mut i = 0;
  while i < show_n do (
    let val = (i * 7919 + 104729 + i * i * 13) % N_TRUE in
    let k = cl_kingdom(val) in
    let color = cl_color(k) in
    mut html = html + "<span style='background:" + color + "22;border:1px solid " + color + ";border-radius:4px;padding:2px 6px;font-size:10px;color:" + color + "'>" + "${val % 1000}" + "</span>";
    mut i = i + 1
  );
  mut html = html + "</div>";
  /* K-means comparison */
  let kmeans_ops = sz * 7 * 20 in
  mut html = html + "<div style='margin:12px 0;padding:8px;border-top:1px solid #333'>";
  mut html = html + "<p style='color:#ffd700;margin:4px 0'>OPERATION COUNT</p>";
  mut html = html + "<p style='color:#ff6666;margin:2px 0;font-size:13px'>K-means (K=7, 20 iterations): ~" + "${kmeans_ops}" + " distance computations</p>";
  mut html = html + "<p style='color:#88ddaa;margin:2px 0;font-size:13px'>CRT kingdom: " + "${sz}" + " GCD operations (O(1) each, zero iterations)</p>";
  mut html = html + "<p style='color:#b0b0c0;margin:2px 0;font-size:13px'>Speedup: " + "${kmeans_ops / sz}" + "x fewer operations</p>";
  mut html = html + "</div></div>";
  dom_inner(result_el, html)
)

fn page_cluster() = (
  dom_head_meta("description", "CRT Clustering. Kingdom = O(1) cluster assignment via GCD. No iteration. No hyperparameters. CC0 patent kill: AWS SageMaker, Google AutoML.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Clustering\",\"description\":\"O(1) kingdom-based clustering over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/cluster\"}");
  let hero = make_hero("CRT Clustering") in
  let eq = dom_create("div") in
  dom_text(eq, "F41: AWS/Google ML. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "Every number in Z/12612600 has a KINGDOM: which axiom prime divides it. gcd(n, N) reveals it in O(1). No iteration. No hyperparameters. No training data. The ring decides.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "Kingdom Classification (PROVED)", "For any n in Z/12612600, gcd(n, N) reveals which axiom primes divide n. This defines 9 clusters: void (gcd=N), sigma (gcd=1), 6 pure kingdoms (one prime divides), and mixed (multiple primes divide). Assignment is O(1): one GCD + one factorization test. No iteration. Deterministic.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "9 clusters", "Algebraically forced", "void, sigma, D, K, E, b, L, GATE, mixed. Not chosen -- discovered.", "");
  render_finding(g1, "O(1)", "One GCD operation", "K-means: O(NKI) for N points, K clusters, I iterations. CRT: O(N).", "");
  render_finding(g1, "No hyperparameters", "K emerges from the ring", "K-means: choose K. DBSCAN: choose epsilon, minPts. CRT: the ring decides.", "");
  render_finding(g1, "Deterministic", "Same input = same cluster", "K-means depends on initialization. CRT: unique, deterministic, algebraic.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Number of points (10-1000):", "dclust-input", "e.g. 100", "Cluster", "demo_cluster_run", "dclust-result");
  render_p(sec2, "Generates random data points in Z/12612600 and classifies each by kingdom. Shows distribution + first 20 assignments.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Clustering vs K-Means");
  render_contrast_row(sec3, "Complexity", "K-means: O(NKI), typically 20+ iterations", "CRT kingdom: O(N). One pass. Done.");
  render_contrast_row(sec3, "Cluster count", "K-means: choose K (hyperparameter)", "CRT: 9 kingdoms emerge from ring structure");
  render_contrast_row(sec3, "Initialization", "K-means: random centroids (non-deterministic)", "CRT: deterministic. GCD is unique.");
  render_contrast_row(sec3, "Stability", "K-means: different runs = different clusters", "CRT: same input = same kingdom. Always.");
  render_contrast_row(sec3, "Interpretability", "K-means: centroid vectors (opaque)", "CRT: kingdoms = axiom primes (algebraic meaning)");
  render_contrast_row(sec3, "Patent status", "AWS SageMaker, Google AutoML", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)
