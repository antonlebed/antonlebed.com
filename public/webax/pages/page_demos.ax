  demo_row(tbl, "C17", "Timetabling", "OR software", "PLANNED", "/demos");
  demo_row(tbl, "C18", "Key Exchange", "RSA/Certicom", "LIVE", "/demos/key_exchange");
  demo_row(tbl, "C19", "Fountain Codes", "Qualcomm Raptor", "ABSORBED", "/demos/ecc_live");
  demo_row(tbl, "C20", "Spread Spectrum", "Qualcomm CDMA", "ABSORBED", "/demos/ecc_live");

  dom_append(sec, tbl);
  dom_append(dom_body(), sec);

  /* === ROADMAP === */
  let sec3 = make_section("850px") in
  render_h2(sec3, "The Path");
  render_p(sec3, "Phase 5: every ABSORBED kill gets its own dedicated demo page. Each demo = interactive widget proving the CC0 claim with working code, not theory. PLANNED kills need new .ax capabilities (audio imports for B12, constraint solver for C17).");
  render_p(sec3, "LIVE demos already prove their claims interactively. The mesh demo routes real CRT packets. The ECC demo corrupts and heals in real time. The ARC solver runs 32 primitives on canvas grids. ABSORBED demos work but share pages with theory content.");
  render_theorem(sec3, "The Goal", "20 kills = 20 dedicated demo pages. 1:1 correspondence. Each URL = /demos/[kill_name]. Each page = one interactive proof that CRT decomposition makes patents obsolete in that domain. All CC0. All irrevocable.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   CRT HASH — dedicated demo page /demos/hash. CC0 kill A7.
   6-channel Feistel. 8 rounds. Pure ring arithmetic.
   ================================================================ */

fn demo_crt_hash(n) = (
  let x0 = n * 137 + 1 in
  mut ch0 = x0 % 8;
  mut ch1 = x0 % 9;
  mut ch2 = x0 % 25;
  mut ch3 = x0 % 49;
  mut ch4 = x0 % 11;
  mut ch5 = x0 % 13;
  mut rd = 0;
  while rd < 8 do (
    let a0 = (ch0 * 3 + ch1 + ch4 * 2 + rd + 1) % 8 in
    let a1 = (ch1 * 2 + ch2 + ch0 * 2 + rd + 1) % 9 in
    let a2 = (ch2 * 2 + ch3 + ch1 * 2 + rd + 1) % 25 in
    let a3 = (ch3 * 3 + ch4 + ch2 * 2 + rd + 1) % 49 in
    let a4 = (ch4 * 2 + ch0 + ch3 * 2 + rd + 1) % 11 in
    let a5 = (ch5 * 2 + ch0 + ch4 * 2 + rd + 1) % 13 in
    let v = a0 * 11036025 + a1 * 1401400 + a2 * 9585576 + a3 * 8494200 + a4 * 3439800 + a5 * 3880800 in
    let x1 = v * 137 + rd * 41 + n in
    mut ch0 = x1 % 8;
    mut ch1 = x1 % 9;
    mut ch2 = x1 % 25;
    mut ch3 = x1 % 49;
    mut ch4 = x1 % 11;
    mut ch5 = x1 % 13;
    mut rd = rd + 1
  );
  ch0 * 11036025 + ch1 * 1401400 + ch2 * 9585576 + ch3 * 8494200 + ch4 * 3439800 + ch5 * 3880800
)

fn demo_hash_run() = (
  let n = parse_int_from("#dhash-input") in
  let result_el = dom_query("#dhash-result") in
  let h = demo_crt_hash(n) in
  let hd = h % 8 in let hk = h % 9 in let he = h % 25 in let hb = h % 49 in let hl = h % 11 in let hg = h % 13 in
  let h2 = demo_crt_hash(n + 1) in
  let h2d = h2 % 8 in let h2k = h2 % 9 in let h2e = h2 % 25 in let h2b = h2 % 49 in let h2l = h2 % 11 in let h2g = h2 % 13 in
  let diff = (if hd == h2d then 0 else 1) + (if hk == h2k then 0 else 1) + (if he == h2e then 0 else 1) + (if hb == h2b then 0 else 1) + (if hl == h2l then 0 else 1) + (if hg == h2g then 0 else 1) in
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT HASH (8 rounds, 6-channel Feistel)</p><p style='color:#88ddaa;margin:4px 0'><b>hash(" + "${n}" + ") = " + "${h}" + "</b></p><p style='color:#b0b0c0;margin:4px 0'>CRT = (" + "${hd}" + ", " + "${hk}" + ", " + "${he}" + ", " + "${hb}" + ", " + "${hl}" + ", " + "${hg}" + ")</p><p style='color:#ffd700;margin:12px 0 4px'>AVALANCHE TEST</p><p style='color:#88ddaa;margin:4px 0'>hash(" + "${n + 1}" + ") = " + "${h2}" + "</p><p style='color:#b0b0c0;margin:4px 0'>CRT = (" + "${h2d}" + ", " + "${h2k}" + ", " + "${h2e}" + ", " + "${h2b}" + ", " + "${h2l}" + ", " + "${h2g}" + ")</p><p style='color:" + (if diff > 4 then "#44ff88" else "#ff8844") + ";margin:4px 0'>Channels changed: <b>" + "${diff}" + "/6</b>" + (if diff > 4 then " -- good diffusion" else "") + "</p></div>")
)

fn demo_hash_batch() = (
  let result_el = dom_query("#dhash-batch-result") in
  mut total_diff = 0;
  mut perfect = 0;
  mut i = 0;
  while i < 100 do (
    let h1 = demo_crt_hash(i) in
    let h2 = demo_crt_hash(i + 1) in
    let d = (if h1 % 8 == h2 % 8 then 0 else 1) + (if h1 % 9 == h2 % 9 then 0 else 1) + (if h1 % 25 == h2 % 25 then 0 else 1) + (if h1 % 49 == h2 % 49 then 0 else 1) + (if h1 % 11 == h2 % 11 then 0 else 1) + (if h1 % 13 == h2 % 13 then 0 else 1) in
    mut total_diff = total_diff + d;
    if d == 6 then mut perfect = perfect + 1 else 0;
    mut i = i + 1
  );
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>BATCH AVALANCHE: 100 consecutive pairs</p><p style='color:#88ddaa;margin:4px 0'>Average channels changed: <b>" + "${total_diff / 100}" + "." + "${(total_diff * 10 / 100) % 10}" + "/6</b></p><p style='color:#b0b0c0;margin:4px 0'>Perfect avalanche (6/6): <b>" + "${perfect}" + "/100</b></p></div>")
)

fn page_hash() = (
  dom_head_meta("description", "CRT Hash Function. 6-channel Feistel network over Z/12612600. 8 rounds. Pure ring arithmetic. CC0 patent kill: crypto hash patents.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Hash Function\",\"description\":\"6-channel Feistel hash over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/hash\"}");
  let hero = make_hero("CRT Hash") in
  let eq = dom_create("div") in
  dom_text(eq, "A7: Crypto patents. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "CRT decomposition IS a hash function. Decompose into 6 independent channels, mix per-channel with primitive roots, fold through CRT reconstruction. 8 rounds. Pure ring arithmetic. No XOR, no bit shifts, no lookup tables.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Hash Principle", "Every integer has a UNIQUE 6-dimensional CRT address in Z/8 x Z/9 x Z/25 x Z/49 x Z/11 x Z/13. Per-channel mixing with generators {3,2,2,3,2,2} creates nonlinearity. Cross-channel addition creates diffusion. CRT reconstruction folds channels back. After 8 rounds, no channel remembers the input alone.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "6 parallel lanes", "CRT decomposition", "6 independent mixing networks. Each uses a different primitive root.", "");
  render_finding(g1, "Cross diffusion", "Neighbor injection", "Each channel absorbs 2 neighbors per round. After 3 rounds, every channel influenced by every other.", "");
  render_finding(g1, "CRT fold", "Bijection breaker", "Reconstruct to integer, multiply by 137 (ADDRESS), re-decompose.", "");
  render_finding(g1, "8 rounds", "Full diffusion", "By round 8, each output depends on every input. Natural from algebraic independence.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Hash an integer (0-12612599):", "dhash-input", "e.g. 42", "Hash", "demo_hash_run", "dhash-result");
  render_p(sec2, "Try: 42 vs 43 (avalanche), 137 (ADDRESS), 1576576 (OMEGA), 0 (void).");
  dom_append(dom_body(), sec2);
  let sec3h = make_section("800px") in
  render_h2(sec3h, "Batch Avalanche Test");
  render_p(sec3h, "Hash 100 consecutive pairs and measure average channel diffusion.");
  let btn = dom_create("button") in
  dom_text(btn, "Run Batch (100 pairs)");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "8px 16px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "borderRadius", "4px");
  dom_on(btn, "click", "demo_hash_batch");
  dom_append(sec3h, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "dhash-batch-result");
  dom_append(sec3h, br);
  dom_append(dom_body(), sec3h);
  let sec5 = make_section("800px") in
  render_h2(sec5, "CRT Hash vs Traditional");
  render_contrast_row(sec5, "Structure", "SHA-256: 64 rounds of bit manipulation", "CRT: 8 rounds of ring arithmetic over 6 channels");
  render_contrast_row(sec5, "Mixing", "XOR + rotate + shift", "Primitive root multiplication");
  render_contrast_row(sec5, "Output space", "2^256 (arbitrary)", "12,612,600 (structural)");
  render_contrast_row(sec5, "Patent status", "Various patents/NIST process", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec5)
)

/* ================================================================
   CRT CONSENSUS — dedicated demo page /demos/consensus. CC0 kill B10.
   6-channel independent voting. O(n) messages.
   ================================================================ */

fn demo_consensus_run() = (
  let n_nodes = parse_int_from("#dcon-nodes") in
  let result_el = dom_query("#dcon-result") in
  let value = parse_int_from("#dcon-value") in
  let n_byz = parse_int_from("#dcon-byz") in
  if n_nodes < 5 then dom_inner(result_el, "<p style='color:#ff6666'>Need at least 5 nodes.</p>")
  else if n_byz >= n_nodes then dom_inner(result_el, "<p style='color:#ff6666'>Byzantine count must be less than node count.</p>")
  else (
    let vtf = value in
    let mods = [8, 9, 25, 49, 11, 13] in
    let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
    let tv = [vtf % 8, vtf % 9, vtf % 25, vtf % 49, vtf % 11, vtf % 13] in
    mut honest0 = 0; mut honest1 = 0; mut honest2 = 0; mut honest3 = 0; mut honest4 = 0; mut honest5 = 0;
    mut i = 0;
    while i < n_nodes do (
      let is_byz = if i < n_byz then 1 else 0 in
      mut ch = 0;
      while ch < 6 do (
        let m = mods[ch] in
        let vote = if is_byz == 1 then rand(m) else tv[ch] in
        let honest_vote = if vote == tv[ch] then 1 else 0 in
        if ch == 0 then mut honest0 = honest0 + honest_vote
        else if ch == 1 then mut honest1 = honest1 + honest_vote
        else if ch == 2 then mut honest2 = honest2 + honest_vote
        else if ch == 3 then mut honest3 = honest3 + honest_vote
        else if ch == 4 then mut honest4 = honest4 + honest_vote
        else mut honest5 = honest5 + honest_vote;
        mut ch = ch + 1
      );
      mut i = i + 1
    );
    let half = n_nodes / 2 in
    let w0 = if honest0 > half then tv[0] else 999 in
    let w1 = if honest1 > half then tv[1] else 999 in
    let w2 = if honest2 > half then tv[2] else 999 in
    let w3 = if honest3 > half then tv[3] else 999 in
    let w4 = if honest4 > half then tv[4] else 999 in
    let w5 = if honest5 > half then tv[5] else 999 in
    let ok0 = if w0 == 999 then 0 else 1 in
    let ok1 = if w1 == 999 then 0 else 1 in
    let ok2 = if w2 == 999 then 0 else 1 in
    let ok3 = if w3 == 999 then 0 else 1 in
    let ok4 = if w4 == 999 then 0 else 1 in
    let ok5 = if w5 == 999 then 0 else 1 in
    let channels_ok = ok0 + ok1 + ok2 + ok3 + ok4 + ok5 in
    let recon = if channels_ok == 6 then
      (idem[0] * w0 + idem[1] * w1 + idem[2] * w2 + idem[3] * w3 + idem[4] * w4 + idem[5] * w5) % 12612600
    else 0 in
    let correct = if channels_ok == 6 then (if recon == vtf then 1 else 0) else 0 in
    let byz_pct = (n_byz * 100) / n_nodes in
    dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT CONSENSUS: " + "${n_nodes}" + " nodes, " + "${n_byz}" + " Byzantine (" + "${byz_pct}" + "%)</p><p style='margin:4px 0;color:#b0b0c0'>True value: " + "${vtf}" + " = (" + "${tv[0]}" + "," + "${tv[1]}" + "," + "${tv[2]}" + "," + "${tv[3]}" + "," + "${tv[4]}" + "," + "${tv[5]}" + ")</p><p style='margin:4px 0;color:#b0b0c0'>Channel majorities: D=" + "${honest0}" + "/" + "${n_nodes}" + " K=" + "${honest1}" + "/" + "${n_nodes}" + " E=" + "${honest2}" + "/" + "${n_nodes}" + " b=" + "${honest3}" + "/" + "${n_nodes}" + " L=" + "${honest4}" + "/" + "${n_nodes}" + " G=" + "${honest5}" + "/" + "${n_nodes}" + "</p><p style='margin:4px 0;color:" + (if correct == 1 then "#44ff88" else "#ff4444") + ";font-size:16px'>" + (if correct == 1 then "CONSENSUS CORRECT" else "CONSENSUS FAILED") + " (" + "${channels_ok}" + "/6 channels held)</p></div>")
  )
)

fn demo_consensus_sweep() = (
  let result_el = dom_query("#dcon-sweep-result") in
  let n = 51 in let value = 42 in
  let tv = [value % 8, value % 9, value % 25, value % 49, value % 11, value % 13] in
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>STRESS TEST: 51 nodes, value=42, sweeping Byzantine 0-25</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Byz</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>%</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>OK</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Result</th></tr>";
  mut byz = 0;
  while byz < 26 do (
    mut h0 = 0; mut h1 = 0; mut h2 = 0; mut h3 = 0; mut h4 = 0; mut h5 = 0;
    mut i = 0;
    while i < n do (
      let is_byz = if i < byz then 1 else 0 in
      mut ch = 0;
      while ch < 6 do (
        let mods = [8, 9, 25, 49, 11, 13] in
        let m = mods[ch] in
        let vote = if is_byz == 1 then rand(m) else tv[ch] in
        let ok = if vote == tv[ch] then 1 else 0 in
        if ch == 0 then mut h0 = h0 + ok
        else if ch == 1 then mut h1 = h1 + ok
        else if ch == 2 then mut h2 = h2 + ok
        else if ch == 3 then mut h3 = h3 + ok
        else if ch == 4 then mut h4 = h4 + ok
        else mut h5 = h5 + ok;
        mut ch = ch + 1
      );
      mut i = i + 1
    );
    let half = n / 2 in
    let ok = (if h0 > half then 1 else 0) + (if h1 > half then 1 else 0) + (if h2 > half then 1 else 0) + (if h3 > half then 1 else 0) + (if h4 > half then 1 else 0) + (if h5 > half then 1 else 0) in
    let pct = (byz * 100) / n in
    let color = if ok == 6 then "#44ff88" else "#ff4444" in
    mut html = html + "<tr><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${byz}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${pct}" + "%</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${ok}" + "/6</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + (if ok == 6 then "CORRECT" else "FAILED") + "</td></tr>";
    mut byz = byz + 1
  );
  dom_inner(result_el, html + "</table></div>")
)

