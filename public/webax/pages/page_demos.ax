  dom_head_meta("description", "CRT PID Controller. 6 independent control channels over Z/12612600. CC0 patent kill: Siemens/ABB.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT PID Controller\",\"description\":\"6-channel multi-scale PID control over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/pid\"}");
