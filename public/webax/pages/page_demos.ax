  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Multi-Scale Control", "A setpoint in Z/12612600 has 6 CRT residues. Each channel runs independent proportional control. Channel D (mod 8) converges in 3 steps. Channel b (mod 49) converges in 6 steps. The controller naturally separates fast/coarse from slow/fine -- no manual tuning.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "6 scales", "CRT decomposition", "D=coarse(8), K=medium(9), E=fine(25), b=depth(49), L=slow(11), G=gate(13).", "");
  render_finding(g1, "Independence", "Algebraic firewall", "Error in one channel cannot propagate to others.", "");
  render_finding(g1, "Auto-tuning", "Modulus = bandwidth", "Channel bandwidth = 1/modulus. No PID tuning needed.", "");
  render_finding(g1, "Convergence", "Per-channel guaranteed", "Each channel converges in O(log(modulus)) steps.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Setpoint (0-12612599):", "dpid-input", "e.g. 42", "Run Controller", "demo_pid_run", "dpid-result");
  render_p(sec2, "Watch 6 channels converge independently. D(mod 8) arrives first, b(mod 49) last.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT PID vs Traditional");
  render_contrast_row(sec3, "Tuning", "PID: Kp, Ki, Kd manual tuning", "CRT: channel modulus IS the bandwidth");
  render_contrast_row(sec3, "Coupling", "Coupled: error in one axis affects all", "Independent: 6 algebraic firewalls");
  render_contrast_row(sec3, "Multi-scale", "Cascaded loops (complex)", "CRT channels = natural scale separation");
  render_contrast_row(sec3, "Convergence", "Heuristic (Ziegler-Nichols)", "Provable: O(log m) per channel");
  render_contrast_row(sec3, "Patent status", "Siemens/ABB process patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   CRT STEGANOGRAPHY — dedicated demo page /demos/stego. CC0 kill C16.
   Hide data in CRT channel residues.
   ================================================================ */

fn demo_stego_encode(carrier, secret) = (
  /* Hide secret in D-channel (low 3 bits of CRT) */
  let cd = carrier % 8 in let ck = carrier % 9 in let ce = carrier % 25 in
  let cb = carrier % 49 in let cl = carrier % 11 in let cg = carrier % 13 in
  let sd = secret % 8 in
  /* Replace D-channel with secret, keep others intact */
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  (sd * idem[0] + ck * idem[1] + ce * idem[2] + cb * idem[3] + cl * idem[4] + cg * idem[5]) % 12612600
)

fn demo_stego_run() = (
  let carrier = parse_int_from("#dsteg-carrier") in
  let secret = parse_int_from("#dsteg-secret") in
  let result_el = dom_query("#dsteg-result") in
  let c = carrier % 12612600 in
  let s = secret % 256 in
  let cd = c % 8 in let ck = c % 9 in let ce = c % 25 in
  let cb = c % 49 in let cl = c % 11 in let cg = c % 13 in
  /* Encode: hide 3 bits in D, 4 bits in K (total 7 bits = one ASCII-ish byte) */
  let s_lo = s % 8 in let s_hi = s / 8 in
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  let stego = (s_lo * idem[0] + (s_hi % 9) * idem[1] + ce * idem[2] + cb * idem[3] + cl * idem[4] + cg * idem[5]) % 12612600 in
  let st_d = stego % 8 in let st_k = stego % 9 in let st_e = stego % 25 in
  let st_b = stego % 49 in let st_l = stego % 11 in let st_g = stego % 13 in
  /* Distortion: how many channels changed? */
  let changed = (if cd == st_d then 0 else 1) + (if ck == st_k then 0 else 1) + (if ce == st_e then 0 else 1) + (if cb == st_b then 0 else 1) + (if cl == st_l then 0 else 1) + (if cg == st_g then 0 else 1) in
  /* Extract */
  let extracted = st_d + (st_k * 8) in
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT STEGANOGRAPHY</p><p style='color:#b0b0c0;margin:4px 0'>Carrier: " + "${c}" + " = (" + "${cd}" + "," + "${ck}" + "," + "${ce}" + "," + "${cb}" + "," + "${cl}" + "," + "${cg}" + ")</p><p style='color:#b0b0c0;margin:4px 0'>Secret byte: " + "${s}" + " (lo=" + "${s_lo}" + " hi=" + "${s_hi % 9}" + ")</p><p style='color:#88ddaa;margin:4px 0'>Stego: " + "${stego}" + " = (" + "${st_d}" + "," + "${st_k}" + "," + "${st_e}" + "," + "${st_b}" + "," + "${st_l}" + "," + "${st_g}" + ")</p><p style='color:" + (if changed < 3 then "#44ff88" else "#ff8844") + ";margin:4px 0'>Channels modified: " + "${changed}" + "/6 (E,b,L,G untouched)</p><p style='color:#ffd700;margin:12px 0 4px'>EXTRACTION</p><p style='color:#88ddaa;margin:4px 0'>Extracted: D + K*8 = " + "${extracted}" + (if extracted == s then " CORRECT" else " MISMATCH") + "</p></div>")
)

fn page_stego() = (
  dom_head_meta("description", "CRT Steganography. Hide data in CRT channel residues. Algebraic invisibility. CC0 patent kill: DRM patents.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Steganography\",\"description\":\"Hide data in CRT channel residues over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/stego\"}");
