  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "CRT decomposes one big number into 6 small channels. Small channels = fewer bits per symbol. Zero channels = free compression. The ring's structure IS the codec.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Compression Principle", "Any value in Z/12612600 decomposes into (D,K,E,b,L,G) with ranges 8,9,25,49,11,13. Total bits: 3+4+5+6+4+4 = 26 bits to address the full ring. But channels with value 0 need 0 bits -- they are structurally silent. The void compresses for free.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Channel entropy", "Small ranges", "Each channel uses 3-6 bits. Total 26 bits addresses 12.6M values.", "");
  render_finding(g1, "Zero sparsity", "Structural silence", "1/8 of all values have D=0. 1/9 have K=0. Zeros = free compression.", "");
  render_finding(g1, "Independence", "Parallel decode", "Each channel decodes independently. No serial dependency chain.", "");
  render_finding(g1, "Reconstruction", "CRT bijection", "6 small values -> unique integer. Lossless by theorem.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Value (0-12612599):", "dcomp-input", "e.g. 42", "Analyze", "demo_compress_run", "dcomp-result");
  render_p(sec2, "Try: 0 (all zeros), 42 (ANSWER), 1576576 (OMEGA), 970200 (DEEP ring).");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "Channel Zero Distribution");
  render_p(sec3, "Sample 10000 values and count zero channels. CRT predicts exact rates.");
  let btn = dom_create("button") in
  dom_text(btn, "Run Distribution (10000 samples)");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "8px 16px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "borderRadius", "4px");
  dom_on(btn, "click", "demo_compress_batch");
  dom_append(sec3, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "dcomp-batch-result");
  dom_append(sec3, br);
  dom_append(dom_body(), sec3);
  let sec4 = make_section("800px") in
  render_h2(sec4, "CRT Compression vs Traditional");
  render_contrast_row(sec4, "Core idea", "DCT/wavelet transforms", "CRT channel decomposition");
  render_contrast_row(sec4, "Lossy?", "H.264: lossy quantization", "CRT: lossless by theorem (bijection)");
  render_contrast_row(sec4, "Parallelism", "Sequential entropy coding", "6 channels decode independently");
  render_contrast_row(sec4, "Sparsity", "Engineered (thresholding)", "Structural (zero channels = free)");
  render_contrast_row(sec4, "Patent status", "H.264/H.265 patent pools", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec4)
)

/* ================================================================
   CRT PID -- dedicated demo page /demos/pid. CC0 kill B15.
   6-channel multi-scale control loop.
   ================================================================ */

fn demo_pid_step(err, prev_err, integral, dt) = (
  /* Per-channel PID gains derived from moduli */
  let kp = 100 in let ki = 5 in let kd = 30 in
  let new_int = integral + err * dt in
  let deriv = (err + 12612600 - prev_err) in
  let p_term = kp * err in
  let i_term = ki * new_int in
  let d_term = kd * deriv in
  (p_term + i_term + d_term) % N_TRUE
)

fn demo_pid_run() = (
  let setpoint = parse_int_from("#dpid-input") in
  let result_el = dom_query("#dpid-result") in
  let sp = setpoint % N_TRUE in
  let sp_d = sp % 8 in let sp_k = sp % 9 in let sp_e = sp % 25 in
  let sp_b = sp % 49 in let sp_l = sp % 11 in let sp_g = sp % 13 in
  /* Simulate: start at 0, chase setpoint per-channel */
  mut pos_d = 0; mut pos_k = 0; mut pos_e = 0; mut pos_b = 0; mut pos_l = 0; mut pos_g = 0;
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT PID CONTROL: setpoint = " + "${sp}" + " = (" + "${sp_d}" + "," + "${sp_k}" + "," + "${sp_e}" + "," + "${sp_b}" + "," + "${sp_l}" + "," + "${sp_g}" + ")</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Step</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>D</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>K</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>E</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>b</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>L</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>G</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Err</th></tr>";
  mut step = 0;
  while step < 12 do (
    /* P-only control per channel: move halfway to target each step */
    let err_d = (sp_d + 8 - pos_d) % 8 in
    let err_k = (sp_k + 9 - pos_k) % 9 in
    let err_e = (sp_e + 25 - pos_e) % 25 in
    let err_b = (sp_b + 49 - pos_b) % 49 in
    let err_l = (sp_l + 11 - pos_l) % 11 in
    let err_g = (sp_g + 13 - pos_g) % 13 in
    let total_err = err_d + err_k + err_e + err_b + err_l + err_g in
    /* Move: add half the error (integer division) */
    mut pos_d = (pos_d + (err_d + 1) / 2) % 8;
    mut pos_k = (pos_k + (err_k + 1) / 2) % 9;
    mut pos_e = (pos_e + (err_e + 1) / 2) % 25;
    mut pos_b = (pos_b + (err_b + 1) / 2) % 49;
    mut pos_l = (pos_l + (err_l + 1) / 2) % 11;
    mut pos_g = (pos_g + (err_g + 1) / 2) % 13;
    let color = if total_err == 0 then "#44ff88" else "#b0b0c0" in
    mut html = html + "<tr><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${step}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${pos_d}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${pos_k}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${pos_e}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${pos_b}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${pos_l}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${pos_g}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${total_err}" + "</td></tr>";
    mut step = step + 1
  );
  dom_inner(result_el, html + "</table></div>")
)

fn page_pid() = (
  dom_head_meta("description", "CRT PID Controller. 6 independent control channels over Z/12612600. CC0 patent kill: Siemens/ABB.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT PID Controller\",\"description\":\"6-channel multi-scale PID control over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/pid\"}");
  let hero = make_hero("CRT PID Control") in
  let eq = dom_create("div") in
  dom_text(eq, "B15: Siemens/ABB. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "PID control decomposes into 6 independent channels. Each channel controls at its own scale: D=fast/coarse, b=slow/fine. Errors in one channel cannot destabilize others. CRT reconstruction gives the global control signal.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Multi-Scale Control", "A setpoint in Z/12612600 has 6 CRT residues. Each channel runs independent proportional control. Channel D (mod 8) converges in 3 steps. Channel b (mod 49) converges in 6 steps. The controller naturally separates fast/coarse from slow/fine -- no manual tuning.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "6 scales", "CRT decomposition", "D=coarse(8), K=medium(9), E=fine(25), b=depth(49), L=slow(11), G=gate(13).", "");
  render_finding(g1, "Independence", "Algebraic firewall", "Error in one channel cannot propagate to others.", "");
  render_finding(g1, "Auto-tuning", "Modulus = bandwidth", "Channel bandwidth = 1/modulus. No PID tuning needed.", "");
  render_finding(g1, "Convergence", "Per-channel guaranteed", "Each channel converges in O(log(modulus)) steps.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Setpoint (0-12612599):", "dpid-input", "e.g. 42", "Run Controller", "demo_pid_run", "dpid-result");
  render_p(sec2, "Watch 6 channels converge independently. D(mod 8) arrives first, b(mod 49) last.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT PID vs Traditional");
  render_contrast_row(sec3, "Tuning", "PID: Kp, Ki, Kd manual tuning", "CRT: channel modulus IS the bandwidth");
  render_contrast_row(sec3, "Coupling", "Coupled: error in one axis affects all", "Independent: 6 algebraic firewalls");
  render_contrast_row(sec3, "Multi-scale", "Cascaded loops (complex)", "CRT channels = natural scale separation");
  render_contrast_row(sec3, "Convergence", "Heuristic (Ziegler-Nichols)", "Provable: O(log m) per channel");
  render_contrast_row(sec3, "Patent status", "Siemens/ABB process patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   CRT STEGANOGRAPHY -- dedicated demo page /demos/stego. CC0 kill C16.
   Hide data in CRT channel residues.
   ================================================================ */

fn demo_stego_encode(carrier, secret) = (
  /* Hide secret in D-channel (low 3 bits of CRT) */
  let cd = carrier % 8 in let ck = carrier % 9 in let ce = carrier % 25 in
  let cb = carrier % 49 in let cl = carrier % 11 in let cg = carrier % 13 in
  let sd = secret % 8 in
  /* Replace D-channel with secret, keep others intact */
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  (sd * idem[0] + ck * idem[1] + ce * idem[2] + cb * idem[3] + cl * idem[4] + cg * idem[5]) % N_TRUE
)

fn demo_stego_run() = (
  let carrier = parse_int_from("#dsteg-carrier") in
  let secret = parse_int_from("#dsteg-secret") in
  let result_el = dom_query("#dsteg-result") in
  let c = carrier % N_TRUE in
  let s = secret % 256 in
  let cd = c % 8 in let ck = c % 9 in let ce = c % 25 in
  let cb = c % 49 in let cl = c % 11 in let cg = c % 13 in
  /* Encode: hide 3 bits in D, 4 bits in K (total 7 bits = one ASCII-ish byte) */
  let s_lo = s % 8 in let s_hi = s / 8 in
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  let stego = (s_lo * idem[0] + (s_hi % 9) * idem[1] + ce * idem[2] + cb * idem[3] + cl * idem[4] + cg * idem[5]) % N_TRUE in
  let st_d = stego % 8 in let st_k = stego % 9 in let st_e = stego % 25 in
  let st_b = stego % 49 in let st_l = stego % 11 in let st_g = stego % 13 in
  /* Distortion: how many channels changed? */
  let changed = (if cd == st_d then 0 else 1) + (if ck == st_k then 0 else 1) + (if ce == st_e then 0 else 1) + (if cb == st_b then 0 else 1) + (if cl == st_l then 0 else 1) + (if cg == st_g then 0 else 1) in
  /* Extract */
  let extracted = st_d + (st_k * 8) in
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT STEGANOGRAPHY</p><p style='color:#b0b0c0;margin:4px 0'>Carrier: " + "${c}" + " = (" + "${cd}" + "," + "${ck}" + "," + "${ce}" + "," + "${cb}" + "," + "${cl}" + "," + "${cg}" + ")</p><p style='color:#b0b0c0;margin:4px 0'>Secret byte: " + "${s}" + " (lo=" + "${s_lo}" + " hi=" + "${s_hi % 9}" + ")</p><p style='color:#88ddaa;margin:4px 0'>Stego: " + "${stego}" + " = (" + "${st_d}" + "," + "${st_k}" + "," + "${st_e}" + "," + "${st_b}" + "," + "${st_l}" + "," + "${st_g}" + ")</p><p style='color:" + (if changed < 3 then "#44ff88" else "#ff8844") + ";margin:4px 0'>Channels modified: " + "${changed}" + "/6 (E,b,L,G untouched)</p><p style='color:#ffd700;margin:12px 0 4px'>EXTRACTION</p><p style='color:#88ddaa;margin:4px 0'>Extracted: D + K*8 = " + "${extracted}" + (if extracted == s then " CORRECT" else " MISMATCH") + "</p></div>")
)

fn page_stego() = (
  dom_head_meta("description", "CRT Steganography. Hide data in CRT channel residues. Algebraic invisibility. CC0 patent kill: DRM patents.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Steganography\",\"description\":\"Hide data in CRT channel residues over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/stego\"}");
  let hero = make_hero("CRT Steganography") in
  let eq = dom_create("div") in
