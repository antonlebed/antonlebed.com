  dom_style(inp_d, "padding", "6px 8px");
  dom_style(inp_d, "fontFamily", "'Courier New', monospace");
  dom_style(inp_d, "width", "120px");
  dom_append(extras, inp_d);
  dom_append(sec2, extras);
  render_p(sec2, "Valid keys: any prime > 13 (17, 19, 23, 29...). Coprime = invertible = valid spreading code.");
  dom_append(dom_body(), sec2);
  let sec3h = make_section("800px") in
  render_h2(sec3h, "Multi-User Test");
  render_p(sec3h, "6 users with different keys (17, 19, 23, 29, 31, 37) sharing one channel. Watch each user recover their own data from the superposition.");
  let btn = dom_create("button") in
