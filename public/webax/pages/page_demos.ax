/* ================================================================
   CRT COMPRESSION -- dedicated demo page /demos/compression. CC0 kill A8.
   CRT channel entropy: 6 small channels < 1 big number.
   ================================================================ */

fn demo_compress_encode(val) = (
  let d = val % 8 in let k = val % 9 in let e = val % 25 in
  let b = val % 49 in let l = val % 11 in let g = val % 13 in
  /* Bits needed: ceil(log2(m)) per channel */
  /* D:3 K:4 E:5 b:6 L:4 G:4 = 26 bits total */
  /* vs raw: ceil(log2(12612600)) = 24 bits (but CRT channels compress STRUCTURE) */
  d * 1000000 + k * 100000 + e * 1000 + b * 100 + l * 10 + g
)

fn demo_compress_bits(m) = (
  if m < 2 then 1
  else if m < 4 then 2
  else if m < 8 then 3
  else if m < 16 then 4
  else if m < 32 then 5
  else if m < 64 then 6
  else 7
)

fn demo_compress_run() = (
  let val = parse_int_from("#dcomp-input") in
  let result_el = dom_query("#dcomp-result") in
  let v = val % N_TRUE in
  let d = v % 8 in let k = v % 9 in let e = v % 25 in
  let b = v % 49 in let l = v % 11 in let g = v % 13 in
  let bd = demo_compress_bits(8) in let bk = demo_compress_bits(9) in
  let be = demo_compress_bits(25) in let bb = demo_compress_bits(49) in
  let bl = demo_compress_bits(11) in let bg = demo_compress_bits(13) in
  let total_bits = bd + bk + be + bb + bl + bg in
  /* Channel entropy: how much of each channel's range is used */
  let entropy_d = (d * 100) / 8 in let entropy_k = (k * 100) / 9 in
  let entropy_e = (e * 100) / 25 in let entropy_b = (b * 100) / 49 in
  let entropy_l = (l * 100) / 11 in let entropy_g = (g * 100) / 13 in
  /* Batch: how many of 1000 consecutive values have at least one zero channel */
  mut sparse = 0;
  mut i = 0;
  while i < 1000 do (
    let tv = (v + i) % N_TRUE in
    let has_zero = if tv % 8 == 0 then 1 else (if tv % 9 == 0 then 1 else (if tv % 25 == 0 then 1 else (if tv % 49 == 0 then 1 else (if tv % 11 == 0 then 1 else (if tv % 13 == 0 then 1 else 0))))) in
    mut sparse = sparse + has_zero;
    mut i = i + 1
  );
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT COMPRESSION: " + "${v}" + "</p><p style='color:#88ddaa;margin:4px 0'>CRT = (" + "${d}" + ", " + "${k}" + ", " + "${e}" + ", " + "${b}" + ", " + "${l}" + ", " + "${g}" + ")</p><p style='color:#b0b0c0;margin:4px 0'>Channel bits: D=" + "${bd}" + " K=" + "${bk}" + " E=" + "${be}" + " b=" + "${bb}" + " L=" + "${bl}" + " G=" + "${bg}" + " = <b>" + "${total_bits}" + " bits total</b></p><p style='color:#b0b0c0;margin:4px 0'>Channel utilization: D=" + "${entropy_d}" + "% K=" + "${entropy_k}" + "% E=" + "${entropy_e}" + "% b=" + "${entropy_b}" + "% L=" + "${entropy_l}" + "% G=" + "${entropy_g}" + "%</p><p style='color:#ffd700;margin:12px 0 4px'>SPARSITY (1000 values from " + "${v}" + ")</p><p style='color:#88ddaa;margin:4px 0'>" + "${sparse}" + "/1000 have at least one zero channel (" + "${sparse / 10}" + "% compressible)</p></div>")
)

fn demo_compress_batch() = (
  let result_el = dom_query("#dcomp-batch-result") in
  /* Count channel zeros across 10000 values */
  mut z0 = 0; mut z1 = 0; mut z2 = 0; mut z3 = 0; mut z4 = 0; mut z5 = 0;
  mut i = 0;
  while i < 10000 do (
    let v = (i * 137 + 42) % N_TRUE in
    if v % 8 == 0 then mut z0 = z0 + 1 else 0;
    if v % 9 == 0 then mut z1 = z1 + 1 else 0;
    if v % 25 == 0 then mut z2 = z2 + 1 else 0;
    if v % 49 == 0 then mut z3 = z3 + 1 else 0;
    if v % 11 == 0 then mut z4 = z4 + 1 else 0;
    if v % 13 == 0 then mut z5 = z5 + 1 else 0;
    mut i = i + 1
  );
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CHANNEL ZERO FREQUENCY (10000 samples)</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Channel</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Mod</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Zeros</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Expected</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Rate</th></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>D</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>8</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z0}" + "</td><td style='padding:3px;color:#888;font-size:12px'>1250</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/8</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>K</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>9</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z1}" + "</td><td style='padding:3px;color:#888;font-size:12px'>1111</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/9</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>E</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>25</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z2}" + "</td><td style='padding:3px;color:#888;font-size:12px'>400</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/25</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>b</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>49</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z3}" + "</td><td style='padding:3px;color:#888;font-size:12px'>204</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/49</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>L</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>11</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z4}" + "</td><td style='padding:3px;color:#888;font-size:12px'>909</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/11</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>G</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>13</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z5}" + "</td><td style='padding:3px;color:#888;font-size:12px'>769</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/13</td></tr></table><p style='color:#b0b0c0;margin:8px 0 0;font-size:12px'>Each zero channel = 1 fewer value to transmit. CRT makes sparsity structural.</p></div>")
)

fn page_compression() = (
  dom_head_meta("description", "CRT Compression. 6-channel decomposition exploits structural sparsity. CC0 patent kill: H.264/H.265 codec pools.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Compression\",\"description\":\"6-channel structural sparsity compression over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/compression\"}");
  let hero = make_hero("CRT Compression") in
  let eq = dom_create("div") in
  dom_text(eq, "A8: H.264/H.265 pools. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
