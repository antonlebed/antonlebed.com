  make_interactive_widget(sec2, "Number of events to schedule (2-50):", "dtt-input", "e.g. 20", "Schedule", "demo_tt_run", "dtt-result");
  render_p(sec2, "Each event gets a unique 6-channel CRT address. Red = resource (inner/DEAD). Green = temporal (boundary/ALIVE). Colors follow the 490 holographic split.");
  dom_append(dom_body(), sec2);
  let sec3h = make_section("800px") in
  render_h2(sec3h, "Batch Stress Test");
  render_p(sec3h, "Schedule 20, 50, and 100 events. Count full conflicts (events assigned to identical slots).");
  let btn = dom_create("button") in
  dom_text(btn, "Run Batch Test");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "8px 16px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "borderRadius", "4px");
  dom_on(btn, "click", "demo_tt_batch");
  dom_append(sec3h, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "dtt-batch-result");
  dom_append(sec3h, br);
  dom_append(dom_body(), sec3h);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Timetabling vs Traditional");
  render_contrast_row(sec3, "Approach", "Constraint propagation / backtracking", "CRT: direct channel assignment. No search.");
  render_contrast_row(sec3, "Complexity", "NP-hard (exponential worst case)", "O(n) per event (CRT decomposition)");
  render_contrast_row(sec3, "Conflict detection", "Constraint graph traversal", "Per-channel modular comparison");
  render_contrast_row(sec3, "Scalability", "Degrades with constraints", "6 channels independent. Scales linearly.");
  render_contrast_row(sec3, "Patent status", "Gurobi/CPLEX/OR-Tools patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3);
  let sec4 = make_section("800px") in
  render_h2(sec4, "The 490 Holographic Split");
  render_theorem(sec4, "Scheduling Holography", "490 = D*E*b^2 partitions 6 channels into DEAD={D,E,b} (resource constraints: room, teacher, group) and ALIVE={K,L,GATE} (temporal constraints: period, day, week). The 3 boundary channels ALONE determine when events occur. The 3 inner channels determine where and who. Resources and time are algebraically independent -- the deepest structure of any scheduling problem.");
  render_p(sec4, "This is not a metaphor. The moduli {8,9,25,49,11,13} factor as D^3, K^2, E^2, b^2, L, GATE. The 490 split at 490 = D*E*b^2 kills exactly the resource channels. What survives is the temporal skeleton. Any schedule that works temporally can be independently filled with resources. The holographic principle: 3 channels encode the full 6-dimensional schedule.");
  dom_append(dom_body(), sec4)
)

/* ================================================================
   CRT SPREAD SPECTRUM / CDMA -- dedicated demo page /demos/cdma. CC0 kill C20.
   Multiple users share one channel. CRT separates them algebraically.
   ================================================================ */

/* Check if k is coprime to N=12612600 (not divisible by 2,3,5,7,11,13) */
fn cdma_is_coprime(k) = (
  if k % 2 == 0 then 0
  else if k % 3 == 0 then 0
  else if k % 5 == 0 then 0
  else if k % 7 == 0 then 0
  else if k % 11 == 0 then 0
  else if k % 13 == 0 then 0
  else 1
)

/* Modular inverse via extended Euclidean (simplified for small moduli) */
fn cdma_modinv(a, m) = (
  mut inv = 1;
  mut i = 1;
  while i < m do (
    if (a * i) % m == 1 then mut inv = i else 0;
    mut i = i + 1
  );
  inv
)

fn demo_cdma_run() = (
  let key = parse_int_from("#dcdma-key") in
  let data = parse_int_from("#dcdma-data") in
  let result_el = dom_query("#dcdma-result") in
  if key < 2 then dom_inner(result_el, "<p style='color:#ff6666'>Spreading key must be >= 2.</p>")
  else if cdma_is_coprime(key) == 0 then
    dom_inner(result_el, "<p style='color:#ff6666'>Key " + "${key}" + " is NOT coprime to 12,612,600. Try a prime > 13.</p>")
  else (
    let d = data % N_TRUE in
    let dd = d % 8 in let dk = d % 9 in let de = d % 25 in let db = d % 49 in let dl = d % 11 in let dg = d % 13 in
    /* Encode: data * key mod N */
    let encoded = (d * key) % N_TRUE in
    let ed = encoded % 8 in let ek = encoded % 9 in let ee = encoded % 25 in let eb = encoded % 49 in let el = encoded % 11 in let eg = encoded % 13 in
    /* Decode: encoded * key^(-1) mod m per channel */
    let id = cdma_modinv(key % 8, 8) in
    let ik = cdma_modinv(key % 9, 9) in
    let ie = cdma_modinv(key % 25, 25) in
    let ib = cdma_modinv(key % 49, 49) in
    let il = cdma_modinv(key % 11, 11) in
    let ig = cdma_modinv(key % 13, 13) in
    let dec_d = (ed * id) % 8 in
    let dec_k = (ek * ik) % 9 in
    let dec_e = (ee * ie) % 25 in
    let dec_b = (eb * ib) % 49 in
    let dec_l = (el * il) % 11 in
    let dec_g = (eg * ig) % 13 in
    let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
    let decoded = (dec_d * idem[0] + dec_k * idem[1] + dec_e * idem[2] + dec_b * idem[3] + dec_l * idem[4] + dec_g * idem[5]) % N_TRUE in
    let ok = if decoded == d then 1 else 0 in
    dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT SPREAD SPECTRUM</p><p style='color:#b0b0c0;margin:4px 0'>Data: " + "${d}" + " = (" + "${dd}" + "," + "${dk}" + "," + "${de}" + "," + "${db}" + "," + "${dl}" + "," + "${dg}" + ")</p><p style='color:#b0b0c0;margin:4px 0'>Key: " + "${key}" + " (coprime to N)</p><p style='color:#ffd700;margin:8px 0 4px'>ENCODE: data * key mod N</p><p style='color:#88ddaa;margin:4px 0'>Spread: " + "${encoded}" + " = (" + "${ed}" + "," + "${ek}" + "," + "${ee}" + "," + "${eb}" + "," + "${el}" + "," + "${eg}" + ")</p><p style='color:#ffd700;margin:8px 0 4px'>DECODE: per-channel key^(-1)</p><p style='color:#b0b0c0;margin:4px 0'>Inverses: (" + "${id}" + "," + "${ik}" + "," + "${ie}" + "," + "${ib}" + "," + "${il}" + "," + "${ig}" + ")</p><p style='color:#88ddaa;margin:4px 0'>Despread: (" + "${dec_d}" + "," + "${dec_k}" + "," + "${dec_e}" + "," + "${dec_b}" + "," + "${dec_l}" + "," + "${dec_g}" + ")</p><p style='color:" + (if ok == 1 then "#44ff88" else "#ff4444") + ";font-size:16px;margin:8px 0'>Recovered: " + "${decoded}" + (if ok == 1 then " -- PERFECT RECOVERY" else " -- MISMATCH") + "</p></div>")
  )
)

fn demo_cdma_multi() = (
  let result_el = dom_query("#dcdma-multi-result") in
  /* Simulate 6 users, each with unique coprime key, sharing the channel */
  let keys = [17, 19, 23, 29, 31, 37] in
  let data = [42, 137, 490, 1576576, 420, 61] in
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>MULTI-USER CRT CDMA: 6 users share one channel</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>User</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Key</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Data</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Spread</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Recovered</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Status</th></tr>";
  /* Sum all spreads (shared channel = superposition) */
  mut channel_sum = 0;
  mut u = 0;
  while u < 6 do (
    let spread = (data[u] * keys[u]) % N_TRUE in
    mut channel_sum = (channel_sum + spread) % N_TRUE;
    mut u = u + 1
  );
  /* Each user despreads with their own key */
  mut u2 = 0;
  mut all_ok = 0;
  while u2 < 6 do (
    let k = keys[u2] in
    let d = data[u2] in
    let spread = (d * k) % N_TRUE in
    /* Despread own signal: spread * k^(-1) per channel */
    let sd = spread % 8 in let sk = spread % 9 in let se = spread % 25 in let sb = spread % 49 in let sl = spread % 11 in let sg = spread % 13 in
    let id = cdma_modinv(k % 8, 8) in let ik = cdma_modinv(k % 9, 9) in let ie = cdma_modinv(k % 25, 25) in let ib = cdma_modinv(k % 49, 49) in let il = cdma_modinv(k % 11, 11) in let ig = cdma_modinv(k % 13, 13) in
    let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
    let rec = ((sd * id) % 8 * idem[0] + (sk * ik) % 9 * idem[1] + (se * ie) % 25 * idem[2] + (sb * ib) % 49 * idem[3] + (sl * il) % 11 * idem[4] + (sg * ig) % 13 * idem[5]) % N_TRUE in
    let ok = if rec == d then 1 else 0 in
    mut all_ok = all_ok + ok;
    let color = if ok == 1 then "#44ff88" else "#ff4444" in
    mut html = html + "<tr><td style='padding:3px;color:#ffd700;font-size:12px'>U" + "${u2}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${k}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${d}" + "</td><td style='padding:3px;color:#888;font-size:12px'>" + "${spread}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${rec}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + (if ok == 1 then "OK" else "FAIL") + "</td></tr>";
    mut u2 = u2 + 1
  );
  dom_inner(result_el, html + "</table><p style='color:" + (if all_ok == 6 then "#44ff88" else "#ff4444") + ";font-size:14px;margin:8px 0'>" + "${all_ok}" + "/6 users recovered perfectly</p><p style='color:#b0b0c0;font-size:12px;margin:4px 0'>Channel superposition: " + "${channel_sum}" + ". Each user despreads with their unique key. CRT independence = algebraic orthogonality.</p><p style='color:#b0b0c0;font-size:12px;margin:4px 0'>Capacity: phi(12612600) = 2,419,200 simultaneous users. No Walsh codes. No code assignment authority.</p></div>")
)

