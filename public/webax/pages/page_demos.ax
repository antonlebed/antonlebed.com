  dom_append(hero, eq);
  render_p(hero, "CRT channels are algebraically independent. Replace D and K channels with secret data -- the remaining 4 channels (E,b,L,G) are untouched. The stego value is still a valid ring element. The secret is invisible to anyone who doesn't know which channels to read.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Steganographic Principle", "Any ring element has 6 independent CRT residues. Modifying D (3 bits) and K (log2(9) bits) channels embeds ~7 bits per carrier value. The other 4 channels carry the original signal undistorted. CRT independence means the hidden data is algebraically invisible in the E,b,L,G subspace.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Channel hiding", "CRT independence", "Secret data replaces inner channels. Outer channels untouched.", "");
  render_finding(g1, "Capacity", "3+4 = 7 bits", "D(3 bits) + K(~3.2 bits) per carrier value.", "");
  render_finding(g1, "Invisibility", "Algebraic orthogonality", "E,b,L,G channels unchanged. No statistical distortion in 4/6 channels.", "");
  render_finding(g1, "Extraction", "Modular arithmetic", "Read D and K channels. Reconstruct secret. Lossless.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Carrier value:", "dsteg-carrier", "e.g. 1000000", "Encode", "demo_stego_run", "dsteg-result");
  let extras = dom_create("div") in
  dom_style(extras, "display", "flex");
  dom_style(extras, "gap", "8px");
  dom_style(extras, "alignItems", "center");
  dom_style(extras, "marginBottom", "12px");
  let inp_s = dom_create("input") in
  dom_attr(inp_s, "type", "text");
  dom_attr(inp_s, "id", "dsteg-secret");
  dom_attr(inp_s, "placeholder", "secret byte (0-71)");
  dom_attr(inp_s, "value", "42");
  dom_style(inp_s, "background", "#111");
  dom_style(inp_s, "color", "#eee");
  dom_style(inp_s, "border", "1px solid #333");
  dom_style(inp_s, "padding", "6px 8px");
  dom_style(inp_s, "fontFamily", "'Courier New', monospace");
  dom_style(inp_s, "width", "120px");
  dom_append(extras, inp_s);
  dom_append(sec2, extras);
  render_p(sec2, "Secret range: 0-71 (D*K = 8*9 = 72 values). D carries low 3 bits, K carries high bits.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Stego vs Traditional");
  render_contrast_row(sec3, "Hiding method", "LSB modification (fragile)", "CRT channel replacement (algebraic)");
  render_contrast_row(sec3, "Distortion", "All bits slightly perturbed", "Only D,K channels changed; E,b,L,G exact");
  render_contrast_row(sec3, "Detection", "Statistical analysis can reveal", "4/6 channels have zero distortion");
  render_contrast_row(sec3, "Extraction", "Bit masking (position-dependent)", "Modular arithmetic (position-free)");
  render_contrast_row(sec3, "Patent status", "DRM/watermarking patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   CRT KEY EXCHANGE — dedicated demo page /demos/key_exchange. CC0 kill C18.
   CRT Diffie-Hellman over Z/12612600.
   ================================================================ */

fn demo_crt_powmod(base, exp, m) = (
  mut result = 1;
  mut b = base % m;
  mut e = exp;
  while e > 0 do (
    if e % 2 == 1 then mut result = (result * b) % m else 0;
    mut b = (b * b) % m;
    mut e = e / 2
  );
  result
)

fn demo_kex_run() = (
  let alice_secret = parse_int_from("#dkex-alice") in
  let bob_secret = parse_int_from("#dkex-bob") in
  let result_el = dom_query("#dkex-result") in
  let a = alice_secret % 420 in
  let b = bob_secret % 420 in
  /* Per-channel DH: generator g, modulus m */
  /* Generators: primitive roots of each modulus */
  let g = [3, 2, 2, 3, 2, 2] in
  let mods = [8, 9, 25, 49, 11, 13] in
  /* Alice public: g^a mod m per channel */
  let ap0 = demo_crt_powmod(g[0], a, mods[0]) in
  let ap1 = demo_crt_powmod(g[1], a, mods[1]) in
  let ap2 = demo_crt_powmod(g[2], a, mods[2]) in
  let ap3 = demo_crt_powmod(g[3], a, mods[3]) in
  let ap4 = demo_crt_powmod(g[4], a, mods[4]) in
  let ap5 = demo_crt_powmod(g[5], a, mods[5]) in
  /* Bob public: g^b mod m per channel */
  let bp0 = demo_crt_powmod(g[0], b, mods[0]) in
  let bp1 = demo_crt_powmod(g[1], b, mods[1]) in
  let bp2 = demo_crt_powmod(g[2], b, mods[2]) in
  let bp3 = demo_crt_powmod(g[3], b, mods[3]) in
  let bp4 = demo_crt_powmod(g[4], b, mods[4]) in
  let bp5 = demo_crt_powmod(g[5], b, mods[5]) in
  /* Shared: bob_pub^a = alice_pub^b = g^(ab) mod m */
  let s0 = demo_crt_powmod(bp0, a, mods[0]) in
  let s1 = demo_crt_powmod(bp1, a, mods[1]) in
  let s2 = demo_crt_powmod(bp2, a, mods[2]) in
  let s3 = demo_crt_powmod(bp3, a, mods[3]) in
  let s4 = demo_crt_powmod(bp4, a, mods[4]) in
  let s5 = demo_crt_powmod(bp5, a, mods[5]) in
  /* Verify: alice computes from bob pub */
  let v0 = demo_crt_powmod(ap0, b, mods[0]) in
  let v1 = demo_crt_powmod(ap1, b, mods[1]) in
  let v2 = demo_crt_powmod(ap2, b, mods[2]) in
  let v3 = demo_crt_powmod(ap3, b, mods[3]) in
  let v4 = demo_crt_powmod(ap4, b, mods[4]) in
  let v5 = demo_crt_powmod(ap5, b, mods[5]) in
  let ch_ok =(if s0 == v0 then 1 else 0) + (if s1 == v1 then 1 else 0) + (if s2 == v2 then 1 else 0) + (if s3 == v3 then 1 else 0) + (if s4 == v4 then 1 else 0) + (if s5 == v5 then 1 else 0) in
  /* CRT reconstruct shared secret */
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  let shared = (s0 * idem[0] + s1 * idem[1] + s2 * idem[2] + s3 * idem[3] + s4 * idem[4] + s5 * idem[5]) % 12612600 in
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT KEY EXCHANGE</p><p style='color:#b0b0c0;margin:4px 0'>Alice secret: " + "${a}" + " | Bob secret: " + "${b}" + "</p><p style='margin:8px 0 4px;color:#ffd700'>Public keys (visible to eavesdropper)</p><p style='color:#b0b0c0;margin:4px 0'>Alice public: (" + "${ap0}" + "," + "${ap1}" + "," + "${ap2}" + "," + "${ap3}" + "," + "${ap4}" + "," + "${ap5}" + ")</p><p style='color:#b0b0c0;margin:4px 0'>Bob public: (" + "${bp0}" + "," + "${bp1}" + "," + "${bp2}" + "," + "${bp3}" + "," + "${bp4}" + "," + "${bp5}" + ")</p><p style='margin:8px 0 4px;color:#ffd700'>Shared secrets (computed independently)</p><p style='color:#88ddaa;margin:4px 0'>Alice computes: (" + "${s0}" + "," + "${s1}" + "," + "${s2}" + "," + "${s3}" + "," + "${s4}" + "," + "${s5}" + ")</p><p style='color:#88ddaa;margin:4px 0'>Bob computes: (" + "${v0}" + "," + "${v1}" + "," + "${v2}" + "," + "${v3}" + "," + "${v4}" + "," + "${v5}" + ")</p><p style='color:" + (if ch_ok == 6 then "#44ff88" else "#ff4444") + ";font-size:16px;margin:8px 0'>Channel agreement: " + "${ch_ok}" + "/6" + (if ch_ok == 6 then " -- KEYS MATCH" else " -- MISMATCH") + "</p><p style='color:#88ddaa;margin:4px 0'>Shared secret (CRT): <b>" + "${shared}" + "</b></p></div>")
)

fn page_key_exchange() = (
  dom_head_meta("description", "CRT Key Exchange. 6-channel Diffie-Hellman over Z/12612600. CC0 patent kill: RSA/Certicom.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Key Exchange\",\"description\":\"6-channel Diffie-Hellman key exchange over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/key_exchange\"}");
  let hero = make_hero("CRT Key Exchange") in
  let eq = dom_create("div") in
  dom_text(eq, "C18: RSA/Certicom. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "Diffie-Hellman key exchange runs in parallel across 6 CRT channels. Each channel uses its own primitive root as generator. 6 small discrete-log problems instead of 1 big one. CRT reconstructs the shared secret from 6 channel agreements.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Diffie-Hellman", "Classic DH: g^a mod p (one big modulus). CRT DH: g_i^a mod m_i for each channel (6 small moduli). Alice sends 6 public residues. Bob sends 6. Each computes 6 shared residues independently. CRT reconstruction gives the unique shared secret in Z/12612600.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "6 generators", "Primitive roots", "Each channel has its own generator: {3,2,2,3,2,2}.", "");
  render_finding(g1, "Parallel exchange", "CRT independence", "6 small key exchanges run independently.", "");
  render_finding(g1, "Shared secret", "CRT reconstruction", "6 channel agreements → unique shared value.", "");
  render_finding(g1, "Channel security", "Discrete log per mod", "Breaking one channel reveals only 3-6 bits.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Alice's secret (1-419):", "dkex-alice", "e.g. 137", "Exchange Keys", "demo_kex_run", "dkex-result");
  let extras = dom_create("div") in
  dom_style(extras, "display", "flex");
  dom_style(extras, "gap", "8px");
  dom_style(extras, "alignItems", "center");
  dom_style(extras, "marginBottom", "12px");
  let inp_b = dom_create("input") in
  dom_attr(inp_b, "type", "text");
  dom_attr(inp_b, "id", "dkex-bob");
  dom_attr(inp_b, "placeholder", "Bob's secret (e.g. 42)");
  dom_attr(inp_b, "value", "42");
  dom_style(inp_b, "background", "#111");
  dom_style(inp_b, "color", "#eee");
  dom_style(inp_b, "border", "1px solid #333");
  dom_style(inp_b, "padding", "6px 8px");
  dom_style(inp_b, "fontFamily", "'Courier New', monospace");
  dom_style(inp_b, "width", "120px");
  dom_append(extras, inp_b);
  dom_append(sec2, extras);
  render_p(sec2, "Secrets mod 420 (= lambda of ring). Try: Alice=137 Bob=42, Alice=1 Bob=419.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Key Exchange vs Traditional");
  render_contrast_row(sec3, "Modulus", "RSA: single 2048-bit prime product", "CRT: 6 small moduli (3-49)");
  render_contrast_row(sec3, "Parallelism", "Sequential modular exponentiation", "6 independent exponentiations");
  render_contrast_row(sec3, "Key size", "256+ bytes", "6 residues (< 20 bytes)");
  render_contrast_row(sec3, "Quantum resistance", "Shor's algorithm breaks RSA", "6 small DLPs -- different attack surface");
  render_contrast_row(sec3, "Patent status", "RSA/Certicom/NIST patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)
