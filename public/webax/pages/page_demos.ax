/* ================================================================
   CRT RNG — dedicated demo page /demos/rng. CC0 kill A9.
   6-channel primitive root mixing.
   ================================================================ */

fn demo_rng_step(s0, s1, i) = (
  let cd = s0 % 8 in let ck = s0 % 9 in let ce = s0 % 25 in
  let cb = s0 % 49 in let cl = s0 % 11 in let cg = s0 % 13 in
  let md = (cd * 3 + cl) % 8 in
  let mk = (ck * 2 + cd) % 9 in
  let mie = (ce * 2 + (ck * cb) % 25) % 25 in
  let mib = (cb * 3 + ce) % 49 in
  let ml = (cl * 2 + cb + cd) % 11 in
  let mg = (cg * 2 + cl + cd) % 13 in
  (md * 11036025 + mk * 1401400 + mie * 9585576 + mib * 8494200 + ml * 3439800 + mg * 3880800) % 12612600
)

fn demo_rng_run() = (
  let seed = parse_int_from("#drng-input") in
  let result_el = dom_query("#drng-result") in
  if seed < 1 then dom_inner(result_el, "<p style='color:#ff6666'>Enter a positive seed.</p>")
  else (
    mut s0 = (seed * 137 + 1) % 12612600;
    mut s1 = (seed * 42 + 7) % 12612600;
    mut nums = "";
    mut first_out = 0;
    mut i = 0;
    while i < 20 do (
      let out = demo_rng_step(s0, s1, i) in
      mut s1 = (s1 * 137 + out) % 12612600;
      mut s0 = (s0 + s1 + i * 7) % 12612600;
      if i == 0 then mut first_out = out else 0;
      mut nums = nums + (if i > 0 then ", " else "") + "${out}";
      mut i = i + 1
    );
    let fd = first_out % 8 in let fk = first_out % 9 in let fe = first_out % 25 in let ffb = first_out % 49 in let fl = first_out % 11 in let fg = first_out % 13 in
    dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT RNG (seed = " + "${seed}" + ")</p><p style='margin:4px 0;color:#b0b0c0;font-size:13px;word-break:break-all'>" + nums + "</p><p style='margin:8px 0 4px;color:#b0b0c0'>First output CRT: (" + "${fd}" + "," + "${fk}" + "," + "${fe}" + "," + "${ffb}" + "," + "${fl}" + "," + "${fg}" + ")</p></div>")
  )
)

fn demo_rng_compare() = (
  let result_el = dom_query("#drng-compare-result") in
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>SEED COMPARISON: first 5 outputs from seeds 1-5</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Seed</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[0]</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[1]</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[2]</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[3]</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[4]</th></tr>";
  mut seed = 1;
  while seed < 6 do (
    mut s0 = (seed * 137 + 1) % 12612600;
    mut s1 = (seed * 42 + 7) % 12612600;
    mut html = html + "<tr><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${seed}" + "</td>";
    mut j = 0;
    while j < 5 do (
      let out = demo_rng_step(s0, s1, j) in
      mut s1 = (s1 * 137 + out) % 12612600;
      mut s0 = (s0 + s1 + j * 7) % 12612600;
      mut html = html + "<td style='padding:3px;color:#b0b0c0;font-size:11px'>" + "${out}" + "</td>";
      mut j = j + 1
    );
    mut html = html + "</tr>";
    mut seed = seed + 1
  );
  dom_inner(result_el, html + "</table></div>")
)

