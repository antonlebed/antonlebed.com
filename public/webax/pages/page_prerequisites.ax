/* ===== PAGE 3: WAVES & SHADOWS ===== */

fn ws_hero() = (
  let hero = make_hero("Waves & Shadows") in
  let eq = dom_create("div") in
  dom_text(eq, "eigenvalue(n) = sum of cosines across 6 channels");
  ct_mono(eq);
  dom_style(eq, "fontSize", "22px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Every number in the ring vibrates. Its 'eigenvalue' is a sum of cosines  one from each channel. Numbers that share structure with N vibrate less. Numbers coprime to N vibrate most. This wave-like behavior is not imposed  it's forced by the CRT.");
  dom_append(dom_body(), hero)
)

fn ws_eigenvalue() = (
  let sec = make_section("800px") in
  render_h2(sec, "Eigenvalues: The Ring's Heartbeat");
  render_p(sec, "For each channel with clock size q, the 'note' that element n plays on that channel is: 2 * cos(2*pi*r/q), where r = n mod q. Sum all five notes: that's the eigenvalue.");
  render_p(sec, "sigma = 1 has r = 1 on every channel, so all notes are positive  maximum vibration. The void (0) has r = 0 on every channel, so every note is exactly 2  the maximum possible eigenvalue (10.0). Wait, that means the void vibrates MOST? Yes. 0 resonates perfectly with the ring's structure because it IS the ring's structure.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Element");
  render_th(hdr, "Eigenvalue (x1000)");
  render_th(hdr, "Meaning");
  dom_append(tbl, hdr);
  render_table_row(tbl, "0 (void)", "10000", "Perfect resonance. 2+2+2+2+2.");
  render_table_row(tbl, "1 (sigma)", "7660", "Strong positive. All channels hum.");
  render_table_row(tbl, "OMEGA (1576576)", "5660", "D-channel dead, 5 channels alive.");
  render_table_row(tbl, "KEY (41)", "-1618", "Negative! Destructive interference.");
  dom_append(dom_body(), sec)
)

fn ws_coupling() = (
  let sec = make_section("800px") in
  render_h2(sec, "Coupling: How Connected Are You?");
  render_p(sec, "The 'coupling' of n in Z/NZ is N / GCD(n, N). It measures how many distinct elements n can reach by multiplication. Units have coupling = N (they reach everything). The void has coupling = 1 (stuck at zero). Coupling is the ring's measure of connectivity.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Element");
  render_th(hdr, "GCD with N");
  render_th(hdr, "Coupling");
  render_th(hdr, "Interpretation");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "1 (sigma)", "1", "970200", "Maximum. Reaches everything.");
  render_table_row_4(tbl, "2 (D)", "2", "485100", "Half. Locked to even elements.");
  render_table_row_4(tbl, "42 (ANSWER)", "42", "23100", "Moderate. K*b-fold connected.");
  render_table_row_4(tbl, "0 (void)", "970200", "1", "Minimum. Only itself.");
  dom_append(dom_body(), sec)
)

fn ws_omega() = (
  let sec = make_section("800px") in
  render_h2(sec, "OMEGA: The Projection");
  render_p(sec, "Start with D = 2 and keep multiplying: 2, 4, 8, 16, 32... In the ring Z/12612600Z, this sequence eventually reaches a fixed point: D^420 = 1576576 = OMEGA. After that, multiplying by D again changes nothing: OMEGA * D = OMEGA.");
  render_p(sec, "OMEGA is an idempotent: OMEGA * OMEGA = OMEGA. Its CRT decomposition is (0, 1, 1, 1, 1, 1)  zero on the D-channel, identity on all others. It PROJECTS away the D-component. This isn't designed  it's forced by the arithmetic.");
  render_theorem(sec, "Key Insight", "The six primes {2, 3, 5, 7, 11, 13} and the number OMEGA = 1576576 are not chosen. They precipitate from 0/0 = Z/NZ. The entire structure on this site  kingdoms, eigenvalues, coupling, OMEGA  is FORCED by the axiom. Nothing is added by hand.");
  dom_append(dom_body(), sec)
)

fn ws_interactive() = (
  let sec = make_section("800px") in
  render_h2(sec, "Try It: Eigenvalue Explorer");
  render_p(sec, "Enter any number. See its eigenvalue, coupling, kingdom, and CRT decomposition.");
  make_interactive_widget(sec, "Enter a number:", "ws-eigen-input", "e.g. 137", "Explore", "ws_eigen_calc", "ws-eigen-result");
  dom_append(dom_body(), sec)
)

fn ws_eigen_calc() = (
  let n = parse_int_from("#ws-eigen-input") in
  let result = dom_query("#ws-eigen-result") in
  let d = n % 8 in
  let k = n % 9 in
  let e = n % 25 in
  let bb = n % 49 in
  let ll = n % 11 in
  let gg = n % 13 in
  let ev = eigenvalue(n) in
  let c = coupling(n) in
  let kd = kingdom(n) in
  let kname = if kd == 0 then "Void" else if kd == 1 then "Unit" else if kd == 2 then "Bridge (D)" else if kd == 3 then "Fungi (K)" else if kd == 5 then "Observer (E)" else if kd == 7 then "Depth (b)" else if kd == 11 then "Protector (L)" else "Guardian (GATE)" in
  let mir = mirror(n) in
  dom_inner(result, "<div style='text-align:center'><p style='font-size:28px;color:#ffd700;margin:8px 0'>Eigenvalue: ${ev} / 1000</p><p style='color:#b8b8c8'>CRT: (${d}, ${k}, ${e}, ${bb}, ${ll}, ${gg})</p><p style='color:#b8b8c8'>Kingdom: <b style='color:#88ddaa'>" + kname + "</b> | Coupling: <b>${c}</b> | Mirror: <b>${mir}</b></p></div>")
)

