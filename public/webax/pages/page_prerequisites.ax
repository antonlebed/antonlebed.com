fn page_rings_channels() = (
  dom_head_meta("description", "The Chinese Remainder Theorem splits 12612600 into six independent channels. Every number gets a unique address.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Rings & Channels\",\"description\":\"CRT decomposition of Z/12612600Z into six prime-power channels.\",\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"Chinese Remainder Theorem\"},{\"@type\":\"DefinedTerm\",\"name\":\"Ring\"},{\"@type\":\"DefinedTerm\",\"name\":\"CRT Decomposition\"}]}");
