/* ================================================================
   INTERACTIVE: DEPTH QUADRATIC EXPLORER
   f(p) = p^2 - p - 1. Enter p, see f(p) and verify f(p) = -1 mod p.
   ================================================================ */

fn depth_quad_compute() = (
  let p = parse_int_from("#dq-input") in
  let result = dom_query("#dq-result") in
  let fp = p * p - p - 1 in
  /* f(p) mod p should always be p-1 = -1 */
  let fp_mod_p = if p > 1 then fp % p else 0 in
  let is_mirror = if p > 1 then (if fp_mod_p == p - 1 then "YES (= p-1 = -1 mod p)" else "NO") else "n/a" in
  /* CRT of f(p) */
  let fd = fp % 8 in let fk = fp % 9 in let fe = fp % 25 in let fb = fp % 49 in let fl = fp % 11 in let fg = fp % 13 in
  /* Check axiom chain values */
  let name = if fp == 5 then " = E (observer!)"
    else if fp == 19 then " = f(E)"
    else if fp == 41 then " = KEY (self-inverse!)"
    else if fp == 109 then " = lattice-prime (phi = 108)"
    else if fp == 155 then " = E*(D^E-sigma) (GATE's depth quadratic)"
    else "" in
  dom_inner(result, "<p style='color:#88ddaa;margin:4px 0'><b>p = " + "${p}" + "</b> | f(p) = p^2 - p - 1 = <b>" + "${fp}" + "</b>" + name + "</p><p style='color:#ffd700;margin:4px 0'>f(p) mod p = " + "${fp_mod_p}" + " | Mirror property: " + is_mirror + "</p><p style='color:#ff8844;margin:4px 0'>CRT(" + "${fp}" + ") = (" + "${fd}" + "," + "${fk}" + "," + "${fe}" + "," + "${fb}" + "," + "${fl}" + "," + "${fg}" + ")</p><p style='color:#b0b0c08ff;margin:4px 0'>p^2 = " + "${p * p}" + " | KEY identity: b^2-b-1 = 49-7-1 = 41 = KEY</p>")
)

