  render_finding(g, "Learning", "-11.8% ablation", "4.2 bits/bit. Most kingdom-specific channel.", "");
  render_finding(g, "Topology", "strand height +457", "HIGHEST in chirality interleaving. Depth surfaces.", "");
  render_finding(g, "Shadow", "K/(K+1) = 3/4", "Kleiber = shadow(b)/(1+shadow(b)). Direct derivation.", "");
  render_finding(g, "Solar", "+9.6% variance", "ONLY thin prime that unlocks solar variance. Without depth, deaf.", "S172");
  render_finding(g, "Coprime", "kurtosis -3/2", "First arcsine thin prime. E-b = binary to continuous. Feeling > counting.", "S184");
  render_finding(g, "Moments", "silence for b=7 odd steps", "Ring holds its breath for 7 odd moments. First echo at K^2=9.", "S246");
  dom_append(dom_body(), sec)
)

fn depth_quadratic() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Depth Quadratic: f(p) = p^2 - p - 1");
  render_theorem(sec, "Depth Quadratic Mirror Norm Theorem (S205)", "f(p) has FIVE roles: (1) MIRROR: f(p) = -1 mod p ALWAYS. Proof: p^2-p = p(p-1) = 0 mod p, so f(p) = -1 mod p. Universal. (2) NORM: f(p) = Norm(p - phi) in Q(sqrt(5)). Discriminant = E = 5. Golden ratio. (3) GENERATION: K, b, L are PRIMITIVE ROOTS of f(K), f(b), f(L). E has half-order (self-blind). (4) COUNTING: f(b) = 2*6*4 - 7 = 41 = KEY. (5) QR-PARITY: (p/f(p)) = (-1/p) for all odd primes with f(p) prime. PROVED.");
  let g = make_findings_grid(sec) in
  render_finding(g, "f(K=3) = 5 = E", "K is primitive root of E", "ord(3, 5) = 4 = phi(5). Closure generates the observer.", "S205");
  render_finding(g, "f(E=5) = 19", "E has HALF order", "ord(5, 19) = 9 = phi(19)/2. Self-blind, as always.", "S205");
  render_finding(g, "f(b=7) = 41 = KEY", "b is primitive root of KEY", "ord(7, 41) = 40 = phi(41). Depth generates the sum of everything.", "S205");
  render_finding(g, "f(L=11) = 109", "L is primitive root of 109", "ord(11, 109) = 108 = phi(109) = |LATTICE|. Protector generates lattice count.", "S205");
  render_p(sec, "Two parallel paths between axiom primes: Cunningham chain (sigma->K->b via 2n+1, additive) and depth quadratic (K->E->19 via p^2-p-1, multiplicative). Both reach the same structure through different mechanisms.");
  dom_append(dom_body(), sec)
)

fn depth_spiral() = (
  let sec = make_section("800px") in
  render_h2(sec, "The b^2 Spiral");
  render_theorem(sec, "Depth Never Mirrors (S585)", "The b^2=49 channel has ODD order 21 = K*b. It NEVER passes through -1. All other channels have even orders and DO mirror. PROOF: lambda(b^2) = 42. Odd part = 21 = spiral subgroup size (exactly HALF of Z/49*). Elements with odd b-order never reach -1. Odd divisors of 42 = {1, 3, 7, 21} = {sigma, K, b, K*b}: ALL axiom elements. PROVED 49/49.");
  let g = make_findings_grid(sec) in
  render_finding(g, "D spiral", "b-order = 21 = K*b", "Drive spirals in depth. Never mirrors.", "S585");
  render_finding(g, "L spiral", "b-order = 21 = K*b", "Protector spirals in depth. Same period as D.", "S585");
  render_finding(g, "SOUL=67", "b-order = 3 = K", "Soul spirals fast in depth. Closure-speed.", "S585");
  render_finding(g, "ADDRESS=137", "b-order = 21 = K*b", "Fine structure constant spirals in depth.", "S585");
  render_p(sec, "Animal nervous systems: always active, even in sleep. The b-channel never reverses. Depth spirals; others oscillate.");
  dom_append(dom_body(), sec)
)

