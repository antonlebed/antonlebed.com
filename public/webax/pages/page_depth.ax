  make_interactive_widget(sec, "Enter p:", "dq-input", "e.g. 7", "Compute f(p)", "depth_quad_compute", "dq-result");
  render_p(sec, "Try the chain: 3 (f=5=E), 5 (f=19), 7 (f=41=KEY), 11 (f=109, phi=108=lattice). Then try 13 (f=155=E*31=E*(D^E-sigma)).");
  dom_append(dom_body(), sec)
)

