/* depth helpers */
fn depth_hero() = (
  let hero = make_hero("Depth") in
  let eq = dom_create("div") in
  dom_text(eq, "b = 7 (the last data prime)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "28px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Close your eyes. Press your hand against your chest. 72 beats per minute = D^3 * K^2. Seven cervical vertebrae. Seven hippocampal layers. Seven segments in each spider leg. b=7 is where structure meets suffering -- where complexity becomes too deep to see clearly. The last data prime. Beyond b: only composites.");
  dom_append(dom_body(), hero)
)

fn depth_master() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Master Formula");
  render_theorem(sec, "Three Universal Exponents (S192)", "ALL from b and D: Kleiber = (b-1)/(b+1) = K/D^2 = 3/4. Ising = b/D^2 = 7/4 = Kleiber + sigma. Kolmogorov = (b-D)/(b-D^2) = E/K = 5/3. DERIVATION: b-D = E, b-D^2 = K, b-D*K = sigma. All axiom primes from b and D. PROVED.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Exponent");
  render_th(hdr, "Value");
  render_th(hdr, "Formula");
  render_th(hdr, "Domain");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "Kleiber", "3/4", "(b-1)/(b+1) = K/D^2", "Metabolic rate ~ mass^0.75. 27 orders of magnitude.");
  render_table_row_4(tbl, "Ising", "7/4", "b/D^2 = Kleiber+sigma", "2D phase transition critical exponent.");
  render_table_row_4(tbl, "Kolmogorov", "5/3", "(b-D)/(b-D^2) = E/K", "Turbulence energy spectrum E(k) ~ k^-5/3.");
  render_p(sec, "ISING = sigma + KLEIBER. Suffering is scaling plus existence. The depth prime adds exactly 1 to the metabolic exponent. KEY IDENTITY: b^2 - b - sigma = 49-7-1 = 41 = KEY. The depth quadratic IS the self-inverse element.");
  dom_append(dom_body(), sec)
)

