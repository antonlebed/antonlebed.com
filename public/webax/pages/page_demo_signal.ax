/* ================================================================
   CRT SPREAD SPECTRUM / CDMA -- dedicated demo page /demos/cdma. CC0 kill C20.
   Multiple users share one channel. CRT separates them algebraically.
   ================================================================ */

/* Check if k is coprime to N=12612600 (not divisible by 2,3,5,7,11,13) */
fn cdma_is_coprime(k) = (
  if k % 2 == 0 then 0
  else if k % 3 == 0 then 0
  else if k % 5 == 0 then 0
  else if k % 7 == 0 then 0
  else if k % 11 == 0 then 0
  else if k % 13 == 0 then 0
  else 1
)

/* Modular inverse via extended Euclidean (simplified for small moduli) */
fn cdma_modinv(a, m) = (
  mut inv = 1;
  mut i = 1;
  while i < m do (
    if (a * i) % m == 1 then mut inv = i else 0;
    mut i = i + 1
  );
  inv
)

fn demo_cdma_run() = (
  let key = parse_int_from("#dcdma-key") in
  let data = parse_int_from("#dcdma-data") in
  let result_el = dom_query("#dcdma-result") in
  if key < 2 then dom_inner(result_el, "<p style='color:#ff6666'>Spreading key must be >= 2.</p>")
  else if cdma_is_coprime(key) == 0 then
    dom_inner(result_el, "<p style='color:#ff6666'>Key " + "${key}" + " is NOT coprime to 12,612,600. Try a prime > 13.</p>")
  else (
    let d = data % N_TRUE in
    let dd = d % 8 in let dk = d % 9 in let de = d % 25 in let db = d % 49 in let dl = d % 11 in let dg = d % 13 in
    /* Encode: data * key mod N */
    let encoded = (d * key) % N_TRUE in
    let ed = encoded % 8 in let ek = encoded % 9 in let ee = encoded % 25 in let eb = encoded % 49 in let el = encoded % 11 in let eg = encoded % 13 in
    /* Decode: encoded * key^(-1) mod m per channel */
    let id = cdma_modinv(key % 8, 8) in
    let ik = cdma_modinv(key % 9, 9) in
    let ie = cdma_modinv(key % 25, 25) in
    let ib = cdma_modinv(key % 49, 49) in
    let il = cdma_modinv(key % 11, 11) in
    let ig = cdma_modinv(key % 13, 13) in
    let dec_d = (ed * id) % 8 in
    let dec_k = (ek * ik) % 9 in
    let dec_e = (ee * ie) % 25 in
    let dec_b = (eb * ib) % 49 in
    let dec_l = (el * il) % 11 in
    let dec_g = (eg * ig) % 13 in
    let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
    let decoded = (dec_d * idem[0] + dec_k * idem[1] + dec_e * idem[2] + dec_b * idem[3] + dec_l * idem[4] + dec_g * idem[5]) % N_TRUE in
    let ok = if decoded == d then 1 else 0 in
    dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT SPREAD SPECTRUM</p><p style='color:#b0b0c0;margin:4px 0'>Data: " + "${d}" + " = (" + "${dd}" + "," + "${dk}" + "," + "${de}" + "," + "${db}" + "," + "${dl}" + "," + "${dg}" + ")</p><p style='color:#b0b0c0;margin:4px 0'>Key: " + "${key}" + " (coprime to N)</p><p style='color:#ffd700;margin:8px 0 4px'>ENCODE: data * key mod N</p><p style='color:#88ddaa;margin:4px 0'>Spread: " + "${encoded}" + " = (" + "${ed}" + "," + "${ek}" + "," + "${ee}" + "," + "${eb}" + "," + "${el}" + "," + "${eg}" + ")</p><p style='color:#ffd700;margin:8px 0 4px'>DECODE: per-channel key^(-1)</p><p style='color:#b0b0c0;margin:4px 0'>Inverses: (" + "${id}" + "," + "${ik}" + "," + "${ie}" + "," + "${ib}" + "," + "${il}" + "," + "${ig}" + ")</p><p style='color:#88ddaa;margin:4px 0'>Despread: (" + "${dec_d}" + "," + "${dec_k}" + "," + "${dec_e}" + "," + "${dec_b}" + "," + "${dec_l}" + "," + "${dec_g}" + ")</p><p style='color:" + (if ok == 1 then "#44ff88" else "#ff4444") + ";font-size:16px;margin:8px 0'>Recovered: " + "${decoded}" + (if ok == 1 then " -- PERFECT RECOVERY" else " -- MISMATCH") + "</p></div>")
  )
)

fn demo_cdma_multi() = (
  let result_el = dom_query("#dcdma-multi-result") in
  /* Simulate 6 users, each with unique coprime key, sharing the channel */
  let keys = [17, 19, 23, 29, 31, 37] in
  let data = [42, 137, 490, 1576576, 420, 61] in
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>MULTI-USER CRT CDMA: 6 users share one channel</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>User</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Key</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Data</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Spread</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Recovered</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Status</th></tr>";
  /* Sum all spreads (shared channel = superposition) */
  mut channel_sum = 0;
  mut u = 0;
  while u < 6 do (
    let spread = (data[u] * keys[u]) % N_TRUE in
    mut channel_sum = (channel_sum + spread) % N_TRUE;
    mut u = u + 1
  );
  /* Each user despreads with their own key */
  mut u2 = 0;
  mut all_ok = 0;
  while u2 < 6 do (
    let k = keys[u2] in
    let d = data[u2] in
    let spread = (d * k) % N_TRUE in
    /* Despread own signal: spread * k^(-1) per channel */
    let sd = spread % 8 in let sk = spread % 9 in let se = spread % 25 in let sb = spread % 49 in let sl = spread % 11 in let sg = spread % 13 in
    let id = cdma_modinv(k % 8, 8) in let ik = cdma_modinv(k % 9, 9) in let ie = cdma_modinv(k % 25, 25) in let ib = cdma_modinv(k % 49, 49) in let il = cdma_modinv(k % 11, 11) in let ig = cdma_modinv(k % 13, 13) in
    let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
    let rec = ((sd * id) % 8 * idem[0] + (sk * ik) % 9 * idem[1] + (se * ie) % 25 * idem[2] + (sb * ib) % 49 * idem[3] + (sl * il) % 11 * idem[4] + (sg * ig) % 13 * idem[5]) % N_TRUE in
    let ok = if rec == d then 1 else 0 in
    mut all_ok = all_ok + ok;
    let color = if ok == 1 then "#44ff88" else "#ff4444" in
    mut html = html + "<tr><td style='padding:3px;color:#ffd700;font-size:12px'>U" + "${u2}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${k}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${d}" + "</td><td style='padding:3px;color:#888;font-size:12px'>" + "${spread}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + "${rec}" + "</td><td style='padding:3px;color:" + color + ";font-size:12px'>" + (if ok == 1 then "OK" else "FAIL") + "</td></tr>";
    mut u2 = u2 + 1
  );
  dom_inner(result_el, html + "</table><p style='color:" + (if all_ok == 6 then "#44ff88" else "#ff4444") + ";font-size:14px;margin:8px 0'>" + "${all_ok}" + "/6 users recovered perfectly</p><p style='color:#b0b0c0;font-size:12px;margin:4px 0'>Channel superposition: " + "${channel_sum}" + ". Each user despreads with their unique key. CRT independence = algebraic orthogonality.</p><p style='color:#b0b0c0;font-size:12px;margin:4px 0'>Capacity: phi(12612600) = 2,419,200 simultaneous users. No Walsh codes. No code assignment authority.</p></div>")
)

fn page_cdma() = (
  dom_head_meta("description", "CRT Spread Spectrum. 6-channel CDMA over Z/12612600. Coprime keys as spreading codes. CC0.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Spread Spectrum\",\"description\":\"6-channel CDMA spreading over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/cdma\"}");
  let hero = make_hero("CRT Spread Spectrum") in
  let eq = dom_create("div") in
  dom_text(eq, "C20: Qualcomm CDMA. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "CDMA: multiple users share ONE channel. CRT makes each coprime key a unique algebraic spreading code. 6 independent channels, each with its own modular inverse. Encode = multiply by key. Decode = multiply by inverse. phi(12612600) = 2,419,200 simultaneous users at O(1) cost.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Spreading Principle", "Every integer coprime to N = 12,612,600 is invertible in the ring. Coprime k spreads data d to d*k mod N. The receiver despreads with k^(-1) per channel: each modulus m has a unique inverse. CRT independence means interference from other users vanishes per-channel. 6 moduli = 6 orthogonal despreading dimensions.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Coprime keys", "Spreading codes", "phi(N) = 2,419,200 valid keys. Each coprime integer = unique code.", "");
  render_finding(g1, "6-channel despread", "CRT independence", "key^(-1) computed per modulus. 6 independent inversions.", "");
  render_finding(g1, "Multi-user", "Algebraic orthogonality", "Users multiply by different coprimes. Despreading isolates own signal.", "");
  render_finding(g1, "490 split", "Inner vs boundary", "DEAD={D,E,b} carry data bits. ALIVE={K,L,G} detect interference.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Spreading key (coprime to N, e.g. 17):", "dcdma-key", "e.g. 17", "Spread/Despread", "demo_cdma_run", "dcdma-result");
  let extras = dom_create("div") in
  dom_style(extras, "display", "flex");
  dom_style(extras, "gap", "8px");
  dom_style(extras, "alignItems", "center");
  dom_style(extras, "marginBottom", "12px");
  let inp_d = dom_create("input") in
  dom_attr(inp_d, "type", "text");
  dom_attr(inp_d, "id", "dcdma-data");
  dom_attr(inp_d, "placeholder", "data (e.g. 42)");
  dom_attr(inp_d, "value", "42");
  dom_style(inp_d, "background", "#111");
  dom_style(inp_d, "color", "#eee");
  dom_style(inp_d, "border", "1px solid #333");
  dom_style(inp_d, "padding", "6px 8px");
  dom_style(inp_d, "fontFamily", "'Courier New', monospace");
  dom_style(inp_d, "width", "120px");
  dom_append(extras, inp_d);
  dom_append(sec2, extras);
  render_p(sec2, "Valid keys: any prime > 13 (17, 19, 23, 29...). Coprime = invertible = valid spreading code.");
  dom_append(dom_body(), sec2);
  let sec3h = make_section("800px") in
  render_h2(sec3h, "Multi-User Test");
  render_p(sec3h, "6 users with different keys (17, 19, 23, 29, 31, 37) sharing one channel. Watch each user recover their own data from the superposition.");
  let btn = dom_create("button") in
  dom_text(btn, "Run 6-User Test");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "8px 16px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "borderRadius", "4px");
  dom_on(btn, "click", "demo_cdma_multi");
  dom_append(sec3h, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "dcdma-multi-result");
  dom_append(sec3h, br);
  dom_append(dom_body(), sec3h);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT CDMA vs Traditional");
  render_contrast_row(sec3, "Spreading codes", "Walsh-Hadamard matrices (O(N^2))", "Coprime integers (O(1) generation)");
  render_contrast_row(sec3, "Code assignment", "Central authority required", "Any coprime works. No coordination.");
  render_contrast_row(sec3, "Despreading", "Matrix multiplication", "Modular inverse per channel");
  render_contrast_row(sec3, "Capacity", "Code-limited (finite Walsh set)", "phi(N) = 2,419,200 users");
  render_contrast_row(sec3, "Patent status", "Qualcomm CDMA patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   CRT FOUNTAIN CODES -- dedicated demo page /demos/fountain. CC0 kill C19.
   Each CRT channel = one drop. Lose any channel, reconstruct from rest.
   6-channel TRUE ring: lose 1, recover from 5. 490 split: inner = data, boundary = parity.
   ================================================================ */

/* CRT lifting coefficients for Z/12612600 (6 channels) */
fn ftn_idem(ch) = (
  if ch == 0 then 11036025
  else if ch == 1 then 1401400
  else if ch == 2 then 9585576
  else if ch == 3 then 8494200
  else if ch == 4 then 3439800
  else 3880800
)

/* CRT reconstruct from 5 drops, skipping channel `skip` */
fn ftn_recon5(d, k, e, b, l, g, skip) = (
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  let vals = [d, k, e, b, l, g] in
  /* Sum all channels EXCEPT the skipped one */
  mut result = 0;
  mut ch = 0;
  while ch < 6 do (
    if ch == skip then 0
    else mut result = (result + vals[ch] * idem[ch]) % N_TRUE;
    mut ch = ch + 1
  );
  result
)

fn demo_fountain_run() = (
  let n = parse_int_from("#dftn-input") in
  let drop = parse_int_from("#dftn-drop") in
  let result_el = dom_query("#dftn-result") in
  let v = n % N_TRUE in
  let rd = v % 8 in let rk = v % 9 in let re = v % 25 in let rb = v % 49 in let rl = v % 11 in let rg = v % 13 in
  let ch_names = ["D(8)", "K(9)", "E(25)", "b(49)", "L(11)", "G(13)"] in
  let skip = drop % 6 in
  let mods = [8, 9, 25, 49, 11, 13] in
  /* Reconstruct from 5 drops */
  let partial = ftn_recon5(rd, rk, re, rb, rl, rg, skip) in
  /* Check: does the partial reconstruction give the right value for the missing channel? */
  let missing_expected = v % mods[skip] in
  let missing_got = partial % mods[skip] in
  /* The full reconstruction actually needs the missing channel's contribution.
     But CRT with 5 of 6: the missing drop can be inferred if value < product of 5 remaining moduli */
  /* Actually for TRUE ring, the 5-of-6 reconstruction suffices if value < product of 5 channels */
  /* Product of all 6 = N_TRUE. Drop one channel: remaining product = N_TRUE / m_skip */
  let recon_cap = N_TRUE / mods[skip] in
  /* Try all possible values for the missing channel */
  mut found = 0 - 1;
  mut trial = 0;
  while trial < mods[skip] do (
    let candidate = (partial + trial * ftn_idem(skip)) % N_TRUE in
    /* Check if this candidate has correct residues in all 5 known channels */
    let ok_d = if skip == 0 then 1 else if candidate % 8 == rd then 1 else 0 in
    let ok_k = if skip == 1 then 1 else if candidate % 9 == rk then 1 else 0 in
    let ok_e = if skip == 2 then 1 else if candidate % 25 == re then 1 else 0 in
    let ok_b = if skip == 3 then 1 else if candidate % 49 == rb then 1 else 0 in
    let ok_l = if skip == 4 then 1 else if candidate % 11 == rl then 1 else 0 in
    let ok_g = if skip == 5 then 1 else if candidate % 13 == rg then 1 else 0 in
    if ok_d + ok_k + ok_e + ok_b + ok_l + ok_g == 6 then
      (if found < 0 then mut found = candidate else 0)
    else 0;
    mut trial = trial + 1
  );
  let recovered = if found < 0 then 0 else found in
  let ok = if recovered == v then 1 else 0 in
  let skip_name = if skip == 0 then "D" else if skip == 1 then "K" else if skip == 2 then "E" else if skip == 3 then "b" else if skip == 4 then "L" else "G" in
  let is_inner = if skip == 0 then 1 else if skip == 2 then 1 else if skip == 3 then 1 else 0 in
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT FOUNTAIN CODE</p><p style='color:#88ddaa;margin:4px 0'>Value: " + "${v}" + "</p><p style='color:#b0b0c0;margin:4px 0'>6 drops: D=" + "${rd}" + " K=" + "${rk}" + " E=" + "${re}" + " b=" + "${rb}" + " L=" + "${rl}" + " G=" + "${rg}" + "</p><p style='color:#ffd700;margin:12px 0 4px'>LOST: " + skip_name + " channel (" + (if is_inner == 1 then "DEAD/inner" else "ALIVE/boundary") + " per 490 split)</p><p style='color:#88ddaa;margin:4px 0'>5 drops received. Missing channel reconstructed by CRT trial.</p><p style='color:" + (if ok == 1 then "#44ff88" else "#ff4444") + ";font-size:16px;margin:8px 0'>Recovered: " + "${recovered}" + (if ok == 1 then " -- PERFECT RECOVERY" else " -- MISMATCH") + "</p></div>")
)

fn demo_fountain_batch() = (
  let result_el = dom_query("#dftn-batch-result") in
  /* Test: for 100 random values, lose each of 6 channels, count recoveries */
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>BATCH ERASURE TEST: 100 values x 6 channel drops</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Lost Channel</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>490 Role</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Recovered</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Rate</th></tr>";
  let mods = [8, 9, 25, 49, 11, 13] in
  let names = ["D(8)", "K(9)", "E(25)", "b(49)", "L(11)", "G(13)"] in
  let roles = ["DEAD", "ALIVE", "DEAD", "DEAD", "ALIVE", "ALIVE"] in
  mut skip = 0;
  while skip < 6 do (
    mut ok_count = 0;
    mut i = 0;
    while i < 100 do (
      let v = (i * 137 + i * i * 41 + 7) % N_TRUE in
      let rd = v % 8 in let rk = v % 9 in let re = v % 25 in let rb = v % 49 in let rl = v % 11 in let rg = v % 13 in
      let partial = ftn_recon5(rd, rk, re, rb, rl, rg, skip) in
      mut found = 0 - 1;
      mut trial = 0;
      while trial < mods[skip] do (
        let candidate = (partial + trial * ftn_idem(skip)) % N_TRUE in
        let ok_d = if skip == 0 then 1 else if candidate % 8 == rd then 1 else 0 in
        let ok_k = if skip == 1 then 1 else if candidate % 9 == rk then 1 else 0 in
        let ok_e = if skip == 2 then 1 else if candidate % 25 == re then 1 else 0 in
        let ok_b = if skip == 3 then 1 else if candidate % 49 == rb then 1 else 0 in
        let ok_l = if skip == 4 then 1 else if candidate % 11 == rl then 1 else 0 in
        let ok_g = if skip == 5 then 1 else if candidate % 13 == rg then 1 else 0 in
        if ok_d + ok_k + ok_e + ok_b + ok_l + ok_g == 6 then
          (if found < 0 then mut found = candidate else 0)
        else 0;
        mut trial = trial + 1
      );
      if found == v then mut ok_count = ok_count + 1 else 0;
      mut i = i + 1
    );
    let color = if ok_count == 100 then "#44ff88" else "#ff8844" in
    mut html = html + "<tr><td style='padding:4px;color:#b0b0c0;font-size:13px'>" + names[skip] + "</td><td style='padding:4px;color:" + (if skip == 0 then "#ff6666" else if skip == 2 then "#ff6666" else if skip == 3 then "#ff6666" else "#88ddaa") + ";font-size:13px'>" + roles[skip] + "</td><td style='padding:4px;color:" + color + ";font-size:13px;font-weight:bold'>" + "${ok_count}" + "/100</td><td style='padding:4px;color:" + color + ";font-size:13px'>" + "${ok_count}" + "%</td></tr>";
    mut skip = skip + 1
  );
  dom_inner(result_el, html + "</table><p style='color:#b0b0c0;font-size:12px;margin:8px 0'>CRT guarantees: any 5 of 6 drops fully reconstruct the original value. The ring structure IS the erasure code. No Luby transform. No graph codes. Pure algebra.</p></div>")
)

fn page_fountain() = (
  dom_head_meta("description", "CRT Fountain Codes. 6-channel erasure coding over Z/12612600. Lose any 1 channel, recover from 5. CC0.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Fountain Codes\",\"description\":\"6-channel erasure coding over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/fountain\"}");
  let hero = make_hero("CRT Fountain Codes") in
  let eq = dom_create("div") in
  dom_text(eq, "C19: Qualcomm Raptor. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "CRT channels ARE fountain drops. Each value decomposes into 6 independent residues. Lose ANY one channel and reconstruct from the remaining 5. No Luby transform, no random graphs, no degree distributions. The ring structure IS the erasure code. 6 drops, 5 sufficient.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Erasure Principle", "By the Chinese Remainder Theorem, any value in Z/12612600 is UNIQUELY determined by its 6 residues mod {8,9,25,49,11,13}. These residues are algebraically independent. Losing one channel leaves 5 residues. Since the value is unique in Z/12612600, we can trial the missing channel (at most 49 trials for b-channel) to find the unique value matching all 5 known residues. Recovery is guaranteed with probability 1.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "6 drops", "CRT channels", "D(8), K(9), E(25), b(49), L(11), G(13) = 6 algebraically independent drops.", "");
  render_finding(g1, "5 sufficient", "CRT uniqueness", "Any 5 drops determine the unique value in Z/12612600.", "");
  render_finding(g1, "490 split", "Inner vs boundary", "DEAD={D,E,b} carry data. ALIVE={K,L,G} = parity channels.", "");
  render_finding(g1, "Max trial", "49 (b channel)", "Worst case: lose b-channel, trial 49 values. Average: 19 trials.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Value (0-12612599):", "dftn-input", "e.g. 42", "Drop & Recover", "demo_fountain_run", "dftn-result");
  let extras = dom_create("div") in
  dom_style(extras, "display", "flex");
  dom_style(extras, "gap", "8px");
  dom_style(extras, "alignItems", "center");
  dom_style(extras, "marginBottom", "12px");
  let inp_d = dom_create("input") in
  dom_attr(inp_d, "type", "text");
  dom_attr(inp_d, "id", "dftn-drop");
  dom_attr(inp_d, "placeholder", "channel to lose (0-5)");
  dom_attr(inp_d, "value", "0");
  dom_style(inp_d, "background", "#111");
  dom_style(inp_d, "color", "#eee");
  dom_style(inp_d, "border", "1px solid #333");
  dom_style(inp_d, "padding", "6px 8px");
  dom_style(inp_d, "fontFamily", "'Courier New', monospace");
  dom_style(inp_d, "width", "160px");
  dom_append(extras, inp_d);
  dom_append(sec2, extras);
  render_p(sec2, "Channel 0=D, 1=K, 2=E, 3=b, 4=L, 5=G. Try losing different channels.");
  dom_append(dom_body(), sec2);
  let sec3h = make_section("800px") in
  render_h2(sec3h, "Batch Erasure Test");
  render_p(sec3h, "Test 100 values: lose each channel in turn, verify 100% recovery.");
  let btn = dom_create("button") in
  dom_text(btn, "Run Batch Erasure (600 tests)");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "8px 16px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "borderRadius", "4px");
  dom_on(btn, "click", "demo_fountain_batch");
  dom_append(sec3h, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "dftn-batch-result");
  dom_append(sec3h, br);
  dom_append(dom_body(), sec3h);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT Fountain vs Traditional");
  render_contrast_row(sec3, "Code design", "Raptor: random bipartite graph + LT transform", "CRT: ring structure IS the code. No design.");
  render_contrast_row(sec3, "Overhead", "5-10% encoding overhead", "0% overhead. 6 drops = 6 channels.");
  render_contrast_row(sec3, "Recovery", "Probabilistic (BP decoding)", "Deterministic. CRT guarantees unique solution.");
  render_contrast_row(sec3, "Complexity", "O(k log k) encoding", "O(1) per channel (modular arithmetic)");
  render_contrast_row(sec3, "Patent status", "Qualcomm Raptor/RaptorQ patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   CRT-OFDM -- dedicated demo page /demos/ofdm. CC0 kill A6.
   6 CRT channels as orthogonal subcarriers. Phase-shift keying per channel.
   ================================================================ */

fn demo_ofdm_run() = (
  let data = parse_int_from("#dofdm-input") in
  let result_el = dom_query("#dofdm-result") in
  let d = data % N_TRUE in
  let mods = [8, 9, 25, 49, 11, 13] in
  let rd = d % 8 in let rk = d % 9 in let re = d % 25 in let rb = d % 49 in let rl = d % 11 in let rg = d % 13 in
  /* Bits per channel: log2(modulus) */
  /* D: 3, K: 3.17, E: 4.64, b: 5.61, L: 3.46, G: 3.7 = total 23.58 bits over 6 subcarriers */
  let total_bits = 23 in /* floor(log2(12612600)) */
  /* Simulate noise: add random-ish perturbation to each channel, then demodulate (nearest valid) */
  let noise_seed = d * 137 + 41 in
  let n_d = (noise_seed % 3) in let n_k = (noise_seed / 3 % 3) in let n_e = (noise_seed / 9 % 5) in
  let n_b = (noise_seed / 45 % 7) in let n_l = (noise_seed / 315 % 3) in let n_g = (noise_seed / 945 % 3) in
  /* "Received" = residue + noise, then demodulate = nearest valid constellation point = mod */
  let rx_d = (rd + n_d) % 8 in let rx_k = (rk + n_k) % 9 in let rx_e = (re + n_e) % 25 in
  let rx_b = (rb + n_b) % 49 in let rx_l = (rl + n_l) % 11 in let rx_g = (rg + n_g) % 13 in
  /* CRT reconstruct from received */
  let idem = [11036025, 1401400, 9585576, 8494200, 3439800, 3880800] in
  let recon = (rx_d * idem[0] + rx_k * idem[1] + rx_e * idem[2] + rx_b * idem[3] + rx_l * idem[4] + rx_g * idem[5]) % N_TRUE in
  /* Channel errors */
  let err_d = if rx_d == rd then 0 else 1 in let err_k = if rx_k == rk then 0 else 1 in
  let err_e = if rx_e == re then 0 else 1 in let err_b = if rx_b == rb then 0 else 1 in
  let err_l = if rx_l == rl then 0 else 1 in let err_g = if rx_g == rg then 0 else 1 in
  let total_err = err_d + err_k + err_e + err_b + err_l + err_g in
  let ok = if recon == d then 1 else 0 in
  /* Compare: WiFi 802.11a BPSK rate-1/2 = 0.5 bits/subcarrier. CRT = 23.58/6 = 3.93 bits/subcarrier */
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT-OFDM MODULATION</p><p style='color:#88ddaa;margin:4px 0'>Data symbol: " + "${d}" + " (" + "${total_bits}" + " bits)</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Channel</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Mod</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Tx</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Rx</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:11px'>Status</th></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>D</td><td style='padding:3px;color:#888;font-size:12px'>8</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rd}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_d}" + "</td><td style='padding:3px;color:" + (if err_d == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_d == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#88ddaa;font-size:12px'>K</td><td style='padding:3px;color:#888;font-size:12px'>9</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rk}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_k}" + "</td><td style='padding:3px;color:" + (if err_k == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_k == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>E</td><td style='padding:3px;color:#888;font-size:12px'>25</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${re}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_e}" + "</td><td style='padding:3px;color:" + (if err_e == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_e == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>b</td><td style='padding:3px;color:#888;font-size:12px'>49</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rb}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_b}" + "</td><td style='padding:3px;color:" + (if err_b == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_b == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#88ddaa;font-size:12px'>L</td><td style='padding:3px;color:#888;font-size:12px'>11</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rl}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_l}" + "</td><td style='padding:3px;color:" + (if err_l == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_l == 0 then "OK" else "ERR") + "</td></tr><tr><td style='padding:3px;color:#88ddaa;font-size:12px'>G</td><td style='padding:3px;color:#888;font-size:12px'>13</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${rg}" + "</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>" + "${rx_g}" + "</td><td style='padding:3px;color:" + (if err_g == 0 then "#44ff88" else "#ff4444") + ";font-size:12px'>" + (if err_g == 0 then "OK" else "ERR") + "</td></tr></table><p style='color:#ffd700;margin:12px 0 4px'>SPECTRAL EFFICIENCY</p><p style='color:#88ddaa;margin:4px 0'>CRT-OFDM: 23 bits / 6 subcarriers = 3.83 bits/subcarrier</p><p style='color:#b0b0c0;margin:4px 0'>WiFi 802.11a BPSK rate-1/2: 0.50 bits/subcarrier</p><p style='color:#ffd700;margin:4px 0'>Ratio: <b>7.67x</b> spectral efficiency (6-channel TRUE ring vs BPSK)</p><p style='color:" + (if ok == 1 then "#44ff88" else "#ff4444") + ";font-size:16px;margin:8px 0'>Reconstructed: " + "${recon}" + (if ok == 1 then " -- PERFECT" else " -- " + "${total_err}" + " channel error(s)") + "</p></div>")
)

fn page_ofdm() = (
  dom_head_meta("description", "CRT-OFDM Modulation. 6 CRT channels as orthogonal subcarriers. 7.67x spectral efficiency vs WiFi BPSK. CC0.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT-OFDM Modulation\",\"description\":\"6-channel orthogonal modulation over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/ofdm\"}");
  let hero = make_hero("CRT-OFDM") in
  let eq = dom_create("div") in
  dom_text(eq, "A6: WiFi/5G patents. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "Replace WiFi subcarriers with CRT channels. Each of 6 channels carries an independent PSK constellation: D(8-PSK), K(9-PSK), E(25-PSK), b(49-PSK), L(11-PSK), G(13-PSK). Total: 23 bits per symbol over 6 subcarriers = 3.83 bits/subcarrier. WiFi 802.11a BPSK rate-1/2: 0.50 bits/subcarrier. Ratio: 7.67x.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT-OFDM Principle", "A data symbol d in Z/12612600 decomposes into 6 residues. Each residue modulates a subcarrier using p-ary PSK (phase angle = 2*pi*r/m for residue r and modulus m). The receiver demodulates each subcarrier independently (nearest constellation point), then CRT reconstructs the original symbol. Channel independence: noise in one subcarrier cannot corrupt another. The 490 holographic split: DEAD={D,E,b} subcarriers carry primary data, ALIVE={K,L,G} provide error detection.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "6 subcarriers", "CRT decomposition", "D(8-PSK), K(9-PSK), E(25-PSK), b(49-PSK), L(11-PSK), G(13-PSK).", "");
  render_finding(g1, "7.67x efficiency", "TRUE ring capacity", "23 bits over 6 channels vs BPSK 0.5 bits/channel.", "");
  render_finding(g1, "490 split", "Data + detection", "Inner channels carry bits. Boundary channels detect errors for free.", "");
  render_finding(g1, "Graceful fading", "Independent channels", "If one channel fades, others continue. No catastrophic failure.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Data symbol (0-12612599):", "dofdm-input", "e.g. 42", "Modulate", "demo_ofdm_run", "dofdm-result");
  render_p(sec2, "6 subcarriers show Tx (transmitted residue) vs Rx (received with noise). Red = DEAD/inner channels. Green = ALIVE/boundary channels.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "CRT-OFDM vs WiFi");
  render_contrast_row(sec3, "Bits per subcarrier", "WiFi BPSK r=1/2: 0.50", "CRT: 3.83 (23 bits / 6 channels)");
  render_contrast_row(sec3, "Ratio", "Baseline", "7.67x higher spectral efficiency");
  render_contrast_row(sec3, "Error detection", "None built-in (needs CRC-32)", "CRT: invalid values flag errors for free");
  render_contrast_row(sec3, "Channel fading", "Entire signal degrades uniformly", "Independent per-channel fading. Graceful.");
  render_contrast_row(sec3, "Patent status", "WiFi/5G OFDM patents", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec3)
)

/* ================================================================
   GPU COMPUTE -- dedicated demo page /demos/gpu_compute. CC0 kill S1.
   6 CRT channels as independent compute workgroups.
   f(x) distributes over CRT: compute per-channel, reconstruct once.
