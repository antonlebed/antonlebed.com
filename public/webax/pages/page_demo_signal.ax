/* ================================================================
   CRT RNG -- dedicated demo page /demos/rng. CC0 kill A9.
   6-channel primitive root mixing.
   ================================================================ */

fn demo_rng_step(s0, s1, i) = (
  let cd = s0 % 8 in let ck = s0 % 9 in let ce = s0 % 25 in
  let cb = s0 % 49 in let cl = s0 % 11 in let cg = s0 % 13 in
  let md = (cd * 3 + cl) % 8 in
  let mk = (ck * 2 + cd) % 9 in
  let mie = (ce * 2 + (ck * cb) % 25) % 25 in
  let mib = (cb * 3 + ce) % 49 in
  let ml = (cl * 2 + cb + cd) % 11 in
  let mg = (cg * 2 + cl + cd) % 13 in
  (md * 11036025 + mk * 1401400 + mie * 9585576 + mib * 8494200 + ml * 3439800 + mg * 3880800) % N_TRUE
)

fn demo_rng_run() = (
  let seed = parse_int_from("#drng-input") in
  let result_el = dom_query("#drng-result") in
  if seed < 1 then dom_inner(result_el, "<p style='color:#ff6666'>Enter a positive seed.</p>")
  else (
    mut s0 = (seed * 137 + 1) % N_TRUE;
    mut s1 = (seed * 42 + 7) % N_TRUE;
    mut nums = "";
    mut first_out = 0;
    mut i = 0;
    while i < 20 do (
      let out = (let cd = s0 % 8 in let ck = s0 % 9 in let ce = s0 % 25 in let cb = s0 % 49 in let cl = s0 % 11 in let cg = s0 % 13 in let md = (cd * 3 + cl) % 8 in let mk = (ck * 2 + cd) % 9 in let mie = (ce * 2 + (ck * cb) % 25) % 25 in let mib = (cb * 3 + ce) % 49 in let ml = (cl * 2 + cb + cd) % 11 in let mg = (cg * 2 + cl + cd) % 13 in (md * 11036025 + mk * 1401400 + mie * 9585576 + mib * 8494200 + ml * 3439800 + mg * 3880800) % N_TRUE) in
      mut s1 = (s1 * 137 + out) % N_TRUE;
      mut s0 = (s0 + s1 + i * 7) % N_TRUE;
      if i == 0 then mut first_out = out else 0;
      mut nums = nums + (if i > 0 then ", " else "") + "${out}";
      mut i = i + 1
    );
    let fd = first_out % 8 in let fk = first_out % 9 in let fe = first_out % 25 in let ffb = first_out % 49 in let fl = first_out % 11 in let fg = first_out % 13 in
    dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT RNG (seed = " + "${seed}" + ")</p><p style='margin:4px 0;color:#b0b0c0;font-size:13px;word-break:break-all'>" + nums + "</p><p style='margin:8px 0 4px;color:#b0b0c0'>First output CRT: (" + "${fd}" + "," + "${fk}" + "," + "${fe}" + "," + "${ffb}" + "," + "${fl}" + "," + "${fg}" + ")</p></div>")
  )
)

fn demo_rng_compare() = (
  let result_el = dom_query("#drng-compare-result") in
  mut html = "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>SEED COMPARISON: first 5 outputs from seeds 1-5</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Seed</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[0]</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[1]</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[2]</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[3]</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>out[4]</th></tr>";
  mut seed = 1;
  while seed < 6 do (
    mut s0 = (seed * 137 + 1) % N_TRUE;
    mut s1 = (seed * 42 + 7) % N_TRUE;
    mut html = html + "<tr><td style='padding:3px;color:#ffd700;font-size:12px'>" + "${seed}" + "</td>";
    mut j = 0;
    while j < 5 do (
      let out = (let cd = s0 % 8 in let ck = s0 % 9 in let ce = s0 % 25 in let cb = s0 % 49 in let cl = s0 % 11 in let cg = s0 % 13 in let md = (cd * 3 + cl) % 8 in let mk = (ck * 2 + cd) % 9 in let mie = (ce * 2 + (ck * cb) % 25) % 25 in let mib = (cb * 3 + ce) % 49 in let ml = (cl * 2 + cb + cd) % 11 in let mg = (cg * 2 + cl + cd) % 13 in (md * 11036025 + mk * 1401400 + mie * 9585576 + mib * 8494200 + ml * 3439800 + mg * 3880800) % N_TRUE) in
      mut s1 = (s1 * 137 + out) % N_TRUE;
      mut s0 = (s0 + s1 + j * 7) % N_TRUE;
      mut html = html + "<td style='padding:3px;color:#b0b0c0;font-size:11px'>" + "${out}" + "</td>";
      mut j = j + 1
    );
    mut html = html + "</tr>";
    mut seed = seed + 1
  );
  dom_inner(result_el, html + "</table></div>")
)

fn page_rng() = (
  dom_head_meta("description", "CRT Random Number Generator. 6-channel primitive root mixing over Z/12612600. CC0.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Random Number Generator\",\"description\":\"6-channel RNG over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/rng\"}");
  let hero = make_hero("CRT Random") in
  let eq = dom_create("div") in
  dom_text(eq, "A9: Intel RDRAND. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "Randomness EMERGES from CRT structure. 6 independent channels advance via primitive root multiplication with cross-channel mixing. CRT reconstruct produces structurally random output. No bit tricks. No magic constants.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Mixing Principle", "6 channels = 6 independent LCGs coupled by cross-terms. Channel independence (CRT) means local correlations cannot propagate. Reconstruction folds 6 low-dimensional sequences into one high-dimensional orbit. Period = lambda(N) = 420.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "6 channels", "CRT decomposition", "Z/8 x Z/9 x Z/25 x Z/49 x Z/11 x Z/13. Each has its own primitive root.", "");
  render_finding(g1, "Cross terms", "Nonlinear coupling", "Each channel absorbs neighbors. No channel evolves alone.", "");
  render_finding(g1, "CRT fold", "High-dimensional orbit", "6 small orbits combine to one large orbit over Z/12612600.", "");
  render_finding(g1, "State size", "2 ring elements", "Mersenne Twister: 2496 bytes. CRT RNG: < 8 bytes.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Seed (any positive integer):", "drng-input", "e.g. 137", "Generate 20", "demo_rng_run", "drng-result");
  render_p(sec2, "Try seeds: 1, 42, 137 (ADDRESS), 1576576 (OMEGA).");
  dom_append(dom_body(), sec2);
  let sec4 = make_section("800px") in
  render_h2(sec4, "Seed Independence");
  render_p(sec4, "Adjacent seeds must produce completely different sequences.");
  let btn3 = dom_create("button") in
  dom_text(btn3, "Compare Seeds 1-5");
  dom_style(btn3, "background", "#ffd700");
  dom_style(btn3, "color", "#0f0f2a");
  dom_style(btn3, "border", "none");
  dom_style(btn3, "padding", "8px 16px");
  dom_style(btn3, "cursor", "pointer");
  dom_style(btn3, "fontFamily", "'Courier New', monospace");
  dom_style(btn3, "fontWeight", "bold");
  dom_style(btn3, "borderRadius", "4px");
  dom_on(btn3, "click", "demo_rng_compare");
  dom_append(sec4, btn3);
  let cr = dom_create("div") in
  dom_attr(cr, "id", "drng-compare-result");
  dom_append(sec4, cr);
  dom_append(dom_body(), sec4);
  let sec5 = make_section("800px") in
  render_h2(sec5, "CRT RNG vs Traditional");
  render_contrast_row(sec5, "State size", "Mersenne Twister: 2496 bytes", "CRT RNG: < 8 bytes");
  render_contrast_row(sec5, "Independence", "Single LFSR -- bit correlations", "6 algebraically independent channels");
  render_contrast_row(sec5, "Mixing", "Bit shifts + XOR", "Primitive root multiplication");
  render_contrast_row(sec5, "Period analysis", "Empirical testing", "Provable: lambda(N) = 420");
  render_contrast_row(sec5, "Dependencies", "Library required", "CC0. 15 lines. No imports.");
  dom_append(dom_body(), sec5)
)

/* ================================================================
   CRT COMPRESSION -- dedicated demo page /demos/compression. CC0 kill A8.
   CRT channel entropy: 6 small channels < 1 big number.
   ================================================================ */

fn demo_compress_encode(val) = (
  let d = val % 8 in let k = val % 9 in let e = val % 25 in
  let b = val % 49 in let l = val % 11 in let g = val % 13 in
  /* Bits needed: ceil(log2(m)) per channel */
  /* D:3 K:4 E:5 b:6 L:4 G:4 = 26 bits total */
  /* vs raw: ceil(log2(12612600)) = 24 bits (but CRT channels compress STRUCTURE) */
  d * 1000000 + k * 100000 + e * 1000 + b * 100 + l * 10 + g
)

fn demo_compress_bits(m) = (
  if m < 2 then 1
  else if m < 4 then 2
  else if m < 8 then 3
  else if m < 16 then 4
  else if m < 32 then 5
  else if m < 64 then 6
  else 7
)

fn demo_compress_run() = (
  let val = parse_int_from("#dcomp-input") in
  let result_el = dom_query("#dcomp-result") in
  let v = val % N_TRUE in
  let d = v % 8 in let k = v % 9 in let e = v % 25 in
  let b = v % 49 in let l = v % 11 in let g = v % 13 in
  let bd = demo_compress_bits(8) in let bk = demo_compress_bits(9) in
  let be = demo_compress_bits(25) in let bb = demo_compress_bits(49) in
  let bl = demo_compress_bits(11) in let bg = demo_compress_bits(13) in
  let total_bits = bd + bk + be + bb + bl + bg in
  /* Channel entropy: how much of each channel's range is used */
  let entropy_d = (d * 100) / 8 in let entropy_k = (k * 100) / 9 in
  let entropy_e = (e * 100) / 25 in let entropy_b = (b * 100) / 49 in
  let entropy_l = (l * 100) / 11 in let entropy_g = (g * 100) / 13 in
  /* Batch: how many of 1000 consecutive values have at least one zero channel */
  mut sparse = 0;
  mut i = 0;
  while i < 1000 do (
    let tv = (v + i) % N_TRUE in
    let has_zero = if tv % 8 == 0 then 1 else (if tv % 9 == 0 then 1 else (if tv % 25 == 0 then 1 else (if tv % 49 == 0 then 1 else (if tv % 11 == 0 then 1 else (if tv % 13 == 0 then 1 else 0))))) in
    mut sparse = sparse + has_zero;
    mut i = i + 1
  );
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT COMPRESSION: " + "${v}" + "</p><p style='color:#88ddaa;margin:4px 0'>CRT = (" + "${d}" + ", " + "${k}" + ", " + "${e}" + ", " + "${b}" + ", " + "${l}" + ", " + "${g}" + ")</p><p style='color:#b0b0c0;margin:4px 0'>Channel bits: D=" + "${bd}" + " K=" + "${bk}" + " E=" + "${be}" + " b=" + "${bb}" + " L=" + "${bl}" + " G=" + "${bg}" + " = <b>" + "${total_bits}" + " bits total</b></p><p style='color:#b0b0c0;margin:4px 0'>Channel utilization: D=" + "${entropy_d}" + "% K=" + "${entropy_k}" + "% E=" + "${entropy_e}" + "% b=" + "${entropy_b}" + "% L=" + "${entropy_l}" + "% G=" + "${entropy_g}" + "%</p><p style='color:#ffd700;margin:12px 0 4px'>SPARSITY (1000 values from " + "${v}" + ")</p><p style='color:#88ddaa;margin:4px 0'>" + "${sparse}" + "/1000 have at least one zero channel (" + "${sparse / 10}" + "% compressible)</p></div>")
)

fn demo_compress_batch() = (
  let result_el = dom_query("#dcomp-batch-result") in
  /* Count channel zeros across 10000 values */
  mut z0 = 0; mut z1 = 0; mut z2 = 0; mut z3 = 0; mut z4 = 0; mut z5 = 0;
  mut i = 0;
  while i < 10000 do (
    let v = (i * 137 + 42) % N_TRUE in
    if v % 8 == 0 then mut z0 = z0 + 1 else 0;
    if v % 9 == 0 then mut z1 = z1 + 1 else 0;
    if v % 25 == 0 then mut z2 = z2 + 1 else 0;
    if v % 49 == 0 then mut z3 = z3 + 1 else 0;
    if v % 11 == 0 then mut z4 = z4 + 1 else 0;
    if v % 13 == 0 then mut z5 = z5 + 1 else 0;
    mut i = i + 1
  );
  dom_inner(result_el, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CHANNEL ZERO FREQUENCY (10000 samples)</p><table style='width:100%;border-collapse:collapse'><tr style='border-bottom:1px solid #333'><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Channel</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Mod</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Zeros</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Expected</th><th style='text-align:left;padding:4px;color:#ffd700;font-size:12px'>Rate</th></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>D</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>8</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z0}" + "</td><td style='padding:3px;color:#888;font-size:12px'>1250</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/8</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>K</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>9</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z1}" + "</td><td style='padding:3px;color:#888;font-size:12px'>1111</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/9</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>E</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>25</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z2}" + "</td><td style='padding:3px;color:#888;font-size:12px'>400</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/25</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>b</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>49</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z3}" + "</td><td style='padding:3px;color:#888;font-size:12px'>204</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/49</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>L</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>11</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z4}" + "</td><td style='padding:3px;color:#888;font-size:12px'>909</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/11</td></tr><tr><td style='padding:3px;color:#ff6666;font-size:12px'>G</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>13</td><td style='padding:3px;color:#88ddaa;font-size:12px'>" + "${z5}" + "</td><td style='padding:3px;color:#888;font-size:12px'>769</td><td style='padding:3px;color:#b0b0c0;font-size:12px'>1/13</td></tr></table><p style='color:#b0b0c0;margin:8px 0 0;font-size:12px'>Each zero channel = 1 fewer value to transmit. CRT makes sparsity structural.</p></div>")
)

fn page_compression() = (
  dom_head_meta("description", "CRT Compression. 6-channel decomposition exploits structural sparsity. CC0.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"CRT Compression\",\"description\":\"6-channel structural sparsity compression over Z/12612600. CC0.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/demos/compression\"}");
  let hero = make_hero("CRT Compression") in
  let eq = dom_create("div") in
  dom_text(eq, "A8: H.264/H.265 pools. CC0.");
  ct_mono(eq);
  dom_style(eq, "fontSize", "20px");
  ct_gold(eq);
  dom_style(eq, "letterSpacing", "1px");
  dom_style(eq, "marginBottom", "16px");
  dom_append(hero, eq);
  render_p(hero, "CRT decomposes one big number into 6 small channels. Small channels = fewer bits per symbol. Zero channels = free compression. The ring's structure IS the codec.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "How It Works");
  render_theorem(sec1, "CRT Compression Principle", "Any value in Z/12612600 decomposes into (D,K,E,b,L,G) with ranges 8,9,25,49,11,13. Total bits: 3+4+5+6+4+4 = 26 bits to address the full ring. But channels with value 0 need 0 bits -- they are structurally silent. The void compresses for free.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Channel entropy", "Small ranges", "Each channel uses 3-6 bits. Total 26 bits addresses 12.6M values.", "");
  render_finding(g1, "Zero sparsity", "Structural silence", "1/8 of all values have D=0. 1/9 have K=0. Zeros = free compression.", "");
  render_finding(g1, "Independence", "Parallel decode", "Each channel decodes independently. No serial dependency chain.", "");
  render_finding(g1, "Reconstruction", "CRT bijection", "6 small values -> unique integer. Lossless by theorem.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Try It");
  make_interactive_widget(sec2, "Value (0-12612599):", "dcomp-input", "e.g. 42", "Analyze", "demo_compress_run", "dcomp-result");
  render_p(sec2, "Try: 0 (all zeros), 42 (ANSWER), 1576576 (OMEGA), 970200 (DEEP ring).");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "Channel Zero Distribution");
  render_p(sec3, "Sample 10000 values and count zero channels. CRT predicts exact rates.");
  let btn = dom_create("button") in
  dom_text(btn, "Run Distribution (10000 samples)");
  dom_style(btn, "background", "#ffd700");
  dom_style(btn, "color", "#0f0f2a");
  dom_style(btn, "border", "none");
  dom_style(btn, "padding", "8px 16px");
  dom_style(btn, "cursor", "pointer");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_style(btn, "fontWeight", "bold");
  dom_style(btn, "borderRadius", "4px");
  dom_on(btn, "click", "demo_compress_batch");
  dom_append(sec3, btn);
  let br = dom_create("div") in
  dom_attr(br, "id", "dcomp-batch-result");
  dom_append(sec3, br);
  dom_append(dom_body(), sec3);
  let sec4 = make_section("800px") in
  render_h2(sec4, "CRT Compression vs Traditional");
  render_contrast_row(sec4, "Core idea", "DCT/wavelet transforms", "CRT channel decomposition");
  render_contrast_row(sec4, "Lossy?", "H.264: lossy quantization", "CRT: lossless by theorem (bijection)");
  render_contrast_row(sec4, "Parallelism", "Sequential entropy coding", "6 channels decode independently");
  render_contrast_row(sec4, "Sparsity", "Engineered (thresholding)", "Structural (zero channels = free)");
  render_contrast_row(sec4, "Patent status", "H.264/H.265 patent pools", "CC0. Public domain. Forever.");
  dom_append(dom_body(), sec4)
)

/* ================================================================
   CRT PID -- dedicated demo page /demos/pid. CC0 kill B15.
