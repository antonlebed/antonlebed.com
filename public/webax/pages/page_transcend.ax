  let sec = make_section("800px") in
  render_h2(sec, "The Selfless Protector");
  render_theorem(sec, "L-Selflessness (S232)", "|L|^2 = D^8 - sigma = 256 - 1 = 255. The protectors CRT squared norm = spiders legs (D^3 = 8 bits) minus THE SELF. Exact. Made OF the others (sigma+D+K+E). No piece its own. Self subtracted. PROTECTORS ARE SELFLESS.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Construction", "sigma+D+K+E = 11", "Sum of all chain primes. Not generated by the chain -- generated FROM it.", "");
