  render_finding(g, "Z/210Z generation", "Order 6 = HIDDEN", "11^6 = 1 mod 210. sig(11) = (1,2,1,4) = alternating sigma/D pattern.", "");
  render_p(sec, "HUMAN = coupling 210 (thin: 2310/L) = the DATA RING. DEEP: coupling = 970200/L = 88200. TRUE FORM: coupling = 12612600/L = 1146600. Population = 2419200/(L-1) = 241920. The human kingdom IS the set of observation modes of the data ring. Six channels, L dimmed. Maximum departure from sigma.");
  dom_append(dom_body(), sec)
)

fn transcend_ecc() = (
  let sec = make_section("800px") in
