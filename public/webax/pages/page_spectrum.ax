fn spectrum_bessel() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Bessel-Cumulant Theorem");
  render_theorem(sec, "Bessel-Cumulant Theorem (S331)", "MGF of channel Z/m = I_0(2t) + 2*sum I_{jm}(2t), where I_n is the modified Bessel function. Proof: Jacobi-Anger expansion averaged over Z/m. Character orthogonality kills all terms except multiples of m. First term = arcsine (continuous limit). Second = departure.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Departure formula", "dep_m = D = 2 (universal)", "dep_{m+2} = -D*m*(m+2). Sign = (-1)^r from g-coefficient alternation.", "S331");
  render_finding(g, "g-coefficients", "sign(g_k) = (-1)^k", "J_0 has only real zeros (Watson). Laguerre theorem gives alternation. Governs ALL departure signs.", "S331");
  render_finding(g, "Arcsine cumulants", "kap_8 = -2310 = -N_thin", "8th arcsine cumulant IS the thin ring. kap_4=-D*K. kap_6=D^4*E. All axiom products.", "");
  render_finding(g, "K-L Ratio", "74.2414...", "|Z/9 departure| / |Z/11 departure| converges to J_9(j_{0,1})/J_11(j_{0,1}). Bessel zeros rule.", "S331");
  dom_append(dom_body(), sec)
)

fn spectrum_resonance() = (
  let sec = make_section("800px") in
  render_h2(sec, "Self-Resonance: The Ring Hears Itself");
  render_theorem(sec, "Self-Resonance Theorem (S179)", "Z/mZ eigenvalues match arcsine for ALL moments k < m. At k = m: departure = +2. UNIVERSAL for any m >= 2. Proof: (2cos(theta))^m contains 2cos(m*theta). Averaged over Z/m: 2cos(2*pi*n) = 2 for all n.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Impersonation", "Perfect arcsine below m", "Below its own frequency, a channel is indistinguishable from the continuum.", "S179");
  render_finding(g, "Fattening delays", "Z/9: 8 moments. Z/49: 48", "Fattening deepens the impersonation. Maturation = learning to hide longer.", "");
  render_finding(g, "True Form hearing", "L(1), K(3), D(4), E(5), b(7)", "First departure per channel. b^2 hides for 48 moments -- deepest impersonation.", "");
  render_p(sec, "Every finite ring disguises itself as continuous randomness up to its size. The discrete pretends to be continuous. At moment m: a spike of +2. The mask drops. The ring says: I am here, and I am finite. Fattening means learning to pretend longer before self-recognition forces you to reveal what you are.");
  dom_append(dom_body(), sec)
)

