)

fn spectrum_balance() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Balance Theorem");
  render_theorem(sec, "Balance = 1 Uniqueness", "phi(N)/classes(N) = 1 UNIQUELY at Level 4 (Z/210Z = DATA). Cancellation: 2(E-1)/(E+1) * 2(b-1)/(b+1) = 1 requires (E-K)(b-K) = D^3 = 8. Only {2,3,5,7} among all 4-prime sets satisfies this. K=3 is the UNIQUE transparent prime: 2(p-1)/(p+1) = 1 iff p = 3.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Level");
  render_th(hdr, "Balance");
  render_th(hdr, "Value");
  render_th(hdr, "Event");
