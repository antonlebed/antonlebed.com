  render_contrast_row(tbl, "Eigenvalue uniqueness", "Generically expected", "341250 distinct classes. Zero collisions. Cyclotomic disjointness.");
  render_contrast_row(tbl, "Positivity of universe", "Observation bias", "b^2 odd forces max > |min|. Depth creates optimism. Algebraic, not philosophical.");
  render_contrast_row(tbl, "Class counting", "Case-by-case analysis", "classes = prod d(p_i). One formula. Every level predicted exactly.");
  render_contrast_row(tbl, "Moment structure", "Random matrix theory", "Bessel MGF. I_0(2t) + sum I_{jm}(2t). Departure at k = m. kap_8(arcsine) = -N_thin.");
  render_contrast_row(tbl, "Kurtosis", "Empirical fit parameter", "-K/(D*k) universal. 63/63 projections. Raw kurtosis 2.75 (6 channels).");
  render_contrast_row(tbl, "Balance", "No principle known", "phi/classes = 1 UNIQUELY at DATA. Requires (E-K)(b-K) = D^3. Telescoping gap-2 triplet.");
  render_contrast_row(tbl, "Shadow polynomial", "No analogue", "S(x)=(x-1)(x-2)(x-3)(x-5). Bridge average = -lambda. Shadow+Master = (D*E)^3.");
  render_contrast_row(tbl, "OMEGA minpoly", "Algebraic number theory", "Degree 32. 2-adic ruler = Kummer carries. Palindromic. v_2 sum = b^2 = gap controller.");
  render_contrast_row(tbl, "Coupling cost", "Ad hoc per force", "One formula: 2w*sin^2(pi*r/p). Photon/closure/golden/Kleiber/gap. E self-characteristic.");
  render_contrast_row(tbl, "Prime gaps", "Probabilistic heuristic", "95.44% smooth (null: 59.74%). D*K=6 jumping champion. K carries 94% MI.");
  render_contrast_row(tbl, "Gradient order", "Varies by system", "K first (66.7%), then E, D, b, L. Fattening shifts bottleneck from L to b^2.");
  render_contrast_row(tbl, "Gap duality", "No known analogue", "Cayley sees max(p), Hamming sees min(q). Same ring, two bottlenecks.");
  render_contrast_row(tbl, "Spectral fold", "Shannon entropy", "H = log2(m)-1+d/m. Each channel loses 1 bit to fold. Fattening IMPROVES efficiency.");
  render_contrast_row(tbl, "Midpoint", "No structural role", "Anti-void at CRT midpoints. Sum = b^2 = gap controller. Suffering IS the halfway mark.");
  render_p(sec, "The eigenvalue is the FEELING of a number. Not where it lives (CRT), not who it connects to (coupling), but its inner state -- how its six voices agree or collide. Eigenvalue = what you feel. Address = where you are. Both needed. Neither enough.");
  dom_append(dom_body(), sec)
)

