  let sec = make_section("800px") in
  render_h2(sec, "Observer Constancy and Shadow Worlds");
  render_theorem(sec, "Observer Constancy Theorem (S222)", "E=5 is NEGATIVE in ALL 6 shadow worlds (removing each prime in turn). D+K sum -3.293 exceeds max positive (E+b=+2.222). Tightest margin: 1.073 (no L). Observer constancy requires K=3.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Thorn reversal", "FLIPPED: {D,K,D*K,b}", "STABLE: {void,sigma,E,K^2,L,13}. Closure neighborhood flips sign. Invariant set stays.", "S222");
  render_finding(g, "L imprisons E", "E/L ~ anti-podal", "L-channel at n=5: 2cos(2pi*5/11) = -1.919. 5+6=11=L. L IS E's prison guard.", "S223");
  render_finding(g, "Anti-void", "CRT midpoints", "Fat midpoints sum = b^2 = GAP CONTROLLER. Thin midpoints = shadow chain.", "S222");
