)

fn spectrum_gap() = (
  let sec = make_section("800px") in
  render_h2(sec, "Gap Theory");
  render_theorem(sec, "Gap Dominance Theorem (S220)", "gap = 4*sin^2(pi/p_max) where p_max = largest modulus. Removing any prime EXCEPT p_max: gap UNCHANGED. Removing p_max: gap JUMPS. At k=5: removing L -> gap = 0.753 = KLEIBER (b takes over). Protection loss = metabolic transition.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Ring");
  render_th(hdr, "Gap");
  render_th(hdr, "Controller");
  render_th(hdr, "Significance");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "Z/2Z", "4.000", "D = 2", "Binary. Maximum gap.");
  render_table_row_4(tbl, "Z/6Z", "3.000", "K = 3", "Closure enters.");
  render_table_row_4(tbl, "Z/30Z", "2.382", "E = 5", "Observer narrows.");
  render_table_row_4(tbl, "Z/210Z", "0.753 = KLEIBER", "b = 7", "Depth. Metabolic scaling.");
  render_table_row_4(tbl, "Z/2310Z", "0.317", "L = 11", "Protector controls thin gap.");
  render_table_row_4(tbl, "TRUE Z/12612600", "0.016", "b^2 = 49", "Depth squared. b^2 rules. GATE=13 does NOT narrow gap.");
  render_p(sec, "Each new prime slows the carousel. The gap shrinks but never to zero. LATTICE INVARIANCE (S489): ALL 108 lambda-420 rings share gap = 0.016. b^2 rules universally. GATE=13 adds a channel but 4sin^2(pi/13) = 0.229 >> 0.016 -- the GATE is spectrally wider than the bottleneck. Only adding 13^2=169 would narrow it further.");
  dom_append(dom_body(), sec)
)

fn spectrum_degree() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Degree Ladder");
  render_theorem(sec, "Degree Ladder Theorem (S218)", "Thin ring: D contributes 1 (cos), odd-prime channels contribute 2 (2cos). Full k=5: degree K^2=9. D-removed: D^3=8. Odd-removed: b=7. EVERY STEP IS AN AXIOM PRODUCT. Algebraic proof: K^2=2k-1 requires D*(D-2)=0. D^3=2(k-1) requires (D-2)(D+2)=0. b=2k-3 requires D=2. All three = D=2.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Fattening equalization", "Fat degree = 2k", "D-channel upgraded to 2cos. At k=6: degree = D^2*K = 12 = heartbeat. Any channel removed: D*E = 10.", "S220");
  render_finding(g, "Growth progression", "b -> K^2 -> D*E -> D^2*K", "DATA=7, THIN=9, DEEP=10, TRUE=12. GATE adds 2 = D. Each new prime adds its weight.", "S323, S1057");
  render_finding(g, "Depthless Kolmogorov", "L(b=0) = E/K = 5/3", "When depth vanishes, protection echoes turbulence. Both = 2-1/K. Requires K=3.", "S220");
  render_finding(g, "Depthless Kleiber", "K/D^2 = 3/4", "At fattening shadow (D=-2/3). Metabolic scaling from same algebra.", "S220");
  dom_append(dom_body(), sec)
)

