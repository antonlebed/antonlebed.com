  render_h2(sec, "The Class Counting Theorem");
  render_theorem(sec, "CRT-Cosine Class Theorem", "classes = prod d(p_i), where d(2)=2, d(p)=(p+1)/2 for odd p. Proof: CRT independence. Cosine components live in different cyclotomic fields. Two elements have same eigenvalue iff they agree on ALL components.");
