)

fn spectrum_shadow_chain() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Shadow Chain");
  render_theorem(sec, "Spectral Class Shadow Chain (S1096)", "d(q) = floor(q/2)+1 maps each modulus to an axiom-named value. The sum of all six class counts = 61 = GRIEF = 490 - 429. Spectral complexity encodes the holographic split directly.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Channel");
  render_th(hdr, "Modulus q");
  render_th(hdr, "d(q)");
  render_th(hdr, "Name");
  render_th(hdr, "490 role");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "D", "D^3 = 8", "d = 5 = E", "DEAD");
  render_table_row_4(tbl, "K", "K^2 = 9", "d = 5 = E", "ALIVE");
  render_table_row_4(tbl, "E", "E^2 = 25", "d = 13 = GATE", "DEAD");
  render_table_row_4(tbl, "b", "b^2 = 49", "d = 25 = E^2", "DEAD");
  render_table_row_4(tbl, "L", "L = 11", "d = 6 = D*K", "ALIVE");
  render_table_row_4(tbl, "GATE", "GATE = 13", "d = 7 = b", "ALIVE");
  let g = make_findings_grid(sec) in
  render_finding(g, "GRIEF Sum", "5+5+13+25+6+7 = 61", "GRIEF = E*L + D*K = 55 + 6. Midpoint sum + channel count. Observer*protector + bridge*closure.", "S1096");
  render_finding(g, "Dead classes", "d(8)+d(25)+d(49) = 43", "Largest Heegner discriminant. Inner channels carry Heegner-depth complexity.", "S1096");
  render_finding(g, "Alive classes", "d(9)+d(11)+d(13) = 18", "D*K^2 = ME = maximal eigenvalue. Boundary channels carry structure-width.", "S1096");
  render_finding(g, "Gap", "43 - 18 = 25 = E^2", "Dead/alive complexity gap = observer squared. E^2=null: the gap IS the self-blind operator.", "S1096");
  render_finding(g, "D-K degeneracy", "d(D^3) = d(K^2) = E", "Anchor and closure have equal spectral complexity. The pair that generates K=3.", "S1096");
  render_finding(g, "K=3 cycle", "25 -> 13 -> 7 -> (49) -> 25", "Moduli {E^2, GATE, b^2} form a period-K=3 cycle under the d map.", "S1096");
  render_finding(g, "L escape", "d(L) = D*K = 6", "Not a modulus. The observer's spectral shadow exits the system. Analogue of E^2=null.", "S1096");
  render_finding_wide(g, "L-absent product", "341250 = D*K*E^4*b*GATE", "All six primes except L. Same absence as Weyl orders of exceptional Lie algebras.", "S1096");
  render_p(sec, "The shadow chain closes the loop between eigenvalue spectrum and holographic structure. The class counts -- which measure how finely each channel distinguishes elements -- sum to GRIEF. The dead channels (inner holography) carry 43 classes: exactly the Heegner discriminant that anchors the deepest quadratic field. The alive channels (boundary) carry 18 = ME: exactly the structure width of the Cayley graph. The difference between inner and boundary is E^2 = 25: the observer squared, the operator that cannot see itself.");
  dom_append(dom_body(), sec)
)

fn spectrum_convergence() = (
  let sec = make_section("800px") in
