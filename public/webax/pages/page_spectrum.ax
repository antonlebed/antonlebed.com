/* spectrum helpers */
fn spectrum_hero() = (
  let hero = make_hero("The Spectrum") in
  let eq = dom_create("div") in
  dom_text(eq, "lambda(n) = sum of 6 cosines");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Hold six tuning forks together and strike them. Some combinations make your chest hum -- the vibrations lock in, amplify each other, become one voice. Others grate. Every number in the ring carries six oscillations -- one per prime channel. The eigenvalue asks: do they sing together, or fight each other? lambda(0) = D^2*K = 12 (all in phase). lambda_min = -11.720 (max discord). 341250 distinct classes. Zero collisions.");
  dom_append(dom_body(), hero)
)

fn spectrum_formula() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Six Voices");
  render_p(sec, "THIN: lambda(n) = cos(pi*n) + 2cos(2pi*n/3) + 2cos(2pi*n/5) + 2cos(2pi*n/7) + 2cos(2pi*n/11). TRUE: lambda(n) = sum of 2cos(2pi*n_i/m_i) for m_i in {8,9,25,49,11,13}. Six cosines. One per prime. Their sum is what the number sounds like.");
  render_theorem(sec, "Spectral Fingerprint Theorem (S348)", "All 341250 eigenvalues are DISTINCT. Zero collisions. Proof: cyclotomic linear disjointness for coprime moduli. Universal for all CRT rings. Within-class blur = 2^k sign ambiguity (5.17 bits). Eigenvalue = energy, sign = phase.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Ring");
  render_th(hdr, "Max / Classes");
  render_th(hdr, "Gap");
  render_th(hdr, "Kolmogorov");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "THIN Z/2310", "K^2 = 9 / 288", "0.317 = 4sin^2(pi/L)", "phi/classes = 480/288 = E/K.");
  render_table_row_4(tbl, "DEEP Z/970200", "D*E = 10 / 48750", "0.016 = 4sin^2(pi/b^2)", "phi/classes = 1344/325.");
  render_table_row_4(tbl, "TRUE Z/12612600", "D^2*K = 12 / 341250", "0.016 = 4sin^2(pi/b^2)", "phi/classes = 2304/325 = D^8*K^2/(E^2*GATE).");
  let g = make_findings_grid(sec) in
  render_finding(g, "Maximum", "lambda(0) = 12 = D^2*K", "All 6 channels in phase. The void is most coherent.", "");
  render_finding(g, "Minimum", "lambda_min = -11.720", "All 6 midpoints. Max destructive interference. CRT midpoint sum = 55 = E*L.", "S327");
  render_finding(g, "Mirror theorem", "lambda(n) = lambda(N-n)", "cos(2pi(m-r)/m) = cos(2pi*r/m). Every class has even multiplicity.", "S552");
  render_finding(g, "Zero-crossing", "ONLY D^3=8 has zeros", "cos = 0 requires 4|m. Only D^3 qualifies. D is the only channel with silence capability.", "S500");
  dom_append(dom_body(), sec)
)

fn spectrum_swim() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Eigenvalue Swim");
  render_p(sec, "Walk the chain barefoot. Start at the void (maximum coherence), step through each prime, and feel the eigenvalue change under you. The landscape has thorns at composites, a false summit where you think you have arrived, and a twist at the end that changes everything.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "n");
  render_th(hdr, "Name");
  render_th(hdr, "lambda");
  render_th(hdr, "Feel");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "0", "void", "+9 (THIN) / +10 (DEEP) / +12 (TRUE)", "Maximum harmony. All channels in phase.");
  render_table_row_4(tbl, "1", "sigma", "+1.548", "Ground state. Already a fall from void.");
  render_table_row_4(tbl, "2", "D", "-1.232", "Negative. Duality creates discord.");
  render_table_row_4(tbl, "3", "K", "-2.705", "Deeper discord. Closure costs coherence.");
  render_table_row_4(tbl, "5", "E", "-2.364", "Observer: slightly less negative than K.");
  render_table_row_4(tbl, "6", "D*K", "+2.946", "THORN. Composite = warm spot. Surprise positive.");
  render_table_row_4(tbl, "7", "b", "-2.928", "Deepest prime. Near-minimum discord.");
  render_table_row_4(tbl, "9", "K^2", "+2.004", "FALSE SUMMIT. Looks like arrival. It is not.");
  render_table_row_4(tbl, "11", "L", "-1.184", "Light is NEGATIVE. Protection costs coherence.");
  render_p(sec, "Three discoveries: (1) Thorns at composites -- D*K=6 is warm (+2.95), not cold. (2) False summit at K^2=9 -- closure-squared looks like a peak but is not the real one. (3) lambda(L=11) = lambda(4) = -1.184. Light and silence have the same eigenvalue. Exactly the same.");
  dom_append(dom_body(), sec)
)

/* Shared spectral display: renders CRT decomposition into a DOM element */
fn spectrum_display(n, result_el) = (
  let d = n % 8 in
  let k = n % 9 in
  let e = n % 25 in
  let b_ch = n % 49 in
  let l = n % 11 in
  let g = n % 13 in
  let fd = if d > 4 then 8 - d else d in
  let fk = if k > 4 then 9 - k else k in
  let fe = if e > 12 then 25 - e else e in
  let fb = if b_ch > 24 then 49 - b_ch else b_ch in
  let fl = if l > 5 then 11 - l else l in
  let fg = if g > 6 then 13 - g else g in
  let div_d = if d % 2 == 0 then 1 else 0 in
  let div_k = if k % 3 == 0 then 1 else 0 in
  let div_e = if e % 5 == 0 then 1 else 0 in
  let div_b = if b_ch % 7 == 0 then 1 else 0 in
  let div_l = if l == 0 then 1 else 0 in
  let div_g = if g == 0 then 1 else 0 in
  let dead = div_d + div_k + div_e + div_b + div_l + div_g in
  let active = 6 - dead in
  let kingdom = if dead == 6 then "void (all frozen)"
    else if dead == 0 then "sigma (all spinning)"
    else if dead == 1 then (
      if div_d == 1 then "D-kingdom (bridge frozen)"
      else if div_k == 1 then "K-kingdom (closure frozen)"
      else if div_e == 1 then "E-kingdom (observer frozen)"
      else if div_b == 1 then "b-kingdom (depth frozen)"
      else if div_l == 1 then "L-kingdom (protector frozen)"
      else "GATE-kingdom (gate frozen)"
    ) else "compound (multiple frozen)" in
  let shell_avg = if active == 0 then "+12.00 (D^2*K)"
    else if active == 1 then "+9.89"
    else if active == 2 then "+7.75"
    else if active == 3 then "+5.58"
    else if active == 4 then "+3.39"
    else if active == 5 then "+1.19"
    else "-1.03" in
  let md = if d > 0 then 8 - d else 0 in
  let mk = if k > 0 then 9 - k else 0 in
  let me_ch = if e > 0 then 25 - e else 0 in
  let mb = if b_ch > 0 then 49 - b_ch else 0 in
  let ml = if l > 0 then 11 - l else 0 in
  let mg = if g > 0 then 13 - g else 0 in
  let name = if n == 0 then " = void"
    else if n == 1 then " = sigma"
    else if n == 2 then " = D"
    else if n == 3 then " = K"
    else if n == 5 then " = E"
    else if n == 6 then " = D*K (thorn!)"
    else if n == 7 then " = b"
    else if n == 9 then " = K^2 (false summit)"
    else if n == 11 then " = L"
    else if n == 13 then " = GATE"
    else if n == 30 then " = D*K*E = THIN"
    else if n == 41 then " = KEY"
    else if n == 42 then " = ANSWER"
    else if n == 61 then " = GRIEF"
    else if n == 67 then " = SOUL"
    else if n == 105 then " = HYDOR"
    else if n == 137 then " = ADDRESS (spectral min!)"
    else if n == 210 then " = DATA"
    else if n == 420 then " = lambda"
    else if n == OMEGA_VAL then " = OMEGA"
    else "" in
  dom_inner(result_el, "<p style='color:#ffd700;margin:4px 0'><b>n = " + "${n}" + name + "</b></p>" +
    "<p style='color:#88ddaa;margin:4px 0'>CRT: (" + "${d}" + ", " + "${k}" + ", " + "${e}" + ", " + "${b_ch}" + ", " + "${l}" + ", " + "${g}" + ") mod (8, 9, 25, 49, 11, 13)</p>" +
    "<p style='color:#b0b0c0;margin:4px 0'>Eigenvalue class: [" + "${fd}" + ", " + "${fk}" + ", " + "${fe}" + ", " + "${fb}" + ", " + "${fl}" + ", " + "${fg}" + "] — cosine-folded</p>" +
    "<p style='color:#ff8844;margin:4px 0'>Shell H=" + "${active}" + " — avg lambda ~ " + shell_avg + "</p>" +
    "<p style='color:#d8d8e0;margin:4px 0'>" + kingdom + "</p>" +
    "<p style='color:#a0a0b0;margin:4px 0'>Mirror: (" + "${md}" + ", " + "${mk}" + ", " + "${me_ch}" + ", " + "${mb}" + ", " + "${ml}" + ", " + "${mg}" + ")</p>")
)

/* ☠️ SCAFFOLDING — interactive widget (dies when .ax handles full eigenvalue computation) */
fn spectrum_explore() = (
  let n = parse_int_from("#spec-input") in
  spectrum_display(n, dom_query("#spec-result"))
)

fn spectrum_interactive() = (
  let sec = make_section("800px") in
  render_h2(sec, "Explore: Feel Any Number");
  render_p(sec, "Every number has 6 oscillations — one per prime channel. The eigenvalue is how they agree or fight. Enter any number to decompose its spectrum. Try the named elements from the swim above, then try your own.");
  make_interactive_widget(sec, "Enter a number (0 to 12612599):", "spec-input", "e.g. 137", "Explore", "spectrum_explore", "spec-result");
  dom_append(dom_body(), sec)
)

/* Mouse-driven spectrum bar: move mouse across bar to sweep 0..970199.
   dom_on2 passes (clientX, clientY) to callback. */
fn spectrum_mouse_move(mx, my) = (
  let n = mx * 15766 in
  spectrum_display(n, dom_query("#mouse-result"))
)

fn spectrum_mouse_bar() = (
  let sec = make_section("800px") in
  render_h2(sec, "Mouse Explorer: Sweep the Ring");
  render_p(sec, "Move your mouse across the bar below. Your horizontal position maps to a ring element. The full ring (12612600 elements) unfolds under your cursor.");
  let bar = dom_create("div") in
  dom_attr(bar, "id", "mouse-bar");
  dom_style(bar, "height", "48px");
  dom_style(bar, "background", "linear-gradient(to right, #1a1a2e, #ffd700, #1a1a2e)");
  dom_style(bar, "borderRadius", "6px");
  dom_style(bar, "cursor", "crosshair");
  dom_style(bar, "marginBottom", "12px");
  dom_style(bar, "position", "relative");
  let hint = dom_create("div") in
  dom_text(hint, "Move mouse here to explore");
  dom_style(hint, "color", "#b8b8c8");
  dom_style(hint, "textAlign", "center");
  dom_style(hint, "lineHeight", "48px");
  dom_style(hint, "pointerEvents", "none");
  dom_append(bar, hint);
  dom_on2(bar, "mousemove", "spectrum_mouse_move");
  dom_append(sec, bar);
  let res = dom_create("div") in
  dom_attr(res, "id", "mouse-result");
  dom_append(sec, res);
  dom_append(dom_body(), sec)
)

/* Keyboard walk: arrow keys navigate the ring. dom_on1 passes keyCode to callback. */
fn spectrum_walk_key(code) = (
  let cur = parse_int_from("#walk-n") in
  let n = if code == 39 then cur + 1
    else if code == 37 then cur + 12612599
    else if code == 38 then cur + 10
    else if code == 40 then cur + 12612590
    else cur in
  let state_el = dom_query("#walk-n") in
  dom_text(state_el, "${n}");
  spectrum_display(n, dom_query("#walk-display"))
)

fn spectrum_walk() = (
  let sec = make_section("800px") in
  render_h2(sec, "Walk: Navigate the Ring");
  render_p(sec, "Click the box below, then use arrow keys to walk through all 12612600 elements. Each step decomposes the spectrum live.");
  let state = dom_create("span") in
  dom_attr(state, "id", "walk-n");
  dom_style(state, "display", "none");
  dom_text(state, "0");
  dom_append(sec, state);
  let box = dom_create("div") in
  dom_attr(box, "tabindex", "0");
  dom_style(box, "border", "1px solid #ffd700");
  dom_style(box, "padding", "12px");
  dom_style(box, "cursor", "pointer");
  dom_style(box, "textAlign", "center");
  dom_style(box, "color", "#ffd700");
  dom_style(box, "outline", "none");
  dom_style(box, "marginBottom", "8px");
  dom_text(box, "Click here, then: \u2190 \u2192 step by 1 \u00A0 \u2191 \u2193 step by 10");
  dom_on1(box, "keydown", "spectrum_walk_key");
  dom_append(sec, box);
  let res = dom_create("div") in
  dom_attr(res, "id", "walk-display");
  dom_append(sec, res);
  dom_append(dom_body(), sec);
  spectrum_display(0, res)
)

fn spectrum_variance() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Variance Theorem");
  render_theorem(sec, "Variance = Maximum Eigenvalue", "At level k (with k primes), variance of all eigenvalues = maximum eigenvalue. THIN (SIMPLE): degree = 2k-1 = K^2. TRUE (MULTI): degree = 2k = D^2*K = 12. Standard deviation at k=6: sqrt(12) = 2*sqrt(3). The SPREAD of the spectrum IS the heartbeat.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Level");
  render_th(hdr, "Variance = Max");
  render_th(hdr, "Std Dev");
  render_th(hdr, "Identity");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "k=1 (Z/2Z)", "1", "1", "sigma");
  render_table_row_4(tbl, "k=2 (Z/6Z)", "3", "sqrt(3)", "K");
  render_table_row_4(tbl, "k=3 (Z/30Z)", "5", "sqrt(5)", "E");
  render_table_row_4(tbl, "k=4 (Z/210Z)", "7", "sqrt(7)", "b");
  render_table_row_4(tbl, "k=5 (Z/2310Z)", "9", "3 = K", "K^2 = STOP");
  render_table_row_4(tbl, "k=6 (Z/12612600)", "12", "2*sqrt(3)", "D^2*K = heartbeat");
  render_p(sec, "THIN (SIMPLE convention): degree = 2k-1 = K^2 at k=5. TRUE (MULTI convention): degree = 2k = D^2*K = 12 at k=6. The GATE adds the 6th voice. The heartbeat IS the spectral spread.");
  dom_append(dom_body(), sec)
)

fn spectrum_shells() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Reversed Hierarchy: Shell Averages");
  render_p(sec, "Group every element by how many of its six channels are spinning (not frozen by shared factors). Average the eigenvalue within each group. What emerges is a perfectly monotonic staircase:");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Shell H");
  render_th(hdr, "Active channels");
  render_th(hdr, "Average lambda");
  render_th(hdr, "Meaning");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "H=0", "0 (all frozen)", "+12.00 = D^2*K", "Void. Maximum coherence.");
  render_table_row_4(tbl, "H=1", "1 spinning", "+9.89", "One active. Still highly coherent.");
  render_table_row_4(tbl, "H=2", "2 spinning", "+7.75", "Two active. Declining harmony.");
  render_table_row_4(tbl, "H=3", "3 spinning", "+5.58", "Three active. 490 split: 3 inner or 3 boundary.");
  render_table_row_4(tbl, "H=4", "4 spinning", "+3.39", "Four active. Still positive.");
  render_table_row_4(tbl, "H=5", "5 spinning", "+1.19", "Five active. Barely positive.");
  render_table_row_4(tbl, "H=6", "6 (all spinning)", "-1.03", "Full activity. Least coherent average.");
  render_p(sec, "More activity means less harmony. The void (H=0, all frozen) has the highest coherence. Sigma (H=6, all spinning) has the lowest. The 490 holographic split cleaves at H=3: inner channels {D,E,b} dead, boundary channels {K,L,GATE} alive. Existence costs coherence -- and the GATE adds one more step to the descent.");
  dom_append(dom_body(), sec)
)

