  render_table_row_4(tbl, "HYDOR = 105", "3 frozen: 2+2+2", "6", "D*K");
  render_table_row_4(tbl, "DATA = 210", "4 frozen: 1+2+2+2", "7", "b");
  render_table_row_4(tbl, "N_THIN = 2310", "5 frozen: 1+2+2+2+2", "9", "K^2");
  render_table_row_4(tbl, "N_TRUE = 12612600", "all 6 frozen: 2+2+2+2+2+2", "12", "D^2*K = heartbeat");
  render_p(sec, "Each composite PROJECTS spectrally to the next axiom value. The membrane D*K averages to K. HYDOR averages to D*K. TRUE FORM EQUALIZATION (S230): in the fat ring, ALL channels contribute +2 equally. Fattening erases the D-channel asymmetry. GATE (the 6th bone) adds +2 to reach 12 = heartbeat.");
