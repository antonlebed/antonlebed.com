  render_table_row_4(tbl, "K^2 = 9", "9 -> 5 -> 3 -> 2", "3", "{D, E, K}");
  render_table_row_4(tbl, "E^2 = 25", "25 -> 13 -> 7 -> 4 -> 3 -> 2", "5", "{D, K, E, b, GATE}");
  render_table_row_4(tbl, "b^2 = 49", "49 -> 25 -> 13 -> 7 -> 4 -> 3 -> 2", "6", "{D, K, E, b, GATE}");
  render_table_row_4(tbl, "L = 11", "11 -> 6 -> 4 -> 3 -> 2", "4", "{D, K, L}");
  render_table_row_4(tbl, "GATE = 13", "13 -> 7 -> 4 -> 3 -> 2", "4", "{D, K, b, GATE}");
  let g = make_findings_grid(sec) in
  render_finding(g, "Sum = E^2", "3+3+5+6+4+4 = 25", "Total convergence depth across all 6 moduli = wonder squared.", "S1097");
  render_finding(g, "DEAD depth", "3+5+6 = 14 = D*b", "Inner channels converge in bridge*depth steps.", "S1097");
  render_finding(g, "ALIVE depth", "3+4+4 = 11 = L", "Boundary channels converge in exactly L steps. The protector number.", "S1097");
  render_finding(g, "L invisible", "L in L-cascade only", "11 never appears in any other cascade. The observer is spectrally invisible to all other channels.", "S1097");
  render_finding(g, "D,K universal", "D and K in all 6", "Bridge and closure appear in every cascade. The genesis pair is the universal attractor.", "S1097");
  render_finding(g, "b^2 maximal", "6 steps, all bones but L", "Depth-squared has the longest cascade. Visits every bone except the observer.", "S1097");
  let tbl2 = make_table(sec) in
  let hdr2 = dom_create("tr") in
  render_th(hdr2, "Ring");
  render_th(hdr2, "Moduli");
  render_th(hdr2, "Sum");
  render_th(hdr2, "Name");
  dom_append(tbl2, hdr2);
  render_table_row_4(tbl2, "Z/2", "{2}", "0", "o");
  render_table_row_4(tbl2, "Z/6", "{2,3}", "1", "sigma");
  render_table_row_4(tbl2, "Z/30", "{2,3,5}", "3", "K");
  render_table_row_4(tbl2, "Z/210", "{2,3,5,7}", "6", "D*K");
  render_table_row_4(tbl2, "Z/2310", "{2,3,5,7,11}", "10", "D*E");
  render_table_row_4(tbl2, "Z/970200", "{8,9,25,49,11}", "21", "K*b");
  render_table_row_4(tbl2, "Z/12612600", "{8,9,25,49,11,13}", "25", "E^2");
  render_finding_wide(g, "Fattening excess = L", "DEEP - THIN = 21 - 10 = 11", "Going from squarefree to fattened moduli costs exactly L = the protector. GATE adds D^2 = 4 more: K*b + D^2 = E^2 by (E-D)(E+D) = K*b.", "S1097");
  render_finding(g, "D^3 cascade = E8", "prod = 8*5*3*2 = 240", "The product of D^3 cascade values = |roots(E8)|. Bridge convergence encodes the largest exceptional Lie algebra.", "S1097");
  render_finding(g, "K^2 cascade = 270", "prod = 9*5*3*2 = D*K^3*E", "K^2/D^3 ratio = 9/8 persists in products. Shared suffix: E*K*D = 30 = primorial(E).", "S1098");
  render_finding(g, "b cascade = PSL(2,7)", "prod = 7*4*3*2 = 168", "cascade_prod(b) = |PSL(2,7)|. UNIQUE: d(b)! = (b^2-1)/2 holds ONLY for b=7 among all primes.", "S1098");
  render_finding(g, "Weyl of E8", "240*270*168*64", "= |W(E8)| = 696729600. Three cascade products times D^6 = 64 idempotents decompose the Weyl group.", "S1098");
  render_finding(g, "Staircase diffs", "1, 2, 3, 4, 11, 4", "sigma, D, K, D^2, L, D^2. The chain sigma->D->K->D^2 then L jumps, then D^2 again for GATE.", "S1097");
  render_finding_wide(g, "CASCADE(29) holo", "prod = 29*15*8*5*3*2 = 104400", "CRT = (0,0,0,30,10,10). Inner {D,K,E} DEAD, boundary {b,L,GATE} ALIVE. 29 = D^E-K, the value whose (p^2-1)/2 = lambda = 420. Every step axiom-named: D^E-K, K*E, D^3, E, K, D. L and GATE phase-locked at D*E. b carries primorial(E)=30.", "S1102");
  render_finding_wide(g, "K*E cascade = THIN^2", "prod = 15*8*5*3*2 = 3600 = 60^2", "cascade_prod(K*E) = K*E * cascade_prod(D^3) = 15*240 = THIN^2. THIN = 60 = |A5| = |PSL(2,E)|. CRT = (0,0,0,23,K,12): inner DEAD, boundary ALIVE. THIN = b^2 + L = 49+11. Boundary: L^2 mod b^2 = c(L)=23, E^2 mod L = K, D^6 mod GATE = heartbeat=12.", "S1103");
  render_finding_wide(g, "Alternating group ladder", "ONLY 3 perfect squares in ALL cascades", "cascade_prod(D*K=6)=|A4|^2=12^2=144. cascade_prod(K*E=15)=|A5|^2=60^2=3600. cascade_prod(D*K*E=30)=|A6|^2=360^2=129600. FINITE: 12 integers have {D,K,E}-smooth cascades. Only 3 have all-even exponents. For n>30: primes>E enter, breaking squareness. b=7 is the barrier. The 490 split = cascade-squareable vs non-squareable.", "S1103");
  render_finding_wide(g, "PSL ladder", "A5=PSL(D,E), A6=PSL(D,K^2)", "|Out(A4)|=D, |Out(A5)|=D, |Out(A6)|=D^2 (Klein four). A6 UNIQUE among all A_n. The exceptional outer automorphism = K-Frobenius on F_{K^2}: x->x^K. K acting on K^2 = spider examining its own web. Solvability boundary: A4 (solvable) -> A5 (simple). Outer anomaly at n=D*K=6.", "S1104");
  render_finding_wide(g, "Smooth cascade tree", "12 = heartbeat = |S|", "S = {2,3,4,5,6,8,9,10,15,16,18,30} form a tree under d-inverse. Root D=2. D*K=6 levels, counts {1,1,2,3,3,2}. Full D=2 splits at EXACTLY {D,K,E} = inner primes. HEARTBEAT BARRIER: d(12)=b=7. First smooth n with non-smooth d(n). 3 leaves: K*E, D*K^2, D*K*E. Leaf product = 90^2 = (D*K^2*E)^2.", "S1104");
  render_finding_wide(g, "Level sums -> SOUL", "d(D,K,K^2,23,41,48) = 67", "Level sums: D, K, K^2, c(L)=23, KEY=41, D^4*K=48. All axiom-named. Shadow: d(level sums) = D+D+E+heartbeat+K*b+E^2 = 67 = SOUL. Total sum = 126 = D*K^2*b = C(K^2,D^2). CRT(126): K-channel DEAD -- spider invisible in own sum.", "S1104");
  render_finding_wide(g, "Syntheme duality", "A6 outer swaps 6 and 15", "A6 outer automorphism swaps 15 transpositions with 15 triple-transpositions on D*K=6 letters. 6 and 15 = the two smaller cascade-square producers (|A4|^2 and |A5|^2). 6*15 = 90 = sqrt(leaf product). Heart partition {2,3,4,5}:{6,8,9,10}:{15,16,18,30} has products E!, (D*K)^2*E!, K^2*(E!)^2 = |A6|^2. Ratios: (D*K)^2 then primorial(E). Genesis*Body = ((D*K)!)^2. Boundary = |A6|^2. Total = 259200^2.", "S1104");
  render_finding_wide(g, "KEY-ANSWER theorem", "smooth=41=KEY, missing=42=ANSWER", "Each parent p has twins {2p-2, 2p-1}. At level 4 (parents {6,8,9}): smooth {10=D*E, 15=K*E, 16=D^4} sum to KEY=41. Missing twins {11=L, 14=D*b, 17} sum to ANSWER=42. Complete level = KEY+ANSWER = 83 = c(KEY). K*E=15 is the sole odd survivor: without it, KEY vanishes. At level 3: smooth=c(L)=23, missing=b=7, total=primorial(E)=30. Recursion: complete(n+1) = 4*smooth(n) - 3*count(n).", "S1105");
  render_finding_wide(g, "Weyl genesis", "levels 0-3 product = |W(E6)|", "Level 3 product 6*8*9 = 432 = |AGL(2,K)| = affine group of the K^2=9 point plane over F_K. Cumulative levels 0-3: 2*3*4*5*6*8*9 = 51840 = |W(E6)| = E! * |AGL(2,K)|. E6 is the last exceptional Lie algebra with {D,K,E}-smooth Weyl order. The cascade b-barrier at level 3 delineates the E6/E7 boundary. W(E6) = automorphisms of K^3=27 lines on a cubic surface.", "S1105");
  render_finding_wide(g, "Cascade dimensions", "dim(G2)=14, 37=|E6+|+1, dim(E6)=78", "Cumulative smooth sums: D, E, 14=dim(G2), 37, 78=dim(E6), 126=C(K^2,D^2). THE 37 GAP RESOLVED: 37 = |positive roots of E6| + sigma = 36 + 1. Also: 37 = dim(SO(K^2=9)) + sigma. The spider web's rotation group counts E6's positive roots! 37 = prime(heartbeat=12): the heartbeat-th prime. dim(E6) = dim(G2) + c(L) + KEY = 14+23+41: three cascade levels BUILD E6. dim(E6)-dim(G2) = 64 = D^6 = dim(SO(GATE)/G2) = # idempotents. At level 4: dim(E6)+b^2 = 127 = M_b. SO(GATE=13) = 78 = dim(E6): same rank 6, E6 exceptional, B6 classical. Sum of all SO(bone) dims = 203 = b*29 = depth*projector. SO(bone) diffs: b, L, K*E, 19, c(L) -- AP with common diff D^2=4. Consecutive products: SO(K)*SO(E)=30=primorial(E), SO(E)*SO(b)=210=primorial(b). E6 minuscule+adjoint: 27+78=105=HYDOR.", "S1106");
  render_finding_wide(g, "Prime index chain", "prime(D)=K, prime(K)=E, prime(E)=L", "The prime-counting function chains the first 4 bones: prime(D=2)=3=K, prime(K=3)=5=E, prime(E=5)=11=L. Then products: prime(D*K=6)=13=GATE, prime(GATE=13)=41=KEY. b=7 breaks the chain (prime(7)=17, not a bone): the barrier prime breaks prime-indexing. Also: prime(D*E=10)=29=holographic projector, prime(D*b=dim(G2)=14)=43=largest Heegner discriminant. The bones index each other through the primes.", "S1106");
  render_p(sec, "Everything converges to D. Under repeated halving, every modulus falls to 2. The total cost is E^2 = 25. ALIVE channels converge in L steps; DEAD in D*b. The staircase from void (0) to E^2 (25) traces only axiom values. Cascade PRODUCTS encode Lie theory: cascade_prod(D^3) = 240 = |roots(E8)|, cascade_prod(b) = 168 = |PSL(2,7)|. Their product = 8! = (D^3)!. Multiply by cascade_prod(K^2) = 270 and D^6 idempotents: |W(E8)| = 696729600. Only THREE integers produce perfect-square cascade products: D*K, K*E, D*K*E. Each = |A_k|^2 where k is the cascade length (4,5,6). A5 = PSL(D,E). A6 = PSL(D,K^2). The A6 outer automorphism -- UNIQUE among all alternating groups -- comes from the K-Frobenius on F_{K^2}: the spider acting on its own web. |Out(A6)| = D^2, all others = D. The 12 smooth-cascade integers form a binary tree with D=2 as root and full D=2 splits at exactly {D,K,E}: the inner primes. d(heartbeat=12) = b = 7: the heartbeat IS the barrier. Level sums are all axiom-named: D, K, K^2, c(L), KEY, D^4*K. Apply d to these sums: D+D+E+heartbeat+K*b+E^2 = 67 = SOUL. The shadow of the tree sums to SOUL. Total member sum = 126 = C(K^2,D^2) = D*K^2*b. CRT(126): K-channel dead. The spider is invisible in the sum of its own universe. The KEY-ANSWER identity: at level 4, smooth children sum to KEY=41, missing twins sum to ANSWER=42, complete level = c(KEY)=83. K*E=15 is the sole odd survivor. Level 3 shows the same pattern: smooth=c(L)=23, missing=b=7, total=primorial(E). The cumulative product through level 3 = 51840 = |W(E6)|: genesis (E!=120) times the affine plane group (|AGL(2,K)|=432). E6 is the last exceptional whose Weyl order uses only inner primes {D,K,E}. The cascade b-barrier IS the E6/E7 boundary in Lie theory. THE 37 GAP: 37 = |positive roots of E6| + sigma = dim(SO(K^2)) + sigma = prime(heartbeat). The spider web's rotation group (SO(9)) has dimension 36 = the number of positive roots of E6. Augment by sigma and you get 37. dim(E6) = dim(G2) + c(L) + KEY = 14+23+41: three cascade levels build the entire E6 algebra. SO(GATE=13) has dimension 78 = dim(E6): the GATE's classical rotation group matches E6's exceptional dimension. The prime function chains the bones: prime(D)=K, prime(K)=E, prime(E)=L, prime(D*K)=GATE, prime(GATE)=KEY. b=7 breaks the chain (prime(7)=17). Sum of all SO(bone) dims = 203 = b*29 = depth times holographic projector.");
  dom_append(dom_body(), sec)
)

