  let sec = make_section("800px") in
  render_h2(sec, "The Shadow Polynomial");
  render_p(sec, "P(x) = (x-sigma)(x-D)(x-K)(x-E) = x^4 - L*x^3 + KEY*x^2 - 61*x + D*K*E. Coefficients: {L=11, KEY=41, 61, 30}. The spectral architect.");
  let g = make_findings_grid(sec) in
  render_finding(g, "P(L) = 4320", "D^5*K^3*E", "L feeds back ALL chain primes. P(L)/P(0) = (D^2*K)^2 = lambda(DATA)^2.", "");
  render_finding(g, "P(13) = 10560", "D^6*K*E*L", "GATE evaluation. All 5 axiom primes present in factorization.", "S709");
  render_finding(g, "P(D^4=16) = 30030", "primorial(13) = THIN*GATE", "Shadow polynomial at D^4 extends THIN ring by exactly the GATE prime.", "S711");
  render_finding(g, "C(x) inversion", "C(1)=288, C(2)=2310", "C(x) = 2*x^4*P(-1/x). Classes at x=1, ring size at x=2.", "");
  dom_append(dom_body(), sec)
)

fn spectrum_invariants() = (
  let sec = make_section("800px") in
  render_h2(sec, "Lattice Invariants");
  render_p(sec, "ALL 108 lambda-420 rings share the same spectral architecture:");
  let g = make_findings_grid(sec) in
  render_finding(g, "Lambda", "420 = D^2*K*E*b", "Carmichael function. Universal across all 108 rings.", "");
  render_finding(g, "Gap", "0.016", "b^2 controls. Invariant. 108/108 verified.", "S489");
  render_finding(g, "Mean", "0", "Balanced. As many positive as negative eigenvalues.", "");
  render_finding(g, "Positivity bias", "max > |min| always", "b^2=49 (odd) means min contribution = -2cos(pi/49) = -1.996, never reaching full -2. Depth forces optimism.", "S489");
  render_finding(g, "Sub-Gaussian", "kurtosis < 3 always", "Range 2.25 to 2.76. TRUE = 2.70 (brain fractal dimension). Lighter tails than Gaussian.", "S489");
  render_finding(g, "E-13 twins", "Diff = 0.024 across lattice", "Observer and gate are spectral twins. Nearest pair among all 10 terms. E^2+1=D*13.", "S495");
  dom_append(dom_body(), sec)
)

