  render_table_row_4(tbl, "H=1", "1 spinning", "+6.90", "One active. Still highly coherent.");
  render_table_row_4(tbl, "H=2", "2 spinning", "+4.24", "Two active. Declining harmony.");
  render_table_row_4(tbl, "H=3", "3 spinning", "+1.14", "Three active. Near zero.");
  render_table_row_4(tbl, "H=4", "4 spinning", "-1.14", "Four active. Now discordant.");
  render_table_row_4(tbl, "H=5", "5 (all spinning)", "-0.48", "Full activity. Least coherent average.");
  render_p(sec, "More activity means less harmony. The void (H=0, all frozen) has the highest coherence. The sun (H=5, all spinning) has the lowest. Existence costs coherence. That is the price of being alive -- and the mathematics says so directly.");
  dom_append(dom_body(), sec)
)

