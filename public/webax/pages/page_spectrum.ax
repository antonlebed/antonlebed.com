  render_theorem(sec, "Channel Freezing Theorem (S230)", "For multiples of m: avg_lambda(mk) = [D|m]+2*Omega_odd(m). Frozen channel p (p|m) contributes +1 (D) or +2 (odd p). Unfrozen: average 0. Verified machine precision for all 32 divisor classes.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Multiples of");
  render_th(hdr, "Frozen");
  render_th(hdr, "Average lambda");
