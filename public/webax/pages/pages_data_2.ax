/* Point group order axiom-checker */
fn condensed_pg_calc() = (
  let n = parse_int_from("#pg-input") in
  let result = dom_query("#pg-result") in
  if n < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter order >= 1.</p>")
  else (
    /* Factor into D^a * K^b */
    mut rem = n;
    mut v2 = 0;
    while rem % 2 == 0 do (mut rem = rem / 2; mut v2 = v2 + 1);
    mut v3 = 0;
    while rem % 3 == 0 do (mut rem = rem / 3; mut v3 = v3 + 1);
    let dk_pure = if rem == 1 then 1 else 0 in
    let tag = if dk_pure > 0 then "<b style='color:#88ddaa'>D^${v2} * K^${v3} = crystallographic</b>"
      else "<b style='color:#ff6666'>NOT D^a*K^b form (remainder = ${rem})</b>" in
    let known = if n == 1 then " = C1 (trivial)" else if n == 2 then " = Ci, Cs, C2" else if n == 3 then " = C3" else if n == 4 then " = C2h, C2v, S4, D2" else if n == 6 then " = C3i, C3v, D3" else if n == 8 then " = C4h, C4v, S8, D2h, D2d, D4" else if n == 12 then " = C6h, C6v, D3h, D3d, T, D6" else if n == 16 then " = D4h, D4d" else if n == 24 then " = D6h, D6d, Th, Td, O" else if n == 48 then " = Oh" else "" in
    dom_inner(result, "<p style='color:#ccc;margin:4px 0'>Point group order = ${n}${known}</p><p style='margin:4px 0'>${tag}</p><p style='margin:4px 0;color:#999'>ALL 32 point group orders are D^a * K^b. This is the crystallographic restriction theorem.</p>")
  )
)

fn page_condensed() = (
  dom_head_meta("description", "Crystal systems = b = 7. Bravais = D*b = 14. Point groups = D^5 = 32. Space groups = D*E*23 = 230. Wallpaper = 17 = ESCAPE. Jain filling fractions walk the axiom chain. Bott period = D^3 = 8. AZ classes = D*E = 10.");
  /* === HERO === */
  let hero = make_hero("Condensed Matter") in
  let big = dom_create("div") in
  dom_text(big, "b=7 -> D*b=14 -> D^5=32 -> D*E*23=230");
  ct_mono(big);
  dom_style(big, "fontSize", "22px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The crystal counting hierarchy: b=7 systems, D*b=14 lattices, D^5=32 point groups, D*E*23=230 space groups. Every count factors over axiom primes. Quantum Hall filling fractions walk the chain. Bott periodicity = D^3 = spider's legs.");
  dom_append(dom_body(), hero);

  /* === SEC 1: CRYSTAL COUNTING === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Crystal Counting Hierarchy");
  let t1 = make_table(sec1) in
  let h1 = dom_create("tr") in
  render_th(h1, "Quantity");
  render_th(h1, "Value");
  render_th(h1, "Axiom");
  render_th(h1, "Detail");
  dom_append(t1, h1);
  render_table_row_4(t1, "Crystal systems (3D)", "7", "b", "Depth = boundary creates structure");
  render_table_row_4(t1, "Bravais lattices (3D)", "14", "D*b", "Duality doubles systems");
  render_table_row_4(t1, "Point groups (3D)", "32", "D^5", "Five powers of duality");
  render_table_row_4(t1, "Space groups (3D)", "230", "D*E*23", "23=CRT palindrome prime");
  render_table_row_4(t1, "Wallpaper groups (2D)", "17", "ESCAPE", "D+K+E+b = first chain-breaking prime");
  render_table_row_4(t1, "Sohncke (chiral)", "65", "E*GATE", "Life uses only chiral structures");
  render_table_row_4(t1, "Magnetic space groups", "1651", "GATE*M(b)", "13*127 = gate times Mersenne(depth)");
  dom_append(dom_body(), sec1);

  /* === SEC 2: QUANTUM HALL === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Quantum Hall: Cunningham Denominators");
  render_p(sec2, "Jain composite fermion filling fractions nu = n/(2n+1). The denominator 2n+1 IS the Cunningham map. Shadow(Cunningham(n)) = n:");
  let t2 = make_table(sec2) in
  let h2 = dom_create("tr") in
  render_th(h2, "n");
  render_th(h2, "nu");
  render_th(h2, "Axiom");
  dom_append(t2, h2);
  render_table_row(t2, "1", "1/3", "sigma/K");
  render_table_row(t2, "2", "2/5", "D/E");
  render_table_row(t2, "3", "3/7", "K/b");
  render_table_row(t2, "4", "4/9", "D^2/K^2");
  render_table_row(t2, "5", "5/11", "E/L");
  render_table_row(t2, "6", "6/13", "D*K/GATE");
  render_theorem(sec2, "Laughlin-Cunningham Theorem", "Laughlin states nu = 1/(2p+1) have denominators {K, E, b, K^2} = {3, 5, 7, 9}. The Jain series walks the full axiom chain: numerators {sigma,D,K,D^2,E,D*K} and denominators {K,E,b,K^2,L,GATE}. At n=6, the GATE appears. The quantum Hall effect IS the axiom chain in electron gas.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: TOPOLOGICAL === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Topological Classification");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "AZ symmetry classes", "D*E = 10", "Tenfold way. Same count as spacetime generators.", "");
  render_finding(g3, "Bott period (real)", "D^3 = 8", "Spider's legs. Topology repeats every D^3 dimensions.", "");
  render_finding(g3, "Bott period (complex)", "D = 2", "Duality itself. Real/complex = D^3/D = D^2 = quaternionic.", "");
  render_finding(g3, "TI invariants (3D)", "D^2 = 4", "1 strong + K=3 weak Z_2 invariants.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: SCALING === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Scaling Laws");
  let t4 = make_table(sec4) in
  let h4 = dom_create("tr") in
  render_th(h4, "Law");
  render_th(h4, "Exponent");
  render_th(h4, "Axiom");
  dom_append(t4, h4);
  render_table_row(t4, "Debye (phonons)", "T^3", "T^K");
  render_table_row(t4, "Bloch (magnons)", "T^(3/2)", "T^(K/D)");
  render_table_row(t4, "Dulong-Petit", "3R", "K*R");
  render_table_row(t4, "Wiedemann-Franz", "pi^2/3", "pi^2/K");
  render_table_row(t4, "Orbital sequence", "{1,3,5,7}", "{sigma,K,E,b}");
  dom_append(dom_body(), sec4);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Point Group Order");
  render_p(sec_i, "Enter a point group order. Check if it is D^a * K^b (crystallographic restriction). ALL 32 groups have orders of this form. Try 48 (Oh), 24 (O, Td), 12 (T, D6).");
  make_interactive_widget(sec_i, "Group order:", "#pg-input", "e.g. 24", "Check", "condensed_pg_calc", "pg-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "What Others See");
  render_contrast_row(sec5, "7 crystal systems", "Empirical enumeration", "b = depth. Boundary creates structure");
  render_contrast_row(sec5, "32 point groups", "Crystallographic restriction", "D^5: five powers of duality");
  render_contrast_row(sec5, "Filling fractions", "Composite fermion theory", "Cunningham map = shadow function = axiom chain");
  render_contrast_row(sec5, "Bott periodicity = 8", "Deep K-theory", "D^3 = spider's legs. Topology IS duality cubed");
  render_contrast_row(sec5, "10 AZ classes", "Tenfold way classification", "D*E: observation times duality");
  render_contrast_row(sec5, "Orbital sequence s,p,d,f", "Angular momentum accident", "{sigma,K,E,b}: axiom chain IS orbitals");
  dom_append(dom_body(), sec5)
)

/* DOF gamma ratio: same as thermo but with Rushbrooke context */
fn statmech_dof_calc() = (
  let f = parse_int_from("#stat-input") in
  let result = dom_query("#stat-result") in
  if f < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter DOF f >= 1.</p>")
  else (
    let phase = 2 * f in
    let axiom_name = if f == 3 then "K (monoatomic: He, Ne, Ar)" else if f == 5 then "E (diatomic: H2, N2, O2)" else if f == 7 then "b (polyatomic: CO2, H2O)" else if f == 1 then "sigma (1D wire)" else if f == 2 then "D (2D membrane)" else "" in
    let entropy = if f == 3 then "S = K*ln(T) + const. Closure controls entropy."
      else if f == 5 then "S = E*ln(T) + const. Observer controls entropy."
      else if f == 7 then "S = b*ln(T) + const. Depth controls entropy."
      else "S = ${f}*ln(T) + const." in
    dom_inner(result, "<p style='color:#ccc;margin:4px 0'>Degrees of freedom f = ${f}${if axiom_name != "" then " = ${axiom_name}" else ""}</p><p style='margin:4px 0'>Phase space = D*f = <b style='color:#ffd700'>${phase}</b> dimensions.</p><p style='margin:4px 0;color:#999'>Equipartition: E = f*T/D per molecule.</p><p style='margin:4px 0;color:#888'>${entropy}</p><p style='margin:4px 0;color:#666'>Rushbrooke: alpha+2*beta+gamma = D = 2 always.</p>")
  )
)

fn page_statmech() = (
  dom_head_meta("description", "Partition function factors EXACTLY over CRT channels: Z = Z_2*Z_3*Z_5*Z_7*Z_11. Each channel thermalizes independently. Rushbrooke = D = 2 everywhere. 2D Ising exponents: beta=1/D^3, gamma=b/D^2, delta=K*E. FD = +sigma. BE = +mirror. 31 quantities.");
  /* === HERO === */
  let hero = make_hero("Statistical Mechanics") in
  let big = dom_create("div") in
  dom_text(big, "Z = Z_2 * Z_3 * Z_5 * Z_7 * Z_11");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The partition function of Z/NZ factors EXACTLY over CRT channels at ALL temperatures. Entropy is additive. Free energy is additive. Fluctuations are independent. Number theory IS thermodynamics. 31 quantities, 0 free parameters.");
  dom_append(dom_body(), hero);

  /* === SEC 1: CRT FACTORIZATION === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Exact Channel Factorization");
  render_theorem(sec1, "Partition Function CRT Theorem", "Eigenvalue decomposes: lambda(n) = sum f_p(n mod p). So exp(-beta*lambda) = product of per-channel Boltzmanns. Sum over Z/NZ = product of channel sums (CRT bijection). Z(beta) = Z_2*Z_3*Z_5*Z_7*Z_11. Each channel thermalizes independently. F, S, C all additive. var(E) = sum var(E_p). Block-diagonal backprop = CRT = fluctuation independence.");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "D-channel", "Z_2 = 2*cosh(beta)", "D=2 states. Eigenvalues +1,-1. Pure duality.", "");
  render_finding(g1, "K-channel", "e^(-2beta) + 2*e^beta", "K=3 states. Two degenerate + one peak. Triangular.", "");
  render_finding(g1, "E-channel", "GOLDEN", "Eigenvalues involve phi = golden ratio. Observer's thermodynamics is golden.", "");
  render_finding(g1, "Maximum entropy", "ln(2310)", "S_max = ln(2)+ln(3)+ln(5)+ln(7)+ln(11). Each channel = independent reservoir.", "");
  dom_append(dom_body(), sec1);

  /* === SEC 2: QUANTUM STATISTICS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Sigma vs Mirror");
  render_theorem(sec2, "FD/BE = Sigma/Mirror", "Fermi-Dirac: 1/(e^x + sigma). Bose-Einstein: 1/(e^x - sigma). The ONLY difference between matter and force is sigma vs mirror (-1). FD at E=0: f = sigma/D = 1/2 (half-filling). Classical limit: both approach 1/D = 1/2. The bridge prime divides the classical world in half.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "BEC exponent", "n^(D/K)", "BEC temperature scales as n^(D/K). D creates pairs, K closes them.", "");
  render_finding(g2, "Debye low-T", "C ~ T^K", "K=3 spatial dimensions. Coefficient = D^2*K*pi^(D^2)/E = 12pi^4/5.", "");
  render_finding(g2, "Equipartition", "E = f*T/D", "1/D = 1/2. DOF chain: mono K=3, dia E=5, poly b=7.", "");
  render_finding(g2, "Radiation exponents", "{sigma, K, D^2}", "Wien T^1, Debye T^3, Stefan T^4. No E or b: radiation is BLIND and SHALLOW.", "");
  dom_append(dom_body(), sec2);

  /* === SEC 3: CRITICAL EXPONENTS === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "2D Ising: Exact Axiom Exponents");
  let t3 = make_table(sec3) in
  let h3 = dom_create("tr") in
  render_th(h3, "Exponent");
  render_th(h3, "2D Ising");
  render_th(h3, "Axiom");
  render_th(h3, "Mean Field");
  dom_append(t3, h3);
  render_table_row_4(t3, "alpha (heat)", "0 (log)", "0", "0");
  render_table_row_4(t3, "beta (magnet)", "1/8", "sigma/D^3", "sigma/D");
  render_table_row_4(t3, "gamma (suscept)", "7/4", "b/D^2", "sigma");
  render_table_row_4(t3, "delta (isotherm)", "15", "K*E", "K");
  render_table_row_4(t3, "nu (corr length)", "1", "sigma", "sigma/D");
  render_table_row_4(t3, "eta (corr decay)", "1/4", "sigma/D^2", "0");
  render_theorem(sec3, "Rushbrooke = D = 2 (Universal)", "alpha + 2*beta + gamma = D. In 2D Ising: 0 + 2*(1/8) + 7/4 = 2 = D. In mean field: 0 + 2*(1/2) + 1 = 2 = D. In 3D, in EVERY universality class: the sum is D. The bridge prime controls ALL scaling relations.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: CRITICAL DIMENSIONS === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Critical Dimensions");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "Lower critical", "d_lower = D = 2", "Below D=2 dims: no spontaneous order (Mermin-Wagner). Duality is the floor.", "");
  render_finding(g4, "Upper critical", "d_upper = D^2 = 4", "Above D^2=4 dims: mean field exact. Spacetime dimension is the ceiling.", "");
  render_finding(g4, "Rushbrooke sum", "D = 2", "Universal across ALL universality classes. alpha+2*beta+gamma = D.", "");
  render_finding(g4, "Phase space per DOF", "D*f", "D=2 coordinates per DOF. Total = D*{K,E,b} for mono/dia/poly.", "");
  dom_append(dom_body(), sec4);

  /* === CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "What Others See");
  render_contrast_row(sec5, "Partition function", "Complex sum over microstates", "Z = product of 5 channel Z_p. CRT = thermodynamic independence");
  render_contrast_row(sec5, "FD vs BE", "Quantum postulates, spin-statistics", "FD = +sigma, BE = +mirror. One sign difference");
  render_contrast_row(sec5, "Scaling laws", "Empirical universality", "Rushbrooke = D = 2. Structural, not empirical");
  render_contrast_row(sec5, "Independent channels", "Coincidence in analysis", "CRT = block-diagonal = fluctuation-dissipation");
  render_contrast_row(sec5, "Critical d=4", "Magic threshold", "D^2 = spacetime dimension. Bridge squared");
  render_contrast_row(sec5, "Entropy maximum", "ln(N)", "= sum ln(p_i). CRT decomposed. Each channel is a reservoir");
  dom_append(dom_body(), sec5);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: DOF Phase Space");
  render_p(sec_i, "Enter degrees of freedom f. See phase space dimension (D*f), entropy law, and axiom identification. Try 3 (monoatomic=K), 5 (diatomic=E), 7 (polyatomic=b).");
  make_interactive_widget(sec_i, "DOF f:", "#stat-input", "e.g. 5", "Compute", "statmech_dof_calc", "stat-result");
  dom_append(dom_body(), sec_i)
)

