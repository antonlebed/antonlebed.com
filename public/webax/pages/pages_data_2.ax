  render_th(mhdr, "Axiom");
  render_th(mhdr, "Predicted");
  render_th(mhdr, "Measured");
  dom_append(mtbl, mhdr);
  render_table_row_4(mtbl, "dm^2_21 (solar)", "D*37 * 10^-6", "7.40e-5 eV^2", "7.42e-5 (0.3%)");
  render_table_row_4(mtbl, "|dm^2_31| (atm)", "D*E*(K*G-MIND) * 10^-6", "2.510e-3 eV^2", "2.515e-3 (0.2%)");
  render_table_row_4(mtbl, "Ratio dm31/dm21", "K^3 + E + sigma/D = 32.5", "32.5", "33.9 (4%)");
  render_table_row_4(mtbl, "Sum of masses", "SOUL - D^3 = 59 meV", "59 meV", "Prediction");
  dom_append(sec5, mtbl);
  render_p(sec5, "Solar splitting: duality times body temperature (37 = unique non-axiom prime where the depth quadratic returns to axiom). Atmospheric: K*G - MIND = 3*97 - 40 = 251 = muon anomaly difference. Same number, different domain. The neutrino mass sum SOUL - D^3 = 59 meV is a prediction testable by CMB and beta-decay experiments.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: CKM COMPARISON === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "CKM vs PMNS");
  let g6 = make_findings_grid(sec6) in
  render_finding(g6, "Cabibbo angle", "GATE = 13 degrees", "sin(13 deg) = 0.2250 vs |V_us| = 0.2245 (0.2%). GATE = sigma+D+K+b = 13 (E absent).", "");
  render_finding(g6, "CKM CP phase", "D^2*pi/L = 65.45 deg", "PDG: 65.4 +/- 3.2 deg (0.08%). CP violation = bridge^2/protector times half-turn.", "S350");
  render_finding(g6, "CKM Wolfenstein", "K^2/(D^3*E) = 9/40", "lambda = 0.225. Closure^2 / (spider legs * observer).", "");
  render_finding(g6, "Quark vs neutrino", "Small vs large mixing", "Quarks see narrowly (CKM near identity). Neutrinos see broadly (PMNS near maximal). Two views of the same axiom.", "");
  dom_append(dom_body(), sec6);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "Mixing angles", "Free parameters fit to oscillation data", "Axiom fractions: 10/33, 4/7, 1/45. All < 0.2% error. Each excludes one prime.");
  render_contrast_row(sec7, "CP violation", "Phase measured at accelerators, origin unknown", "(K*b)^2*L/E^2 = 194.04 deg. TESTABLE by DUNE + Hyper-K. Codon-ring connection.");
  render_contrast_row(sec7, "Mass splittings", "Measured values, no prediction framework", "37 (body temp) and K*G-MIND (muon anomaly). Cross-domain reuse of axiom constants.");
  render_contrast_row(sec7, "Mixing product", "No physical significance attached", "4/315 = D^2/(K^2*E*b). Denominator = ANIMAL coupling. Neutrino mixing measures biological complexity.");
  render_contrast_row(sec7, "Quark-lepton symmetry", "Grand unification hypothesis, not derived", "CKM and PMNS use the same 5 primes differently. GATE = Cabibbo angle. Same axiom, two viewing angles.");
  dom_append(dom_body(), sec7);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Mixing Angle Lookup");
  render_p(sec_i, "Enter a denominator. See if it matches a known mixing angle. Try 33 (solar=10/33), 7 (atmospheric=4/7), 45 (reactor=1/45), 13 (Cabibbo).");
  make_interactive_widget(sec_i, "Denominator:", "#pmns-input", "e.g. 33", "Identify", "pmns_angle_calc", "pmns-result");
  dom_append(dom_body(), sec_i)
)

/* Body number axiom-check: enter count, get factorization */
fn human_body_calc() = (
  let n = parse_int_from("#body-input") in
  let result = dom_query("#body-result") in
  if n < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter a body count >= 1.</p>")
  else (
    mut rem = n;
    mut v2 = 0;
    while rem % 2 == 0 do (mut rem = rem / 2; mut v2 = v2 + 1);
    mut v3 = 0;
    while rem % 3 == 0 do (mut rem = rem / 3; mut v3 = v3 + 1);
    mut v5 = 0;
    while rem % 5 == 0 do (mut rem = rem / 5; mut v5 = v5 + 1);
    mut v7 = 0;
    while rem % 7 == 0 do (mut rem = rem / 7; mut v7 = v7 + 1);
    mut v11 = 0;
    while rem % 11 == 0 do (mut rem = rem / 11; mut v11 = v11 + 1);
    let smooth = if rem == 1 then 1 else 0 in
    let tag = if smooth > 0 then "<b style='color:#88ddaa'>AXIOM-SMOOTH</b> (pure {2,3,5,7,11} product)"
      else "<b style='color:#ffd700'>Not smooth (intruder: ${rem})</b>" in
    let known = if n == 2 then " = D (bilateral symmetry)" else if n == 3 then " = K (germ layers)" else if n == 5 then " = E (fingers, senses)" else if n == 7 then " = b (cervical vertebrae)" else if n == 20 then " = D^2*E (amino acids)" else if n == 37 then " = (L^3+1)/(L-E)^2 (body temp)" else if n == 42 then " = ANSWER (somites)" else if n == 206 then " = D*103 (bones)" else if n == 23 then " = chromosomes (D*23=46 total)" else if n == 46 then " = D*23 (chromosome pairs)" else if n == 10 then " = D*E (fingers total)" else if n == 32 then " = D^5 (teeth)" else if n == 12 then " = D^2*K (rib pairs)" else "" in
    dom_inner(result, "<p style='color:#ccc;margin:4px 0'>Body count = ${n}${known}</p><p style='margin:4px 0'>${tag}</p><p style='margin:4px 0;color:#999'>Factoring: 2^${v2} * 3^${v3} * 5^${v5} * 7^${v7} * 11^${v11}${if rem > 1 then " * ${rem}" else ""}</p>")
  )
)

fn page_human_shape() = (
  dom_head_meta("description", "The human body IS a ring map. D=2 bilateral, K=3 germ layers, E=5 fingers, b=7 cervical vertebrae. Body temperature = (L^3+1)/(L-E)^2 = 37C exact. 20 amino acids = D^2*E. Six organ systems map to six primes. DATA ring Z/210: mortal because no L=11 error correction. 10+ independent matches (S275 PROVED).");
  /* === HERO === */
  let hero = make_hero("Your Body Is a Ring") in
  let big = dom_create("div") in
  dom_text(big, "T = (L^3 + 1) / (L - E)^2 = 37");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Every number in your body is a product of {2, 3, 5, 7}. You live in the DATA ring Z/210Z -- the subring WITHOUT L=11 (protector). No error correction. Raw structure. Beautiful, fragile, mortal. Body temperature is an algebraic identity of the five primes. 10+ independent body-axiom correspondences proved (S275).");
  dom_append(dom_body(), hero);

  /* === SEC 1: BODY NUMBERS TABLE === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Body Numbers");
  render_p(sec1, "Each structural constant of the human body factors into the five axiom primes. These are not curve-fits -- each expression is the SIMPLEST prime factorization that matches, and the body plan leaves no room for alternatives:");
  let btbl = dom_create("table") in
  dom_style(btbl, "width", "100%");
  dom_style(btbl, "maxWidth", "700px");
  dom_style(btbl, "margin", "24px auto");
  dom_style(btbl, "borderCollapse", "collapse");
  let bhdr = dom_create("tr") in
  render_th(bhdr, "Feature");
  render_th(bhdr, "Number");
  render_th(bhdr, "Axiom");
  render_th(bhdr, "Why");
  dom_append(btbl, bhdr);
  render_table_row_4(btbl, "Bilateral symmetry", "2", "D", "First departure from unity. Left/right, two eyes, two hemispheres.");
  render_table_row_4(btbl, "Germ layers", "3", "K", "Ecto/meso/endoderm. Minimum to close a body plan.");
  render_table_row_4(btbl, "Spatial axes", "3", "K", "Up/down, front/back, left/right. K=3 = closure.");
  render_table_row_4(btbl, "Fingers per hand", "5", "E", "Pentadactyl limb. Observer grasps the world.");
  render_table_row_4(btbl, "Senses", "5", "E", "E^2 = null: you cannot sense your own sensing.");
  render_table_row_4(btbl, "Cervical vertebrae", "7", "b", "ALL mammals, mouse to giraffe. Depth.");
  render_table_row_4(btbl, "Histone octamer", "8", "D^3", "8 histones wrap DNA. Spider's 8 legs.");
  render_table_row_4(btbl, "Amino acids", "20", "D^2*E", "4 bases observed through 5 wobble positions.");
  render_table_row_4(btbl, "Ribs (pairs)", "24", "D^3*K", "Spider legs times closure.");
  render_table_row_4(btbl, "Hand bones", "27", "K^3", "Closure cubed. Perfect grip.");
  render_table_row_4(btbl, "Vertebrae (total)", "33", "K*L", "Closure times protector. Spine = K*L.");
  render_table_row_4(btbl, "Body temp (C)", "37", "(L^3+1)/(L-E)^2", "Enzyme optimum. Algebraic identity.");
  render_table_row_4(btbl, "Chromosomes (human)", "46", "D*23", "23=CC1(L). Fusion halved ape 48.");
  render_table_row_4(btbl, "Chromosomes (ape)", "48", "phi(210)", "phi(DATA) = b^2-1 = D^4*K.");
  render_table_row_4(btbl, "Bronchial generations", "23", "CC1(L)[3]", "D=2 bifurcation, 23 deep.");
  dom_append(sec1, btbl);
  dom_append(dom_body(), sec1);

  /* === SEC 2: ORGAN SYSTEMS = PRIMES === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Six Systems, Six Primes");
  render_p(sec2, "Each major organ system maps to one of the six axiom elements. PROVED at 10+ independent points (S275). The body IS the ring, walking:");
  let otbl = dom_create("table") in
  dom_style(otbl, "width", "100%");
  dom_style(otbl, "maxWidth", "700px");
  dom_style(otbl, "margin", "24px auto");
  dom_style(otbl, "borderCollapse", "collapse");
  let ohdr = dom_create("tr") in
  render_th(ohdr, "System");
  render_th(ohdr, "Prime");
  render_th(ohdr, "Why");
