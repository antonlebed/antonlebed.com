fn omega_hero() = (
  let hero = make_hero("OMEGA") in
  let eq = dom_create("div") in
  dom_text(eq, "D^420 = 606376");
  ct_mono(eq);
  dom_style(eq, "fontSize", "28px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "The terminal projector. OMEGA^2 = OMEGA: one pass is enough. D-channel dies; everything else survives. Not an absorber -- a filter. What passes through OMEGA has lost its duality but kept its depth, its closure, its observation, and its protection.");
  dom_append(dom_body(), hero)
)

fn omega_idempotent() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Idempotent");
  render_p(sec, "OMEGA is the D-spiral's fixed point: raise D=2 to the 420th power mod 970200. What remains is an idempotent projector -- applying it twice changes nothing. The D-channel (mod 8) is nilpotent: 2^3 = 0 mod 8. The four odd channels cycle and return to 1. Result: CRT(0,1,1,1,1).");
  let g = make_findings_grid(sec) in
  render_finding(g, "Value", "606376", "D^420 mod 970200. PROOF: compute D^k mod each channel. D^3=0(mod 8), 2^6=1(mod 9), 2^20=1(mod 25), 2^21=1(mod 49), 2^10=1(mod 11). lcm(3,6,20,21,10)=420.", "S311");
  render_finding(g, "CRT", "(0, 1, 1, 1, 1)", "D-channel = 0 (dead). All odd channels = sigma (alive). Death is selective.", "S311");
  render_finding(g, "OMEGA^2", "= OMEGA", "Idempotent. PROOF: (0,1,1,1,1)^2 = (0,1,1,1,1). Channel-wise squaring.", "");
  render_finding(g, "Image", "|image| = N/D^3 = 121275", "OMEGA*n = (0, n mod 9, n mod 25, n mod 49, n mod 11). D-channel erased, rest preserved.", "S478");
  render_finding(g, "Coupling", "121275", "Same as image size. Maximal for non-units. OMEGA sees N/D^3 elements.", "");
  render_finding(g, "Factorization", "OMEGA = D^3 * 75797", "75797 is PRIME. CRT(75797) = (5, 8, 22, 43, 7) = (E, D^3, E^2-K, 43, b). The axiom primes appear in its own factors.", "S311");
  dom_append(dom_body(), sec)
)

fn omega_decomposition() = (
  let sec = make_section("800px") in
  render_h2(sec, "Idempotent Decomposition of Existence");
  render_theorem(sec, "sigma = OMEGA + e_D", "e_D = sigma - OMEGA = 363825 = K^3*E^2*b^2*L. CRT(e_D) = (1,0,0,0,0). The D-channel identity. OMEGA^2 = OMEGA, e_D^2 = e_D, OMEGA*e_D = 0, OMEGA + e_D = sigma. This is a complete orthogonal decomposition: existence splits into terminal fate and duality, with zero interference between them.");
  render_p(sec, "OMEGA = sigma + E*N/D^3. e_D = K*N/D^3. Cross-chain pair (K,E) as idempotent coefficients. The observer builds the terminal; closure builds the dual. Self-referential.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Coupling duality", "coupling(OMEGA) = N/D^3 = 121275", "coupling(e_D) = D^3 = 8. Each is the OTHER's channel modulus. Perfect complementarity.", "");
  render_finding(g, "Spectral duality", "eigenvalue(e_D) = 8 + sqrt(2) = 9.414", "eigenvalue(OMEGA) = 9.135. The D-only projector resonates HIGHER. PROOF: e_D has 4 zero channels (each contributing 2) + D at residue 1 giving 2*cos(pi/4) = sqrt(2). OMEGA: D=0 gives 2, four channels at residue 1 sum ~7.135.", "S773");
  render_finding(g, "Kernel", "|ker(OMEGA)| = D^3 = 8", "Only 8 elements truly die. Mean coupling of kernel = D*K = 6.", "");
  dom_append(dom_body(), sec)
)

fn omega_spiral() = (
  let sec = make_section("800px") in
  render_h2(sec, "The D-Spiral: Sub-Returns");
  render_theorem(sec, "D-Spiral Theorem", "D^n is a spiral, not a cycle. D^0 = sigma (all alive), D^3 = D-channel dies, D^420 = OMEGA (limit). The void is UNREACHABLE by D^n. OMEGA is the fixed point. Algebraic distinction: void = before the spiral, OMEGA = after. The D-channel is nilpotent (2^3 = 0 mod 8). Once dead, never returns.");
  render_p(sec, "Five CRT channels evolve independently. Each has its own period. The sub-returns mark where channels come home:");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Step k");
  render_th(hdr, "Event");
  render_th(hdr, "CRT State");
  render_th(hdr, "Why");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "k=3", "D DIES", "(0, -, -, -, -)", "2^3 = 0 mod 8. Nilpotent.");
  render_table_row_4(tbl, "k=6", "K home", "(0, 1, -, -, -)", "ord(2, 9) = 6. Closure returns.");
  render_table_row_4(tbl, "k=10", "L home", "(0, -, -, -, 1)", "ord(2, 11) = 10. Protection returns.");
  render_table_row_4(tbl, "k=20", "E home", "(0, -, 1, -, -)", "ord(2, 25) = 20. Observer returns.");
  render_table_row_4(tbl, "k=21", "b home", "(0, -, -, 1, -)", "ord(2, 49) = 21. Depth returns.");
  render_table_row_4(tbl, "k=42", "K+b sync", "ANSWER", "lcm(6,21)=42. Closure meets depth.");
  render_table_row_4(tbl, "k=60", "baby period", "K+E+L sync", "lcm(6,20,10)=60. Three channels.");
  render_table_row_4(tbl, "k=210", "DATA sync", "4 channels home", "lcm(6,20,21,10)=420/2. Half-cycle.");
  render_table_row_4(tbl, "k=420", "OMEGA", "(0, 1, 1, 1, 1)", "lcm(6,20,21,10)=420. ALL sync. Lambda.");
  render_p(sec, "Growth takes 420 steps. Collapse takes 1 (OMEGA*e_D=0). Rebirth is free (0/0=R). Living is slow. Dying is fast. Birth costs nothing.");
  dom_append(dom_body(), sec)
)

fn omega_broadcaster() = (
  let sec = make_section("800px") in
  render_h2(sec, "The OMEGA Broadcaster");
  render_theorem(sec, "OMEGA Broadcast Theorem (S712)", "OMEGA*p = CRT(0, p, p, p, p) for p in {D, K, E, b}. Each axiom prime broadcasts uniformly into all preserved channels. EXCEPT: OMEGA*L = (0, 2, 11, 11, 0). L-channel = 0 because 11 mod 11 = 0. The protector sacrifices its own channel through the terminal projector.");
  render_p(sec, "OMEGA kills D. L kills itself through OMEGA. Together: two channels die at the boundary. This is the axiom's own death signature -- duality and protection are the two things that cannot survive their own projection.");
