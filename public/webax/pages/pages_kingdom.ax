  render_finding(g, "OMEGA*K", "(0, 3, 3, 3, 3)", "Closure broadcasts uniformly.", "S712");
  render_finding(g, "OMEGA*E", "(0, 5, 5, 5, 5)", "Observer broadcasts uniformly.", "S712");
  render_finding(g, "OMEGA*b", "(0, 7, 7, 7, 7)", "Depth broadcasts uniformly.", "S712");
  render_finding(g, "OMEGA*L", "(0, 2, 11, 11, 0)", "L-channel DIES: 11 mod 11 = 0. The protector's sacrifice.", "S712");
  dom_append(dom_body(), sec)
)

