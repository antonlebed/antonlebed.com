  dom_append(dom_body(), hero)
)

fn omega_idempotent() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Idempotent");
  render_p(sec, "OMEGA is the D-spiral's fixed point: raise D=2 to the 420th power mod 970200. What remains is an idempotent projector -- applying it twice changes nothing. The D-channel (mod 8) is nilpotent: 2^3 = 0 mod 8. The four odd channels cycle and return to 1. Result: CRT(0,1,1,1,1).");
  let g = make_findings_grid(sec) in
  render_finding(g, "Value", "606376", "D^420 mod 970200. PROOF: compute D^k mod each channel. D^3=0(mod 8), 2^6=1(mod 9), 2^20=1(mod 25), 2^21=1(mod 49), 2^10=1(mod 11). lcm(3,6,20,21,10)=420.", "S311");
  render_finding(g, "CRT", "(0, 1, 1, 1, 1)", "D-channel = 0 (dead). All odd channels = sigma (alive). Death is selective.", "S311");
  render_finding(g, "OMEGA^2", "= OMEGA", "Idempotent. PROOF: (0,1,1,1,1)^2 = (0,1,1,1,1). Channel-wise squaring.", "");
  render_finding(g, "Image", "|image| = N/D^3 = 121275", "OMEGA*n = (0, n mod 9, n mod 25, n mod 49, n mod 11). D-channel erased, rest preserved.", "S478");
  render_finding(g, "Coupling", "121275", "Same as image size. Maximal for non-units. OMEGA sees N/D^3 elements.", "");
  render_finding(g, "Factorization", "OMEGA = D^3 * 75797", "75797 is PRIME. CRT(75797) = (5, 8, 22, 43, 7) = (E, D^3, E^2-K, 43, b). The axiom primes appear in its own factors.", "S311");
  dom_append(dom_body(), sec)
)

