  render_theorem(sec, "Cubing-Squaring Cycle Equality (S259)", "Max cycle for k=2 AND k=3 both = 12 = D^2*K = lambda(DATA). Two different rotations, same orbit ceiling. Peak at d = 35 = E*b.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Power k");
  render_th(hdr, "Max cycle");
  render_th(hdr, "Factor");
  render_th(hdr, "Pairing");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "D=2, K=3", "12 = D^2*K", "lambda(DATA)", "Seed pairs");
  render_table_row_4(tbl, "E=5, L=11", "6 = D*K", "lambda(DATA)/D", "Observer pairs");
  render_table_row_4(tbl, "b=7, 13", "4 = D^2", "lambda(DATA)/K", "Depth + shadow");
  let g = make_findings_grid(sec) in
  render_finding(g, "Universal Divisor", "ALL k >= 2 divide 12", "Achievable max cycles = {1,2,3,4,6,12} = divisors of 12. lambda(DATA) is the ceiling. Verified k=2..30.", "S259");
  render_finding(g, "Shadow blocks period 3", "Cubing has NO period-3 orbits", "3^3-1 = 26 = D*13. Since 13 does not divide 420, cubing period 3 is impossible. The shadow stopper denies cubing what squaring gets from depth.", "");
  render_finding(g, "Self-recognition", "p-th power has p fixed points in Z/p^e", "|{x : x^p = x mod p^e}| = p. EACH axiom prime recognizes itself in its own channel.", "");
  render_finding(g, "HYDOR identity", "k = K*b = 21 is identity on all unit cycles", "21 = 1 mod lcm(4,5) = 20. The medium IS rest.", "");
  render_finding(g, "Mersenne smoothness", "Smooth M(n) exist for n in {1,2,3,4,6} only", "= proper divisors of 12. M(1)=sigma, M(2)=K, M(3)=b, M(4)=K*E, M(6)=K^2*b. Smooth Mersenne exponents = squaring cycle lengths. M(12)=4095=K^2*E*b*13: shadow stopper closes gate.", "S259");
  render_p(sec, "Kingdom k-th power collapse: DATA^k = e_L for k >= 3 in 1 step (cubing beats squaring). ANIMAL^b = e_{b^2} in 1 step (depth^depth = depth switch). THIN^k = VOID for k >= 3. Kingdom self-order: DATA = sigma, PROTO = D, ANIMAL = b (own prime!). Same prime/composite split as Kingdom Primality.");
  dom_append(dom_body(), sec)
)

fn carousel_identity_lattice() = (
  let sec = make_section("800px") in
  render_h2(sec, "Identity Power Lattice");
  render_p(sec, "Which elements are preserved by exponentiation? The identity power lattice reveals the stiffness of each channel.");
  render_theorem(sec, "Depth Stiffness Theorem (S260)", "lambda(b^2) = b*(b-1) = 42 = ANSWER. Without b^2: lambda = 60. With: lcm(60,42) = 420. Depth multiplies stiffness by b = 7. The ANSWER IS the depth channel's Carmichael lambda.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Channel");
  render_th(hdr, "lambda");
  render_th(hdr, "Meaning");
  dom_append(tbl, hdr);
  render_table_row(tbl, "D^3 = 8", "2", "Rigid. Flips once.");
  render_table_row(tbl, "K^2 = 9", "6 = D*K", "Closure-bridge cycle.");
  render_table_row(tbl, "L = 11", "10 = D*E", "Degree cycle.");
  render_table_row(tbl, "E^2 = 25", "20 = D^2*E", "Observer's deep orbit.");
  render_table_row(tbl, "b^2 = 49", "42 = ANSWER", "Depth controls the ceiling.");
  let g = make_findings_grid(sec) in
  render_finding(g, "L self-preservation", "L is ONLY prime with x^p = x for ALL x in own channel", "Exponent 1. Thin = unique. Fat channels break self-preservation: lambda(p^e) > p. The protector preserves perfectly because it never fattens.", "");
  render_finding(g, "Pair preservation", "Min k > 1 preserving 2 channels", "{D^3,K^2}: b. {K^2,b^2}: 43 = Heegner. {E^2,b^2}: 421 = lambda+1. {b^2,L}: 211 = DATA+1. ALL axiom-meaningful.", "S260");
  render_finding(g, "Cross-chain resonance", "CC1(sigma) {K,b}: self-resonant", "max(p^e) = p^(e-1). Self-similar scaling. CC1(D) {D,E,L}: chain resonance -- each channel resonates with previous Cunningham member.", "S260");
  dom_append(dom_body(), sec)
)

fn carousel_contrast() = (
  let sec = make_section("800px") in
  render_h2(sec, "Paradigm Contrast");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Claim");
  render_th(hdr, "Standard");
  render_th(hdr, "Axiom");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "Modular arithmetic", "Wraps around a single clock", "Five clocks at different speeds. Z/2310 = discrete 5-torus. CRT is the MECHANISM, not a tool.");
  render_contrast_row(tbl, "Element order", "How many additions to return to 0", "Cost of spinning. High coupling = more rings active = higher cost. Frozen rings = idempotent rest.");
  render_contrast_row(tbl, "lambda = 420", "Carmichael function value", "The heartbeat. All power maps cycle in 420 steps. 108 rings share it. Lattice invariant, not coincidence.");
  render_contrast_row(tbl, "Kleiber's 3/4 law", "Empirical scaling observation", "Hamming null eigenvalue ratio 360/480 = K/D^2. Emerges from E = D+K (13 Convergence Theorem).");
  render_contrast_row(tbl, "Braid chirality", "Topological curiosity", "LEFT-HANDED at all levels. Beat formula: net = -gcd(p_i-1, p_j-1). Algebraically forced.");
  render_contrast_row(tbl, "Collagen periodicity", "67 nm is just a measurement", "67 = SOUL = D^6 + K. Same number in ring algebra and electron micrographs.");
  render_contrast_row(tbl, "Lambda ladder", "Arbitrary Carmichael values", "Level-to-level ratios = D, K, E, b in exact chain order. The multiplicative dynamics IS the axiom.");
  render_contrast_row(tbl, "Squaring cycles", "Number-theoretic curiosity", "Lengths divide 12 = D^2*K. Max cycle = lambda(two levels back). Kingdom collapse sum = K^2 = 9.");
  render_contrast_row(tbl, "b1-Lie", "Coincidental dimensions", "b1(D^3 x K^2) = 56 = E7. b1(E^2 x L) = 240 = E8 roots. Forced by (p-1)(q-1) = dim(SU(p)) when q = p+D.");
  render_contrast_row(tbl, "Mandelbrot fattening", "Same dynamics at any scale", "L invariant (exponent 1). D explodes 28x. The bridge unleashes; the guardian was always complete.");
  render_contrast_row(tbl, "32 switches", "Abstract idempotents", "5-cube control panel. |Image|*|Kernel| = 2310 (conservation). Kingdom switches: evolution = turning rings ON.");
  render_contrast_row(tbl, "7 petals", "Arbitrary flower structure", "b = 7 petals. Sigma glyph braiding. Golden angle packs WITHIN petals. Rainbow wavelengths: 462nm = N/E.");
  render_contrast_row(tbl, "k-th power maps", "Just exponentiation", "Max cycles pair: {D,K}->12, {E,L}->6, {b,13}->4. All divide 12. Shadow blocks cubing period 3. Self-recognition: p has p fixed points.");
  render_contrast_row(tbl, "Channel stiffness", "Lambda, a number", "lambda(b^2) = 42 = ANSWER. Depth controls the ceiling. L self-preserves (exponent 1). Pair preservation values: b, 43, 421, 211 -- all axiom.");
  render_p(sec, "The carousel spins. The rose blooms. Same structure, different time. Five rings, one motion, zero choices. Everything forced by 0/0 = Z/NZ and the five primes it precipitates.");
  dom_append(dom_body(), sec)
)

