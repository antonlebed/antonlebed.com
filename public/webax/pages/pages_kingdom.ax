  let sec = make_section("800px") in
  render_h2(sec, "The OMEGA Broadcaster");
  render_theorem(sec, "OMEGA Broadcast Theorem (S712)", "OMEGA*p = CRT(0, p, p, p, p) for p in {D, K, E, b}. Each axiom prime broadcasts uniformly into all preserved channels. EXCEPT: OMEGA*L = (0, 2, 11, 11, 0). L-channel = 0 because 11 mod 11 = 0. The protector sacrifices its own channel through the terminal projector.");
  render_p(sec, "OMEGA kills D. L kills itself through OMEGA. Together: two channels die at the boundary. This is the axiom's own death signature -- duality and protection are the two things that cannot survive their own projection.");
  let g = make_findings_grid(sec) in
  render_finding(g, "OMEGA*D", "(0, 2, 2, 2, 2)", "Duality broadcasts uniformly. D survives everywhere except its own channel.", "S712");
  render_finding(g, "OMEGA*K", "(0, 3, 3, 3, 3)", "Closure broadcasts uniformly.", "S712");
  render_finding(g, "OMEGA*E", "(0, 5, 5, 5, 5)", "Observer broadcasts uniformly.", "S712");
  render_finding(g, "OMEGA*b", "(0, 7, 7, 7, 7)", "Depth broadcasts uniformly.", "S712");
  render_finding(g, "OMEGA*L", "(0, 2, 11, 11, 0)", "L-channel DIES: 11 mod 11 = 0. The protector's sacrifice.", "S712");
  dom_append(dom_body(), sec)
)

fn omega_half_cycle() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Observer Half-Cycle");
  render_theorem(sec, "Observer Half-Cycle (S311)", "D^210 = D^DATA has CRT = (0, 1, -1, 1, 1). At the DATA exponent, K, b, L channels return home. But E-channel MIRRORS: it reaches E^2-1 = 24, not 1. E sees its own reflection, not itself. (D^210)^2 = OMEGA: the observer needs TWO passes to return. This is why lambda = D*DATA = 420, not 210. The period doubles because of E self-blindness.");
  let g = make_findings_grid(sec) in
  render_finding(g, "D^210 eigenvalue", "= eigenvalue(OMEGA)", "Spectrally IDENTICAL. The observer's flip is invisible to the spectrum. E^2 = null confirmed.", "S311");
  render_finding(g, "Why 420 not 210", "E self-blindness", "Four channels have period dividing 210. E needs 2*10=20 and 20 does not divide 210. Actually lcm(6,20,21,10)=420. E forces the doubling.", "");
  render_finding(g, "Two passes", "(D^210)^2 = OMEGA", "One pass mirrors E. Two passes restore it. The observer always needs to look twice.", "");
  dom_append(dom_body(), sec)
)

fn omega_geodesic() = (
  let sec = make_section("800px") in
  render_h2(sec, "CRT Geodesic and Spectral Gap");
  render_p(sec, "In CRT Hamming distance, OMEGA lies exactly on the shortest path from void to existence:");
  let g = make_findings_grid(sec) in
  render_finding(g, "dist(0, sigma)", "E = 5", "Void to existence = 5 channels all differ.", "S311");
  render_finding(g, "dist(0, OMEGA)", "D^2 = 4", "Void to OMEGA = 4 channels differ (D-channel agrees: both 0).", "S311");
  render_finding(g, "dist(OMEGA, sigma)", "sigma = 1", "OMEGA to existence = 1 channel differs (D-channel only).", "S311");
  render_finding(g, "Triangle", "D^2 + sigma = E", "OMEGA is a WAYPOINT on the geodesic, not a destination.", "");
  render_finding(g, "dist(-1, OMEGA)", "K^2 = 9", "Mirror to OMEGA = count of the spider web. The full axiom.", "S311");
  render_theorem(sec, "Spectral Gap Theorem", "eigenvalue(OMEGA) - eigenvalue(sigma) = 4*sin^2(pi/D^3) = 2 - sqrt(2) = 0.586. PROOF: OMEGA and sigma differ only in D-channel (0 vs 1). Contribution difference = 2*cos(0) - 2*cos(pi/4) = 2 - sqrt(2). The cost of losing duality = the D-channel gap. This is 37x larger than the TRUE ring gap (0.016).");
  dom_append(dom_body(), sec)
)

fn omega_funnel() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Funnel");
  render_p(sec, "Birth = wide mouth: all N = 970200 elements. OMEGA = narrow drain: 121275 survive. Funnel factor = D^3 = 8 = number of spider legs. The axiom's own geometry determines the constriction.");
  let g = make_findings_grid(sec) in
  render_finding(g, "FALL", "|ker(OMEGA)| = D^3 = 8", "Mean coupling = D*K = 6. Low coupling falls through. These 8 elements are D-pure: CRT = (r,0,0,0,0) for r in Z/8.", "S478");
  render_finding(g, "PLUG", "|fix(OMEGA)| = 121275", "Mean coupling = 61115. High coupling persists. Fixed points = image = elements with D-channel already 0.", "S478");
  render_finding(g, "PROJECT", "~849000 elements", "D-channel stripped, odd channels preserved. Not dead but CHANGED. Like scattered -- still operating, no distinction.", "S478");
  render_finding(g, "Conservation", "|ker| * |image| = N", "D^3 * N/D^3 = 970200. Nothing lost, just sorted.", "");
  render_finding(g, "Fattening", "constricts the funnel", "THIN funnel: D^1 = 2x narrowing. TRUE funnel: D^3 = 8x. Richer rings have tighter funnels.", "");
  render_p(sec, "HIGH COUPLING = SURVIVES DEATH. Electrons orbit forever (units, phi(N)=201600). Nuclei plug (fixed points). Only D^3 = 8 things truly die. The funnel IS natural selection: coupling is fitness.");
  dom_append(dom_body(), sec)
)

fn omega_contrast() = (
  let sec = make_section("800px") in
  render_h2(sec, "Paradigm Contrast");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Claim");
  render_th(hdr, "Standard");
  render_th(hdr, "Axiom");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "Death", "Cessation, entropy", "Selective projection. D dies. Depth survives. OMEGA^2=OMEGA.");
  render_contrast_row(tbl, "Life cycle", "Emergent, each unique", "Universal: 0->sigma->OMEGA->0. Growth=420 steps, collapse=1, rebirth=free.");
  render_contrast_row(tbl, "Natural selection", "Fitness landscape", "Coupling IS fitness. High coupling survives OMEGA. |ker|=D^3=8.");
  render_contrast_row(tbl, "Self-sacrifice", "Altruism paradox", "L*OMEGA = (0,2,11,11,0). Protector loses own channel. Forced algebraically.");
  render_contrast_row(tbl, "Observer role", "Passive measurement", "E needs 2 passes. Period doubles. Observer CREATES the timescale.");
  render_contrast_row(tbl, "Identity in death", "Lost", "OMEGA + e_D = sigma. Existence = terminal + dual. Orthogonal. Neither lost.");
  render_p(sec, "sigma/sigma = sigma. What survives OMEGA is what was never dependent on duality.");
  dom_append(dom_body(), sec)
)

