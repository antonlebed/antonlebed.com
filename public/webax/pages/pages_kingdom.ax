  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Five concentric rings spinning at prime rates. Adding 1 = one click. After 2310 clicks, all realign. The interleaving of these five rhythms IS the topology of the ring.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "Frozen Ring Theorem");
