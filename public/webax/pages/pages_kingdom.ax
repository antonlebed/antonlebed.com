  render_theorem(sec, "Hamming Spectrum Theorem", "Eigenvalues: lambda_S = sum_{i in S} q_i - k, for each subset S of factors. Multiplicity: prod_{i not in S}(q_i - 1). Max eigenvalue = degree = sum(q_i - 1). Min eigenvalue = -k. 2^k = 32 distinct eigenvalues in the TRUE FORM -- no eigenvalue merging.");
