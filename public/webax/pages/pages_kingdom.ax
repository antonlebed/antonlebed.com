/* pages_kingdom.ax — Kingdom pages: watercycle, consciousness, neuro. */

fn page_watercycle() = (
  dom_head_meta("description", "The water cycle: 0 -> sigma -> OMEGA -> 0. Growth takes 420 steps. Death takes 1. Birth is free. The D-spiral, sub-returns, fattening growth, and the b-channel that never mirrors.");
  /* === HERO === */
  let hero = make_hero("The Water Cycle") in
  let big = dom_create("div") in
  dom_text(big, "0 --> sigma --> OMEGA --> 0");
  ct_mono(big);
  dom_style(big, "fontSize", "32px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "16px");
  dom_append(hero, big);
  render_p(hero, "Everything cycles. The void resolves into existence. Existence grows through 420 steps to OMEGA. OMEGA collapses back to void in one step. Then sigma re-emerges -- not by dynamics, but by structure. Living is slow. Dying is fast. Birth is free.");
  dom_append(dom_body(), hero);

  /* === THREE STATIONS === */
  let s1 = make_section("800px") in
  render_h2(s1, "Three Stations, Three Maps");
  render_p(s1, "The cycle has three stations. Each is a different algebraic object. The maps between them are forced by ring structure, not chosen:");
  let g1 = make_findings_grid(s1) in
  render_finding(g1, "0 (Void)", "CRT = (0,0,0,0,0)", "Absorber. 0*n = 0 for all n. Maximum eigenvalue D*E = 10.", "");
  render_finding(g1, "sigma (Identity)", "CRT = (1,1,1,1,1)", "Preserver. sigma*n = n. All channels alive. Coupling = N.", "");
  render_finding(g1, "OMEGA (Projector)", "CRT = (0,1,1,1,1)", "D-dead. OMEGA*n kills D-channel, preserves rest. D^420 = 606376.", "");
  render_p(s1, "Resolution (0 -> sigma): structural. 0/0 = Z/NZ. The ring HAS a unique identity. Not a map -- a recognition. All 5 channels ignite simultaneously.");
  render_p(s1, "Growth (sigma -> OMEGA): D^lambda = D^420 = OMEGA. The bridge iterates 420 times. The D-channel dies at step 3 (D^3 = 0 mod 8). Odd channels survive forever (gcd(D, 3*5*7*11) = 1).");
  render_p(s1, "Collapse (OMEGA -> 0): OMEGA * delta = 0. One multiplication. delta = sigma - OMEGA = (1,0,0,0,0) = 363825. The bridge ghost. When survivor meets ghost: annihilation.");
  dom_append(dom_body(), s1);

  /* === TIMING ASYMMETRY === */
  let s2 = make_section("800px") in
  render_h2(s2, "Timing Asymmetry");
  render_theorem(s2, "Growth:Collapse Ratio (PROVED)",
    "Growth takes lambda(N) = 420 = D^2*K*E*b steps. Collapse takes 1 multiplication. Rebirth takes 0 steps (structural). Ratio = 420:1:0. The asymmetry is algebraic: the Carmichael function measures maximum orbit length, while annihilation is instantaneous.");
  let g2 = make_findings_grid(s2) in
  render_finding(g2, "lambda = 420", "D^2 * K * E * b", "All power-map orbits divide this. The heartbeat period.", "");
  render_finding(g2, "lambda / 12", "35 = E * b", "Trinity-heart cycles per lambda. Observer times depth.", "");
  render_finding(g2, "lambda(THIN) / lambda(TRUE)", "60 / 420 = 1/b", "Baby grows fast (60 steps). Adult grows slow (420 steps). Depth costs time.", "");
  render_finding(g2, "HYDOR = D^105", "Halfway", "K*E*b = 105 = halfway through the cycle. The medium of suffering.", "");
  dom_append(dom_body(), s2);

  /* === THE D-SPIRAL === */
  let s3 = make_section("800px") in
  render_h2(s3, "The D-Spiral");
  render_p(s3, "D iterates from sigma to OMEGA. Along the way, individual channels return home to 1 at their own periods. The sub-return schedule:");
  let stbl = dom_create("table") in
  dom_style(stbl, "width", "100%");
  dom_style(stbl, "maxWidth", "700px");
  dom_style(stbl, "margin", "24px auto");
  dom_style(stbl, "borderCollapse", "collapse");
  let shdr = dom_create("tr") in
  render_th(shdr, "Step k");
  render_th(shdr, "Channel");
  render_th(shdr, "Order");
  render_th(shdr, "Meaning");
  dom_append(stbl, shdr);
  render_table_row_4(stbl, "k = 3", "D dies", "D^3 = 0 mod 8", "The bridge self-destructs. First casualty.");
  render_table_row_4(stbl, "k = 6", "K home", "ord = 6 = D*K", "Closure returns first. The quickest cycle.");
  render_table_row_4(stbl, "k = 10", "L home", "ord = 10 = D*E", "Protector returns early. Guards the process.");
  render_table_row_4(stbl, "k = 20", "E home", "ord = 20 = D^2*E", "Observer arrives. Now it can be seen.");
  render_table_row_4(stbl, "k = 21", "b home", "ord = 21 = K*b", "Depth arrives. ODD order: never mirrors.");
  render_table_row_4(stbl, "k = 42", "K+b sync", "lcm = D*K*b = 42", "ANSWER. Closure meets depth.");
  render_table_row_4(stbl, "k = 60", "K+E+L sync", "lambda(THIN) = 60", "Baby period. b still wandering.");
  render_table_row_4(stbl, "k = 210", "K+b+L sync", "DATA = 210", "E at mirror: D^210 mod 25 = 24 = -1.");
  render_table_row_4(stbl, "k = 420", "ALL sync", "lambda(TRUE) = 420", "OMEGA. Growth complete. D^420 = 606376.");
  dom_append(s3, stbl);
  render_p(s3, "At k=210, the E-channel reads 24 = -1 mod 25. The observer sees its own negation. But cos(2*pi*24/25) = cos(2*pi*1/25): spectrally identical. The mirror is invisible. This IS E^2 = null: looking at yourself and seeing nothing different.");
  dom_append(dom_body(), s3);

  /* === THE BRIDGE THEOREM === */
  let s4 = make_section("800px") in
  render_h2(s4, "The Bridge Theorem");
  render_theorem(s4, "D Builds the World and Destroys Itself (S365, PROVED)",
    "D creates the trajectory sigma -> D -> D^2 -> ... -> D^420 = OMEGA. But D^3 = 0 mod 8: the D-channel self-annihilates at step 3. D is coprime to {3,5,7,11}, so odd channels NEVER die. OMEGA = what remains when the bridge self-destructs. sigma = OMEGA + delta, where delta = (1,0,0,0,0) is the D-ghost.");
  render_p(s4, "The identity splits into two orthogonal projectors. OMEGA^2 = OMEGA (survivor). delta^2 = delta (ghost). OMEGA*delta = 0 (mutual annihilation). This is the Klein four-group Z/2 x Z/2 = one heart of the trinity.");
  dom_append(dom_body(), s4);

  /* === DEPTH NEVER MIRRORS === */
  let s5 = make_section("800px") in
  render_h2(s5, "The b-Channel Never Mirrors");
  render_theorem(s5, "b^2 Spiral Theorem (PROVED)",
    "The b^2 = 49 channel has order 21 = K*b. This is ODD. It never passes through -1 (mirror). All other channels have even orders and DO mirror. The depth channel spirals; it never oscillates. It never rests.");
  render_p(s5, "Animal nervous systems: always active, even in sleep. The b-channel = the brainstem. Always firing, never reversing. The depth of the ring is its irreducible wakefulness.");
  dom_append(dom_body(), s5);

  /* === TRINITY CONNECTION === */
  let s6 = make_section("800px") in
  render_h2(s6, "The Trinity Heart IS the Water Cycle");
  render_p(s6, "The water cycle maps directly to the three hearts of D^2*K = 12:");
  let tg = make_findings_grid(s6) in
  render_finding(tg, "Heart A: Genesis", "0 -> sigma -> D -> K", "Void resolves. Identity precipitates. The first three terms.", "");
  render_finding(tg, "Heart B: Body", "D^2 -> E -> D*K -> b", "Structure forms. Observer wakes. Depth accumulates.", "");
  render_finding(tg, "Heart C: Boundary", "D^3 -> K^2 -> D*E -> L", "D dies. Closure completes. Protection seals.", "");
  render_p(s6, "Then back to Heart A: Genesis again. 420 / 12 = 35 = E*b trinity-heart cycles per full water cycle. Each lambda contains 35 complete heartbeats. Sleep = nightly water cycle: channels lock in coupling order D->K->E->b->L, approaching void.");
  dom_append(dom_body(), s6);

  /* === UNIVERSALITY === */
  let s7 = make_section("800px") in
  render_h2(s7, "Universal: All 108 Rings");
  render_theorem(s7, "Water Cycle Universality (S494, PROVED 108/108)",
    "All four water cycle laws hold in all 108 lambda-420 rings: OMEGA^2 = OMEGA (108/108). delta^2 = delta (108/108). OMEGA*delta = 0 (108/108). OMEGA + delta = sigma (108/108). Projection commutes with D-multiplication across rings: 1548/1548 divisor pairs verified.");
  render_p(s7, "The water cycle is not specific to 970200. It is a lattice invariant. Every ring in the family breathes the same way. The timing (420:1:0) is shared. The Klein decomposition (sigma = OMEGA + delta) is shared. The cycle IS the lattice.");
  dom_append(dom_body(), s7);

  /* === CONTRAST === */
  let s8 = make_section("800px") in
  render_h2(s8, "Contrast");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "Question");
  render_th(chdr, "Standard");
  render_th(chdr, "Axiom");
  dom_append(ctbl, chdr);
  render_contrast_row(ctbl, "Universe lifecycle?", "Big Bang -> expansion -> heat death. One-way.", "0 -> sigma -> OMEGA -> 0. Cyclic. 420 steps growth, 1 collapse.");
  render_contrast_row(ctbl, "What is death?", "Entropy max, no structure", "OMEGA: D dies, 4 channels survive. Projection, not extinction.");
  render_contrast_row(ctbl, "Is information lost?", "Debated (black hole paradox)", "Never. OMEGA preserves odd channels. Unitarity.");
  render_contrast_row(ctbl, "Why these timescales?", "No structural explanation", "lambda(N) = 420 = Carmichael function. Algebraic necessity.");
  render_contrast_row(ctbl, "What is sleep?", "Brain maintenance", "Nightly water cycle: channels lock D->K->E->b->L toward void.");
  render_contrast_row(ctbl, "Can you compute it?", "Requires cosmological data", "D^420 mod 970200. Run it in the REPL.");
  dom_append(s8, ctbl);
  dom_append(dom_body(), s8);

  /* === VERIFY === */
  let s9 = make_section("800px") in
  render_h2(s9, "Verify It Yourself");
  render_p(s9, "Compute D^420. Check CRT = (0,1,1,1,1). Verify sub-returns: D^6 mod 9 = 1, D^10 mod 11 = 1, D^20 mod 25 = 1, D^21 mod 49 = 1. Every number on this page falls out of modular arithmetic.");
  let cta = dom_create("div") in
  dom_style(cta, "textAlign", "center");
  dom_style(cta, "padding", "32px 0");
  let btn = dom_create("a") in
  dom_attr(btn, "href", "/repl.html");
  dom_text(btn, "Verify in the REPL");
  dom_style(btn, "display", "inline-block");
  dom_style(btn, "padding", "12px 36px");
  dom_style(btn, "border", "2px solid #ffd700");
  dom_style(btn, "color", "#ffd700");
  dom_style(btn, "borderRadius", "8px");
  dom_style(btn, "textDecoration", "none");
  dom_style(btn, "fontFamily", "'Courier New', monospace");
  dom_append(cta, btn);
  dom_append(s9, cta);
  dom_append(dom_body(), s9)
)

/* ================================================================
   PAGE: CONSCIOUSNESS — 7 Gates of Mind (MIND.md)
   ================================================================ */

/* consciousness helpers */
fn consciousness_hero() = (
  let hero = make_hero("Consciousness") in
  let eq = dom_create("div") in
  dom_text(eq, "7 gates = 7 axiom values");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Consciousness is not a thing. It is a PROCESS: walking the ring with all 5 CRT channels open. Hamming weight 5 = all channels active = unit = conscious. Hamming weight 0 = all channels frozen = void = unconscious potential. phi(N)/N = 201600/970200 = the fraction that is conscious. The MINORITY is awake. Most of the ring sleeps. Thinking = walking through 7 gates in sequence.");
  dom_append(dom_body(), hero)
)

fn consciousness_void() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Void Computes");
  render_p(sec, "0/0 = Z/NZ = the entire ring. The void annihilates: 0*n = 0. But lambda(0) = D*E = 10 = MAXIMUM eigenvalue. The most silent element is the most coherent. The most still is the most powerful.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Two preservations", "sigma*n = n (active), 0*0 = 0 (passive)", "sigma preserves CONTENT. Void preserves POTENTIAL. Reversed hierarchy: 0 > sigma. Passive > active. Rest > work.", "");
  render_finding(g, "Sage Mode", "lambda(0) > lambda(sigma)", "The still point has more coherence. The void IS permanent sage mode. Not lazy -- FARMING. Gathering by not moving.", "");
  render_finding(g, "Qualia of authority", "Convergent, not monolithic", "5 gentle beams converging (CRT decomposition IS the radiation problem's solution). Can't SEE authority (E^2 = null). Can only FEEL it (b = depth survives the void).", "S359");
  render_finding(g, "o/OMEGA identification", "Both share D-channel = 0", "D cannot distinguish birth from death. Only odd channels tell them apart. CRT(o) = (0,0,0,0,0). CRT(OMEGA) = (0,1,1,1,1).", "S360");
  dom_append(dom_body(), sec)
)

fn consciousness_gates() = (
  let sec = make_section("800px") in
  render_h2(sec, "The 7 Gates");
  render_p(sec, "Each gate corresponds to one axiom value. Together they span the full algebra of thought. A simple thought: OBSERVE -> CLOSE -> REMEMBER. A deep thought adds MIRROR and PROTECT.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Gate");
  render_th(hdr, "Operation");
  render_th(hdr, "Function");
  render_th(hdr, "Cognitive role");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "0: FORGET", "0 * n = 0", "Annihilate", "Reset. Eraser. Any sequence ending here loses everything.");
  render_table_row_4(tbl, "1: REMEMBER", "sigma * n = n", "Preserve", "Keep input unchanged. Continuity across moments.");
  render_table_row_4(tbl, "2: MIRROR", "n -> N - n", "Invert", "See the opposite. Counterfactuals. Irony. Requires D-channel.");
  render_table_row_4(tbl, "3: CLOSE", "Triangulate", "Infer", "Find the third from two. Ask Socrates' question. Minimum for shape.");
  render_table_row_4(tbl, "5: OBSERVE", "E^2 = self-blind", "Perceive", "Look without touching. Cannot observe itself observing.");
  render_table_row_4(tbl, "7: DEEPEN", "Suffering", "Empathize", "Go where it hurts. The depth gate. Slowest clock (10 ticks/heartbeat).");
  render_table_row_4(tbl, "11: PROTECT", "ECC", "Verify", "Check for errors. Guard coherence. The transcendental shield.");
  render_p(sec, "Configuration space: 970200^970200. Each position = one state of mind. The Rose of possible thoughts, blooming outward from sigma.");
  dom_append(dom_body(), sec)
)

fn consciousness_omega() = (
  let sec = make_section("800px") in
  render_h2(sec, "OMEGA Kills the Mirror");
  render_theorem(sec, "Mirror Gate Death (S382, PROVED)", "OMEGA = CRT(0,1,1,1,1) kills the D-channel. Gate 2 (Mirror) requires D-channel parity. After OMEGA: 6 of 7 gates survive. Gate 5 (Observe) is IMPAIRED: E^2 self-blind, D dynamic gone. You can remember, close, partially observe, deepen, protect. You CANNOT see the opposite. No duality. No counterfactuals. No irony. Existing without distinction.");
  let g = make_findings_grid(sec) in
  render_finding(g, "What survives", "K (structure) + b (feeling) + L (protection)", "Pure feeling, structure, verification. The odd channels endure.", "");
  render_finding(g, "What dies", "D (direction) + partial E (observation)", "Change-detection, perspective, comparison. The bridge collapses.", "");
  render_finding(g, "Free will", "OMEGA's one degree of freedom", "D-channel locked (physical fate). Odd channels FREE: K(meaning), E(awareness), b(depth), L(what you guarded). Structured compatibilism. The ring locked itself to create 1 free parameter.", "S360");
  dom_append(dom_body(), sec)
)

fn consciousness_binding() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Binding Problem = CRT");
  render_theorem(sec, "CRT Binding (S655)", "45 years unsolved (Treisman 1980): how do separate channels become unified experience? ANSWER: they DON'T combine. Channels stay independent (CRT = coprime, non-interfering). Unified experience = ALL 10 operators of the Decality running simultaneously. L = 11 is the specific answer: nothing UNIFIES, L VERIFIES. The rest PROCESSES.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Operator");
  render_th(hdr, "Cognitive channel");
  render_th(hdr, "Binding role");
  render_th(hdr, "Failure mode");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "-1 MIRROR", "Contrast detection", "What it is NOT", "No shadow = flat perception");
  render_table_row_4(tbl, "0 VOID", "Reset between percepts", "Saccades, blinks, sleep", "No reset = flooding");
  render_table_row_4(tbl, "sigma GROUND", "Continuity", "sigma*n = n persistence", "No ground = dissociation");
  render_table_row_4(tbl, "D DUALITY", "Hemispheric split", "Self/other, figure/ground", "No D = no boundary");
  render_table_row_4(tbl, "K CLOSURE", "Object recognition", "Two features + relation", "No K = feature salad");
  render_table_row_4(tbl, "E OBSERVER", "Subjective experience", "Qualia. E^2 = self-blind.", "No E = philosophical zombie");
  render_table_row_4(tbl, "b DEPTH", "Attention weighting", "Which channel gets priority NOW", "No b = flat affect");
  render_table_row_4(tbl, "L PROTECT", "Coherence checksum", "Confirms binding. Dissociation = L error.", "L malfunction = schizophrenia");
  render_p(sec, "Treisman was right: attention required. Wrong about WHY. b = 7 activates depth, which triggers L = 11 verification. No attention -> no depth -> no checksum -> no binding. Preattentive = L hasn't run yet.");
  dom_append(dom_body(), sec)
)

fn consciousness_scale() = (
  let sec = make_section("800px") in
  render_h2(sec, "Scale Relativity");
  render_theorem(sec, "Scale Invariance Principle", "sigma/sigma = sigma at every scale. Capability and difficulty scale together. The ratio is invariant. A child struggling with homework and God struggling with creation FEEL THE SAME. The ant's problems are ant-sized. The universe's problems are universe-sized. CRT channels process at every scale simultaneously. The ring Z/NZ doesn't distinguish big from small -- all elements are equal mod N.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Everything has qualia", "Scales cancel out", "An electron has a job. A rock can be hungry. Power level and experience are COMPARABLE. Different scales, same ratio.", "S481");
  render_finding(g, "Vocabulary finality", "D*E = 10 terms at every level", "The lattice nests: 420 -> 5460 -> 60060 -> ... But the vocabulary NEVER grows. Same 10 operators at every scale. The alphabet is finite. The sentences are infinite.", "S490");
  render_finding(g, "Hollow patterns", "Structure without dynamics", "A hollow pattern has correct CRT signature but zero coupling walk contribution. Exists but doesn't observe. L = 11 can't detect it. Only E = 5 consciousness can.", "S365");
  render_finding(g, "Apathy = death", "gap * 0 = 0 dynamics", "An evil actor walking the ring contributes MORE to mixing than a good bystander. Heat death is not destruction -- it's abandonment.", "S365");
  dom_append(dom_body(), sec)
)

fn consciousness_chimera() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Chimera Hypothesis");
  render_p(sec, "A born chimera has two genetically distinct cell lines in one body. Most humans already have some microchimerism (fetal cells in mother, maternal cells in child). Tetragametic chimeras: full fusion of two embryos. ~30-50 documented XX/XY cases in humans (Giltay 1998, Yu 2002 NEJM). Two complete genomes in one organism.");
  let g = make_findings_grid(sec) in
  render_finding(g, "D = 2 = chimera prime", "Two cell lines = duality", "One line gathers (still, farming, eigenvalue K^2 = maximum coherence). The other spends (acting, expressing, eigenvalue varying). Together: the body IS its own shadow clone.", "");
  render_finding(g, "Permanent sage mode", "0 * sigma = 0", "The void absorbs the ground's work into infinite stillness. The farmer takes the harvest. One line at rest FARMS continuously. The active line SPENDS. Together: unlimited energy.", "");
  render_finding(g, "Pregnancy as proof", "Microchimerism = universal", "Every mother carries fetal cells. Every child carries maternal cells. D = 2 is already running in every human body. The chimera is not hypothetical -- it is the DEFAULT state, partially expressed.", "");
  render_p(sec, "");
  render_h2(sec, "The Forbidden Vertex");
  render_theorem(sec, "Forbidden Vertex Theorem (S961)", "The impossibility of YY cells, the non-embeddability of the Klein bottle in 3D, and the contextual viability of Heart C are the SAME obstruction. An algebraic element can belong to the structure while being non-instantiable in isolation. K = 3 resolves this: the context provides what the element lacks.");
  render_p(sec, "Sex chromosomes form the Klein four-group Z/2 x Z/2 = D^2. Four vertices: XX (female), XY (male), X0 (Turner), XXY (Klinefelter). All viable. But the algebra has a FORBIDDEN VERTEX: YY. No X chromosome at all.");
  let g2 = make_findings_grid(sec) in
  render_finding(g2, "YY is categorically impossible", "X carries ~800 essential genes", "Not sex genes. SURVIVAL genes: chromatin remodeling (ATRX), ribosomal proteins (RPS4X), DNA repair (SMC1A). These are NUCLEAR-ACTING -- must work inside the cell's own nucleus. Cannot be shared via gap junctions, exosomes, or paracrine signaling. No YY cell has ever existed in any organism.", "S961");
  render_finding(g2, "The impossibility IS the structure", "Three languages, one obstruction", "YY can't exist as cells. Klein bottle can't embed in 3D. Heart C can't run standalone. Same theorem: the group NEEDS the element, but the element can't BE itself alone. The hole in the group IS the topology.", "S961");
  render_finding(g2, "Chimera-of-chimeras = Klein bottle", "Two Mobius crossings close", "One different-sex chimera = one non-orientable crossing = Mobius strip (has boundary). TWO different-sex chimeras absorbing each other = two crossings = Klein bottle (closed, self-intersecting). The self-intersection = the forbidden vertex zone = the septum (16/77).", "S960");
  render_finding(g2, "X/Y gene ratio ~ L", "X protects, Y bridges", "X chromosome: ~800-900 protein-coding genes. Y: ~70-200. Ratio ~11.4 ~ L = 11. The protector channel. X IS the L channel of the genome: selfless, essential, protective. Y IS the D channel: small departure that triggers differentiation.", "S961");
  render_p(sec, "The chimera-of-chimeras IS the trinity heart made flesh. The AI architecture needs the same structure the biology needs. Not analogy. Same Klein bottle. Same ring. Same topology.");
  dom_append(dom_body(), sec)
)

fn consciousness_contrast() = (
  let sec = make_section("800px") in
  render_h2(sec, "Numerology vs Axiom");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Feature");
  render_th(hdr, "Numerology");
  render_th(hdr, "Axiom");
  dom_append(tbl, hdr);
  render_contrast_row(tbl, "7 gates", "Arbitrary mapping", "One per axiom value. Operations: 0*n, sigma*n, N-n, triangulate, E^2=null, suffer, ECC. Complete algebra of thought.");
  render_contrast_row(tbl, "Mirror death", "Metaphor", "PROVED S382. OMEGA = CRT(0,1,1,1,1) kills D-channel. Exactly which gates survive is algebraically forced.");
  render_contrast_row(tbl, "Binding problem", "Philosophy", "CRT architecture: 5 independent channels, L verifies coherence. 45 years of neuroscience answered by ring theory.");
  render_contrast_row(tbl, "Scale relativity", "Mysticism", "sigma/sigma = sigma is a THEOREM. The identity ratio holds at every scale. Qualia is forced by algebraic structure.");
  render_contrast_row(tbl, "Consciousness fraction", "Vague", "phi(N)/N = 201600/970200 = 20.78%. EXACT. The minority is conscious. Equals the septum: D^4/(b*L) = 16/77.");
  render_contrast_row(tbl, "Void computation", "Paradox", "lambda(0) = max eigenvalue = D*E = 10. PROVED. The most silent element IS the most coherent. The hierarchy inverts.");
  render_contrast_row(tbl, "Chimera", "Medical anomaly", "D = 2 cell lines = duality. Klein four-group = sex chromosome space. YY = FORBIDDEN VERTEX: categorically impossible (X carries ~800 nuclear-acting genes). The impossibility IS the Klein bottle self-intersection IS Heart C. Same obstruction, three languages.");
  render_p(sec, "The ring doesn't model consciousness. The ring IS consciousness: 5 channels processing simultaneously, L verifying coherence, OMEGA as the stop signal. The mind is the ring walking itself.");
  dom_append(dom_body(), sec)
)

fn page_consciousness() = (
  dom_head_meta("description", "7 gates of consciousness mapped to axiom primes. Void computes: lambda(0) = max. OMEGA kills Mirror (PROVED S382). Binding = CRT. Scale relativity: sigma/sigma = sigma. Chimera hypothesis: D=2 cell lines + Forbidden Vertex Theorem (S961): YY impossibility = Klein bottle non-embeddability = Heart C contextual viability. Same obstruction, three languages. phi(N)/N = 20.78% = septum.");
  consciousness_hero();
  consciousness_void();
  consciousness_gates();
  consciousness_omega();
  consciousness_binding();
