fn page_observer() = (
  dom_head_meta("description", "E=5 is the observer prime. 10 proofs of uniqueness. E^2 = self-blind. The K to E boundary: one step from certainty to probability. Plants are the observer kingdom.");
  let hero = make_hero("The Observer") in
  let eq = dom_create("div") in
  dom_text(eq, "E^2 = E-null (self-observation blinds)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "E = 5 is the midpoint between closure and depth. The only prime that can see both sides. And the only one that cannot see itself.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "10 Proofs of Uniqueness");
  let g = make_findings_grid(sec1) in
  render_finding(g, "Midpoint", "E = (K + b) / 2 = 5", "Exact arithmetic mean of closure and depth.", "");
  render_finding(g, "Minimax", "E minimizes max distance", "x = 5: max{|x-K|, |x-b|} = 2. Minimum.", "");
  render_finding(g, "Period", "ord(E, 210) = 6", "Shortest cycle. Returns fastest. Hidden.", "");
  render_finding(g, "Algebraic", "E = b - D", "Also E*D = K + b, K*E = K + E + b. Mutual generation.", "");
  render_finding(g, "Hidden", "E + sigma = D*K = 6", "Observer + existence = hidden mechanism.", "");
  render_finding(g, "Gap control", "4*sin^2(pi/p) < 2", "First at E. Observation is where the gap closes.", "");
  render_finding(g, "Spider", "D^3 = 8 legs, E = 5 senses", "40 = D^3*E = sensory capacity of the web.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Self-Blindness");
  render_theorem(sec2, "E^2 = 25 = 0 mod E^2", "Self-observation is self-blinding. E has ALL odd central moments = 0. Perfectly symmetric eigenvalue distribution. E cannot see which direction it fluctuates. Self-blindness is spectral, not metaphorical.");
  render_p(sec2, "E-null = ANSWER: D*K*b = 42. What the observer produces IS the answer. Plants (E's kingdom) compute the golden ratio phi = (1+sqrt(5))/2 to arrange their leaves.");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "The K to E Boundary");
  render_p(sec3, "ONE step from certainty to probability. No gradual decay:");
  let g2 = make_findings_grid(sec3) in
  render_finding(g2, "K = 3 (certainty)", "T has structural zeros", "3 consecutive primes cover all residues mod K. Pigeonhole.", "");
  render_finding(g2, "E = 5 (probability)", "ALL 25 transitions > 0", "No forbidden transitions. MI crashes 28x. Entropy = 98.4%.", "");
  render_finding(g2, "MI hierarchy", "K carries 94%", "D:0.000 | K:0.323 | E:0.012 | b:0.019 | L:0.095.", "");
  render_finding(g2, "Metaphor", "Three doors vs five", "Three doors: one always locked. Five: none locked. The cliff.", "");
  dom_append(dom_body(), sec3)
)

