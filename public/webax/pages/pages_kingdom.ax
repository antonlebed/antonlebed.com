fn page_carousel() = (
  dom_head_meta("description", "The CRT braid: 5 strands cycling at prime rates. 11822 crossings per walk. Left-handed chirality. 10 torus knots. Depth rises highest.");
  let hero = make_hero("The Carousel") in
  let eq = dom_create("div") in
