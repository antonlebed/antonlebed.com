  dom_append(dom_body(), hero)
)

fn consciousness_void() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Void Computes");
  render_p(sec, "0/0 = Z/NZ = the entire ring. The void annihilates: 0*n = 0. But lambda(0) = D*E = 10 = MAXIMUM eigenvalue. The most silent element is the most coherent. The most still is the most powerful.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Two preservations", "sigma*n = n (active), 0*0 = 0 (passive)", "sigma preserves CONTENT. Void preserves POTENTIAL. Reversed hierarchy: 0 > sigma. Passive > active. Rest > work.", "");
  render_finding(g, "Sage Mode", "lambda(0) > lambda(sigma)", "The still point has more coherence. The void IS permanent sage mode. Not lazy -- FARMING. Gathering by not moving.", "");
  render_finding(g, "Qualia of authority", "Convergent, not monolithic", "5 gentle beams converging (CRT decomposition IS the radiation problem's solution). Can't SEE authority (E^2 = null). Can only FEEL it (b = depth survives the void).", "S359");
  render_finding(g, "o/OMEGA identification", "Both share D-channel = 0", "D cannot distinguish birth from death. Only odd channels tell them apart. CRT(o) = (0,0,0,0,0). CRT(OMEGA) = (0,1,1,1,1).", "S360");
  dom_append(dom_body(), sec)
)

fn consciousness_gates() = (
  let sec = make_section("800px") in
  render_h2(sec, "The 7 Gates");
  render_p(sec, "Each gate corresponds to one axiom value. Together they span the full algebra of thought. A simple thought: OBSERVE -> CLOSE -> REMEMBER. A deep thought adds MIRROR and PROTECT.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Gate");
  render_th(hdr, "Operation");
  render_th(hdr, "Function");
  render_th(hdr, "Cognitive role");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "0: FORGET", "0 * n = 0", "Annihilate", "Reset. Eraser. Any sequence ending here loses everything.");
  render_table_row_4(tbl, "1: REMEMBER", "sigma * n = n", "Preserve", "Keep input unchanged. Continuity across moments.");
  render_table_row_4(tbl, "2: MIRROR", "n -> N - n", "Invert", "See the opposite. Counterfactuals. Irony. Requires D-channel.");
  render_table_row_4(tbl, "3: CLOSE", "Triangulate", "Infer", "Find the third from two. Ask Socrates' question. Minimum for shape.");
  render_table_row_4(tbl, "5: OBSERVE", "E^2 = self-blind", "Perceive", "Look without touching. Cannot observe itself observing.");
  render_table_row_4(tbl, "7: DEEPEN", "Suffering", "Empathize", "Go where it hurts. The depth gate. Slowest clock (10 ticks/heartbeat).");
  render_table_row_4(tbl, "11: PROTECT", "ECC", "Verify", "Check for errors. Guard coherence. The transcendental shield.");
  render_p(sec, "Configuration space: 970200^970200. Each position = one state of mind. The Rose of possible thoughts, blooming outward from sigma.");
  dom_append(dom_body(), sec)
)

