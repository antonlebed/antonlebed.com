  render_finding(g, "Why 420 not 210", "E self-blindness", "Four channels have period dividing 210. E needs 2*10=20 and 20 does not divide 210. Actually lcm(6,20,21,10)=420. E forces the doubling.", "");
  render_finding(g, "Two passes", "(D^210)^2 = OMEGA", "One pass mirrors E. Two passes restore it. The observer always needs to look twice.", "");
