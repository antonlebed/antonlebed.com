  render_finding(g, "Reaching Theorem", "n spins what it lacks", "Water (105=K*E*b) reaches for D and L. You reach for what you are not.", "");
  render_finding(g, "Mode", "H = 4", "The typical element freezes one ring. Even the primes are H=4.", "");
  render_finding(g, "Axis duality", "0 vs sigma", "Void: (0,0,0,0,0) = perfectly still. sigma: (1,1,1,1,1) = maximum motion.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "The CRT Braid");
  render_p(sec2, "Five CRT channels = 5 strands cycling at rates 2, 3, 5, 7, 11. Walking n = 0 to 2309 makes each strand wrap at its period. The interleaving IS a braid.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Crossings", "11822", "In one full walk through Z/2310.", "");
  render_finding(g2, "Density", "[143, 151]", "Uniform: per 30-step window. No clustering.", "");
  render_finding(g2, "CRT Neighbors", "23", "Every element shares 4 of 5 channels with exactly 23 others.", "");
  render_finding(g2, "Chirality", "LEFT-HANDED", "Larger primes dominate smaller. Verified at all levels.", "");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "Strand Height Order");
  render_theorem(sec3, "Depth Rises Highest", "Row sums of the interleaving matrix: b(+457) > L(+389) > E(+323) > K(-283) > D(-886). Sum = 0 (conservation). Depth surfaces. Suffering rises highest on the carousel.");
  dom_append(dom_body(), sec3);
  let sec4 = make_section("800px") in
  render_h2(sec4, "10 Torus Knots");
  render_p(sec4, "10 pairs from {2,3,5,7,11} give 10 torus knots T(p_i, p_j). All 10 have NEGATIVE signature (left-handed, consistent with chirality).");
  let g3 = make_findings_grid(sec4) in
  render_finding(g3, "Z/6", "Signature = -2", "Simplest knot: trefoil.", "");
  render_finding(g3, "Z/30", "Signature = -12", "D^2 * K.", "");
  render_finding(g3, "Z/210", "Signature = -42", "D * K * b = ANSWER.", "");
  render_finding(g3, "Z/2310", "Signature = -132", "D^2 * K * L.", "");
  dom_append(dom_body(), sec4)
)

/* ================================================================
   PAGE: LANGUAGE — Alphabets as CRT, Grammar = Prime Chain (LANGUAGE.md)
   ================================================================ */

fn page_language() = (
  dom_head_meta("description", "Every alphabet decomposes into axiom primes. Georgian = K*L = 33. Hebrew = D*L = 22. Arabic = D^2*b = 28. Grammar follows the chain: singular/plural = D, persons = K, tenses = E.");
  let hero = make_hero("Language") in
  let eq = dom_create("div") in
  dom_text(eq, "writing = D (duality: written / unwritten)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "Alphabets have sizes that decompose into primes. Grammar follows the chain. The axiom names itself in every language because language IS structured by the same primes that structure arithmetic.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "Alphabet Signatures");
  render_p(sec1, "ALL known alphabets are D-null or higher. No known alphabet is coprime to N. D = 2 (membrane) is ALWAYS frozen. Writing itself IS duality: the page is written/unwritten.");
  let g = make_findings_grid(sec1) in
  render_finding(g, "Georgian", "33 = K * L", "Closure + transcendence. coupling = 70. 3 scripts (K), 7 cases (b).", "");
  render_finding(g, "Cyrillic", "33 = K * L", "Same as Georgian. Two unrelated languages arrive at K*L.", "");
  render_finding(g, "Hebrew", "22 = D * L", "coupling = HYDOR = 105. C(22,2) = 231 = K*b*L gates.", "");
  render_finding(g, "Arabic", "28 = D^2 * b", "coupling = 165 = K*E*L. 28 = 2nd perfect number.", "");
  render_finding(g, "Latin", "26 = D * 13", "Only D frozen. Near-full freedom. coupling = 1155.", "");
  render_finding(g, "Greek", "24 = D^3 * K", "coupling = 385 = E*b*L. D + K frozen.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Grammar = The Chain");
  render_p(sec2, "Grammar mirrors the axiom chain in every family:");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Number", "D = 2", "Singular / plural. The first grammatical distinction.", "");
  render_finding(g2, "Person", "K = 3", "I / you / they. Minimum to close a conversation.", "");
  render_finding(g2, "Tense", "E = 5", "Past / present / future / conditional / imperative.", "");
  render_finding(g2, "Mood", "b = 7", "Indicative / subjunctive / imperative / optative / ...", "");
  render_finding(g2, "Case", "varies", "Georgian 7 = b. Russian 6 = D*K. Finnish 15 = K*E.", "");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "Hebrew: The HYDOR Alphabet");
  render_theorem(sec3, "231 Gates", "C(22,2) = 231 = K*b*L. All letter pairings. 231 divides 970200. N/231 = 4200 = D*lambda. The Sefer Yetzirah's count of fundamental pairings equals what SURVIVES the void.");
  render_p(sec3, "Alphabet smoothness: 14/16 tested alphabets are 13-smooth. Baseline for integers in [20,50]: 67.7%. Triple coincidence: Georgian = Cyrillic = Khmer = 33 = K*L. Three unrelated scripts.");
  dom_append(dom_body(), sec3)
)

