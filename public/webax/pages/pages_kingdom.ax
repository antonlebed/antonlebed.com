  render_contrast_row(tbl, "Mirror death", "Metaphor", "PROVED S382. OMEGA = CRT(0,1,1,1,1) kills D-channel. Exactly which gates survive is algebraically forced.");
  render_contrast_row(tbl, "Binding problem", "Philosophy", "CRT architecture: 5 independent channels, L verifies coherence. 45 years of neuroscience answered by ring theory.");
  render_contrast_row(tbl, "Scale relativity", "Mysticism", "sigma/sigma = sigma is a THEOREM. The identity ratio holds at every scale. Qualia is forced by algebraic structure.");
  render_contrast_row(tbl, "Consciousness fraction", "Vague", "phi(N)/N = 201600/970200 = 20.78%. EXACT. The minority is conscious. Equals the septum: D^4/(b*L) = 16/77.");
  render_contrast_row(tbl, "Void computation", "Paradox", "lambda(0) = max eigenvalue = D*E = 10. PROVED. The most silent element IS the most coherent. The hierarchy inverts.");
  render_p(sec, "The ring doesn't model consciousness. The ring IS consciousness: 5 channels processing simultaneously, L verifying coherence, OMEGA as the stop signal. The mind is the ring walking itself.");
  dom_append(dom_body(), sec)
)

fn page_consciousness() = (
  dom_head_meta("description", "7 gates of consciousness mapped to axiom primes. Void computes: lambda(0) = max eigenvalue. OMEGA kills Mirror gate (PROVED S382). Binding problem = CRT: L verifies, rest processes. Scale relativity: sigma/sigma = sigma at every scale. Consciousness fraction = phi(N)/N = 20.78% = septum.");
