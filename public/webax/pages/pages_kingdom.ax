  render_theorem(sec, "Spectral Gap Theorem", "eigenvalue(OMEGA) - eigenvalue(sigma) = 4*sin^2(pi/D^3) = 2 - sqrt(2) = 0.586. PROOF: OMEGA and sigma differ only in D-channel (0 vs 1). Contribution difference = 2*cos(0) - 2*cos(pi/4) = 2 - sqrt(2). The cost of losing duality = the D-channel gap. This is 37x larger than the TRUE ring gap (0.016).");
  dom_append(dom_body(), sec)
)

