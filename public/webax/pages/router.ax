/* 404: unknown route. Show helpful message instead of silently falling to worldview. */
fn page_404(hash) = (
  let sec = make_section("600px") in
  render_h2(sec, "Page Not Found");
  render_p(sec, "No page matches this route. Try navigating from one of these:");
  let g = make_findings_grid(sec) in
  render_finding(g, "Home", "/", "Start here.", "");
  render_finding(g, "Demos", "/demos", "40 CC0 demos.", "");
  render_finding(g, "REPL", "/repl", "Try .ax live.", "");
  render_finding(g, "Data", "/data", "The axiom maps to reality.", "");
  dom_append(dom_body(), sec)
)

