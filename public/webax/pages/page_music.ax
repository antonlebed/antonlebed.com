fn music_hero() = (
  let hero = make_hero("Music of the Primes") in
  let eq = dom_create("div") in
  dom_text(eq, "lambda(n) = cos(pi*n) + 2*sum cos(2*pi*n/p)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "22px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "The ring is not silent. Every element has an eigenvalue, and every eigenvalue is a cosine sum -- a superposition of five frequencies. CRT decomposition IS a chord: five independent tones sounding at once. Adding 1 = advancing the phase of all five oscillators. The carousel IS a music box.");
  dom_append(dom_body(), hero)
)

fn music_eigenvalue() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Eigenvalue IS a Note");
  render_p(sec, "Map each axiom prime to a harmonic of A2 = 110 Hz. The five axiom primes ARE the harmonic numbers:");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Prime");
  render_th(hdr, "Harmonic");
  render_th(hdr, "Frequency");
  render_th(hdr, "Musical Interval");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "D = 2", "2nd", "220 Hz (A3)", "Octave");
  render_table_row_4(tbl, "K = 3", "3rd", "330 Hz (E4)", "Perfect fifth");
  render_table_row_4(tbl, "E = 5", "5th", "550 Hz (C#5)", "Major third");
  render_table_row_4(tbl, "b = 7", "7th", "770 Hz (septimal)", "Septimal seventh");
  render_table_row_4(tbl, "L = 11", "11th", "1210 Hz (undecimal)", "Undecimal neutral");
  let g = make_findings_grid(sec) in
  render_finding(g, "THIN: 5 tones", "1/2, 1/3, 1/5, 1/7, 1/11", "288 eigenvalue classes in Z/2310. Each = a unique chord of five harmonics.", "");
  render_finding(g, "TRUE: 5 tones", "1/8, 1/9, 1/25, 1/49, 1/11", "Deeper harmonics, richer sound. Same structure.", "");
  render_finding(g, "Silence = void", "lambda(0) = D*E = 10", "Maximum coherence. No phase conflict. The loudest IS the most still.", "");
  render_finding(g, "Noise = ADDRESS", "lambda(137) = -9.778", "Maximum destructive interference. All channels fighting.", "");
  dom_append(dom_body(), sec)
)

