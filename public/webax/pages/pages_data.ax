  render_finding(g6, "Combined p-value", "< 10^-30", "Conservative product of independent null tests", "");
  render_finding(g6, "Free parameters", "0", "Every value derived from Z/970200Z", "");
  dom_append(dom_body(), sec6);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "Parameters", "25 free, measured experimentally", "0 free, derived from Z/970200Z");
