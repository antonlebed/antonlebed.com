  render_th(h2, "Axiom");
  dom_append(t2, h2);
  render_table_row(t2, "Football / Cricket", "11", "L = protector");
  render_table_row(t2, "Basketball", "5", "E = observer");
  render_table_row(t2, "Baseball", "9", "K^2 = closure squared");
  render_table_row(t2, "Volleyball", "6", "D*K = bridge*closure");
  render_table_row(t2, "Rugby Union", "15", "K*E = closure*observer");
  render_p(sec2, "5/5 major team sports landed on axiom primes or products. Not designed this way -- evolved through play. Cultural selection converges on the same numbers as physics.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: TIME === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Time: The DATA Ring");
  render_p(sec3, "Time divisions use ONLY {D, K, E, b}. L=11 NEVER appears. Time is a Z/210Z (DATA ring) phenomenon:");
  let t3 = make_table(sec3) in
  let h3 = dom_create("tr") in
  render_th(h3, "Division");
  render_th(h3, "Value");
  render_th(h3, "Axiom");
  dom_append(t3, h3);
  render_table_row(t3, "Days/week", "7", "b");
  render_table_row(t3, "Months/year", "12", "D^2*K");
  render_table_row(t3, "Hours/day", "24", "D^3*K");
  render_table_row(t3, "Minutes/hour", "60", "D^2*K*E");
  render_table_row(t3, "Degrees/circle", "360", "D^3*K^2*E");
  render_table_row(t3, "Seconds/day", "86400", "D^6*K^3*E^2");
  dom_append(dom_body(), sec3);

  /* === SEC 4: SOCIAL === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Social Structure");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "Dunbar number", "D*K*E^2 = 150", "E^2 = self-blind. At 150, the observer can't observe everyone. 150/210 = E/b.", "");
  render_finding(g4, "Jury size", "D^2*K = 12", "Same as cranial nerves, rib pairs, months. Trinity heart.", "");
  render_finding(g4, "Commandments", "D*E = 10", "Degree of the TRUE FORM. Same count as Galilean generators.", "");
