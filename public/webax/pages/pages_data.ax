/* pages_data.ax — DATA: domain template pages + physics domains.
   Z/210Z. Every constant has a derivation. 26 pages. */
/* ================================================================
   PAGE: THERMO — Thermodynamics from the Ring (CONSTANTS_DOMAINS.md)
   ================================================================ */

fn page_thermo() = (
  dom_head_meta("description", "Partition function factorizes EXACTLY over CRT channels at ALL temperatures. Entropy is additive over channels. DOF = axiom chain. Stefan-Boltzmann T^4 = T^(D^2). Bose = subtract identity.");
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, "Thermodynamics");
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let eq = dom_create("div") in
  dom_text(eq, "Z(beta) = prod_p Z_p(beta)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "The partition function factorizes EXACTLY over CRT channels at all temperatures. Entropy is additive. The DOF chain K=3, E=5, b=7 IS the gas hierarchy. Kolmogorov and monoatomic gamma are the same ratio for the same reason.");
  dom_append(dom_body(), hero);
  let sec1 = make_section("800px") in
  render_h2(sec1, "Partition Function Factorization");
  render_theorem(sec1, "Exact Factorization", "Z(beta) = product over primes of Z_p(beta). EXACT at ALL temperatures. The eigenvalue is a sum of cosines, one per channel. The exponential of a sum is the product of exponentials. The sum over Z/NZ equals the product of sums over Z/pZ by CRT bijection.");
  let g = make_findings_grid(sec1) in
  render_finding(g, "Entropy", "S = k_B * sum ln(classes_i)", "Additive over CRT channels. Each channel contributes independently.", "");
  render_finding(g, "Entropy twins", "D^3 and K^2", "floor(8/2)+1 = floor(9/2)+1 = 5. Equal entropy.", "");
  render_finding(g, "GATE in entropy", "E^2 = 25 channel", "floor(25/2)+1 = 13 = GATE distinct levels.", "");
  render_finding(g, "Balance", "phi/classes = E/K", "THIN: 480/288 = 5/3 = Kolmogorov.", "");
  dom_append(dom_body(), sec1);
  let sec2 = make_section("800px") in
  render_h2(sec2, "Power-Law Exponents");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Stefan-Boltzmann", "T^(D^2) = T^4", "Radiation power scales as bridge squared.", "");
  render_finding(g2, "Debye", "T^K = T^3", "Low-temperature heat capacity = closure.", "");
  render_finding(g2, "Fick diffusion", "t^(sigma/D) = t^(1/2)", "Square root of time. Identity over bridge.", "");
  render_finding(g2, "Planck", "nu^K / (e^x - sigma)", "Bose-Einstein: subtract identity from exponential.", "");
  dom_append(dom_body(), sec2)
)

fn domain_hero(title:str, equation:str, intro:str) = (
  let hero = dom_create("section") in
  dom_style(hero, "textAlign", "center");
  dom_style(hero, "padding", "80px 24px 40px");
  let h1 = dom_create("h1") in
  dom_text(h1, title);
  ct_heading(h1);
  dom_style(h1, "fontSize", "2.2em");
  dom_style(h1, "fontWeight", "normal");
  dom_style(h1, "marginBottom", "16px");
  dom_append(hero, h1);
  let eq = dom_create("div") in
  dom_text(eq, equation);
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, intro);
  dom_append(dom_body(), hero)
)

