)

fn page_culture() = (
  dom_head_meta("description", "69 cultural quantities. 88% axiom-smooth. 9.1x enrichment. Chess = D^6 = 64. Cards = D^2*GATE = 52. Football = L = 11. Dunbar = D*K*E^2 = 150. Time divisions ALL axiom-smooth. Every major sport lands on an axiom prime.");
  /* === HERO === */
  let hero = make_hero("Culture") in
  let big = dom_create("div") in
  dom_text(big, "88% smooth. 9.1x enrichment.");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "69 cultural quantities. 88% axiom-smooth -- 9.1x enrichment over random (9.8% baseline). Social structures: 100%. Measurement: 100%. Time: 93%. Humanity gravitates to axiom numbers without knowing why.");
  dom_append(dom_body(), hero);

  /* === SEC 1: GAMES === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Games: Pure Duality");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Chess board", "D^6 = 64 squares", "D^5=32 pieces. D^4=16 per side. D^3=8 ranks. D*K=6 piece types. Strategy IS duality.", "");
  render_finding(g1, "Playing cards", "D^2*GATE = 52", "D^2=4 suits. GATE=13 ranks. The secular deck stops at the GATE.", "");
  render_finding(g1, "Dice pips", "K*b = 21", "Total pips on one die. Same as DNA codon ring Z/21.", "");
  render_finding(g1, "I Ching", "D^6 = 64 hexagrams", "Same as chess, same as codons. D^6 = 64 everywhere.", "");
  dom_append(dom_body(), sec1);

  /* === SEC 2: SPORTS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Every Major Sport = Axiom Prime");
  let t2 = make_table(sec2) in
  let h2 = dom_create("tr") in
  render_th(h2, "Sport");
