  render_contrast_row(sec6, "Gravity 10^39 weaker", "Hierarchy problem, fine-tuning", "E*b + D^2 = 39. Derived, not tuned");
  dom_append(dom_body(), sec6)
)

fn page_gr() = (
  dom_head_meta("description", "D+D=D*D=4 gives spacetime, 20 Riemann components, 2 GW polarizations, and the Schwarzschild orbit ladder. All of GR from {2,3,5,7,11}. Einstein coupling 8pi=D^3*pi. The bridge IS spacetime.");
  /* === HERO === */
  let hero = make_hero("General Relativity") in
  let big = dom_create("div") in
  dom_text(big, "D + D = D * D = 4");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "2px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The unique property of D=2: addition equals multiplication. No other prime has this. This single identity gives spacetime, curvature decomposition, gravitational waves, and black holes. Every structural fact in GR flows from D+D = D*D.");
  dom_append(dom_body(), hero);

  /* === SEC 1: TENSOR COMPONENTS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Tensor Component Counts");
  render_p(sec1, "In d = D^2 = 4 spacetime dimensions. All counts factor over {D, E}. K^2 = 9 tensor types total -- the nonility in geometry.");
  let t1 = make_table(sec1) in
  let h1 = dom_create("tr") in
  render_th(h1, "Tensor");
  render_th(h1, "Count");
  render_th(h1, "Expression");
  dom_append(t1, h1);
  render_table_row(t1, "Scalar R", "1", "sigma");
  render_table_row(t1, "GW polarizations", "2", "D");
  render_table_row(t1, "Killing vectors", "4", "D^2");
  render_table_row(t1, "Metric g_uv", "10", "D*E");
  render_table_row(t1, "Ricci R_uv", "10", "D*E");
  render_table_row(t1, "Weyl C_abcd", "10", "D*E");
  render_table_row(t1, "Riemann R_abcd", "20", "D^2*E");
  render_table_row(t1, "Christoffel", "40", "D^3*E");
  render_theorem(sec1, "Riemann Decomposition IS D+D=D*D", "Riemann(20) = Ricci(10) + Weyl(10). That is: D^2*E = D*E + D*E. The decomposition of spacetime curvature into matter-coupled (Ricci) and free (Weyl) parts IS the D+D = D*D identity at the tensor level.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: ORBIT LADDER === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Schwarzschild Orbit Ladder");
  render_p(sec2, "All radii in units of GM/c^2. The orbit ladder IS the axiom chain:");
  let t2 = make_table(sec2) in
  let h2 = dom_create("tr") in
  render_th(h2, "r");
  render_th(h2, "Name");
  render_th(h2, "Axiom");
  render_th(h2, "Meaning");
  dom_append(t2, h2);
  render_table_row_4(t2, "2", "Event horizon", "D", "Point of no return. Time/space swap = duality");
  render_table_row_4(t2, "3", "Photon sphere", "K", "Light orbits in circles = minimum closure");
  render_table_row_4(t2, "4", "Marginally bound", "D^2", "Zero total energy. D*D = spacetime dim");
  render_table_row_4(t2, "6", "ISCO", "D*K", "Innermost stable circular orbit = bridge*closure");
  render_p(sec2, "Orbit ratios: r_ph/r_s = K/D. r_isco/r_s = K. r_isco/r_ph = D. The ladder walks the chain. Same D*K = 6 appears in perihelion precession: delta_phi = D*K*pi*GM/(ac^2).");
  dom_append(dom_body(), sec2);

  /* === SEC 3: EINSTEIN EQUATION === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Einstein's Equation");
  render_theorem(sec3, "8pi = D^3 * pi", "G_uv = (D^3*pi*G/c^4) T_uv. Why D^3? Gauss in K=3 dims: solid angle = D^2*pi. GR is rank-D (metric = 2-index). Rank-n theory coupling = D^(n+1)*pi. EM (rank-1): D^2*pi = 4pi. GR (rank-2): D^3*pi = 8pi. The spider's eight legs times pi.");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "GW polarizations", "D = 2", "Massless spin-2 in D^2 dims: d(d-K)/2 = 4*1/2 = D. Plus (+) and cross (x). Same count as photon.", "");
  render_finding(g3, "Binary decay", "E/K = 5/3", "Orbital period: dP/dt ~ -P^(-E/K). Kolmogorov in the stars. Chirp mass: M_c ~ (m1*m2)^(K/E).", "Hulse-Taylor 0.2%");
  render_finding(g3, "Penrose extraction", "1 - 1/sqrt(D) = 29.3%", "Maximum energy from rotating BH. 29 = sigma+D+K+E+b+L = full axiom sum.", "");
  render_finding(g3, "BH entropy", "S = k_B*A/(D^2*l_P^2)", "Area in D^2 Planck cells. Spacetime dimension = states per cell.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: GRAVITY AS VOID === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "The Hierarchy: Why 10^39");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "Gravity exponent", "E*b + D^2 = 39", "Observer*depth + spacetime = 35 + 4. Not fine-tuning. Derived.", "");
