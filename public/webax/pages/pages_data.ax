  render_finding(g5, "Gravity ratio", "10^(E*b + D^2) = 10^39", "Observer times depth plus spacetime. Not fine-tuning -- derived.", "");
  render_finding(g5, "Rydberg", "GATE + K/E = 13.6 eV", "Same hydrogen ground state from the quantum page.", "2 ppm");
  render_finding(g5, "Conductance quantum", "D*e^2/h", "D in the numerator. Duality bridges charge and current.", "");
