  render_contrast_row(sec7, "Coupling link", "No connection between forces", "Persistence ratio 7/194 unifies all four");
  render_contrast_row(sec7, "Boson masses", "Independent measurements", "E^3, GATE*b, D^4*E -- pure axiom products");
  render_contrast_row(sec7, "Top quark", "Just the heaviest fermion", "CRT(173)=(1,2,3,5): carries the axiom signature");
  dom_append(dom_body(), sec7)
)

fn page_quantum() = (
  dom_head_meta("description", "Hydrogen spectrum from ten terms. Rydberg = GATE + K/E = 13.6 eV. Mass ratio = D^2*K^3*ESCAPE = 1836. Shell capacity = D*n^2. 43 quantities from Z/970200Z. The gate IS hydrogen.");
  /* === HERO === */
  let hero = make_hero("Quantum Mechanics") in
  let big = dom_create("div") in
  dom_text(big, "Rydberg = GATE + K/E = 13.6 eV");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The hydrogen ground state IS the axiom boundary. GATE = 13 = where Cunningham chains stop, Heegner class numbers jump, and hydrogen degeneracies break. K/E = 3/5 is the Kolmogorov exponent. The atom IS the chain.");
  dom_append(dom_body(), hero);

  /* === SEC 1: HYDROGEN === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Hydrogen: The Gate Atom");
  let g1 = make_findings_grid(sec1) in
  render_finding(g1, "Rydberg energy", "GATE + K/E = 13.6 eV", "13 = h(-191) = D-chain class number. K/E = h(-23)/h(-47). Number theory IS atomic physics.", "2 ppm refined");
  render_finding(g1, "Proton/electron", "D^2*K^3*ESCAPE = 1836", "108 (sacred) times 17 (sum of inner primes). Heavy particles SIT (nucleus). Light ones ORBIT.", "0.6 ppm refined");
  render_finding(g1, "21-cm line", "K*b = 21 cm", "Hydrogen hyperfine wavelength = codon ring Z/21. Hydrogen speaks at the wavelength of the genetic code.", "exact");
  render_finding(g1, "Lyman alpha", "(K/D^2) * 13.6 = 10.2 eV", "K/D^2 = 3/4 = Kleiber metabolic scaling. First spectral line = metabolic scaling times ionization.", "0.01%");
  dom_append(dom_body(), sec1);

  /* === SEC 2: SHELL STRUCTURE === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Shell Structure: D*n^2");
  render_p(sec2, "Every shell holds D*n^2 electrons. Noble gases are axiom-smooth. Subshell capacity = D*(2l+1) = D times the Cunningham map. The periodic table IS the axiom chain.");
  let t2 = make_table(sec2) in
  let h2 = dom_create("tr") in
  render_th(h2, "Shell n");
  render_th(h2, "Capacity");
  render_th(h2, "Axiom");
  render_th(h2, "Noble Gas");
  dom_append(t2, h2);
