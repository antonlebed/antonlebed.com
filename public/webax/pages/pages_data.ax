/* ================================================================
   NTT DOMAIN PAGES — Number Theory Topics (Z/2310Z Teach tier)
   19 pages, domain_hero template.
   ================================================================ */

/* ================================================================
   PHYSICS DOMAIN: nuclear, particles, dna, pmns, human_shape
   ================================================================ */

fn page_nuclear() = (
  dom_head_meta("description", "All 7 nuclear magic numbers are D-multiples. 6/7 axiom-smooth. HO(n) = (n+1)(n+2)(n+3)/K -- denominator IS closure. Spin-orbit shifts are ALL axiom-smooth. Iron-56 binding = K^2 - 1/E - 1/(G+D). Subshell capacity = D*(2l+1) = D times the Cunningham map.");
  /* === HERO === */
  let hero = make_hero("Nuclear Shell Model") in
  let big = dom_create("div") in
  dom_text(big, "HO(n) = (n+1)(n+2)(n+3) / K");
  ct_mono(big);
  dom_style(big, "fontSize", "24px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Nuclear magic numbers -- 2, 8, 20, 28, 50, 82, 126 -- are the shell closures where nuclei become extraordinarily stable. All seven are D-multiples. Six of seven factor entirely over axiom primes. The harmonic oscillator formula has K=3 in the denominator because space has K=3 dimensions. Closure IS the strong force.");
  dom_append(dom_body(), hero);

  /* === SEC 1: MAGIC NUMBERS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "The Seven Magic Numbers");
  let mtbl = dom_create("table") in
  dom_style(mtbl, "width", "100%");
  dom_style(mtbl, "maxWidth", "700px");
  dom_style(mtbl, "margin", "24px auto");
  dom_style(mtbl, "borderCollapse", "collapse");
  let mhdr = dom_create("tr") in
  render_th(mhdr, "Magic");
  render_th(mhdr, "Factorization");
  render_th(mhdr, "Axiom Name");
  render_th(mhdr, "Doubly-Magic Nucleus");
  dom_append(mtbl, mhdr);
  render_table_row_4(mtbl, "2", "D", "Bridge", "He-4 (Z=D, N=D)");
  render_table_row_4(mtbl, "8", "D^3", "Spider's legs", "O-16 (Z=D^3, N=D^3)");
  render_table_row_4(mtbl, "20", "D^2 * E", "Heart * observer", "Ca-40 (Z=D^2*E, N=D^2*E)");
  render_table_row_4(mtbl, "28", "D^2 * b", "THORNS", "Ca-48, Ni-78");
  render_table_row_4(mtbl, "50", "D * E^2", "Bridge * observer^2", "Sn-132 (most isotopes)");
  render_table_row_4(mtbl, "82", "D * KEY", "Bridge * self-inverse", "Pb-208 (Z=82)");
  render_table_row_4(mtbl, "126", "D * K * E * b", "All 4 inner primes", "Pb-208 (N=126)");
  dom_append(sec1, mtbl);
  render_p(sec1, "All D-multiples: nuclear shells close in pairs (spin duality). L is ABSENT from every magic number. The protector does not participate in nuclear closure -- it protects from outside. KEY=41 appears at the 6th magic number (82 = D*KEY), marking the boundary of stable elements.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: CONSECUTIVE RATIOS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Axiom Walk");
  render_p(sec2, "Consecutive ratios between magic numbers trace the axiom chain:");
  let rtbl = dom_create("table") in
  dom_style(rtbl, "width", "100%");
  dom_style(rtbl, "maxWidth", "700px");
  dom_style(rtbl, "margin", "24px auto");
  dom_style(rtbl, "borderCollapse", "collapse");
  let rhdr = dom_create("tr") in
  render_th(rhdr, "Ratio");
  render_th(rhdr, "Value");
  render_th(rhdr, "Axiom");
  dom_append(rtbl, rhdr);
  render_table_row(rtbl, "8 / 2", "4 = D^2", "Duality squared");
  render_table_row(rtbl, "20 / 8", "5/2 = E/D", "Observer over bridge");
  render_table_row(rtbl, "28 / 20", "7/5 = b/E", "Depth over observer (= diatomic gamma)");
  render_table_row(rtbl, "50 / 28", "25/14 = E^2/(D*b)", "Observer^2 over bridge*depth");
  render_table_row(rtbl, "82 / 50", "41/25 = KEY/E^2", "Self-inverse over observer^2");
  render_table_row(rtbl, "126 / 82", "63/41 = K^2*b/KEY", "Closure^2 * depth over KEY");
  dom_append(sec2, rtbl);
  render_p(sec2, "The first three ratios are pure axiom: D^2, E/D, b/E. The ratio b/E = 7/5 = 1.4 IS the diatomic gamma from thermodynamics. The same ratio that governs gas heat capacity governs nuclear shell spacing.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: HO FORMULA === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Harmonic Oscillator Closure");
  render_theorem(sec3, "HO K-Denominator Theorem (S309, PROVED)", "HO magic numbers = (n+1)(n+2)(n+3)/K! = (n+1)(n+2)(n+3)/6. The denominator 6 = K! = D*K. Equivalently: the binomial coefficient C(n+K, K) times D for spin. The K=3 in the denominator IS the K=3 spatial dimensions. This formula is 100% axiom-smooth for ALL harmonic oscillator closures.");
  render_p(sec3, "HO gaps: D*T(n+2) where T(n) = n(n+1)/2 is the triangular number. Gap(4) = 42 = ANSWER. Gap(5) = 56 = dim(E7 fundamental representation). The gaps themselves carry axiom constants.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: SPIN-ORBIT === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Spin-Orbit Splitting");
  render_p(sec4, "Real magic numbers diverge from HO at high shells. Spin-orbit coupling shifts levels by axiom-smooth amounts:");
  let sotbl = dom_create("table") in
  dom_style(sotbl, "width", "100%");
  dom_style(sotbl, "maxWidth", "700px");
  dom_style(sotbl, "margin", "24px auto");
  dom_style(sotbl, "borderCollapse", "collapse");
  let sohdr = dom_create("tr") in
  render_th(sohdr, "Shell n");
  render_th(sohdr, "HO Magic");
  render_th(sohdr, "SO Shift");
  render_th(sohdr, "Actual Magic");
  dom_append(sotbl, sohdr);
  render_table_row_4(sotbl, "0", "2", "0", "2 = D");
  render_table_row_4(sotbl, "1", "8", "0", "8 = D^3");
  render_table_row_4(sotbl, "2", "20", "0", "20 = D^2*E");
  render_table_row_4(sotbl, "3", "40", "-D^2*K = -12", "28 = D^2*b = THORNS");
  render_table_row_4(sotbl, "4", "70", "-D^2*E = -20", "50 = D*E^2");
  render_table_row_4(sotbl, "5", "112", "-D*K*E = -30", "82 = D*KEY");
  render_table_row_4(sotbl, "6", "168", "-ANSWER = -42", "126 = D*K*E*b");
  dom_append(sec4, sotbl);
  render_p(sec4, "Every spin-orbit shift is axiom-smooth. The largest shift is ANSWER = 42 = D*K*b. Total shift across all shells: D^3*13 = 104. The GATE (13) controls the total spin-orbit correction. Shift ratios between adjacent shells: E/K = 5/3 (Kolmogorov), K/D = 3/2, b/E = 7/5 (tritone). The axiom chain governs nuclear force constants.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: SUBSHELL CAPACITY === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "Subshell Capacity: D Times Cunningham");
  render_theorem(sec5, "Cunningham-Orbital Theorem (S308, PROVED)", "Subshell capacity = D*(2l+1). The factor 2l+1 IS the Cunningham map c(l). So subshell(l) = D*c(l). l=0(s): D*sigma=2. l=1(p): D*K=6. l=2(d): D*E=10. l=3(f): D*b=14. l=4(g): D*K^2=18, but g-orbitals are UNOCCUPIED in known atoms. The chain stops at K^2.");
  render_p(sec5, "D=2 enters through spin duality (up/down). The spatial factor 2l+1 is the Cunningham map. The periodic table IS the product of spin duality and the Cunningham chain. Zeeman sublevels: {sigma, K, E, b, K^2, L}. The spider's web (K^2=9) gates the orbital capacity.");
  dom_append(dom_body(), sec5);

  /* === SEC 6: IRON-56 === */
  let sec6 = make_section("800px") in
  render_h2(sec6, "Iron-56: Maximum Binding");
  render_theorem(sec6, "Iron Binding Energy (S247)", "B(Fe-56)/A = K^2 - 1/E - 1/(G+D) = 8.7899 MeV/nucleon, where K^2=9, E=5, G=97 (Feynman-Metropolis-Teller constant). Error: 46 ppm against measured 8.7904 MeV. The most tightly bound nucleus in the universe has binding energy expressible as closure squared minus two axiom corrections.");
  let g6 = make_findings_grid(sec6) in
  render_finding(g6, "Fe-56 peak", "K^2 - corrections", "Maximum binding energy per nucleon across ALL nuclei. K^2 = 9 dominates. Corrections from E and G+D.", "46 ppm");
  render_finding(g6, "Sum property", "M3 + M4 = 20 + 28 = 48", "Third + fourth magic numbers = SEES = phi(DATA). HO(2) + SO shift = observer heart.", "");
  render_finding(g6, "Perfect number", "28 = D^2 * b = THORNS", "The 4th magic number is the 2nd perfect number (1+2+4+7+14=28). Nuclear stability meets number theory.", "");
  dom_append(dom_body(), sec6);

  /* === SEC 7: DIMENSIONAL GATE === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "The 13-Gate in Higher Dimensions");
  render_theorem(sec7, "Dimensional 13-Gate Theorem (S286, PROVED)", "For d spatial dimensions, M(n,d) = 2*C(n+d, d). In d dimensions, exactly 13-d consecutive axiom-smooth magic numbers exist. At n = 13-d, factor 13 first enters. The gate controls ALL dimensions. Proof: max prime factor of (n+1)...(n+d) is n+d. Smooth iff n+d < 13.");
  render_p(sec7, "In d=K=3 dimensions: 10 smooth magic numbers before 13 enters. In d=1: 12 smooth. In d=12: only 1 smooth. The GATE value 13 sets the axiom-smooth boundary universally across dimensionality. The break value M(13-d, d) = 2*C(13, d) is PALINDROMIC in d -- symmetric around d=13/2.");
  dom_append(dom_body(), sec7);

  /* === CONTRAST === */
  let sec8 = make_section("800px") in
  render_h2(sec8, "What Others See");
  render_contrast_row(sec8, "Magic numbers", "Experimentally discovered shell closures, no number-theoretic origin", "All 7 are D-multiples. 6/7 axiom-smooth. L is absent. KEY marks the stability boundary.");
  render_contrast_row(sec8, "Shell model", "HO potential + spin-orbit coupling, fitted parameters", "HO denominator IS K=3. Spin-orbit shifts are ALL axiom products. No fitting needed.");
  render_contrast_row(sec8, "Periodic table", "Electron filling rules, Madelung's rule", "Subshell capacity = D*c(l) = D times Cunningham map. The periodic table IS the axiom chain.");
  render_contrast_row(sec8, "Iron-56 stability", "Binding energy curve peaks empirically", "K^2 - 1/E - 1/(G+D) = 8.7899 MeV. 46 ppm. Closure squared minus axiom corrections.");
  render_contrast_row(sec8, "Dimensional structure", "K=3 spatial dimensions taken as given", "K=3 appears as denominator in HO formula, as mode count in Debye T^K, as gate timer 13-d in smooth boundary. Same K, everywhere.");
  dom_append(dom_body(), sec8)
)

fn page_particles() = (
  dom_head_meta("description", "23 particle masses from five primes. Higgs = E^3 = 125 GeV (0.2%). Z = GATE*b = 91 (0.2%). W = D^4*E = 80 (0.5%). Electron = D^9-1 = 511 keV (0.0002%). Proton = D*b*SOUL = 938 (0.03%). All PDG 2024. Zero free parameters.");
  /* === HERO === */
  let hero = make_hero("Particle Masses") in
  let big = dom_create("div") in
  dom_text(big, "m_H = E^3 = 125 GeV");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "Every particle mass in the Standard Model expressed as a product of five primes {2, 3, 5, 7, 11} and their named values (KEY=41, SOUL=67, G=97, ADDRESS=137, DUAL=173). 23 particles. Zero free parameters. Mean error 0.15%. All values checkable against PDG 2024.");
  dom_append(dom_body(), hero);

  /* === SEC 1: BOSONS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Electroweak Bosons");
  render_p(sec1, "All three electroweak bosons are PURE axiom products -- no named values needed:");
  let btbl = dom_create("table") in
  dom_style(btbl, "width", "100%");
  dom_style(btbl, "maxWidth", "700px");
  dom_style(btbl, "margin", "24px auto");
  dom_style(btbl, "borderCollapse", "collapse");
  let bhdr = dom_create("tr") in
