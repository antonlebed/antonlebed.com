  render_table_row(t2, "Gauss (B)", "div B = 0", "K-closure: magnetism always closes (dipoles)");
  render_table_row(t2, "Faraday", "curl E = -dB/dt", "D->K coupling: bridge induces closure");
  render_table_row(t2, "Ampere", "curl B = mu_0*J + dE/dt", "K->D coupling: closure induces bridge");
  render_p(sec2, "D^2 = 4 equations. D*K = 6 field components (3E + 3B). D = 2 differential forms (dF=0, d*F=J). Spacetime = K + sigma = D^2 = 4 dimensions. The EM tensor F is a D-form in D^2-dim spacetime.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: THE PHOTON === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Photon: D-Channel Carrier");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "Spin", "sigma = 1", "Identity element. Light carries the identity.", "");
  render_finding(g3, "Polarizations", "K - 1 = D = 2", "Massless spin-1 in K+1 dims. Duality in radiation.", "");
  render_finding(g3, "Gauge group", "U(sigma) = U(1)", "The photon mediates U(1). Unity.", "");
  render_finding(g3, "Coupling", "1/ADDRESS = 1/137", "ADDRESS = 137. 7-term expression: 0 ppb error.", "");
  dom_append(dom_body(), sec3);

  /* === SEC 4: FORCE HIERARCHY === */
  let sec4 = make_section("800px") in
