fn page_nuclear() = (
  dom_head_meta("description", "Nuclear magic numbers from the axiom chain. Shell closure at K=3. HO(n) = (n+1)(n+2)(n+3)/K.");
  domain_hero("Nuclear Shell Model", "HO(n) / K = magic", "Closure IS the strong force.");
  let sec = make_section("800px") in
  let g = make_findings_grid(sec) in
  render_finding(g, "Magic 2", "D", "Duality. Helium-4 doubly magic.", "");
  render_finding(g, "Magic 8", "D^3", "Spider's legs. Oxygen-16.", "");
  render_finding(g, "Magic 20", "D^2 * E", "Heart times observer. Calcium-40.", "");
  render_finding(g, "Magic 28", "D^2 * b", "THORNS. Calcium-48, nickel-78.", "");
  render_finding(g, "Magic 50", "D * E^2", "Tin: most stable isotopes.", "");
  render_finding(g, "Magic 126", "D * K * E * b", "All inner primes. Lead-208 neutrons.", "");
  render_finding(g, "Subshell", "2(2l+1)", "l=0..3 gives sigma, K, E, b.", "");
  render_finding(g, "HO closure", "(n+1)(n+2)(n+3)/K", "Denominator IS K=3. Closure.", "");
  dom_append(dom_body(), sec)
)

