  render_contrast_row(sec5, "8 histones", "Octamer", "D^3 = spider's legs");
  render_contrast_row(sec5, "3 germ layers", "Developmental fact", "K=3 = closure. Same as domains of life");
  render_contrast_row(sec5, "20 amino acids", "Evolutionary accident", "D^2*E = 20. Duality^2 times observer. Same count as Riemann components");
