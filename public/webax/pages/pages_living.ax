  render_contrast_row(sec7, "Dimensional solvability", "3D Ising unsolved, no structural reason known", "d=K=3 decomposes solvability. Irrational exponents at the closure dimension.");
  render_contrast_row(sec7, "Control systems", "Standard PID: 1 controller, 1 resolution, 0 fault tolerance", "CRT PID: 6 independent channels, multi-scale, algebraic fault tolerance. L=11 + GATE=13 = dual integrity.");
  dom_append(dom_body(), sec7)
)

