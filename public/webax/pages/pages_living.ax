    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>Depth level ${k}: ${primes}</p><p style='margin:4px 0'>Ring: <b style='color:#ffd700'>${name}</b></p><p style='margin:4px 0;color:#b0b0c0'>Product = ${ring}</p>")
  )
)

