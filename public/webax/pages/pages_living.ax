  dom_append(sec1, ctbl);
  render_p(sec1, "Total output: 8+9+25+49+11 = 102 classes. Standard equivalent: 970200 classes. Ratio: 9512x compression. The backprop Jacobian is block-diagonal: 25654x fewer entries at N=2310.");
