fn chain_mirror_law() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Mirror Laws");
  render_theorem(sec, "Cunningham Mirror Law (S263)", "c(p) = D*p + sigma, so D*p = -1 mod c(p). Each new axiom prime is BORN as the mirror of D times its predecessor: D^2 = -1 mod E. D*K = -1 mod b. D*E = -1 mod L.");
  let g = make_findings_grid(sec) in
  render_finding(g, "(p-1) Ladder", "{D, D^2, D*K, D*E}", "K-1=D, E-1=D^2, b-1=D*K, L-1=D*E. Every axiom prime minus 1 = D times predecessor.", "S326");
  render_finding(g, "D-generation", "ONLY D creates primes", "Of 15 p*q+1 products, only D*{D,K,E}+1 = {E,b,L}. D is the sole generative bridge.", "S326");
  render_finding(g, "Shadow polynomial", "P(x) = x^4 - Lx^3 + KEYx^2 - 61x + DKE", "Coefficients = {L=11, KEY=41, 61, 30}. The spectral architect.", "");
  render_finding(g, "Cumulant departure", "Universal for ALL primes", "The axiom is special because its shadows are prime, not because the theorem is.", "S178");
  dom_append(dom_body(), sec)
)

