)

fn page_chain() = (
  dom_head_meta("description", "The axiom chain: sigma->D->K->E->b->L. D-chain class numbers produce axiom constants (1,3,5,8,13,17). Ratios: Kolmogorov 5/3, golden 8/5, Fibonacci 13/8. Two Cunningham chains from {1,2}. Sigma-chain produces Fibonacci. Shadow polynomial. ~1773 proved theorems.");
