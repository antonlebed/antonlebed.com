  render_th(chdr, "Size");
  render_th(chdr, "Domain");
  render_th(chdr, "Why");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "Z/8 (D^3)", "8 classes", "Spatial / structural", "Vision, geometry, ARC grids");
  render_table_row_4(ctbl, "Z/9 (K^2)", "9 classes", "Compositional", "Syntax, closure, K=3 patterns");
