)

fn chain_gap_palindrome() = (
  let sec = make_section("800px") in
  render_h2(sec, "Gap Exponent Palindrome");
  render_p(sec, "The consecutive gaps between axiom primes {2,3,5,7,11} are {1,2,2,4}. Every gap is a power of D=2. The exponents are (0,1,1,2) -- the first four Fibonacci numbers. The gap ratios (D, sigma, D) form a palindrome with identity at the center.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Gap");
  render_th(hdr, "Value");
  render_th(hdr, "D-power");
  render_th(hdr, "Fib");
  render_th(hdr, "Cumulative");
  dom_append(tbl, hdr);
  render_table_row_5(tbl, "K - D", "1", "D^0", "F(0)", "sigma");
  render_table_row_5(tbl, "E - K", "2", "D^1", "F(1)", "K");
  render_table_row_5(tbl, "b - E", "2", "D^1", "F(2)", "E");
  render_table_row_5(tbl, "L - b", "4", "D^2", "F(3)", "K^2");
  render_theorem(sec, "Gap Exponent Palindrome (S964, PROVED)", "Consecutive gaps between axiom primes are D-powers with Fibonacci exponents. Sum of gaps = K^2. Product = D^4. Distinct sum = b. Cumulative gaps from D yield {o, sigma, K, E, K^2} -- axiom terms. GATE (13) breaks the Fibonacci pattern: gap 2, not D^3 = 8.");
  let g = make_findings_grid(sec) in
  render_finding(g, "Ratio palindrome", "(D, sigma, D)", "Center = identity. Wings = bridge. Mirror symmetry in ratio space.", "S964");
