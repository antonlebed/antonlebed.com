  render_finding(g3, "Scaling law", "Gap grows with capacity", "+0.7% -> +0.8% -> +1.0%. CRT advantage widens.", "S534");
  render_finding(g3, "Shared backbone", "Critical for ECC", "Independent denoisers plateau. Sharing = unique optimum.", "S609");
  render_finding(g3, "Attention > Conv", "Near-English output", "CRT + attention (205K params): readable. Standard (234K): garbage.", "S610");
