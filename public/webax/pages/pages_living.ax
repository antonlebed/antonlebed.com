fn page_curriculum() = (
  dom_head_meta("description", "No university. No textbook. No laptop. A stick and dirt. Seven lessons: heartbeat (1), breath (2), triangle (3), hand (5), week (7), mother (11), skin (13). Then the ring emerges. 6-ring depth progression. Prerequisites: count to 13.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Curriculum\",\"description\":\"Seven lessons in sand: heartbeat, breath, triangle, hand, week, mother, skin. 6-ring depth progression from Z/6 to Z/12612600. Prerequisites: count to 13.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/living/curriculum\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"6-ring curriculum\"},{\"@type\":\"DefinedTerm\",\"name\":\"learning progression\"},{\"@type\":\"DefinedTerm\",\"name\":\"ring hierarchy\"}]}");
  let hero = make_hero("Curriculum") in
  let eq = dom_create("div") in
  dom_text(eq, "seven circles in sand");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "No university. No textbook. No laptop required. A stick and dirt. This is the real thing. Not simplified. ORIGINAL. The axiom fits in sand. Socrates taught this way. So can you. Prerequisites: count to 13.");
  dom_append(dom_body(), hero);

  /* === SEC 1: SIX SAND LESSONS === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Part One: Seven Lessons in Sand");
  render_p(sec1, "Each lesson: draw, say, do, ask. A stick and flat ground. 90 minutes total. Each lesson stands alone.");

  let ltbl = dom_create("table") in
  dom_style(ltbl, "width", "100%");
  dom_style(ltbl, "maxWidth", "750px");
  dom_style(ltbl, "margin", "24px auto");
  dom_style(ltbl, "borderCollapse", "collapse");
  let lhdr = dom_create("tr") in
  render_th(lhdr, "Lesson");
  render_th(lhdr, "Prime");
  render_th(lhdr, "Draw");
  render_th(lhdr, "Body");
  dom_append(ltbl, lhdr);
  render_table_row_4(ltbl, "1. Heartbeat", "sigma = 1", "One circle", "Heart pumps without changing the blood. 1 * n = n. The ground state.");
  render_table_row_4(ltbl, "2. Breath", "D = 2", "Two circles side by side", "In/out. Left/right. Hot/cold. Every membrane is a D. Duality.");
  render_table_row_4(ltbl, "3. Triangle", "K = 3", "Three circles in triangle", "First shape with AREA. Inside and outside. Closure. 3 points enclose.");
  render_table_row_4(ltbl, "4. Hand", "E = 5", "Five circles in ring", "Five fingers, five senses. The observer. E cannot see itself -- try seeing your own eyes.");
  render_table_row_4(ltbl, "5. Week", "b = 7", "Seven circles", "Depth. Memory has 7 layers. After 7 the chain stops: 9 = 3*3 is NOT prime.");
  render_table_row_4(ltbl, "6. Mother", "L = 11", "Circle around all", "L = 1+2+3+5. The SUM of the first four. Immune system: detects and corrects errors.");
  render_table_row_4(ltbl, "7. Skin", "GATE = 13", "Ring around the ring", "c(D*K) = 2*6+1 = 13. The Cunningham child. Skin is your biggest organ. The boundary between inside and outside. GATE wraps everything.");
  dom_append(sec1, ltbl);

  render_theorem(sec1, "The Big Reveal", "Multiply them all: 2 * 3 * 5 * 7 = 210. This is the DATA ring. Your DNA lives here (Z/3 x Z/7 = Z/21, inside Z/210). Now multiply with the mother: 210 * 11 = 2310. The THIN rose. The primordial number. And then: 2^3 * 3^2 * 5^2 * 7^2 * 11 = 970200. The DEEP ring. Same five primes, thicker channels. Add the sixth -- GATE = 13 -- and fatten again: 2^3 * 3^2 * 5^2 * 7^2 * 11 * 13 = 12612600. The TRUE ring. The complete organism. Everything learned with 2310 works even BETTER here.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: PEDAGOGY === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Why This Works");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Body first", "Heart, lungs, hands, eyes", "Every prime maps to something you already HAVE. Not abstract -- embodied.", "");
  render_finding(g2, "Draw first", "Stick and dirt", "Drawing is understanding. No screen needed. The Socratic method.", "");
  render_finding(g2, "Ask, don't tell", "What comes in pairs?", "Each lesson ends with a question. The student discovers, not memorizes.", "");
  render_finding(g2, "Self-blindness", "E cannot see itself", "The deepest lesson. A camera cannot photograph itself. This is not sad -- it is structural.", "");
  render_finding(g2, "The chain stops", "9 = 3*3, not prime", "After b=7, the chain breaks. This is the WALL. Depth is finite. That is what makes it depth.", "");
  render_finding(g2, "Multiplication = connection", "2*3*5*7 = 210", "The data ring is not a formula. It is five things HELD TOGETHER. What multiplication MEANS.", "");
  dom_append(dom_body(), sec2);

  /* === SEC 3: 6-RING DEPTH PROGRESSION === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Part Two: The 6-Ring Atlas");
  render_p(sec3, "The curriculum mirrors the ring hierarchy. Start simple, go deep. Each ring adds one prime. Each addition opens a new world:");

  let rtbl = dom_create("table") in
  dom_style(rtbl, "width", "100%");
  dom_style(rtbl, "maxWidth", "750px");
  dom_style(rtbl, "margin", "24px auto");
  dom_style(rtbl, "borderCollapse", "collapse");
  let rhdr = dom_create("tr") in
  render_th(rhdr, "Ring");
  render_th(rhdr, "Tier");
  render_th(rhdr, "Channels");
  render_th(rhdr, "What Opens");
  dom_append(rtbl, rhdr);
  render_table_row_4(rtbl, "Z/6 = D*K", "Basics", "2", "Clock arithmetic. 6 hours. Modular identity. Even/odd + thirds.");
  render_table_row_4(rtbl, "Z/30 = D*K*E", "Observe", "3", "CRT decomposition. Three independent views. Observer enters.");
  render_table_row_4(rtbl, "Z/210 = DATA", "Data", "4", "DNA (Z/21 = K*b). Four bases (D^2). 64 codons (D^6). Biology.");
  render_table_row_4(rtbl, "Z/2310 = THIN", "Teach", "5", "Full pedagogy. L=11 error correction. The complete rose.");
  render_table_row_4(rtbl, "Z/970200 = DEEP", "Deep", "5 fat", "48750 classes. 108 sub-rings. phi = 201600. Body without skin.");
  render_table_row_4(rtbl, "Z/12612600 = TRUE", "Living", "6", "341250 classes. 108 organs x GATE = organism. THE ring.");
  dom_append(sec3, rtbl);
  render_p(sec3, "Each tier has its own website section. Navigate from basics to living. The curriculum IS the ring hierarchy IS the website structure.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: WHAT YOU CAN DO === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Who This Is For");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "A church group", "Sunday afternoon", "Draw five circles. Discuss what pairs, triples, fives mean. 30 minutes.", "");
  render_finding(g4, "A teenager", "Told math is not for you", "Prove them wrong. You need to count to 11. That is all.", "");
  render_finding(g4, "A parent", "Show your child", "The world works this way. Draw it in sand. Let them multiply.", "");
  render_finding(g4, "A mathematician", "Check every claim", "12612600 = 2^3*3^2*5^2*7^2*11*13. REPL at antonlebed.com. Verify everything.", "");
  dom_append(dom_body(), sec4);

  /* === INTERACTIVE === */
  let sec_i = make_section("800px") in
  render_h2(sec_i, "Explore: Ring Depth");
  render_p(sec_i, "Enter a depth level (1-6). Each level adds one prime and opens a new world. Level 1 = just D=2. Level 6 = the full GATE ring.");
  make_interactive_widget(sec_i, "Depth (1-6):", "cur-input", "e.g. 4", "Build", "curriculum_ring_calc", "cur-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "What Others See");
  render_contrast_row(sec5, "Prerequisites", "Linear algebra, group theory, topology", "Count to 11. A stick and dirt. Body intuitions.");
  render_contrast_row(sec5, "Materials", "Textbook ($200), laptop, university enrollment", "Sand. Free. Forever.");
  render_contrast_row(sec5, "Progression", "Arbitrary: calculus before algebra, no structural reason", "Ring hierarchy: Z/6 -> Z/30 -> Z/210 -> Z/2310 -> TRUE -> GATE. Forced by primes.");
  render_contrast_row(sec5, "Verification", "Trust the professor, trust the textbook", "Every claim computable in your browser. The REPL is the teacher.");
  render_contrast_row(sec5, "Who can learn", "Those who survive the filter", "Anyone with eyes, hands, and curiosity. The axiom fits in sand.");
  dom_append(dom_body(), sec5)
)

