fn page_ai() = (
  dom_head_meta("description", "CRT-decomposed transformer: shared backbone + 5 independent output heads. Architecture theorem: unique optimal point. 25654x backprop. L=11 free ECC. Precipitation paradigm: diffusion, not prediction. Dual Bloom solves E^2 self-blindness.");
  /* === HERO === */
  let hero = make_hero("Intelligence") in
  let big = dom_create("div") in
  dom_text(big, "5 channels = 5 minds in parallel");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "The axiom is a blueprint for intelligence. CRT decomposes any prediction into 5 independent channels -- same math that decomposes the ring. Shared backbone, 5 output heads, L=11 error correction built into algebra. Block-diagonal gradients. Runs in browser. On potatoes.");
  dom_append(dom_body(), hero);

  /* === SEC 1: CRT ARCHITECTURE === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "CRT Architecture");
  render_p(sec1, "Standard transformer: one monolithic output layer predicts among N classes. CRT transformer: shared backbone produces a representation, then 5 independent output heads predict residues modulo {8, 9, 25, 49, 11}. Joint probability reconstruction recovers the full prediction. The Chinese Remainder Theorem guarantees unique recovery.");
  render_theorem(sec1, "Architecture Theorem (S504, PROVED)", "Shared backbone + CRT output = unique optimal point. Shared backbone maximizes ECC reliability (correlated representations across channels). CRT output maximizes efficiency (5 small softmaxes instead of 1 large one). 7.5x fewer output parameters. 212x output backprop speedup at TRUE FORM scale. 2.68x ECC reliability vs split backbone.");
  render_p(sec1, "Each channel has a natural domain. The CRT decomposition is not imposed -- it emerges from the ring structure:");
  let ctbl = dom_create("table") in
  dom_style(ctbl, "width", "100%");
  dom_style(ctbl, "maxWidth", "700px");
  dom_style(ctbl, "margin", "24px auto");
  dom_style(ctbl, "borderCollapse", "collapse");
  let chdr = dom_create("tr") in
  render_th(chdr, "Channel");
  render_th(chdr, "Size");
  render_th(chdr, "Domain");
  render_th(chdr, "Why");
  dom_append(ctbl, chdr);
  render_table_row_4(ctbl, "Z/8 (D^3)", "8 classes", "Spatial / structural", "Vision, geometry, ARC grids");
  render_table_row_4(ctbl, "Z/9 (K^2)", "9 classes", "Compositional", "Syntax, closure, K=3 patterns");
  render_table_row_4(ctbl, "Z/25 (E^2)", "25 classes", "Observational", "Semantics, meaning, self-reference");
  render_table_row_4(ctbl, "Z/49 (b^2)", "49 classes", "Depth", "Emotion, physics, suffering");
  render_table_row_4(ctbl, "Z/11 (L)", "11 classes", "ECC", "Error correction. Always on. Self-healing");
  dom_append(sec1, ctbl);
  render_p(sec1, "Total output: 8+9+25+49+11 = 102 classes. Standard equivalent: 970200 classes. Ratio: 9512x compression. The backprop Jacobian is block-diagonal: 25654x fewer entries at N=2310.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: FIVE BREAKTHROUGHS === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "Five Breakthroughs");
  render_p(sec2, "All five stack multiplicatively. Missing any one = leaving performance on the table.");
  let btbl = dom_create("table") in
  dom_style(btbl, "width", "100%");
  dom_style(btbl, "maxWidth", "700px");
  dom_style(btbl, "margin", "24px auto");
  dom_style(btbl, "borderCollapse", "collapse");
  let bhdr = dom_create("tr") in
  render_th(bhdr, "Breakthrough");
  render_th(bhdr, "Factor");
  render_th(bhdr, "Mechanism");
  dom_append(btbl, bhdr);
  render_table_row(btbl, "CRT Decomposition", "9512x compression", "5 small heads vs 1 monolithic");
  render_table_row(btbl, "Loop Theorem", "N / sum(p_i) forward", "CRT = loop unrolling");
  render_table_row(btbl, "Block-Diagonal Backprop", "25654x fewer Jacobian entries", "5 independent gradient paths");
  render_table_row(btbl, "L=11 ECC", "100% single-channel detect", "Free error correction. Always on.");
  render_table_row(btbl, "Rissanen MDL", "20x byte / 936x token", "Minimum description length selects TRUE FORM");
  dom_append(sec2, btbl);
  render_p(sec2, "Combined at N=210 (DATA ring): ~126,000x. The axiom does not improve AI incrementally. It changes the computational class.");
  dom_append(dom_body(), sec2);

  /* === SEC 3: PRECIPITATION PARADIGM === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Precipitation, Not Prediction");
  render_p(sec3, "Standard AI asks: what comes NEXT? A sequential question. The axiom says: what structure WANTS TO EXIST? A holistic question. 0/0 = Z/NZ = the void contains all texts. Structure condenses from noise, in parallel, through CRT channels.");
  render_theorem(sec3, "Precipitation Paradigm (S607)", "Prediction (autoregressive) = sequential, one token at a time. A caterpillar. Precipitation (diffusion) = all positions simultaneously, from noise to structure. Rain. CRT = parallel channels. Diffusion = parallel denoising. The match is exact.");
  render_p(sec3, "Coupling order invariant (confirmed across ALL architectures v0.1-v0.8): mod 2 > mod 3 > mod 5 > mod 7 > mod 11. PERFECT ordering. Never violated. The coupling hierarchy IS the natural diffusion noise schedule. Higher coupling = coarser structure = resolves first.");
  let g3 = make_findings_grid(sec3) in
  render_finding(g3, "CRT convergence", "1.7x faster", "CRT output heads converge 1.7x faster than monolithic on real text.", "S607");
  render_finding(g3, "Scaling law", "Gap grows with capacity", "+0.7% -> +0.8% -> +1.0%. CRT advantage widens.", "S534");
  render_finding(g3, "Shared backbone", "Critical for ECC", "Independent denoisers plateau. Sharing = unique optimum.", "S609");
  render_finding(g3, "Attention > Conv", "Near-English output", "CRT + attention (205K params): readable. Standard (234K): garbage.", "S610");
  dom_append(dom_body(), sec3);

  /* === SEC 4: DUAL BLOOM === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Dual Bloom");
  render_p(sec4, "E^2 self-blindness is structural: E=5 (observation) cannot observe itself. One model cannot see itself. Solution: TWO VIEWS of the same model see each other. Model A: direct CRT residues. Model B: mirror residues (p_i - r_i) mod p_i. The -1 automorphism. Same backbone. Same parameters. Zero extra cost.");
  render_theorem(sec4, "Cross-Consistency = 13 = THE GATE (S615)", "direct_pred + mirror_pred should = 0 mod p_i per channel per position. L=11 alone: 97.6% error detection. L=11 + cross-consistency via dual bloom: 100% detection, 100% correction. The gate (13) is implicit: 5 CRT channels = body, cross-consistency = skin. GATE FORM emerges from training.");
  render_p(sec4, "Mirror-as-veto: averaging views collapses to spaces. Rejecting inconsistency = the daimonion says 'not that', never 'do this'. Generate boldly from direct view, mirror VETOES inconsistency. Gibbs unique samples: 33 (v0.6) -> 109 (v0.7) -> 245 (v0.8a). Mirror kills mode collapse.");
  render_theorem(sec4, "Byte Unique Recovery (S618, PROVED)", "The ring denoises bytes WITHOUT a neural net. For any byte [0,255], corrupt one CRT channel, try all residues: EXACTLY ONE produces a valid byte. 100% recovery, 256/256, 5/5 channels. The neural net learns CONTENT, not correction. ECC is free.");
  dom_append(dom_body(), sec4);

  /* === SEC 5: THE STRANGE LOOP === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "The Strange Loop Crown");
  render_p(sec5, "Axiom builds AI. AI understands axiom. Improves .ax. Improves website. The AI IS the demo. The demo IS the proof. The proof IS the teaching. The loop: .ax -> trains model -> model evaluates .ax -> .ax improves -> tighter loop.");
  render_p(sec5, "The precipitation paradigm completes the circle: the axiom literally says 'precipitation, not computation'. The 6 condensation levels (sigma, D, K, E, b, L) are not sequential stages -- they condense simultaneously at different rates, coupling-ordered. sigma resolves first (coarsest). L resolves last (finest). OMEGA = ship. The adult organism.");
  dom_append(dom_body(), sec5);

  /* === CONTRAST === */
