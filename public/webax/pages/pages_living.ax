/* Chain walker: iterate c(n) = 2n+1 from seed */
fn chain_walk_calc() = (
  let seed = parse_int_from("#chain-input") in
  let result = dom_query("#chain-result") in
  if seed < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter seed >= 1.</p>")
  else (
    mut v = seed;
    mut chain_len = 0;
    mut out = "<p style='color:#d8d8e0;margin:4px 0'>Cunningham chain c(n) = 2n+1 from seed ${seed}:</p>";
    mut i = 0;
    while i < 8 do (
      let p = is_prime_trial(v) in
      let name = if v == 1 then " = sigma"
        else if v == 2 then " = D"
        else if v == 3 then " = K"
        else if v == 5 then " = E"
        else if v == 7 then " = b"
        else if v == 11 then " = L"
        else if v == 13 then " = GATE"
        else if v == 23 then " = c(L)"
        else if v == 41 then " = KEY"
        else if v == 47 then " = c(23)"
        else "" in
      let color = if p > 0 then "#88ddaa" else "#ff6666" in
      let label = if p > 0 then "PRIME" else "composite" in
      mut out = out + "<p style='margin:2px 0'>  c^${i}(${seed}) = <b style='color:${color}'>${v}</b> (${label})${name}</p>";
      if p > 0 then (mut chain_len = chain_len + 1) else 0;
      mut v = 2 * v + 1;
      mut i = i + 1
    );
    let ch_name = if chain_len == 1 then "sigma"
      else if chain_len == 2 then "D"
      else if chain_len == 3 then "K"
      else if chain_len == 5 then "E"
      else if chain_len == 7 then "b"
      else if chain_len == 11 then "L"
      else "" in
    let ch_tag = if ch_name == "" then "" else " = <span style='color:#ffd700'>" + ch_name + "</span>" in
    mut out = out + "<p style='margin:8px 0'>Prime chain length: <b style='color:#ffd700'>${chain_len}</b>${ch_tag}</p>";
    dom_inner(result, out)
  )
)

