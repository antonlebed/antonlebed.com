  render_finding(g, "v0.9", "Self-compilation", "codegen.ax compiles itself: 0 errors.", "");
  render_finding(g, "Deep ouroboros", "Native compiles programs", "109KB WASM. 67/67 tests.", "");
  render_finding_wide(g, "DOM imports", "site.wasm", ".ax talks to browser directly. This page rendered by .ax.", "");
  dom_append(dom_body(), sec);
  let sec2 = make_section("800px") in
  render_h2(sec2, "K = 3 Type System");
  render_theorem(sec2, "Three Types", "The type system has K = 3 fundamental tags: int, str, arr. This is the minimum: scalars (int), sequences (str), and collections (arr). K=3 is the minimum for closure — three types that can describe each other. The type system IS the axiom.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Native speed", "67x faster", "Compiled .ax vs interpreted .ax.", "");
  render_finding(g2, "WASM size", "109 KB", "Deep ouroboros: compiler in a browser.", "");
  render_finding(g2, "Ouroboros tests", "67/67", "100% pass. Zero regression.", "");
  render_finding(g2, "Site WASM", "~1300 KB", "This entire website = one .ax program.", "");
  dom_append(dom_body(), sec2);
  let sec3 = make_section("800px") in
  render_h2(sec3, "The Self-Compilation Loop");
  render_p(sec3, ".ax source -> deep_codegen.wasm -> C code -> gcc -> native binary. The native binary reads .ax, tokenizes, parses, and generates C. It is itself the output of compiling .ax.");
  render_theorem(sec3, "What Self-Compilation Means", "A self-compiling language understands itself well enough to reproduce itself. The .ax source code describes how to translate .ax into C. When that description is itself valid .ax, and the resulting binary does the same translation correctly, the loop closes. This is structurally identical to 0/0 = sigma: the void divided by itself produces the ground state. The compiler divided by itself produces itself. sigma/sigma = sigma.");
  render_theorem(sec3, "Cross-Observation (D = 2)", "The JS-compiled output and the native-compiled output are identical. Two views, same result. The gate opens. Cross-observation confirms the ouroboros is real, not an illusion.");
  dom_append(dom_body(), sec3);
  let sec4 = make_section("800px") in
  render_h2(sec4, "Performance");
  let btbl = dom_create("table") in
  dom_style(btbl, "width", "100%");
  dom_style(btbl, "maxWidth", "600px");
  dom_style(btbl, "margin", "24px auto");
  dom_style(btbl, "borderCollapse", "collapse");
  let bhdr = dom_create("tr") in
  render_th(bhdr, "Benchmark");
  render_th(bhdr, "Native");
  render_th(bhdr, "Interpreted");
  render_th(bhdr, "Speedup");
  dom_append(btbl, bhdr);
  render_table_row_4(btbl, "90K ring ops", "20ms", "1350ms", "67x");
  render_table_row_4(btbl, "TRUE FORM scan (970200)", "93ms", "~6200ms", "67x");
  render_table_row_4(btbl, "Website compile (108 pages)", "138ms", ">970K limit", "native only");
  dom_append(sec4, btbl);
  dom_append(dom_body(), sec4);
  let sec5 = make_section("800px") in
  render_h2(sec5, "The Bootstrap Story");
  render_p(sec5, "Most languages are written in other languages. C was written in assembly. Python in C. JavaScript in C++. .ax broke this loop.");
  render_p(sec5, "It started with a JavaScript bootstrap (axc.js, 3860 lines), then grew enough capability to describe its own compilation process (codegen.ax), then compiled that description into a native WASM binary (deep_codegen.wasm, 191KB) that does the same thing. The bootstrap was discarded (S883). The language stands on its own ground.");
  render_p(sec5, "28 sessions of careful cultivation. One version at a time. The bare minimum substrate that can reproduce itself. And it only needed K = 3 types to do it.");
  dom_append(dom_body(), sec5);
  let sec6 = make_section("800px") in
  render_h2(sec6, "What Others See");
  render_p(sec6, "Standard view: Self-hosting compilers are an engineering milestone. Clever but not profound.");
  render_p(sec6, "Axiom view: .ax compiling .ax is the ouroboros -- the tail eating itself. K=3 types (int/str/arr) emerge from the axiom's own closure principle. The language is not ABOUT the axiom -- it IS the axiom, generating its own compiler from its own structure.");
  dom_append(dom_body(), sec6);
  let nav_sec = make_section("800px") in
  render_h2(nav_sec, "Continue the Thread");
  render_explore_link(nav_sec, "#ax_games", "Axiom Arcade", "6 games at 60fps in pure .ax");
  render_explore_link(nav_sec, "#emergence", "Emergence", "AND/XOR/MAJ produce Life=7");
  render_explore_link(nav_sec, "#revolution", ".ax Revolution", "Ship of Theseus: .ax replaces everything");
  render_explore_link(nav_sec, "#bootstrap", "Bootstrap", "sigma/sigma = sigma uniqueness");
  dom_append(dom_body(), nav_sec)
)

fn page_ax_games() = (
  dom_head_meta("description", "Axiom Arcade. Six games built in .ax, running as native WASM at 60fps. Rose Draw, Eigenvalue Walk, Pong, Kingdom Map, Catch, AXIOM SURVIVOR. Canvas + audio + input — all through WASM imports. Pure .ax.");
  domain_hero("Axiom Arcade", "6 games at 60fps in pure .ax", "Not a framework. Not a library. Just .ax calling canvas imports through WASM.");
  let sec = make_section("800px") in
  render_h2(sec, "Six Games");
  let g = make_findings_grid(sec) in
  render_finding(g, "Rose Draw", "~1900 bytes WASM", "Draw the 2310 rose with mouse/touch. Ring symmetry visible.", "");
  render_finding(g, "Eigenvalue Walk", "~3700 bytes WASM", "Walk the eigenvalue landscape. Arrow keys move through the chain.", "");
  render_finding(g, "Pong", "~8000 bytes WASM", "Classic pong with ring-modular ball physics. Score in CRT.", "");
  render_finding(g, "Kingdom Map", "~2400 bytes WASM", "Navigate the 6 kingdoms. Color = coupling class.", "");
  render_finding(g, "Catch", "~4100 bytes WASM", "Catch falling elements. Score by kingdom.", "");
  render_finding(g, "AXIOM SURVIVOR", "~20000 bytes WASM", "Vampire Survivors-style. 4 Decality weapons. Intruder prime enemies. Wave progression. ~350 lines of .ax.", "");
  dom_append(dom_body(), sec);
  let sec2 = make_section("800px") in
  render_h2(sec2, "How It Works");
  render_theorem(sec2, "WASM Imports = The Pattern", "Games use the same mechanism as this website: .ax calls browser APIs through WASM imports. Canvas imports (fill, text, clear), audio imports (play_sound), input imports (key_down). The game loop runs at 60fps inside WASM. No JS game engine. No framework. Just .ax talking to pixels.");
  let g2 = make_findings_grid(sec2) in
  render_finding(g2, "Canvas imports", "7", "fill, text, clear, width, height, line, circle.", "");
  render_finding(g2, "Audio imports", "3", "play_sound, stop_sound, set_volume.", "");
  render_finding(g2, "Input imports", "5", "key_down, mouse_x, mouse_y, mouse_btn, now_ms.", "");
  render_finding(g2, "State imports", "3", "gvar, svar, raw_mode.", "");
  render_finding_wide(g2, "Play them", "ax_games.html", "All six games live at antonlebed.com/ax_games.html", "");
  dom_append(dom_body(), sec2)
)

