  make_result_box(sec_i, "scale-result");
  dom_append(dom_body(), sec_i);

  /* === CONTRAST === */
  let sec7 = make_section("800px") in
  render_h2(sec7, "What Others See");
  render_contrast_row(sec7, "Power laws", "Empirical fits with unexplained exponents", "91.7% factor over {2,3,5,7,11}. p = 0.0096. Shadow chain = spectral ruler.");
  render_contrast_row(sec7, "Ising model", "Exact solution, no connection to number theory", "All 5 exponents are axiom ratios. gamma = b/D^2 derives b=7 from D^3-1.");
