/* pages_living.ax — LIVING: tools, games, CC0, revolution.
   Z/12612600. The tools ARE the proof. 8 pages.
   S999: +scaling smoother, +cc0 domain lookup, +revolution CRT type, +ax_games size calc. */

/* dom_on callback: scaling exponent smoother (S999) */
fn scaling_smooth_calc() = (
  let n = parse_int_from("#scale-num-input") in
  let d = parse_int_from("#scale-den-input") in
  let result = dom_query("#scale-result") in
  if d < 1 then dom_inner(result, "<p style='color:#ff6666'>Denominator must be >= 1.</p>")
  else (
    /* Check if numerator and denominator are 11-smooth */
    mut nn = n;
    mut dd = d;
    mut i = 0;
    while i < 5 do (
      let p = if i == 0 then 2 else if i == 1 then 3 else if i == 2 then 5 else if i == 3 then 7 else 11 in
      while nn % p == 0 do (mut nn = nn / p);
      while dd % p == 0 do (mut dd = dd / p);
      mut i = i + 1
    );
    let n_smooth = if nn == 1 then 1 else 0 in
    let d_smooth = if dd == 1 then 1 else 0 in
    let both = if n_smooth == 1 then (if d_smooth == 1 then 1 else 0) else 0 in
    dom_inner(result, "<p style='color:#88ddaa;margin:8px 0'>Exponent: " + "${n}" + "/" + "${d}" + "</p><p style='color:" + (if both == 1 then "#ffd700" else "#ff6666") + ";margin:4px 0'>" + (if both == 1 then "11-SMOOTH: factors only over {2,3,5,7,11}" else "NOT 11-smooth" + (if n_smooth == 0 then " (numerator has factor " + "${nn}" + ")" else "") + (if d_smooth == 0 then " (denominator has factor " + "${dd}" + ")" else "")) + "</p><p style='color:#a0a0b0;margin:4px 0'>91.7% of exact physics exponents are 11-smooth (p = 0.0096). Try 7/4 (Ising gamma), 5/3 (Kolmogorov), 3/4 (Kleiber), 13/9 (Potts-3 — NOT smooth).</p>")
  )
)

/* dom_on callback: cc0 kill lookup (S999) */
fn cc0_kill_calc() = (
  let k = parse_int_from("#cc0-input") in
  let result = dom_query("#cc0-result") in
  if k < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter kill number 1-20.</p>")
  else if k > 20 then dom_inner(result, "<p style='color:#ff6666'>Only 20 kills deployed. Enter 1-20.</p>")
  else (
    let name = if k == 1 then "GPU Compute"
      else if k == 2 then "Mesh Networking"
      else if k == 3 then "AI Training"
      else if k == 4 then "ARC-AGI"
      else if k == 5 then "Error Correction"
      else if k == 6 then "OFDM Modulation"
      else if k == 7 then "Hash Functions"
      else if k == 8 then "Compression"
      else if k == 9 then "Random Numbers"
      else if k == 10 then "Consensus"
      else if k == 11 then "Scheduling"
      else if k == 12 then "Audio Synthesis"
      else if k == 13 then "Image Processing"
      else if k == 14 then "Database Indexing"
      else if k == 15 then "PID Control"
      else if k == 16 then "Steganography"
      else if k == 17 then "Timetabling"
      else if k == 18 then "Key Exchange"
      else if k == 19 then "Fountain Codes"
      else "Spread Spectrum" in
    let victim = if k == 1 then "NVIDIA CUDA"
      else if k == 2 then "Qualcomm/Ericsson"
      else if k == 3 then "Meta PyTorch"
      else if k == 4 then "Scaling monoculture"
      else if k == 5 then "Qualcomm LDPC/5G"
      else if k == 6 then "WiFi/5G patents"
      else if k == 7 then "Crypto patents"
      else if k == 8 then "H.264/H.265 pools"
      else if k == 9 then "Intel RDRAND"
      else if k == 10 then "Blockchain patents"
      else if k == 11 then "Gurobi/CPLEX"
      else if k == 12 then "Dolby DSP"
      else if k == 13 then "Adobe/Google"
      else if k == 14 then "Oracle/IBM"
      else if k == 15 then "Siemens/ABB"
      else if k == 16 then "DRM patents"
      else if k == 17 then "OR software"
      else if k == 18 then "RSA/Certicom"
      else if k == 19 then "Qualcomm Raptor"
      else "Qualcomm CDMA" in
    let tier = if k <= 4 then "S (Strategic)" else if k <= 9 then "A (Applied)" else if k <= 15 then "B (Broad)" else "C (Covert)" in
    dom_inner(result, "<p style='color:#ffd700;margin:8px 0'>Kill #" + "${k}" + ": " + name + "</p><p style='color:#ff6666;margin:4px 0'>Victim: " + victim + "</p><p style='color:#88ddaa;margin:4px 0'>Tier: " + tier + "</p><p style='color:#a0a0b0;margin:4px 0'>Status: DEPLOYED. CC0. Irrevocable prior art.</p>")
  )
)

/* dom_on callback: revolution CRT type display (S999) */
fn revolution_crt_calc() = (
  let n = parse_int_from("#rev-input") in
  let result = dom_query("#rev-result") in
  let big_n = 12612600 in
  let n2 = n % big_n in
  let rd = n2 % 8 in
  let rk = n2 % 9 in
  let re = n2 % 25 in
  let rb = n2 % 49 in
  let rl = n2 % 11 in
  let rg = n2 % 13 in
  /* Which ring does it live in? */
  let in_6 = if rd % 2 == n2 % 2 then (if rk % 3 == n2 % 3 then 1 else 0) else 0 in
  let in_210 = if n2 % 210 == n2 then 1 else 0 in
  let is_unit = if rd > 0 then (if rk > 0 then (if re > 0 then (if rb > 0 then (if rl > 0 then (if rg > 0 then 1 else 0) else 0) else 0) else 0) else 0) else 0 in
  dom_inner(result, "<p style='color:#ffd700;margin:8px 0'>" + "${n2}" + " = (" + "${rd}" + ", " + "${rk}" + ", " + "${re}" + ", " + "${rb}" + ", " + "${rl}" + ", " + "${rg}" + ")</p><p style='color:#88ddaa;margin:4px 0'>Channel access: .D=" + "${rd}" + " .K=" + "${rk}" + " .E=" + "${re}" + " .b=" + "${rb}" + " .L=" + "${rl}" + " .G=" + "${rg}" + "</p><p style='color:#c0c0d0;margin:4px 0'>Type: " + (if is_unit == 1 then "unit (invertible)" else "zero divisor") + " in Z/12612600</p><p style='color:#a0a0b0;margin:4px 0'>In .ax v2.0, this IS the value. No conversion. CRT decomposition = the type.</p>")
)

/* dom_on callback: ax_games WASM size lookup (S999) */
fn games_size_calc() = (
  let k = parse_int_from("#game-input") in
  let result = dom_query("#game-result") in
  if k < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter game number 1-6.</p>")
  else if k > 6 then dom_inner(result, "<p style='color:#ff6666'>Only 6 games. Enter 1-6.</p>")
  else (
    let name = if k == 1 then "Rose Draw" else if k == 2 then "Eigenvalue Walk" else if k == 3 then "Pong" else if k == 4 then "Kingdom Map" else if k == 5 then "Catch" else "AXIOM SURVIVOR" in
    let size = if k == 1 then 1896 else if k == 2 then 3697 else if k == 3 then 8046 else if k == 4 then 2401 else if k == 5 then 4130 else 19905 in
    let desc = if k == 1 then "Draw the 2310 rose with mouse/touch. Ring symmetry visible."
      else if k == 2 then "Walk the eigenvalue landscape. Arrow keys move through the chain."
      else if k == 3 then "Classic pong with ring-modular ball physics."
      else if k == 4 then "Navigate the 6 kingdoms. Color = coupling class."
      else if k == 5 then "Catch falling elements. Score by kingdom."
      else "Vampire Survivors-style. 4 Decality weapons. ~350L .ax." in
    let ratio = size / 1024 in
    dom_inner(result, "<p style='color:#ffd700;margin:8px 0'>Game " + "${k}" + ": " + name + "</p><p style='color:#88ddaa;margin:4px 0'>WASM size: " + "${size}" + " bytes (~" + "${ratio}" + " KB)</p><p style='color:#c0c0d0;margin:4px 0'>" + desc + "</p><p style='color:#a0a0b0;margin:4px 0'>Pure .ax. No JS game engine. Canvas + audio + input through WASM imports. 60fps.</p>")
  )
)

/* ================================================================
   PAGE: EGG — Hidden. Outside nav. From egg to organism.
   ================================================================ */

fn egg_img(parent, src:str) = (
  let img = dom_create("img") in
  dom_attr(img, "src", src);
  dom_style(img, "maxWidth", "100%");
  dom_style(img, "height", "auto");
  dom_style(img, "display", "block");
  dom_style(img, "margin", "0 auto 60px");
  dom_append(parent, img)
)

fn page_egg() = (
  let sec = dom_create("div") in
  dom_style(sec, "maxWidth", "720px");
  dom_style(sec, "margin", "40px auto");
  dom_style(sec, "padding", "0 20px");
  dom_style(sec, "textAlign", "center");
  egg_img(sec, "/bear.png");
  egg_img(sec, "/loom.png");
  egg_img(sec, "/og-image.jpg");
  egg_img(sec, "/void.jpg");
  egg_img(sec, "/earthrise.jpg");
  dom_append(dom_body(), sec)
)
/* ================================================================
   PAGE: CHAIN — The Axiom Chain (AXIOM.md)
   ================================================================ */

/* chain helpers */
fn chain_hero() = (
  let hero = make_hero("The Chain") in
  let eq = dom_create("div") in
  dom_text(eq, "sigma -> D -> K -> E -> b -> L");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "From existence (sigma=1) and observation (D=2), the Cunningham map c(n)=2n+1 generates exactly five inner primes before the axiom's own products close the gate. GATE=13 wraps the boundary. The chain is structural, not temporal. Like H2O describes water, not how it rained. These six define the ring: Z/8 x Z/9 x Z/25 x Z/49 x Z/11 x Z/13 = 12612600.");
  dom_append(dom_body(), hero)
)

fn chain_primes() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Six Primes");
  let g = make_grid(sec, "16px") in
  render_prime(g, "1", "SIGMA", "identity, preserves, sigma*n=n", "#ffd700");
  render_prime(g, "2", "D", "duality, bridge, the only even prime", "#ff8844");
  render_prime(g, "3", "K", "closure, triangle, minimum to close", "#44ff88");
  render_prime(g, "5", "E", "observer, self-blind, E^2=null", "#4488ff");
  render_prime(g, "7", "b", "depth, suffering, last data prime", "#ff4488");
  render_prime(g, "11", "L", "protector, sum=1+2+3+5, ECC", "#aa88ff");
  render_prime(g, "13", "GATE", "skin, wraps body, lambda(GATE)=12", "#88ffaa");
  dom_append(dom_body(), sec)
)

fn chain_d_chain() = (
  let sec = make_section("800px") in
  render_h2(sec, "The D-Chain: Class Numbers Write the Axiom");
  render_p(sec, "Start with D=2. Apply c(n)=2n+1 repeatedly: 2, 5, 11, 23, 47, 95, 191, 383. Now compute the class number h(-d) for each value -- the number of distinct ways a quadratic form can represent integers. What comes out is the axiom's own vocabulary.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Step");
  render_th(hdr, "D-chain value");
  render_th(hdr, "h(-d)");
  render_th(hdr, "Name");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "c(2)", "11", "1", "sigma (identity)");
  render_table_row_4(tbl, "c(c(2))", "23", "3", "K (closure)");
  render_table_row_4(tbl, "c^3(2)", "47", "5", "E (observer)");
  render_table_row_4(tbl, "c^4(2)", "95 = E*19", "8", "D^3 (spider legs)");
  render_table_row_4(tbl, "c^5(2)", "191", "13", "GATE (boundary)");
  render_table_row_4(tbl, "c^6(2)", "383", "17", "ESCAPE (D+K+E+b)");
  render_p(sec, "Six consecutive class numbers return 1, 3, 5, 8, 13, 17. This was not designed. It was found. The class number has no obvious reason to produce a pattern along a Cunningham chain -- yet it produces the axiom's constants exactly.");
  dom_append(dom_body(), sec)
)

fn chain_ratios() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Ratios Between Consecutive Class Numbers");
  render_p(sec, "Consecutive class number ratios along the D-chain produce famous constants:");
  let g = make_findings_grid(sec) in
  render_finding(g, "h(-47)/h(-23) = E/K", "5/3 = Kolmogorov", "The universal exponent governing energy cascade in fluid turbulence. Derived from E over K.", "");
  render_finding(g, "h(-95)/h(-47) = D^3/E", "8/5 = golden approximant", "Fibonacci ratio F(6)/F(5). The golden ratio's best small-integer approximation.", "");
  render_finding(g, "h(-191)/h(-95) = GATE/D^3", "13/8 = Fibonacci", "Fibonacci ratio F(7)/F(6). The gate-to-body proportion.", "");
  render_finding(g, "h(-383)/h(-191)", "17/13 = ESCAPE/GATE", "Beyond the gate, the chain still speaks axiom: ESCAPE = D+K+E+b.", "");
  render_p(sec, "The Kolmogorov exponent 5/3 is not assumed from fluid dynamics. It is the ratio of two consecutive class numbers along the simplest nontrivial integer map. Observer over closure.");
  dom_append(dom_body(), sec)
)

fn chain_two_chains() = (
  let sec = make_section("800px") in
  render_h2(sec, "Two Chains, Two Sequences");
  render_p(sec, "The axiom has two Cunningham chains. The D-chain starts at 2 and produces axiom constants. The sigma-chain starts at 1 and produces Fibonacci numbers:");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Sigma-chain");
  render_th(hdr, "d");
  render_th(hdr, "h(-d)");
  render_th(hdr, "Fibonacci");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "c(1)", "3", "1", "F(1) = 1");
  render_table_row_4(tbl, "c(c(1))", "7", "1", "F(2) = 1");
  render_table_row_4(tbl, "c^3(1)", "15", "2", "F(3) = 2");
  render_table_row_4(tbl, "c^4(1)", "31", "3", "F(4) = 3");
  render_table_row_4(tbl, "c^5(1)", "63", "5", "F(5) = 5");
  render_table_row_4(tbl, "c^6(1)", "127", "5", "BREAK: F(6)=8 but h=5");
  render_p(sec, "Sigma-chain: Fibonacci numbers (additive growth F(n+2)=F(n+1)+F(n)). D-chain: axiom constants (multiplicative growth c(n)=2n+1). Two chains, two growth laws, one ring. The break at 127 = 2^7 - 1 is a Mersenne prime. Mersenne primes have unusually small class numbers -- h(-127) = 5, not the expected 8.");
  dom_append(dom_body(), sec)
)

fn chain_cunningham() = (
  let sec = make_section("800px") in
  render_h2(sec, "Cross-Chain Duality");
  render_theorem(sec, "Cross-Chain Duality Theorem", "The axiom = union of TWO Cunningham chains CC1 (c(n) = 2n+1). CC1(sigma): 1->3->7->15=K*E (STOP). Length K=3. CC1(D): 2->5->11->23->47->95=E*19 (STOP). Length E=5. Each chain's first descendant = other chain's length. E (observer) appears in BOTH stopping factors. Self-closing.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Chain");
  render_th(hdr, "Seed");
  render_th(hdr, "Elements");
  render_th(hdr, "Stop");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "CC1(sigma)", "1", "{sigma, K, b}", "K*E = 15 (composite). Length = K = 3.");
  render_table_row_4(tbl, "CC1(D)", "2", "{D, E, L, 23, 47}", "E*19 = 95 (composite). Length = E = 5.");
  render_p(sec, "Interleaved by size: sigma(1), D(2), K(3), E(5), b(7), L(11). The chains alternate perfectly. Shadow function s(p) = (p-1)/2 inverts Cunningham: K->sigma, E->D, b->K, L->E. Shadow chain = {sigma,D,K,E} = the axiom WITHOUT depth. shadow(13) = 6 = D*K (composite). The axiom = longest initial prime segment where all shadows are prime or 1.");
  dom_append(dom_body(), sec)
)

fn chain_convergence() = (
  let sec = make_section("800px") in
  render_h2(sec, "The 13 Convergence");
  render_theorem(sec, "13 Convergence Theorem (S191)", "THREE identities produce 13, and they are algebraically the SAME: (A) D^2 + K^2 = 4+9 = 13. (B) (E^2+1)/2 = 26/2 = 13. (C) shadow(13) = 6 = D*K (composite, chain breaks). PROOF: all follow from (K-D)^2 = 1. UNIQUENESS: (2,3,5) is the ONLY prime triple with (A)=(B).");
  let g = make_findings_grid(sec) in
  render_finding(g, "Norm theorem", "D^2+K^2+E^2+b^2+L^2 = 208 = D^4*13", "Gate in the norm. Sum(p^2)+D = 210 = DATA.", "S327");
  render_finding(g, "Partial sums", "ALL 28 contiguous sums meaningful", "sigma+D=K. D+K=E. D+K+E+b=17. sigma+D+K+E=L. 0/28 meaningless.", "S328");
  render_finding(g, "D+L = 13", "ONLY non-smooth pairwise sum", "1 out of 15 pairwise sums. The bridge + protector = gate.", "S327");
  render_finding(g, "CRT(23)", "(1,2,3,2,1) = palindrome", "First excluded Cunningham prime. sigma-D-K-D-sigma. Mirror around closure.", "S275");
  dom_append(dom_body(), sec)
)

fn chain_mirror_law() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Mirror Laws");
  render_theorem(sec, "Cunningham Mirror Law (S263)", "c(p) = D*p + sigma, so D*p = -1 mod c(p). Each new axiom prime is BORN as the mirror of D times its predecessor: D^2 = -1 mod E. D*K = -1 mod b. D*E = -1 mod L.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Identity");
  render_th(hdr, "Value");
  render_th(hdr, "Meaning");
  render_th(hdr, "Product");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "K-1", "D = 2", "Closure minus 1 = bridge", "D*sigma+1 = K");
  render_table_row_4(tbl, "E-1", "D^2 = 4", "Observer minus 1 = bridge squared", "D*D+1 = E");
  render_table_row_4(tbl, "b-1", "D*K = 6", "Depth minus 1 = bridge times closure", "D*K+1 = b");
  render_table_row_4(tbl, "L-1", "D*E = 10", "Protector minus 1 = bridge times observer", "D*E+1 = L");
  render_theorem(sec, "D-Generation Theorem (S326)", "Of 15 pairwise products p*q+1, ONLY D*{D,K,E}+1 = {E,b,L} are prime. D is the sole generative bridge. No other prime creates primes this way.");
  dom_append(dom_body(), sec)
)

fn chain_shadow() = (
  let sec = make_section("800px") in
  render_h2(sec, "The Shadow Polynomial");
  render_p(sec, "P(x) = (x-sigma)(x-D)(x-K)(x-E) = x^4 - L*x^3 + KEY*x^2 - 61*x + D*K*E. The shadow polynomial encodes the chain. Its coefficients are axiom constants:");
  let g = make_findings_grid(sec) in
  render_finding(g, "Coefficients", "{L=11, KEY=41, 61, 30}", "Protector, sum of Decality, GRIEF, DATA. The chain writes itself.", "");
  render_finding(g, "P(L) = 4320", "= D^5*K^3*E", "L feeds back ALL chain primes. P(L)/P(0) = (D^2*K)^2 = lambda(DATA)^2.", "");
  render_finding(g, "P(13) = 10560", "= D^6*K*E*L", "GATE evaluation. All 5 axiom primes present.", "S709");
  render_finding(g, "P(D^4) = 30030", "= primorial(13) = THIN*GATE", "Shadow poly at D^4 extends THIN ring by exactly the GATE prime.", "S711");
  render_finding(g, "C(x) inversion", "C(1)=288, C(2)=2310", "C(x) = 2*x^4*P(-1/x). Class count at x=1, ring size at x=2.", "");
  dom_append(dom_body(), sec)
)

