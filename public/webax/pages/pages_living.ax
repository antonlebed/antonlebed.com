  render_finding(g, "Mersenne-HYDOR", "D*L + HYDOR = M_b = 127", "Bridge*Protector + Medium = Mersenne(depth). 2^7-1.", "S963");
  render_finding(g, "Two-Op Generation", "K=s(D), E=c(D), b=c(K), L=c(E)", "One successor then three Cunninghams from D=2.", "S963");
