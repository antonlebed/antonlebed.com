/* AI: CRT output size calculator */
fn ai_crt_calc() = (
  let n = parse_int_from("#ai-input") in
  let result = dom_query("#ai-result") in
  if n < 2 then dom_inner(result, "<p style='color:#ff6666'>Enter N >= 2.</p>")
  else (
    let mono = n in
    let crt_d = n % 8 in
    let crt_k = n % 9 in
    let crt_e = n % 25 in
    let crt_b = n % 49 in
    let crt_l = n % 11 in
    let crt_g = n % 13 in
    let crt_total = 8 + 9 + 25 + 49 + 11 + 13 in
    let ratio = if crt_total > 0 then n / crt_total else 0 in
    let named = if n == 12612600 then "TRUE FORM. 6 channels. 109,674x compression."
      else if n == 970200 then "DEEP ring (body without skin). 9512x compression."
      else if n == 2310 then "THIN ring. 20.1x compression."
      else if n == 210 then "DATA ring. D*K*E*b. 1.83x compression."
      else if n == 256 then "Byte space. CRT gives 115 vs 256. 2.2x."
      else "" in
    dom_inner(result, "<p style='color:#d8d8e0;margin:4px 0'>N = ${n}</p><p style='margin:4px 0'>Monolithic softmax: <b>${mono}</b> classes</p><p style='margin:4px 0'>CRT output: 8+9+25+49+11+13 = <b style='color:#ffd700'>${crt_total}</b> classes (fixed)</p><p style='margin:4px 0'>Compression: <b style='color:#ffd700'>${ratio}x</b></p><p style='margin:4px 0;color:#b8b8c8'>${named}</p><p style='margin:4px 0;color:#b0b0c0'>CRT(${n}) = (${crt_d}, ${crt_k}, ${crt_e}, ${crt_b}, ${crt_l}, ${crt_g})</p>")
  )
)

/* CRT multi-scale PID — absorbed from pid_demo.html (S1022) */
fn pid_multiscale_calc() = (
  let n = parse_int_from("#pid-input") in
  let result = dom_query("#pid-result") in
  if n < 0 then dom_inner(result, "<p style='color:#ff6666'>Enter a non-negative control signal.</p>")
  else (
    let v = n % 12612600 in
    let cd = v % 8 in let ck = v % 9 in let ce = v % 25 in let cb = v % 49 in let cl = v % 11 in let cg = v % 13 in
    /* L=11 + GATE=13 integrity: reconstruct from 4 data channels, compare L and GATE */
    let r4 = cd * 11036025 + ck * 1401400 + ce * 9585576 + cb * 8494200 in
    let check_l = r4 % 11 in
    let check_g = r4 % 13 in
    let ok_l = if check_l == cl then 1 else 0 in
    let ok_g = if check_g == cg then 1 else 0 in
    let integrity = if ok_l > 0 then if ok_g > 0 then "PASS" else "GATE FAIL" else "L FAIL" in
    dom_inner(result, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT MULTI-SCALE DECOMPOSITION</p><p style='color:#88ddaa;margin:4px 0'>Signal: " + "${v}" + " (mod 12612600)</p><p style='color:#b0b0c0;margin:4px 0'>Z/8  (D-coarse):   " + "${cd}" + " / 8   — 12.5% resolution (emergency corrections)</p><p style='color:#b0b0c0;margin:4px 0'>Z/9  (K-medium):   " + "${ck}" + " / 9   — 11.1% resolution (mode switching)</p><p style='color:#b0b0c0;margin:4px 0'>Z/25 (E-fine):     " + "${ce}" + " / 25  — 4.0% resolution (tracking)</p><p style='color:#b0b0c0;margin:4px 0'>Z/49 (b-precise):  " + "${cb}" + " / 49  — 2.0% resolution (precision)</p><p style='color:#b0b0c0;margin:4px 0'>Z/11 (L-integrity): " + "${cl}" + " / 11  — error detection</p><p style='color:#b0b0c0;margin:4px 0'>Z/13 (GATE-skin):  " + "${cg}" + " / 13  — boundary check</p><p style='color:#ffd700;margin:12px 0 4px'>DUAL INTEGRITY (L=11 + GATE=13)</p><p style='color:" + (if ok_l > 0 then if ok_g > 0 then "#44ff88" else "#ff4444" else "#ff4444") + ";margin:4px 0'>L-check: expected " + "${cl}" + " got " + "${check_l}" + " | GATE-check: expected " + "${cg}" + " got " + "${check_g}" + " — <b>" + integrity + "</b></p><p style='color:#a0a0b0;margin:8px 0 0;font-size:12px'>Total control space: 8 x 9 x 25 x 49 x 11 x 13 = 12612600 distinct states. ~23 bits with algebraic structure. CC0.</p></div>")
  )
)

/* CRT byte entropy — absorbed from compression.html (S1022) */
fn comp_entropy_calc() = (
  let txt = dom_value(dom_query("#comp-input")) in
  let result = dom_query("#comp-result") in
  let tlen = len(txt) in
  if tlen < 1 then dom_inner(result, "<p style='color:#ff6666'>Enter some text to analyze.</p>")
  else (
    /* Count byte frequencies for joint entropy */
    mut joint_bits = 0;
    /* Per-channel: count residue frequencies, compute entropy */
    /* Channel entropies computed via frequency counting */
    /* We compute a simplified version: show CRT decomposition of first 5 bytes + redundancy estimate */
    let b0 = charCode(txt, 0) in
    let b1 = if tlen > 1 then charCode(txt, 1) else 0 in
    let b2 = if tlen > 2 then charCode(txt, 2) else 0 in
    let b3 = if tlen > 3 then charCode(txt, 3) else 0 in
    let b4 = if tlen > 4 then charCode(txt, 4) else 0 in
    /* CRT decompose first byte */
    let d0 = b0 % 2 in let k0 = b0 % 3 in let e0 = b0 % 5 in let bb0 = b0 % 7 in let l0 = b0 % 11 in
    /* Max channel entropies (bits): log2(2)=1, log2(3)=1.58, log2(5)=2.32, log2(7)=2.81, log2(11)=3.46 */
    /* Sum of max channel entropies = 11.17 bits. Joint max = 7.71 bits (log2(210)). */
    /* Theoretical max redundancy = 11.17 / 7.71 = 1.45x for uniform. For structured: much higher. */
    /* Show the decomposition and theoretical framework */
    dom_inner(result, "<div style='background:#0a0a18;border:1px solid #333;border-radius:8px;padding:16px;margin:8px 0'><p style='color:#ffd700;margin:0 0 8px'>CRT BYTE DECOMPOSITION (" + "${tlen}" + " bytes)</p><p style='color:#88ddaa;margin:4px 0'>First byte: " + "${b0}" + " (char '" + substr(txt, 0, 1) + "')</p><p style='color:#b0b0c0;margin:4px 0'>CRT(" + "${b0}" + ") = (" + "${d0}" + ", " + "${k0}" + ", " + "${e0}" + ", " + "${bb0}" + ", " + "${l0}" + ")</p><p style='color:#b0b0c0;margin:4px 0'>Channels: Z/2(D) Z/3(K) Z/5(E) Z/7(b) Z/11(L)</p><p style='color:#ffd700;margin:12px 0 4px'>RISSANEN FRAMEWORK</p><p style='color:#b0b0c0;margin:4px 0'>Data ring: Z/210 = Z/2 x Z/3 x Z/5 x Z/7 x Z/11</p><p style='color:#b0b0c0;margin:4px 0'>Max channel entropy sum: 11.17 bits (1+1.58+2.32+2.81+3.46)</p><p style='color:#b0b0c0;margin:4px 0'>Max joint entropy: 7.71 bits (log2 210)</p><p style='color:#88ddaa;margin:4px 0'>Theoretical max redundancy: <b>1.45x</b> (uniform) to <b>20x</b> (structured)</p><p style='color:#b0b0c0;margin:4px 0'>MDL parameters: sum(p_i)/N = 28/210. Learning 7.5x faster.</p><p style='color:#a0a0b0;margin:8px 0 0;font-size:12px'>Bytes 0-209 map 1:1 to Z/210. Bytes 210-255 wrap (mod 210). For text: small channels (D=2, K=3) saturate → redundancy climbs. CC0.</p></div>")
  )
)

