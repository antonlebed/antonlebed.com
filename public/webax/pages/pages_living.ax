fn page_scaling() = (
  dom_head_meta("description", "91.7% of exact power-law exponents from physics are 11-smooth (p = 0.0096). Ising-2D: all 5 Onsager exponents are axiom ratios. DOF chain: K->E->b. Dimensional solvability: exact solutions only at d=D and d=D^2. Shadow boundary = exponent boundary.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Scaling Laws\",\"description\":\"91.7% of exact power-law exponents are 11-smooth (p=0.0096). Ising-2D exponents are axiom ratios. DOF chain K->E->b IS the gas hierarchy.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/living/scaling\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"scaling laws\"},{\"@type\":\"DefinedTerm\",\"name\":\"11-smooth numbers\"},{\"@type\":\"DefinedTerm\",\"name\":\"axiom primes\"}]}");
  /* === HERO === */
  let hero = make_hero("Scaling Laws") in
  let big = dom_create("div") in
  dom_text(big, "33/36 = 91.7% axiom-smooth");
  ct_mono(big);
  dom_style(big, "fontSize", "28px");
  ct_gold(big);
  dom_style(big, "letterSpacing", "1px");
  dom_style(big, "marginBottom", "24px");
  dom_append(hero, big);
  render_p(hero, "33 of 36 exact power-law exponents from physics, biology, and phase transitions factor entirely over axiom primes {2, 3, 5, 7, 11}. Null model: random 5-prime sets achieve this rate with probability p = 0.0096. The axiom primes are not chosen to match exponents -- they are chosen by the shadow chain. That they cover 91.7% is consequence, not cause.");
  dom_append(dom_body(), hero);

  /* === SEC 1: COVERAGE HIERARCHY === */
  let sec1 = make_section("800px") in
  render_h2(sec1, "Coverage Hierarchy");
  render_p(sec1, "Each axiom prime contributes less than the last. Diminishing returns, but the first three primes alone capture 88.9%:");
  let htbl = dom_create("table") in
  dom_style(htbl, "width", "100%");
  dom_style(htbl, "maxWidth", "700px");
  dom_style(htbl, "margin", "24px auto");
  dom_style(htbl, "borderCollapse", "collapse");
  let hhdr = dom_create("tr") in
  render_th(hhdr, "Prime Set");
  render_th(hhdr, "Coverage");
  render_th(hhdr, "Key Exponents Added");
  dom_append(htbl, hhdr);
  render_table_row(htbl, "{D=2}", "36.1%", "Inverse square, diffusion, Stefan-Boltzmann");
  render_table_row(htbl, "{D, K=3}", "69.4%", "+ Kolmogorov E/K, Kepler K/D, surface/volume");
  render_table_row(htbl, "{D, K, E=5}", "88.9%", "+ Flory K/E, Potts-3 nu, percolation beta");
  render_table_row(htbl, "{D, K, E, b=7}", "91.7%", "+ Ising-2D gamma = b/D^2. ONE exponent.");
  render_table_row(htbl, "{D, K, E, b, L=11}", "91.7%", "L adds NOTHING. L is for ECC, not exponents.");
  dom_append(sec1, htbl);
  render_p(sec1, "b=7 adds exactly one exponent: the Ising susceptibility. But that exponent is THE signature. L=11 adds zero exponents -- it protects, it does not scale. Each prime does what the axiom says it does.");
  dom_append(dom_body(), sec1);

  /* === SEC 2: ISING-2D === */
  let sec2 = make_section("800px") in
  render_h2(sec2, "The Ising-2D Signature");
  render_p(sec2, "Onsager solved the 2D Ising model exactly in 1944. All five critical exponents are axiom ratios:");
  let itbl = dom_create("table") in
  dom_style(itbl, "width", "100%");
  dom_style(itbl, "maxWidth", "700px");
  dom_style(itbl, "margin", "24px auto");
  dom_style(itbl, "borderCollapse", "collapse");
  let ihdr = dom_create("tr") in
  render_th(ihdr, "Exponent");
  render_th(ihdr, "Value");
  render_th(ihdr, "Axiom Form");
  render_th(ihdr, "Physics");
  dom_append(itbl, ihdr);
  render_table_row_4(itbl, "beta", "1/8", "sigma / D^3", "Order parameter");
  render_table_row_4(itbl, "gamma", "7/4", "b / D^2", "Susceptibility. THE b=7 signature.");
  render_table_row_4(itbl, "delta", "15", "K * E", "Critical isotherm. Closure * observer.");
  render_table_row_4(itbl, "eta", "1/4", "sigma / D^2", "Anomalous dimension");
  render_table_row_4(itbl, "nu", "1", "sigma", "Correlation length. Identity.");
  dom_append(sec2, itbl);
  render_theorem(sec2, "Where Does b=7 Come From?", "gamma = 2 - eta = 2 - 1/4 = 7/4 = (D^3 - sigma)/D^2. So b = D^3 - sigma = D^3 - 1 = 7. The Mersenne prime from the Cunningham chain: CC1(sigma): 1 -> 3 -> 7. Each step: 2n+1. The Ising susceptibility exponent IS the depth prime. The D^3 in gamma is the SAME D^3 in the DEEP ring (970200 = D^3 * K^2 * E^2 * b^2 * L) and TRUE ring (12612600 = D^3 * K^2 * E^2 * b^2 * L * GATE).");
  dom_append(dom_body(), sec2);

  /* === SEC 3: DIMENSIONAL SOLVABILITY === */
  let sec3 = make_section("800px") in
  render_h2(sec3, "Dimensional Solvability");
  render_p(sec3, "Exact rational Ising exponents exist ONLY at d = D = 2 and d = D^2 = 4 spatial dimensions. d = K = 3 has genuinely irrational exponents (conformal bootstrap, 2020). The axiom brackets statistical mechanics:");
  let dtbl = dom_create("table") in
  dom_style(dtbl, "width", "100%");
  dom_style(dtbl, "maxWidth", "700px");
  dom_style(dtbl, "margin", "24px auto");
  dom_style(dtbl, "borderCollapse", "collapse");
  let dhdr = dom_create("tr") in
  render_th(dhdr, "Dimension");
  render_th(dhdr, "Axiom Name");
  render_th(dhdr, "Exponents");
  render_th(dhdr, "Primes Used");
  dom_append(dtbl, dhdr);
  render_table_row_4(dtbl, "d = 1", "sigma", "No phase transition", "Lower critical dimension");
  render_table_row_4(dtbl, "d = 2", "D", "EXACT rational", "{sigma, D, K, E, b} = all 5");
  render_table_row_4(dtbl, "d = 3", "K", "IRRATIONAL", "Decomposes solvability");
  render_table_row_4(dtbl, "d = 4", "D^2", "EXACT rational (mean field)", "{sigma, D, K} = 3 survive");
  render_table_row_4(dtbl, "d > 4", "> D^2", "Mean field", "Same as d = D^2");
  dom_append(sec3, dtbl);
  render_p(sec3, "2D uses all 5 primes. 4D uses 3. E and b are STRIPPED by dimension. K persists in both (delta = K*E at d=D, delta = K at d=D^2). K is solvability's spine. alpha (specific heat) PEAKS at d=K: maximum thermal chaos at the decomposition dimension.");
  render_p(sec3, "Cross-dimensional ratios are all axiom: delta(D)/delta(D^2) = E. nu(D)/nu(D^2) = D. gamma(D)/gamma(D^2) = b/D^2. What Ising loses in dimension, Fibonacci gains in period: pi(TRUE)/pi(THIN) = E*b = 35.");
  dom_append(dom_body(), sec3);

  /* === SEC 4: DOF CHAIN === */
  let sec4 = make_section("800px") in
  render_h2(sec4, "Degrees of Freedom Chain");
  render_theorem(sec4, "DOF Chain Theorem (S469, PROVED)", "Heat capacity degrees of freedom follow the axiom chain: K=3 -> E=5 -> b=7, step D=2. Each gas type adds D=2 DOF. The chain IS thermodynamics.");
  let ftbl = dom_create("table") in
  dom_style(ftbl, "width", "100%");
  dom_style(ftbl, "maxWidth", "700px");
  dom_style(ftbl, "margin", "24px auto");
  dom_style(ftbl, "borderCollapse", "collapse");
  let fhdr = dom_create("tr") in
  render_th(fhdr, "Gas Type");
  render_th(fhdr, "DOF");
  render_th(fhdr, "gamma");
  render_th(fhdr, "Connection");
  dom_append(ftbl, fhdr);
  render_table_row_4(ftbl, "Monoatomic", "f = K = 3", "E/K = 5/3", "= Kolmogorov turbulence exponent");
  render_table_row_4(ftbl, "Diatomic", "f = E = 5", "b/E = 7/5", "+ D=2 rotational modes");
  render_table_row_4(ftbl, "Polyatomic", "f = b = 7", "K^2/b = 9/7", "+ D=2 vibrational modes");
  dom_append(sec4, ftbl);
  render_p(sec4, "Kolmogorov -5/3 and monoatomic gamma = 5/3 are the SAME RATIO because both describe K=3 independent modes. The turbulence cascade IS a gas in wavenumber space. Kleiber 3/4 = K/D^2 = spectral gap of sigma. The gap between Kolmogorov and Kleiber: |5/3 - 3/4| = 11/12 = axiom sum / chromatic number.");
  let g4 = make_findings_grid(sec4) in
  render_finding(g4, "Kolmogorov", "-5/3 = -E/K", "Turbulence cascade. Derived from Z/210Z Laplacian.", "S186");
  render_finding(g4, "Kleiber", "3/4 = K/D^2", "Metabolic scaling across 27 orders of magnitude.", "0.4% match");
  render_finding(g4, "Murmuration", "b = 7 neighbors", "Topological, not distance. Global coherence from local depth.", "Ballerini 2008");
  render_finding(g4, "Cell types", "b = 7 compartments", "Membrane, nucleus, mito, ER, Golgi, lysosome, peroxisome.", "S498");
  dom_append(dom_body(), sec4);

  /* === SEC 5: SHADOW BOUNDARY === */
  let sec5 = make_section("800px") in
  render_h2(sec5, "The Shadow Boundary");
  render_p(sec5, "Three counterexamples exist. ALL three need primes >= 13:");
  let stbl = dom_create("table") in
  dom_style(stbl, "width", "100%");
  dom_style(stbl, "maxWidth", "700px");
  dom_style(stbl, "margin", "24px auto");
  dom_style(stbl, "borderCollapse", "collapse");
  let shdr = dom_create("tr") in
