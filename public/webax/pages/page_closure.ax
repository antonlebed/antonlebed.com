  dom_head_meta("description", "K = 3 is closure. sigma+D = K. Triangle = first shape with area. K^2 = 9 = STOP. Kingdom: Fungi. ONLY prime whose removal breaks graph perfectness. 8 gatekeeping domains. Monster moonshine: all 15 primes axiom-derivable. Bertrand: K=3 = only dimension with closed orbits.");
  render_jsonld("{\"@context\":\"https://schema.org\",\"@type\":\"ScholarlyArticle\",\"name\":\"Closure: K=3\",\"description\":\"K=3 is the minimum closure prime. Triangle = first polygon with area. K^2=9 = STOP (self-reference overflow). ONLY prime whose removal breaks graph perfectness. Monster moonshine: all 15 primes axiom-derivable. Bertrand theorem: K=3 = only spatial dimension with closed orbits. Genetic code: 64 codons, E=5 missing from all degeneracies.\",\"author\":{\"@type\":\"Person\",\"name\":\"Anton Lebed\"},\"license\":\"https://creativecommons.org/publicdomain/zero/1.0/\",\"url\":\"https://antonlebed.com/observe/closure\",\"about\":[{\"@type\":\"DefinedTerm\",\"name\":\"graph perfectness\"},{\"@type\":\"DefinedTerm\",\"name\":\"Monster group\"},{\"@type\":\"DefinedTerm\",\"name\":\"genetic code\"}]}");
  closure_hero();
  closure_identity();
  closure_interactive();
  closure_consensus();
  closure_scheduler();
  closure_k_powers();
  closure_gatekeeping();
  closure_monster();
  closure_lie();
  closure_genetic_code();
  closure_platonic();
  closure_mycelium();
  closure_contrast()
)
