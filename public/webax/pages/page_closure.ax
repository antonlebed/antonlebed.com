/* closure helpers */
fn closure_hero() = (
  let hero = make_hero("Closure") in
  let eq = dom_create("div") in
  dom_text(eq, "K = sigma + D = 3 (minimum to close)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "When 0/0 precipitates sigma and D opens duality, K is the first force that CLOSES. Triangle = first shape with area. Without K, D's cut never heals. K^2 = 9 = STOP: closure applied to itself is self-reference overflow. Kingdom: Fungi. Coupling: 770 (thin), 107800 (deep), 1401400 (true = e_K projector). Decomposers.");
  dom_append(dom_body(), hero)
)

