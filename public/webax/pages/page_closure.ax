  render_p(sec, "K closes. K decomposes. K terminates. The scaffolding that leaves no trace in the finished structure. Closure applied to itself (K^2=9) is the STOP that keeps the universe finite. Without K, D's cut never heals and the chain never cycles.");
  dom_append(dom_body(), sec)
)

