  render_h2(sec, "Eight Domains of Gatekeeping");
  let g = make_findings_grid(sec) in
  render_finding(g, "Prime alternation", "T[1][1]=T[2][2]=0 mod 3", "Consecutive gaps can't both be nonzero mod K. Pigeonhole on K consecutive primes.", "S190");
  render_finding(g, "Gap admissibility", "R(g)=0 unless 6|g", "3-term AP needs K|d. Closure decides which gaps can REPEAT.", "S200");
  render_finding(g, "K-immunity", "K never divides b^k+1", "Cunningham: b=2K+1 so b=1 mod K. Power map can't reach closure from depth.", "S195");
  render_finding(g, "Self-discrimination", "K=3 pairs see each other", "K*b=21, K*L=33, b*L=77. Sum=131 (prime). Like K Fates recognizing without mirrors.", "S204");
  render_finding(g, "Generosity", "K fattening = 5/3 = Kolmogorov", "Maximum gain among all primes. K is the only odd prime where ALL non-zero residues are negative.", "S224");
  render_finding(g, "Cunningham terminator", "49.8% of chain stops", "p=1 mod 3: ALWAYS K-terminated at length 1. p=2 mod 3: NEVER. K bifurcates the prime world.", "S230");
  render_finding(g, "Cube-breaker", "Fano plane UNIQUE to Z/2310", "At level 6 (N=30030): Z/3 LEAKS. K shatters the binary cube. Fano exists precisely where L enters.", "");
  render_finding(g, "Break law", "break(E) = K = 3", "Observer channel's fattening limit set BY closure. K gates E's growth.", "S284");
  dom_append(dom_body(), sec)
)

fn closure_monster() = (
  let sec = make_section("800px") in
  render_h2(sec, "Monster Moonshine");
  render_theorem(sec, "Monster-Axiom Completeness (S341)", "ALL 15 primes dividing |Monster| are axiom-derivable via Cunningham. Maximum depth: 2 steps from axiom-smooth seed. The gate reaches everywhere. K*E = 15 primes = chain termination level.");
  render_theorem(sec, "196883 Trinity (S341)", "dim(V_1) = 196883 = 47 * 59 * 71. THREE outermost Monster primes. 47=c(c(L)), 59=c(c(D*b)), 71=c(E*b). CRT(196883, TRUE) = (K, D^3, D^3, sigma, E). coupling = 970200 = FULL. The Monster dimension IS the ring.");
  let g = make_findings_grid(sec) in
  render_finding(g, "c = 24", "= D^3*K = HYDOR - K^4", "SIX independent paths. Catalan K^2=D^3+1. (D^2)!=24. L+GATE=24. |SL(2,F_K)|=24.", "S737");
  render_finding(g, "SL(2) chain", "All 5 axiom primes smooth", "|SL(2,F_D)|=6, F_K=24, F_E=120, F_b=336, F_L=1320. ALL axiom-smooth.", "S737");
  render_finding(g, "Factorial Trinity", "(D^3)! = 168*24*10", "GL(K,F_D) * SL(D,F_K) * degree(TRUE). Ratio = b = 7.", "S737");
  render_finding(g, "Exponent sum", "83 = c(KEY)", "v_p exponents: 46,20,9,6,2. Sum = Cunningham of the self-inverse element.", "S341");
  render_p(sec, "BEDROCK TO HEAVENS: 0 -> K=3 (triangle) -> c=24 (central charge) -> Monster. The simplest geometry produces the most complex finite group. K^3=27 = dim(Jordan algebra) = rank sum of all 5 exceptional Lie algebras.");
  dom_append(dom_body(), sec)
)

