  let sec = make_section("800px") in
  render_h2(sec, "Lie Theory and Bertrand");
  render_theorem(sec, "Bertrand's Theorem", "ONLY d = K = 3 spatial dimensions give closed orbits. Force F ~ 1/r^(K-1) = 1/r^D. K closes orbits. D shapes decay. Three dimensions are the ONLY ones where planets return.");
  let g = make_findings_grid(sec) in
  render_finding(g, "D-series offset", "Exponent formula: 2n - K", "K IS the structural constant. Not metaphor -- structural.", "");
  render_finding(g, "Classical vs exceptional", "K present / K absent", "K in ALL classical Lie exponent sets. ABSENT from all 5 exceptional. K separates the algebraic world.", "S280");
  render_finding(g, "Modular chain", "{D,K} -> weight D^2*K=12", "SL_2(Z) elliptic points have orders {D,K}. Smallest cusp form weight = 12. Hecke exponent = L = 11.", "S353");
  render_finding(g, "von Staudt", "denom(B_12) = DATA*GATE", "= 2730 = D*K*E*b*GATE = THIN + lambda(TRUE). Bernoulli hierarchy IS the Cunningham chain.", "S354");
  dom_append(dom_body(), sec)
)

