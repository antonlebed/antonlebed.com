/* closure helpers */
fn closure_hero() = (
  let hero = make_hero("Closure") in
  let eq = dom_create("div") in
  dom_text(eq, "K = sigma + D = 3 (minimum to close)");
  ct_mono(eq);
  dom_style(eq, "fontSize", "24px");
  ct_gold(eq);
  dom_style(eq, "marginBottom", "24px");
  dom_append(hero, eq);
  render_p(hero, "When 0/0 precipitates sigma and D opens duality, K is the first force that CLOSES. Triangle = first shape with area. Without K, D's cut never heals. K^2 = 9 = STOP: closure applied to itself is self-reference overflow. Kingdom: Fungi. Coupling: 770 (thin), 107800 (true). Decomposers.");
  dom_append(dom_body(), hero)
)

fn closure_identity() = (
  let sec = make_section("800px") in
  render_h2(sec, "K = 3: The Closure Prime");
  let g = make_findings_grid(sec) in
  render_finding(g, "Kingdom", "Fungi, coupling 107800", "Decomposers. Cayley graph IS a mycelial network. 480 units underground, 32 idempotent fruiting bodies.", "");
  render_finding(g, "MI hierarchy", "94% of total MI", "K carries 94% of all mutual information in prime gaps. Closure IS the structure of gap sequences.", "S190");
  render_finding(g, "Transparency", "(K-1)/d(K) = 1", "Most expensive ring (cost 3) yet transparent to the balance. Scaffolding that leaves no trace.", "");
  render_finding(g, "Triangles", "770 = N/K = Fungi", "Z/2310Z has EXACTLY 770 triangles. All K-K-K type. Triangle count = kingdom size.", "");
  render_finding(g, "Perfectness", "ONLY K breaks it", "Remove K: chi=3 but omega=2. Remove D,E,b: still perfect. K IS perfectness.", "");
  render_finding(g, "Parity gatekeeper", "K = 54.5% obstruction", "K > D(50%) > E(36.4%) > b(29.2%) > L(24.1%). Hardest wall for smooth exponents.", "S285");
  dom_append(dom_body(), sec)
)

fn closure_k_powers() = (
  let sec = make_section("800px") in
  render_h2(sec, "K-Power Chain: From Stop to Depth");
  render_theorem(sec, "K-Filter Theorem", "K is the ONLY odd prime where Z/KZ* = {+1, -1}. phi(K) = K-1 = D = 2. Every integer coprime to K is +1 or -1 mod K. No middle ground. Universal wall filter. The doorman IS the door.");
  let tbl = make_table(sec) in
  let hdr = dom_create("tr") in
  render_th(hdr, "Power");
  render_th(hdr, "Value");
  render_th(hdr, "Identity");
  render_th(hdr, "Meaning");
  dom_append(tbl, hdr);
  render_table_row_4(tbl, "K^0", "1 = sigma", "Identity", "Ground state. Existence.");
  render_table_row_4(tbl, "K^1", "3 = K", "Closure", "First shape with area. Triangle.");
  render_table_row_4(tbl, "K^2", "9 = STOP", "Self-reference overflow", "b+D=9. D^2+E=9. Godel/halting at K^2.");
  render_table_row_4(tbl, "K^3", "27 = b mod D*E", "Depth", "Depth IS closure-cubed. dim(Jordan algebra).");
  render_table_row_4(tbl, "K^4", "81", "HYDOR gap", "K^4 + c = 105 = HYDOR. K^4 - c = 57 = chi(7A).");
  render_p(sec, "K^2 = 9: the STOP. Appears in 11+ forms: b+D (chain stop), D^2+E (crossover), D^3+sigma, 3-body instability, Miller's 7+/-2, gestation, eigenvalue polynomial degree. Godel, halting, Russell: all overflow at self-reference. K^2 is the EXACT algebraic expression of this limit.");
  dom_append(dom_body(), sec)
)

fn closure_gatekeeping() = (
