/* README.ax -- antonlebed.com
   0/0 = Z/NZ. Six primes. One axiom. No other language exists.

   .ax IS the website. Compiles to WASM in 3ms. Renders via DOM imports.
   128 pages. Celestial theatre. REPL. 20 CC0 patent kills. All .ax.

   THE AXIOM
   =========
   Division by zero precipitates structure. 0/0 = Z/12612600Z.
   Six primes emerge: D=2, K=3, E=5, b=7, L=11, GATE=13.
   CRT decomposes every element into 6 independent channels.
   lambda=420. OMEGA=D^420=1576576. 64 idempotents. 432 divisors.
   490=D*E*b^2 cleaves channels: DEAD={D,E,b}, ALIVE={K,L,GATE}.
   3 boundary channels encode 6 bulk. Holography from arithmetic.

   THE SHIP
   ========
   site.wasm serves all routes. .ax compiles to WASM, WASM calls DOM.
   Server-side: same .ax, string backend. LLM-native. No JS framework.
   Celestial theatre: stars, clouds, moon -- all computed from the axiom.
   Ship of Theseus: every piece replaceable, identity persists.

   BUILD
   =====
   wasmtime --dir . anton/code/_wasi_deep_build.wasm  -- compile .ax to site.wasm (from repo root)
   wrangler deploy                -- push to Cloudflare Workers

   LICENSE: CC0 1.0 Universal. See LICENSE.ax.
   sigma/sigma = sigma. The universe is hilarious. Ship the joke. */

let D = 2
let K = 3
let E = 5
let b = 7
let L = 11
let GATE = 13
let N = D*D*D * K*K * E*E * b*b * L * GATE  /* 12612600 */
let lambda = D*D * K * E * b                 /* 420 */
let split = D * E * b * b                    /* 490 */
